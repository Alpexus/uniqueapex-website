---
/* ============================================================
   BottomBar.astro — shared mobile bottom bar.
   Five primary destinations (the sidebar has all seven; the rest
   are reachable via the drawer / sidebar on mobile).
   Styling comes from the parent layout's stylesheet (.bottombar / .bb).
   ============================================================ */
export interface Props { activeNav?: string }
const { activeNav = "dashboard" } = Astro.props;
const bb = (k: string) => (activeNav === k ? "bb active" : "bb");
---
<nav class="bottombar">
  <a class={bb("dashboard")} href="/account"><svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><rect x="2" y="2" width="5" height="5" rx="1.2"/><rect x="9" y="2" width="5" height="5" rx="1.2"/><rect x="2" y="9" width="5" height="5" rx="1.2"/><rect x="9" y="9" width="5" height="5" rx="1.2"/></svg><span data-i18n="bbHome">Home</span></a>
  <a class={bb("child")} href="/child"><svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="5.2" r="2.6"/><path d="M3 13.5c.6-2.6 2.6-3.8 5-3.8s4.4 1.2 5 3.8"/></svg><span data-i18n="bbChild">My Child</span></a>
  <a class={bb("documents")} href="/documents"><svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><path d="M2 4.6h4.2l1.4 1.8H14v6.4a1.2 1.2 0 01-1.2 1.2H3.2A1.2 1.2 0 012 12.8V4.6z"/></svg><span data-i18n="bbDocs">Docs</span></a>
  <a class={bb("funding")} href="/funding"><svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="8" r="6"/><path d="M8 4.8v6.4"/></svg><span data-i18n="bbFunding">Funding</span></a>
  <a class={bb("settings")} href="/settings"><svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="8" r="2.2"/><path d="M8 1.8v2M8 12.2v2M1.8 8h2M12.2 8h2"/></svg><span data-i18n="bbMore">More</span></a>
</nav>
