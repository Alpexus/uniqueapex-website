---
// =============================================================================
// UniqueApex · Platform Features v2 — modern interactive cards
// Replaces: src/components/platform-features.astro
// Cards expand on click for one extra detail line; violet glow follows cursor.
// =============================================================================
// @ts-ignore
import { Icon } from "astro-icon/components";

interface Props {
  lang?: "en" | "fr";
}

const { lang = "en" } = Astro.props;

const content = {
  en: {
    heading: "Much more than a",
    headingAccent: "search tool",
    body: "UniqueApex is a long-term support system that grows with your family — from first concern through every stage of your child's development. Here's everything we're building.",
    more: "More",
    less: "Less",
    badges: { beta: "Available in Beta", soon: "Coming Soon" },
    features: [
      {
        title: "Provider Matching & Outreach",
        description: "We identify matched providers and contact them on your behalf. You receive a curated shortlist with availability, fees, and fit notes.",
        detail: "Speech, OT, behavioural and more — matched on fit, not just postal code.",
        icon: "bx:bxs-network-chart",
        status: "beta",
      },
      {
        title: "Family Passport",
        description: "One portable child profile that captures your child's full history — diagnosis, therapy records, communication profile, school contacts — and travels with them to every provider, school, and transition.",
        detail: "You control what's shared, and everything exports to PDF for any meeting.",
        icon: "bx:bxs-id-card",
        status: "beta",
      },
      {
        title: "Government Funding Navigator",
        description: "Every grant, subsidy, tax credit, and support programme your family qualifies for, across every jurisdiction — with plain-language explanations and direct application links.",
        detail: "Built first for Québec and federal programs, growing as we expand.",
        icon: "bx:bxs-bank",
        status: "beta",
      },
      {
        title: "Expert Workshops & Peer Community",
        description: "Live sessions with psychologists, occupational therapists, and autism specialists, plus a peer community of families who understand what you are navigating.",
        detail: "Ask questions in a space where nobody needs the backstory explained.",
        icon: "bx:bxs-group",
        status: "beta",
      },
      {
        title: "AI Document Intelligence",
        description: "Upload diagnosis reports, therapy notes, or IEP documents. The platform reads them, summarises key findings in plain language, and updates your child's Passport automatically.",
        detail: "Findings and recommendations in parent language — you review everything before it's saved.",
        icon: "bx:bxs-file-find",
        status: "soon",
      },
      {
        title: "Transition Alert System",
        description: "Proactive alerts 60–90 days before a therapist contract ends, a programme closes, or a school year transitions — so you are never caught without a plan.",
        detail: "The platform watches the calendar so your family doesn't have to.",
        icon: "bx:bxs-bell",
        status: "soon",
      },
    ],
  },
  fr: {
    heading: "Bien plus qu'un",
    headingAccent: "outil de recherche",
    body: "UniqueApex est un système de soutien à long terme qui grandit avec votre famille — de la première préoccupation à chaque étape du développement de votre enfant. Voici tout ce que nous bâtissons.",
    more: "Plus",
    less: "Moins",
    badges: { beta: "Offert en version bêta", soon: "À venir" },
    features: [
      {
        title: "Jumelage et démarches auprès des professionnels",
        description: "Nous identifions les professionnels qui correspondent et les contactons en votre nom. Vous recevez une liste ciblée avec les disponibilités, les tarifs et des notes sur la compatibilité.",
        detail: "Orthophonie, ergothérapie, comportement et plus — un jumelage basé sur la compatibilité, pas seulement le code postal.",
        icon: "bx:bxs-network-chart",
        status: "beta",
      },
      {
        title: "Passeport familial",
        description: "Un profil enfant portable qui rassemble tout l'historique de votre enfant — diagnostic, dossiers de thérapie, profil de communication, contacts scolaires — et le suit chez chaque professionnel, école et transition.",
        detail: "Vous contrôlez ce qui est partagé, et tout s'exporte en PDF pour n'importe quelle rencontre.",
        icon: "bx:bxs-id-card",
        status: "beta",
      },
      {
        title: "Navigateur de financement gouvernemental",
        description: "Chaque subvention, crédit d'impôt et programme de soutien auquel votre famille a droit, dans toutes les juridictions — avec des explications en langage clair et des liens directs vers les demandes.",
        detail: "Conçu d'abord pour les programmes du Québec et du fédéral, et grandit avec notre expansion.",
        icon: "bx:bxs-bank",
        status: "beta",
      },
      {
        title: "Ateliers d'experts et communauté de pairs",
        description: "Des séances en direct avec des psychologues, ergothérapeutes et spécialistes de l'autisme, ainsi qu'une communauté de familles qui comprennent ce que vous vivez.",
        detail: "Posez vos questions dans un espace où personne n'a besoin qu'on lui explique le contexte.",
        icon: "bx:bxs-group",
        status: "beta",
      },
      {
        title: "Intelligence documentaire par IA",
        description: "Téléversez des rapports de diagnostic, des notes de thérapie ou des plans d'intervention. La plateforme les lit, résume les points clés en langage clair et met à jour le Passeport de votre enfant automatiquement.",
        detail: "Constats et recommandations en langage parent — vous révisez tout avant l'enregistrement.",
        icon: "bx:bxs-file-find",
        status: "soon",
      },
      {
        title: "Système d'alertes de transition",
        description: "Des alertes proactives de 60 à 90 jours avant la fin d'un contrat de thérapie, la fermeture d'un programme ou un changement d'année scolaire — pour ne jamais être pris au dépourvu.",
        detail: "La plateforme surveille le calendrier pour que votre famille n'ait pas à le faire.",
        icon: "bx:bxs-bell",
        status: "soon",
      },
    ],
  },
}[lang];
---

<section class="py-16 my-4" id="pf2">
  <div class="text-center max-w-3xl mx-auto">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      {content.heading} <span class="text-violet-600">{content.headingAccent}</span>
    </h2>
    <p class="text-lg mt-4 text-slate-600 mx-auto">
      {content.body}
    </p>
  </div>

  <div id="pf2-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 mt-14 gap-5">
    {
      content.features.map((item) => (
        <button type="button" class="pf2-card group flex flex-col text-left p-6 rounded-3xl border border-slate-200 bg-white cursor-pointer" aria-expanded="false">
          <div class="flex items-center justify-between mb-4 relative">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-500 to-violet-700 flex items-center justify-center shadow-md shadow-violet-200 transition-transform duration-200 group-hover:scale-110 group-hover:-rotate-3">
              <Icon class="text-white w-6 h-6" name={item.icon} />
            </div>
            <span class={`text-xs font-semibold px-3 py-1 rounded-full ${item.status === "beta" ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : "bg-slate-100 text-slate-500 border border-slate-200"}`}>
              {content.badges[item.status as keyof typeof content.badges]}
            </span>
          </div>
          <h3 class="font-semibold text-lg text-slate-800 group-hover:text-violet-700 transition-colors relative">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed text-[15px] relative">{item.description}</p>
          <div class="pf2-more relative">
            <p class="text-[14.5px] leading-relaxed text-violet-800 bg-violet-50 border border-violet-100 rounded-xl px-3.5 py-2.5 m-0">{item.detail}</p>
          </div>
          <span class="pf2-toggle mt-auto pt-4 inline-flex items-center gap-1 text-xs font-bold text-violet-600 uppercase tracking-wide relative">
            <span class="pf2-toggle-txt">{content.more}</span>
            <svg class="pf2-chev transition-transform duration-200" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </span>
        </button>
      ))
    }
  </div>
</section>

<style is:global>
  #pf2 .pf2-card{position:relative;overflow:hidden;opacity:0;transform:translateY(18px);transition:opacity .55s ease,transform .25s ease,border-color .2s ease,box-shadow .25s ease}
  #pf2 .pf2-card.pf2-in{opacity:1;transform:none}
  #pf2 .pf2-card.pf2-in:hover{transform:translateY(-4px);border-color:#c4b5fd;box-shadow:0 12px 32px -12px rgba(124,58,237,.25)}
  #pf2 .pf2-card::before{content:"";position:absolute;inset:0;border-radius:inherit;background:radial-gradient(240px circle at var(--mx,50%) var(--my,50%),rgba(124,58,237,.10),transparent 65%);opacity:0;transition:opacity .25s ease;pointer-events:none}
  #pf2 .pf2-card:hover::before{opacity:1}
  #pf2 .pf2-more{max-height:0;overflow:hidden;transition:max-height .3s ease,margin-top .3s ease;margin-top:0}
  #pf2 .pf2-card.pf2-open .pf2-more{max-height:180px;margin-top:10px}
  #pf2 .pf2-card.pf2-open .pf2-chev{transform:rotate(180deg)}
  @media (prefers-reduced-motion: reduce){
    #pf2 .pf2-card{opacity:1;transform:none;transition:border-color .2s ease}
    #pf2 .pf2-card.pf2-in:hover{transform:none}
    #pf2 .pf2-card::before{display:none}
    #pf2 .pf2-more{transition:none}
  }
</style>

<script is:inline>
  (function () {
    var grid = document.getElementById("pf2-grid");
    if (!grid) return;
    var cards = grid.querySelectorAll(".pf2-card");

    cards.forEach(function (card) {
      card.addEventListener("mousemove", function (ev) {
        var r = card.getBoundingClientRect();
        card.style.setProperty("--mx", (ev.clientX - r.left) + "px");
        card.style.setProperty("--my", (ev.clientY - r.top) + "px");
      });
      card.addEventListener("click", function () {
        var open = card.classList.toggle("pf2-open");
        card.setAttribute("aria-expanded", open ? "true" : "false");
        var txt = card.querySelector(".pf2-toggle-txt");
        if (txt) txt.textContent = open ? txt.getAttribute("data-less") : txt.getAttribute("data-more");
      });
      var txt = card.querySelector(".pf2-toggle-txt");
      if (txt) { txt.setAttribute("data-more", txt.textContent.trim()); }
    });

    var lessLabels = { More: "Less", Plus: "Moins" };
    cards.forEach(function (card) {
      var txt = card.querySelector(".pf2-toggle-txt");
      if (txt) txt.setAttribute("data-less", lessLabels[txt.getAttribute("data-more")] || "Less");
    });

    function reveal() { cards.forEach(function (c, i) { setTimeout(function () { c.classList.add("pf2-in"); }, i * 80); }); }
    if (!("IntersectionObserver" in window)) { reveal(); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { io.disconnect(); reveal(); } });
    }, { threshold: 0.1 });
    io.observe(grid);
  })();
</script>