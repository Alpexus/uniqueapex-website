---
const steps = [
  {
    number: "01",
    title: "Submit one profile",
    desc: "Fill in your child's needs once. UniqueApex stores it securely and uses it for every outreach.",
  },
  {
    number: "02",
    title: "We reach out for you",
    desc: "The platform contacts matched speech, OT, and behavioural providers in your area automatically.",
  },
  {
    number: "03",
    title: "You hear back",
    desc: "Providers respond directly to you. No chasing, no re-explaining, no repeated forms.",
  },
];
---

<section class="py-16 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-2">How it works</h2>
    <p class="text-center text-slate-500 mb-12">Three steps to stop waiting and start moving.</p>
    <div class="grid md:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="flex flex-col items-center text-center">
          <span class="text-5xl font-bold text-violet-200 mb-3">{step.number}</span>
          <h3 class="text-lg font-semibold mb-2">{step.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>