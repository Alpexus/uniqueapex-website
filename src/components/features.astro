---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "One Child Profile",
    description:
      "Submit your child's information once. UniqueApex uses it to match and reach out to the right providers automatically.",
    icon: "bx:bxs-user-circle",
  },
  {
    title: "Smart Provider Matching",
    description:
      "We match your child's needs to verified speech, occupational, and behavioural therapy providers in your area.",
    icon: "bx:bxs-map",
  },
  {
    title: "Waitlist Tracking",
    description:
      "No more calling around. UniqueApex tracks waitlist status across multiple providers so you always know where you stand.",
    icon: "bx:bxs-time",
  },
  {
    title: "Concierge Support",
    description:
      "Need more help? A dedicated coordinator handles follow-ups, documentation, and cross-service orchestration for you.",
    icon: "bx:bxs-heart",
  },
  {
    title: "Expert Workshops",
    description:
      "Access community workshops and peer support led by specialists — designed for parents navigating the system.",
    icon: "bx:bxs-graduation",
  },
  {
    title: "Bilingual Platform",
    description:
      "UniqueApex serves families in both English and French — because language should never be a barrier to support.",
    icon: "bx:bxs-conversation",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Everything your family needs
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    UniqueApex brings together the tools, connections, and support that families of neurodivergent children deserve.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start p-5 rounded-xl transition-colors duration-200 hover:bg-violet-50 cursor-default">
        <div class="mt-1 bg-violet-100 rounded-lg p-2 w-10 h-10 shrink-0 flex items-center justify-center">
          <Icon class="text-violet-600 w-5 h-5" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>