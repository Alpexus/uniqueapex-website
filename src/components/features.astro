---
// @ts-ignore
import { Icon } from "astro-icon/components";

interface Props {
  lang?: "en" | "fr";
}

const { lang = "en" } = Astro.props;

const allFeatures = {
  en: [
    {
      title: "One Child Profile",
      description: "Submit your child's information once. UniqueApex uses it to match and reach out to the right providers automatically.",
      icon: "bx:bxs-user-circle",
    },
    {
      title: "Smart Provider Matching",
      description: "We match your child's needs to verified speech, occupational, and behavioural therapy providers in your area.",
      icon: "bx:bxs-map",
    },
    {
      title: "Waitlist Tracking",
      description: "No more calling around. UniqueApex tracks waitlist status across multiple providers so you always know where you stand.",
      icon: "bx:bxs-time",
    },
    {
      title: "Concierge Support",
      description: "Need more help? A dedicated coordinator handles follow-ups, documentation, and cross-service orchestration for you.",
      icon: "bx:bxs-heart",
    },
    {
      title: "Expert Workshops",
      description: "Access community workshops and peer support led by specialists — designed for parents navigating the system.",
      icon: "bx:bxs-graduation",
    },
    {
      title: "Bilingual Platform",
      description: "UniqueApex serves families in both English and French — because language should never be a barrier to support.",
      icon: "bx:bxs-conversation",
    },
  ],
  fr: [
    {
      title: "Un seul profil enfant",
      description: "Soumettez les informations de votre enfant une seule fois. UniqueApex les utilise pour contacter les bons professionnels automatiquement.",
      icon: "bx:bxs-user-circle",
    },
    {
      title: "Jumelage intelligent",
      description: "Nous jumelons les besoins de votre enfant avec des professionnels vérifiés en orthophonie, ergothérapie et thérapie comportementale dans votre région.",
      icon: "bx:bxs-map",
    },
    {
      title: "Suivi des listes d'attente",
      description: "Fini les appels à répétition. UniqueApex suit l'état de vos listes d'attente chez plusieurs professionnels pour que vous sachiez toujours où vous en êtes.",
      icon: "bx:bxs-time",
    },
    {
      title: "Service de conciergerie",
      description: "Besoin de plus d'aide? Un coordonnateur dédié gère les suivis, la documentation et la coordination entre services pour vous.",
      icon: "bx:bxs-heart",
    },
    {
      title: "Ateliers d'experts",
      description: "Accédez à des ateliers communautaires et du soutien par les pairs, animés par des spécialistes — conçus pour les parents qui naviguent le système.",
      icon: "bx:bxs-graduation",
    },
    {
      title: "Plateforme bilingue",
      description: "UniqueApex sert les familles en français et en anglais — parce que la langue ne devrait jamais être un obstacle au soutien.",
      icon: "bx:bxs-conversation",
    },
  ],
};

const features = allFeatures[lang];

const sectionTitle = {
  en: { heading: "Everything your family needs", body: "UniqueApex brings together the tools, connections, and support that families of neurodivergent children deserve." },
  fr: { heading: "Tout ce dont votre famille a besoin", body: "UniqueApex réunit les outils, les connexions et le soutien que les familles d'enfants neurodivergents méritent." },
}[lang];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    {sectionTitle.heading}
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    {sectionTitle.body}
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start p-5 rounded-xl transition-colors duration-200 hover:bg-violet-50 cursor-default">
        <div class="mt-1 bg-violet-100 rounded-lg p-2 w-10 h-10 shrink-0 flex items-center justify-center">
          <Icon class="text-violet-600 w-5 h-5" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
