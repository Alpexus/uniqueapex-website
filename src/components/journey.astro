---
// =============================================================================
// UniqueApex · Journey v2 — "We're with you from the very first concern"
// Save as: src/components/journey.astro  (replaces the interactive rail version)
//
// ILLUSTRATIONS — put these 7 PNGs in /public (any size, white/transparent bg):
//   /journey-1-first-concern.png
//   /journey-2-assessment.png
//   /journey-3-first-provider.png
//   /journey-4-ongoing-therapy.png
//   /journey-5-school-entry.png
//   /journey-6-iep-transitions.png
//   /journey-7-adolescence.png
// Until a file exists, its card shows a soft violet placeholder (no broken-
// image icon). The moment you add the PNG, it appears — no code changes.
// v2 · 2026-07-06
// =============================================================================
const { lang = "en" } = Astro.props;

const t = {
  en: {
    label: "Your journey, our promise",
    heading: "We're with you from the very first concern",
    headingAccent: "— even before a diagnosis.",
    body: "Start building your child's profile today. The earlier you begin, the more it grows with them.",
    banner1: "No official assessment needed to get started.",
    banner2: "We're here when you need us, at every step.",
    startHere: "Start here",
    how: "How we help:",
    outro: "Every stage asks something new of you. Here's how UniqueApex keeps up —",
    stages: [
      { title: "First Concern", desc: "You notice something is different and want to understand more.", help: ["Understand early signs", "Learn what to look for", "Get guidance right away", "Plan your next steps"] },
      { title: "Assessment", desc: "You're ready to explore further and seek answers.", help: ["Find the right assessments", "Prepare with confidence", "Organize documents", "Track everything"] },
      { title: "First Provider", desc: "You meet with professionals and start building your team.", help: ["Find trusted providers", "Prepare for appointments", "Keep notes in one place", "Ask the right questions"] },
      { title: "Ongoing Therapy", desc: "You begin therapies and routines that support their growth.", help: ["Therapy schedules", "Progress tracking", "Share updates easily", "Adjust as needs change"] },
      { title: "School Entry", desc: "New environments, new people, new questions.", help: ["IEP & school planning", "Document organization", "Communication tools", "Advocate with confidence"] },
      { title: "IEP & Transitions", desc: "Plans evolve and transitions bring new decisions.", help: ["IEP planning support", "Track goals & progress", "Transition checklists", "Important deadlines"] },
      { title: "Adolescence & Beyond", desc: "Your child grows, and so does our support.", help: ["Milestone tracking", "Life skills & goals", "Plan for the future", "Continued guidance"] },
    ],
  },
  fr: {
    label: "Votre parcours, notre promesse",
    heading: "On est là dès les premières inquiétudes",
    headingAccent: "— même avant le diagnostic.",
    body: "Commencez à bâtir le profil de votre enfant dès aujourd'hui. Plus tôt vous commencez, plus il grandit avec lui.",
    banner1: "Aucune évaluation officielle n'est requise pour commencer.",
    banner2: "On est là quand vous en avez besoin, à chaque étape.",
    startHere: "Commencez ici",
    how: "Comment on aide :",
    outro: "Chaque étape vous demande quelque chose de nouveau. Voici comment UniqueApex suit le rythme —",
    stages: [
      { title: "Premières préoccupations", desc: "Vous remarquez quelque chose de différent et voulez mieux comprendre.", help: ["Comprendre les premiers signes", "Savoir quoi observer", "Des conseils dès maintenant", "Planifier les prochains pas"] },
      { title: "Évaluation", desc: "Vous êtes prêts à aller plus loin et à chercher des réponses.", help: ["Trouver les bonnes évaluations", "Se préparer avec confiance", "Organiser les documents", "Tout suivre au même endroit"] },
      { title: "Premier professionnel", desc: "Vous rencontrez des professionnels et bâtissez votre équipe.", help: ["Trouver des intervenants fiables", "Préparer les rendez-vous", "Des notes au même endroit", "Poser les bonnes questions"] },
      { title: "Thérapie continue", desc: "Les thérapies et les routines qui soutiennent son développement commencent.", help: ["Horaires de thérapie", "Suivi des progrès", "Partager les mises à jour", "S'ajuster aux besoins"] },
      { title: "Entrée à l'école", desc: "Nouveaux milieux, nouvelles personnes, nouvelles questions.", help: ["Planification PI et école", "Organisation des documents", "Outils de communication", "Défendre avec assurance"] },
      { title: "Plan d'intervention", desc: "Les plans évoluent et les transitions amènent de nouvelles décisions.", help: ["Soutien au plan d'intervention", "Suivre objectifs et progrès", "Listes de transition", "Échéances importantes"] },
      { title: "Adolescence et au-delà", desc: "Votre enfant grandit, et notre soutien grandit avec lui.", help: ["Suivi des jalons", "Compétences de vie", "Planifier l'avenir", "Un soutien continu"] },
    ],
  },
}[lang] || {};

// Illustration files, index-matched to stages — drop these into /public
const imgs = [
  "/journey-1-first-concern.png",
  "/journey-2-assessment.png",
  "/journey-3-first-provider.png",
  "/journey-4-ongoing-therapy.png",
  "/journey-5-school-entry.png",
  "/journey-6-iep-transitions.png",
  "/journey-7-adolescence.png",
];

// Stage icons — bold FILLED glyphs (24×24) so they stay crisp at large sizes
const stageIcons = [
  '<path d="M12 21s-7.6-4.8-10-9.4C.6 8.2 2.7 4.5 6.3 4.5c2.2 0 3.8 1.2 4.7 2.5.9-1.3 2.5-2.5 4.7-2.5 3.6 0 5.7 3.7 4.3 7.1C19.6 16.2 12 21 12 21z"/>',
  '<rect x="4" y="12" width="3.8" height="8.5" rx="1.2"/><rect x="10.1" y="6.5" width="3.8" height="14" rx="1.2"/><rect x="16.2" y="9.5" width="3.8" height="11" rx="1.2"/>',
  '<circle cx="12" cy="7.6" r="3.9"/><path d="M4.2 20.5c.9-4.1 4.1-6.3 7.8-6.3s6.9 2.2 7.8 6.3z"/>',
  '<path d="M20 4H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h2v4l5-4h9a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/>',
  '<path d="M12 3L1.5 8 12 13l8.5-4.05V13.5h2V8L12 3z"/><path d="M5.5 11.4v3.4c0 1.9 2.9 3.6 6.5 3.6s6.5-1.7 6.5-3.6v-3.4L12 14.5 5.5 11.4z"/>',
  '<path d="M15.2 3.4a3.2 3.2 0 0 0-6.4 0H7a2 2 0 0 0-2 2V20a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V5.4a2 2 0 0 0-2-2h-1.8z"/><path d="M9 12.6l2.2 2.2 4-4.6" fill="none" stroke="#ffffff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>',
  '<circle cx="9" cy="8.4" r="3.4"/><path d="M2.3 19.6c.8-3.6 3.5-5.4 6.7-5.4s5.9 1.8 6.7 5.4z"/><circle cx="17.2" cy="9.6" r="2.7"/><path d="M14.6 19.6c.4-2.7 1.9-4.4 4.1-4.9 2 .5 3.1 2.2 3.5 4.9z"/>',
];
---

<section class="py-16 my-4" id="ua-journey">
  <div class="text-center max-w-3xl mx-auto">
    <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">{t.label}</p>
    <h2 class="text-3xl md:text-4xl font-bold mt-3 text-slate-800 leading-tight">
      {t.heading} <span class="text-violet-700">{t.headingAccent}</span>
    </h2>
    <p class="text-slate-500 mt-6 text-lg">{t.body}</p>
  </div>

  <!-- banner -->
  <div class="jn2-banner flex justify-center mt-8">
    <div class="inline-flex items-center gap-3 rounded-2xl bg-white border border-violet-100 shadow-md shadow-violet-100/60 px-5 py-3.5 max-w-2xl text-left">
      <span class="w-12 h-12 rounded-full bg-violet-100 text-violet-700 flex items-center justify-center shrink-0">
        <svg class="jn2-pulse" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 8.6c1.1-2.1 4.2-2.1 5.1.2.8 2.1-1.5 4-5.1 6.6-3.6-2.6-5.9-4.5-5.1-6.6.9-2.3 4-2.3 5.1-.2z"/></svg>
      </span>
      <p class="m-0 text-[15px] leading-snug"><span class="font-bold text-violet-700">{t.banner1}</span> <span class="text-slate-500">{t.banner2}</span></p>
    </div>
  </div>

  <!-- wavy dotted icon timeline (only when the 7 cards sit in one row) -->
  <div id="jn2-strip" class="hidden xl:block relative mt-10 mb-4 h-[104px]">
    <svg id="jn2-wave" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></svg>
    {t.stages.map((_, i) => (
      <span class="jn2-dot absolute" style={`left:${(((i + 0.5) * 100) / 7).toFixed(3)}%;top:${i % 2 === 0 ? "36%" : "64%"};transition-delay:${(0.15 + i * 0.08).toFixed(2)}s`}>
        <span class="jn2-bob flex w-[72px] h-[72px] rounded-full bg-white shadow-lg shadow-violet-200/60 items-center justify-center text-violet-700" style={`--bd:${(4.8 + i * 0.4).toFixed(1)}s;--bl:${(i * 0.35).toFixed(2)}s`}>
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" set:html={stageIcons[i]} />
        </span>
      </span>
    ))}
  </div>

  <!-- 7 stage cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-7 xl:grid-rows-[auto_auto_1fr_auto] xl:gap-y-0 mt-8 xl:mt-0">
    {t.stages.map((s, i) => (
      <div class="jn2-card relative flex flex-col xl:grid xl:grid-rows-subgrid xl:row-span-4 bg-white border border-violet-100 rounded-2xl shadow-md shadow-violet-100/50 p-3" style={`transition-delay:${(0.2 + i * 0.07).toFixed(2)}s`}>
        <span class="absolute top-2.5 left-2.5 z-10 rounded-lg bg-violet-700 text-white text-[10px] font-bold px-1.5 py-0.5">{String(i + 1).padStart(2, "0")}</span>

        <!-- illustration slot: placeholder shows until the PNG exists in /public -->
        <div class="relative h-36 xl:h-40 rounded-xl bg-gradient-to-br from-violet-50 to-white flex items-center justify-center overflow-hidden mb-3">
          <svg class="w-14 h-14 text-violet-200" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={stageIcons[i]} />
          <img src={imgs[i]} alt={s.title} class="absolute inset-0 w-full h-full object-contain" loading="lazy" onerror="this.style.display='none'" />
        </div>

        <div>
          <span class="block text-[15px] font-bold text-slate-800 leading-tight">{s.title}</span>
          {i === 0 && (
            <span class="inline-block mt-1.5 rounded-full bg-violet-100 text-violet-700 text-[9px] font-bold uppercase tracking-wide px-2 py-0.5">{t.startHere}</span>
          )}
        </div>
        <p class="text-[11.5px] text-slate-500 leading-snug mt-1.5 mb-3 xl:mb-0 m-0 self-start">{s.desc}</p>

        <div class="mt-auto xl:mt-3 xl:h-full rounded-xl bg-violet-50/70 border border-violet-100/70 p-2.5">
          <span class="block text-[10px] font-bold text-violet-700 mb-1.5">{t.how}</span>
          {s.help.map((h) => (
            <span class="flex items-start gap-1.5 text-[10.5px] text-slate-600 leading-snug mt-1">
              <svg class="w-3 h-3 text-violet-500 shrink-0 mt-[1px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              {h}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <p class="text-center text-slate-500 italic text-lg mt-14 max-w-2xl mx-auto">{t.outro}</p>
</section>

<style is:global>
  #ua-journey .jn2-banner{opacity:0;transform:translateY(8px);transition:opacity .5s ease,transform .5s ease}
  #ua-journey.ua-in .jn2-banner{opacity:1;transform:none}
  #ua-journey .jn2-dot{opacity:0;transform:translate(-50%,-50%) scale(.85);transition:opacity .45s ease,transform .45s ease}
  #ua-journey.ua-in .jn2-dot{opacity:1;transform:translate(-50%,-50%) scale(1)}
  #ua-journey .jn2-bob{animation:none}
  #ua-journey.ua-in .jn2-bob{animation:jn2Bob var(--bd,5s) ease-in-out var(--bl,0s) infinite alternate}
  @keyframes jn2Bob{from{transform:translateY(-3px)}to{transform:translateY(4px)}}
  #ua-journey #jn2-wave{opacity:0;transition:opacity .7s ease .1s}
  #ua-journey.ua-in #jn2-wave{opacity:1}
  #ua-journey.ua-in #jn2-wave .jn2-flow{animation:jn2Flow 30s linear infinite}
  @keyframes jn2Flow{to{stroke-dashoffset:-546}}
  #ua-journey .jn2-pulse{transform-origin:center;animation:jn2Pulse 2.4s ease-in-out infinite}
  @keyframes jn2Pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
  #ua-journey .jn2-card img{transition:transform .4s ease}
  #ua-journey.ua-in .jn2-card:hover{transform:translateY(-4px)}
  #ua-journey .jn2-card:hover img{transform:scale(1.06)}
  #ua-journey .jn2-card{opacity:0;transform:translateY(12px);transition:opacity .5s ease,transform .5s ease,box-shadow .25s ease}
  #ua-journey.ua-in .jn2-card{opacity:1;transform:none}
  #ua-journey.ua-in .jn2-card:hover{box-shadow:0 12px 28px -12px rgba(124,58,237,.25)}
  @media (prefers-reduced-motion: reduce){
    #ua-journey .jn2-banner,#ua-journey .jn2-card{opacity:1;transform:none;transition:none}
    #ua-journey .jn2-dot{opacity:1;transform:translate(-50%,-50%);transition:none}
    #ua-journey #jn2-wave{opacity:1;transition:none}
    #ua-journey.ua-in .jn2-bob,#ua-journey .jn2-pulse{animation:none}
    #ua-journey.ua-in #jn2-wave .jn2-flow{animation:none}
    #ua-journey.ua-in .jn2-card:hover{transform:none}
    #ua-journey .jn2-card:hover img{transform:none}
  }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById("ua-journey");
    if (!root) return;

    function drawWave() {
      var strip = document.getElementById("jn2-strip");
      var svg = document.getElementById("jn2-wave");
      if (!strip || !svg) return;
      if (!window.matchMedia("(min-width: 1280px)").matches) { svg.innerHTML = ""; return; }
      var w = strip.clientWidth, h = strip.clientHeight;
      if (!w) return;
      svg.setAttribute("viewBox", "0 0 " + w + " " + h);
      // Same formula as the dot elements: left = (i + 0.5)/7, top = 36% / 64%
      var pts = [];
      for (var i = 0; i < 7; i++) pts.push([((i + 0.5) * w) / 7, (i % 2 === 0 ? 0.36 : 0.64) * h]);
      var d = "M" + pts[0][0] + " " + pts[0][1];
      for (var j = 1; j < 7; j++) {
        var x1 = pts[j - 1][0], y1 = pts[j - 1][1], x2 = pts[j][0], y2 = pts[j][1];
        var dx = (x2 - x1) / 2;
        d += " C " + (x1 + dx) + " " + y1 + ", " + (x2 - dx) + " " + y2 + ", " + x2 + " " + y2;
      }
      var lx = pts[6][0], ly = pts[6][1];
      var tx = w - 26, ty = h * 0.5;
      d += " C " + (lx + (tx - lx) / 2) + " " + ly + ", " + (tx - 16) + " " + ty + ", " + tx + " " + ty;
      svg.innerHTML =
        '<path class="jn2-flow" fill="none" stroke="#A78BFA" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="0.1 9" d="' + d + '"/>' +
        '<path fill="none" stroke="#A78BFA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M' + (tx - 8) + " " + (ty - 7) + " L " + (tx + 1) + " " + ty + " L " + (tx - 8) + " " + (ty + 7) + '"/>';
    }

    requestAnimationFrame(drawWave);
    window.addEventListener("load", drawWave);
    var rt;
    window.addEventListener("resize", function () { clearTimeout(rt); rt = setTimeout(drawWave, 120); });

    if (!("IntersectionObserver" in window)) { root.classList.add("ua-in"); drawWave(); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { root.classList.add("ua-in"); drawWave(); io.disconnect(); } });
    }, { threshold: 0.12 });
    io.observe(root);
  })();
</script>