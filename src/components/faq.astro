---
const faqs = [
  {
    question: "How does UniqueApex work?",
    answer:
      "You create one child profile with your child's needs and location. UniqueApex automatically matches and reaches out to verified therapy providers on your behalf — no more cold-calling or repeated form-filling.",
  },
  {
    question: "What types of therapy does UniqueApex support?",
    answer:
      "We currently support speech-language therapy and occupational therapy, with behavioural therapy coming soon. More service types will be added as we expand.",
  },
  {
    question: "Is UniqueApex free to use?",
    answer:
      "Yes — the core platform is free. Families can submit one child profile and receive one outreach batch per service type at no cost. Our Concierge service is available as a paid upgrade.",
  },
  {
    question: "Is my child's information kept private?",
    answer:
      "Absolutely. Your child's profile is only shared with providers you are matched with. We follow strict data privacy standards and never sell your information.",
  },
  {
    question: "When is UniqueApex launching?",
    answer:
      "We are launching our pilot in Montréal, serving both English and French-speaking families. Join the waitlist to be among the first families to get access.",
  },
];
---

<div class="mt-24 grid md:grid-cols-2 gap-16">
  <div>
    <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">FAQ'S</p>
    <h2 class="text-4xl font-bold mt-3 leading-tight">
      Frequently Asked Questions
    </h2>
<p class="text-slate-500 mt-6">Can't find what you're looking for?</p>
    <a href="/contact" class="inline-flex items-center gap-2 text-violet-700 font-semibold mt-2 hover:underline">
      Contact Us →
    </a>
  </div>

  <div class="divide-y divide-slate-200">
    {
      faqs.map((faq) => (
        <details class="group py-5 cursor-pointer rounded-xl px-4 hover:bg-violet-50 transition-colors duration-200">
          <summary class="flex justify-between items-center font-semibold text-lg list-none transition-colors duration-200">
            {faq.question}
            <span class="text-violet-700 group-open:rotate-45 transition-transform duration-200 text-2xl shrink-0 ml-4">+</span>
          </summary>
          <p class="text-slate-500 mt-3 leading-relaxed">{faq.answer}</p>
        </details>
      ))
    }
  </div>
</div>