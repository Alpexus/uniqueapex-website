---
/* ============================================================
   Sidebar.astro — the ONE sidebar, shared by every app layout.
   Logo + 7 fixed top-level items + footer account chip.
   The footer chip opens an account popover (up), and "Help"
   slides in a "send us a message" panel that writes to Supabase.
   Layout classes (.sidebar/.nav-item/.logo/.sidebar-foot) come
   from the parent layout's stylesheet; the popover/panel styles
   come from sidebar-menu.css (imported here).
   activeNav: dashboard | child | documents | funding |
              providers | resources | settings
   ============================================================ */
import "../styles/sidebar-menu.css";
export interface Props { activeNav?: string }
const { activeNav = "dashboard" } = Astro.props;
const a = (k: string) => (activeNav === k ? "nav-item active" : "nav-item");
---
<aside class="sidebar" id="ua-sidebar">
  <a class="logo" href="/" aria-label="UniqueApex home">
    <img src="/logo3.png" alt="UniqueApex" style="height:42px;width:auto;max-width:100%;display:block;object-fit:contain" />
  </a>

  <a class={a("dashboard")} href="/account">
    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><rect x="2" y="2" width="5" height="5" rx="1.2"/><rect x="9" y="2" width="5" height="5" rx="1.2"/><rect x="2" y="9" width="5" height="5" rx="1.2"/><rect x="9" y="9" width="5" height="5" rx="1.2"/></svg>
    <span data-i18n="navDashboard">Dashboard</span></a>

  <a class={a("child")} href="/child">
    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="5.2" r="2.6"/><path d="M3 13.5c.6-2.6 2.6-3.8 5-3.8s4.4 1.2 5 3.8"/></svg>
    <span data-i18n="navChild">My Child</span></a>

  <a class={a("documents")} href="/documents">
    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><path d="M2 4.6h4.2l1.4 1.8H14v6.4a1.2 1.2 0 01-1.2 1.2H3.2A1.2 1.2 0 012 12.8V4.6z"/></svg>
    <span data-i18n="navDocuments">Documents</span></a>

  <a class={a("funding")} href="/funding">
    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="8" r="6"/><path d="M8 4.8v6.4M6 10c.4.7 1.1 1 2 1 1.2 0 2-.6 2-1.5C10 7.6 6.2 8.5 6.2 6.5c0-.9.8-1.5 1.8-1.5.9 0 1.5.3 1.9 1"/></svg>
    <span data-i18n="navFunding">Funding</span></a>

  <a class={a("providers")} href="/providers">
    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="8" r="5.6"/><circle cx="8" cy="8" r="1.6"/></svg>
    <span data-i18n="navProviders">Providers</span></a>

  <a class={a("resources")} href="/resources">
    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><rect x="2" y="3.4" width="9" height="9.2" rx="1.4"/><path d="M11 7l3-2v6l-3-2"/></svg>
    <span data-i18n="navResources">Resources</span></a>

  <div class="sidebar-foot">
    <a class={a("settings")} href="/settings">
      <svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><circle cx="8" cy="8" r="2.2"/><path d="M8 1.8v2M8 12.2v2M1.8 8h2M12.2 8h2M3.6 3.6l1.4 1.4M11 11l1.4 1.4M12.4 3.6L11 5M5 11l-1.4 1.4"/></svg>
      <span data-i18n="navSettings">Settings</span></a>

    <div class="side-acct" id="ua-acct">
      <button class="acct-trigger" id="ua-acct-btn" type="button" aria-haspopup="true" aria-expanded="false">
        <span class="avatar" id="ua-side-avatar">·</span>
        <span class="side-user-meta">
          <span class="side-user-name" id="ua-side-name">Your account</span><br />
          <span class="side-user-plan" id="ua-side-plan">Signed in</span>
        </span>
        <svg class="chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4.5 6.5L8 10l3.5-3.5"/></svg>
      </button>

      <div class="acct-menu" id="ua-acct-menu" role="menu">
        <div class="acct-head">
          <span class="avatar" id="ua-acct-avatar">·</span>
          <span class="meta"><span class="nm" id="ua-acct-name">Your account</span><span class="em" id="ua-acct-email">Signed in</span></span>
        </div>
        <a class="acct-item" href="/settings" role="menuitem">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="8" cy="8" r="2.2"/><path d="M8 1.8v2M8 12.2v2M1.8 8h2M12.2 8h2M3.6 3.6l1.4 1.4M11 11l1.4 1.4M12.4 3.6L11 5M5 11l-1.4 1.4"/></svg>
          <span data-i18n="acctAccount">Account</span></a>
        <a class="acct-item" href="/settings/notifications" role="menuitem">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 2a4 4 0 014 4c0 3 1.2 4 1.2 4H2.8S4 9 4 6a4 4 0 014-4zM6.6 13a1.5 1.5 0 002.8 0"/></svg>
          <span data-i18n="acctNotifications">Notifications</span></a>
        <a class="acct-item" href="/settings/privacy" role="menuitem">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 1.8l5 2v4.2c0 3.2-2.2 5.4-5 6.2-2.8-.8-5-3-5-6.2V3.8l5-2z"/></svg>
          <span data-i18n="acctPrivacy">Privacy &amp; Data</span></a>
        <a class="acct-item" href="/settings/subscription" role="menuitem">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="3.5" width="12" height="9" rx="1.6"/><path d="M2 6.5h12"/></svg>
          <span data-i18n="acctSubscription">Subscription</span></a>
        <div class="acct-sep"></div>
        <button class="acct-item" id="ua-help-open" type="button" role="menuitem">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="8" cy="8" r="6"/><path d="M6.2 6.1c.2-1 1-1.6 1.9-1.6 1 0 1.8.7 1.8 1.6 0 1.3-1.7 1.4-1.7 2.6"/><circle cx="8" cy="11.2" r=".6" fill="currentColor" stroke="none"/></svg>
          <span data-i18n="acctHelp">Help</span></button>
        <div class="acct-sep"></div>
        <button class="acct-item danger" id="ua-logout" type="button" role="menuitem">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2.5H3.5A1 1 0 002.5 3.5v9a1 1 0 001 1H6M10.5 11l3-3-3-3M13.5 8H6"/></svg>
          <span data-i18n="acctLogout">Log out</span></button>
      </div>
    </div>
  </div>
</aside>

<!-- ===== Help: send us a message (slides in from the right) ===== -->
<div class="help-scrim" id="ua-help-scrim"></div>
<aside class="help-panel" id="ua-help-panel" aria-hidden="true" aria-label="Send us a message" data-i18n-aria="helpTitle">
  <div class="help-top">
    <h2 data-i18n="helpTitle">Send us a message</h2>
    <button class="help-x" id="ua-help-close" type="button" aria-label="Close" data-i18n-aria="helpClose">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4l8 8M12 4l-8 8"/></svg>
    </button>
  </div>
  <div class="help-body">
    <div id="ua-help-form-wrap">
      <p class="sub" data-i18n="helpSub">Questions, feedback, or stuck on something? We read every message and reply by email.</p>
      <div class="help-field"><label for="ua-help-name" data-i18n="helpName">Your name</label><input class="help-input" id="ua-help-name" type="text" autocomplete="name" /></div>
      <div class="help-field"><label for="ua-help-email" data-i18n="helpEmail">Email</label><input class="help-input" id="ua-help-email" type="email" autocomplete="email" /></div>
      <div class="help-field"><label for="ua-help-subject"><span data-i18n="helpSubject">Subject</span> <span style="color:var(--muted,#7B7491);font-weight:400" data-i18n="helpOptional">(optional)</span></label><input class="help-input" id="ua-help-subject" type="text" /></div>
      <div class="help-field"><label for="ua-help-msg" data-i18n="helpMessage">Message</label><textarea class="help-textarea" id="ua-help-msg" placeholder="How can we help?" data-i18n-ph="helpMsgPh"></textarea></div>
      <span class="help-err" id="ua-help-err">Please write a message.</span>
      <button class="help-send" id="ua-help-send" type="button" data-i18n="helpSend">Send message</button>
    </div>
    <div class="help-success" id="ua-help-success">
      <div class="ok"><svg viewBox="0 0 16 16" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2"><path d="M3.5 8.5l3 3 6-6.5"/></svg></div>
      <h3 data-i18n="helpThanksTitle">Thanks — we'll be in touch</h3>
      <p data-i18n="helpThanksBody">We've received your message and will reply to your email.</p>
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    var SUPABASE_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
    var ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";

    var session = null;
    try { session = JSON.parse(localStorage.getItem("ua_session") || "null"); } catch (e) {}
    var email = (session && session.user && session.user.email) || "";
    var uname = email ? email.split("@")[0] : "";

    function byId(id) { return document.getElementById(id); }
    function setText(id, t) { var el = byId(id); if (el) el.textContent = t; }

    // Shell dictionary (from I18nBoot in the layout <head>). These IDs are
    // script-owned — user data replaces them — so the script translates
    // its own fallbacks instead of using data-i18n (no overwrite races).
    var ST = window.uaShellT || {};
    var FALLBACK_NAME = ST.yourAccount || "Your account";
    var FALLBACK_PLAN = ST.signedIn || "Signed in";
    if (window.uaLang && window.uaLang !== "en") {
      if (!uname) { setText("ua-side-name", FALLBACK_NAME); }
      setText("ua-side-plan", FALLBACK_PLAN);
    }

    // ----- popover header -----
    setText("ua-acct-name", uname || FALLBACK_NAME);
    setText("ua-acct-email", email || FALLBACK_PLAN);
    var initial = (email[0] || "U").toUpperCase();
    var av = byId("ua-acct-avatar"); if (av) av.textContent = initial;

    // ----- popover open/close -----
    var acct = byId("ua-acct"), btn = byId("ua-acct-btn");
    if (btn && acct) {
      btn.addEventListener("click", function (e) {
        e.stopPropagation();
        var open = acct.classList.toggle("open");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
      });
      document.addEventListener("click", function (e) {
        if (!e.target.closest("#ua-acct")) { acct.classList.remove("open"); btn.setAttribute("aria-expanded", "false"); }
      });
    }

    // ----- log out -----
    var logout = byId("ua-logout");
    if (logout) logout.addEventListener("click", function () {
      try { localStorage.removeItem("ua_session"); localStorage.removeItem("ua_active_child"); } catch (e) {}
      location.href = "/login";
    });

    // ----- help panel -----
    var scrim = byId("ua-help-scrim"), panel = byId("ua-help-panel");
    function openHelp() {
      if (acct) acct.classList.remove("open");
      var n = byId("ua-help-name"); if (n && !n.value && uname) n.value = uname;
      var em = byId("ua-help-email"); if (em && !em.value) em.value = email;
      scrim.classList.add("open"); panel.classList.add("open"); panel.setAttribute("aria-hidden", "false");
    }
    function closeHelp() { scrim.classList.remove("open"); panel.classList.remove("open"); panel.setAttribute("aria-hidden", "true"); }
    var openBtn = byId("ua-help-open"); if (openBtn) openBtn.addEventListener("click", openHelp);
    var xBtn = byId("ua-help-close"); if (xBtn) xBtn.addEventListener("click", closeHelp);
    if (scrim) scrim.addEventListener("click", closeHelp);
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") { closeHelp(); if (acct) { acct.classList.remove("open"); if (btn) btn.setAttribute("aria-expanded", "false"); } }
    });

    // ----- submit to Supabase (support_messages) -----
    var send = byId("ua-help-send");
    if (send) send.addEventListener("click", function () {
      var msgEl = byId("ua-help-msg"), err = byId("ua-help-err");
      var message = (msgEl.value || "").trim();
      if (!message) { err.textContent = ST.helpWriteMsg || "Please write a message."; err.style.display = "block"; msgEl.focus(); return; }
      err.style.display = "none";
      send.disabled = true; send.textContent = ST.helpSending || "Sending…";
      var body = {
        user_id: (session && session.user && session.user.id) || null,
        name: ((byId("ua-help-name").value) || "").trim() || null,
        email: ((byId("ua-help-email").value) || "").trim() || null,
        subject: ((byId("ua-help-subject").value) || "").trim() || null,
        message: message
      };
      fetch(SUPABASE_URL + "/rest/v1/support_messages", {
        method: "POST",
        headers: {
          apikey: ANON,
          Authorization: "Bearer " + ((session && session.access_token) || ANON),
          "Content-Type": "application/json",
          Prefer: "return=minimal"
        },
        body: JSON.stringify(body)
      }).then(function (r) {
        if (r.ok) {
          byId("ua-help-form-wrap").style.display = "none";
          byId("ua-help-success").style.display = "block";
        } else {
          send.disabled = false; send.textContent = ST.helpSend || "Send message";
          err.textContent = ST.helpSendFail || "Couldn't send — please try again."; err.style.display = "block";
        }
      }).catch(function () {
        send.disabled = false; send.textContent = ST.helpSend || "Send message";
        err.textContent = ST.helpSendFail || "Couldn't send — please try again."; err.style.display = "block";
      });
    });
  })();
</script>
