---
// =============================================================================
// UniqueApex · Partner Support — v2 "nodes-in-svg"  (data-psv="2")
// Save as: src/components/partner-support.astro  (replaces ALL earlier copies)
//
// HOW TO VERIFY THIS VERSION IS RUNNING:
//   Open the page → press F12 → Elements → find <section id="ua-partner">.
//   It must say  data-psv="2".  If it doesn't, an old file is being served.
//
// Why this version can't break: the icon circles are drawn INSIDE the SVG,
// at the exact same coordinates used for the dashed-line vertices. Node and
// line share one source of truth, so the node always sits on its line.
// Center illustration: /public/mother-son.png
// v2 · 2026-07-05
// =============================================================================
const { lang = "en" } = Astro.props;

const t = {
  en: {
    label: "Your partner. Your guide. Your support system.",
    heading: "More than a platform.",
    headingAccent: "A partner for every step.",
    body: "UniqueApex is your all-in-one assistant that helps you understand, organize, and navigate your child's journey — and reminds you that you're not doing it alone.",
    badge1: "You focus on your child.",
    badge2: "We take care of the rest.",
    imgAlt: "A mother and her son playing together",
    left: [
      { title: "Understand Every Report", desc: "We break down complex reports into simple, easy-to-understand summaries." },
      { title: "Securely Store Everything", desc: "All reports, assessments, and documents in one safe, private place." },
      { title: "Track Milestones", desc: "Keep track of development milestones and celebrate every win." },
      { title: "Manage Appointments", desc: "Therapy, school meetings, assessments — all in one smart calendar." },
    ],
    right: [
      { title: "Learn & Grow Together", desc: "Access expert-led workshops, guides, and articles anytime, anywhere." },
      { title: "Connect with a Mentor", desc: "Get paired with experienced parents who truly understand your journey." },
      { title: "Find Your People", desc: "Join a community that listens, supports, and celebrates with you." },
      { title: "Emotional Support", desc: "Because this journey is not just about your child, it's about you too." },
    ],
    bandTitle1: "You are not alone.",
    bandTitle2: "We're with you, every step.",
    minis: [
      { l1: "Expert guidance", l2: "you can trust" },
      { l1: "Private &", l2: "secure" },
      { l1: "Save time &", l2: "reduce stress" },
      { l1: "A community", l2: "that cares" },
    ],
  },
  fr: {
    label: "Votre partenaire. Votre guide. Votre système de soutien.",
    heading: "Plus qu'une plateforme.",
    headingAccent: "Un partenaire à chaque étape.",
    body: "UniqueApex est votre assistant tout-en-un qui vous aide à comprendre, organiser et naviguer le parcours de votre enfant — et vous rappelle que vous n'êtes pas seuls.",
    badge1: "Vous vous concentrez sur votre enfant.",
    badge2: "On s'occupe du reste.",
    imgAlt: "Une mère et son fils qui jouent ensemble",
    left: [
      { title: "Comprendre chaque rapport", desc: "Nous transformons les rapports complexes en résumés simples et clairs." },
      { title: "Tout conserver en sécurité", desc: "Rapports, évaluations et documents, réunis dans un espace sûr et privé." },
      { title: "Suivre les étapes clés", desc: "Suivez les jalons du développement et célébrez chaque victoire." },
      { title: "Gérer les rendez-vous", desc: "Thérapies, rencontres scolaires, évaluations — dans un seul calendrier intelligent." },
    ],
    right: [
      { title: "Apprendre et grandir ensemble", desc: "Ateliers animés par des experts, guides et articles, en tout temps." },
      { title: "Être jumelé à un mentor", desc: "Des parents d'expérience qui comprennent vraiment votre parcours." },
      { title: "Trouver votre communauté", desc: "Une communauté qui écoute, soutient et célèbre avec vous." },
      { title: "Soutien émotionnel", desc: "Parce que ce parcours ne concerne pas seulement votre enfant — vous aussi." },
    ],
    bandTitle1: "Vous n'êtes pas seuls.",
    bandTitle2: "On est là, à chaque étape.",
    minis: [
      { l1: "Des conseils d'experts", l2: "fiables" },
      { l1: "Privé et", l2: "sécurisé" },
      { l1: "Gagnez du temps,", l2: "moins de stress" },
      { l1: "Une communauté", l2: "bienveillante" },
    ],
  },
}[lang] || {};

// Icon paths, 24×24 viewBox (index 0–3 = left cards/nodes, 4–7 = right cards/nodes)
const icons = [
  '<path d="M6 2.5h8L19 8v13.5H6z"/><path d="M13.5 2.5V8H19M9 12h6M9 16h6"/>',
  '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><rect x="9.5" y="10" width="5" height="4.5" rx="1"/><path d="M10.8 10V8.8a1.2 1.2 0 0 1 2.4 0V10"/>',
  '<path d="M12 3l2.6 5.4 5.9.8-4.3 4.1 1 5.9-5.2-2.8-5.2 2.8 1-5.9L3.5 9.2l5.9-.8z"/>',
  '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4M9.5 15.5l2 2 3.5-4"/>',
  '<path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M6 10.5V16c1.8 1.6 3.8 2.4 6 2.4s4.2-.8 6-2.4v-5.5"/>',
  '<circle cx="10" cy="8" r="3.5"/><path d="M3.5 20c.8-3.4 3.4-5.2 6.5-5.2 1 0 2 .2 2.8.6"/><path d="M17.5 14.5l1 2.1 2.3.3-1.7 1.6.4 2.3-2-1.1-2 1.1.4-2.3-1.7-1.6 2.3-.3z"/>',
  '<circle cx="9" cy="9" r="3"/><circle cx="16.5" cy="10" r="2.4"/><path d="M2.5 20c.7-3.2 3.2-5 6.5-5s5.8 1.8 6.5 5"/><path d="M15 15.4c2.6.3 4.5 1.9 5 4.6"/>',
  '<path d="M12 9.2c1-1.9 3.8-1.9 4.6.2.7 1.9-1.4 3.7-4.6 6-3.2-2.3-5.3-4.1-4.6-6 .8-2.1 3.6-2.1 4.6-.2z"/><path d="M3.5 16.5c2.2 2.8 5.2 4.3 8.5 4.3s6.3-1.5 8.5-4.3"/>',
];

// Node positions (% of the center stage box), spread like the reference:
// upper / mid-upper / mid-lower / lower on each side, just outside the circle.
// Left 0–3 (top→bottom), right 4–7 (top→bottom). The SVG draws each node AND
// bends its line at these exact points.
const nodePos = [
  [11, 19.5],
  [1.8, 38.9],
  [1.8, 61.1],
  [11, 80.5],
  [89, 19.5],
  [98.2, 38.9],
  [98.2, 61.1],
  [89, 80.5],
];
---

<section class="py-16 my-4" id="ua-partner" data-psv="2">
  <div class="text-center max-w-3xl mx-auto mb-10">
    <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">{t.label}</p>
    <h2 class="text-3xl md:text-4xl font-bold mt-3 text-slate-800 leading-tight">
      {t.heading}<br /><span class="text-violet-700">{t.headingAccent}</span>
    </h2>
    <p class="text-slate-500 mt-6 text-lg">{t.body}</p>
  </div>

  <!-- main panel -->
  <div id="ps-panel" class="relative rounded-3xl border border-violet-100 bg-violet-50/60 p-5 lg:p-8 overflow-hidden">
    <svg id="ps-svg" class="hidden lg:block absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></svg>

    <div class="relative grid gap-4 lg:grid-cols-[1fr_auto_1fr] lg:gap-x-10 xl:gap-x-16 items-center">
      <!-- center: badge + circle (first on small screens) -->
      <div class="order-first lg:order-none lg:col-start-2 lg:row-start-1 flex flex-col items-center gap-5">
        <div class="ps-badge relative z-20 inline-flex items-center gap-3 rounded-2xl bg-violet-700 text-white px-5 py-3 shadow-lg shadow-violet-300/50 max-w-[300px]">
          <span class="w-8 h-8 rounded-lg bg-white/15 flex items-center justify-center shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 8.6c1.1-2.1 4.2-2.1 5.1.2.8 2.1-1.5 4-5.1 6.6-3.6-2.6-5.9-4.5-5.1-6.6.9-2.3 4-2.3 5.1-.2z"/></svg>
          </span>
          <span class="text-[13.5px] font-semibold leading-snug">
            <span class="block">{t.badge1}</span>
            <span class="block">{t.badge2}</span>
          </span>
        </div>

        <div id="ps-stage" class="relative w-[280px] h-[280px] lg:w-[340px] lg:h-[340px] xl:w-[400px] xl:h-[400px]">
          <div class="ps-hero absolute inset-7 rounded-full bg-white p-2 shadow-xl shadow-violet-200/60 z-10">
            <img src="/mother-son.png" alt={t.imgAlt} class="w-full h-full rounded-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- left cards -->
      <div class="grid sm:grid-cols-2 gap-3 lg:col-start-1 lg:row-start-1 lg:flex lg:flex-col lg:gap-4 lg:justify-center">
        {t.left.map((c, i) => (
          <div class="ps-card relative z-10 bg-white rounded-2xl shadow-md shadow-violet-200/40 px-4 py-4 flex items-start gap-3.5" style={`transition-delay:${(0.15 + i * 0.08).toFixed(2)}s`}>
            <span class="w-14 h-14 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i]} />
            </span>
            <span class="min-w-0">
              <span class="block text-[15px] font-bold text-slate-800 leading-tight">{c.title}</span>
              <span class="block text-[12.5px] text-slate-500 leading-snug mt-1">{c.desc}</span>
            </span>
          </div>
        ))}
      </div>

      <!-- right cards -->
      <div class="grid sm:grid-cols-2 gap-3 lg:col-start-3 lg:row-start-1 lg:flex lg:flex-col lg:gap-4 lg:justify-center">
        {t.right.map((c, i) => (
          <div class="ps-card relative z-10 bg-white rounded-2xl shadow-md shadow-violet-200/40 px-4 py-4 flex items-start gap-3.5" style={`transition-delay:${(0.2 + i * 0.08).toFixed(2)}s`}>
            <span class="w-14 h-14 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i + 4]} />
            </span>
            <span class="min-w-0">
              <span class="block text-[15px] font-bold text-slate-800 leading-tight">{c.title}</span>
              <span class="block text-[12.5px] text-slate-500 leading-snug mt-1">{c.desc}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- reassurance band -->
  <div class="mt-6 rounded-3xl border border-violet-100 bg-violet-50/60 px-6 lg:px-10 py-6 flex flex-col lg:flex-row items-center gap-6 lg:gap-10">
    <div class="flex items-center gap-4 shrink-0 lg:pr-10 lg:border-r lg:border-slate-200">
      <svg class="w-16 h-16 text-violet-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8.8c1.1-2.1 4.3-2.1 5.2.2.8 2.1-1.5 4.1-5.2 6.7-3.7-2.6-6-4.6-5.2-6.7.9-2.3 4.1-2.3 5.2-.2z"/><path d="M3.5 16.5c2.2 2.9 5.2 4.4 8.5 4.4s6.3-1.5 8.5-4.4"/></svg>
      <span>
        <span class="block text-[19px] font-bold text-slate-800 leading-tight">{t.bandTitle1}</span>
        <span class="block text-[19px] font-bold text-violet-700 leading-tight">{t.bandTitle2}</span>
      </span>
    </div>
    <div class="flex-1 w-full grid grid-cols-2 gap-y-5 lg:flex lg:items-center">
      {t.minis.map((m, i) => (
        <span class={`flex items-center justify-center gap-3 lg:flex-1 ${i === 0 ? "" : "lg:border-l lg:border-slate-200"}`}>
          <span class="text-violet-600 shrink-0">
            {i === 0 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9.5" cy="8" r="3.5"/><path d="M3 20c.8-3.5 3.4-5.4 6.5-5.4 1.2 0 2.3.3 3.2.8"/><path d="M14.5 17.5l2 2 3.5-4"/></svg>}
            {i === 1 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4.5"/></svg>}
            {i === 2 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2.5"/></svg>}
            {i === 3 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8.6c1.1-2.1 4.2-2.1 5.1.2.8 2.1-1.5 4-5.1 6.6-3.6-2.6-5.9-4.5-5.1-6.6.9-2.3 4-2.3 5.1-.2z"/></svg>}
          </span>
          <span class="text-[14px] font-semibold text-slate-700 leading-snug">
            <span class="block">{m.l1}</span>
            <span class="block">{m.l2}</span>
          </span>
        </span>
      ))}
    </div>
  </div>
</section>

<style is:global>
  #ua-partner .ps-card{opacity:0;transform:translateY(10px) scale(.97);transition:opacity .5s ease,transform .5s ease}
  #ua-partner.ua-in .ps-card{opacity:1;transform:none}
  #ua-partner .ps-hero{opacity:0;transform:scale(.94);transition:opacity .6s ease,transform .6s ease;transition-delay:.15s}
  #ua-partner.ua-in .ps-hero{opacity:1;transform:none}
  #ua-partner .ps-badge{opacity:0;transform:translateY(-8px);transition:opacity .5s ease,transform .5s ease;transition-delay:.3s}
  #ua-partner.ua-in .ps-badge{opacity:1;transform:none}
  #ua-partner #ps-svg{opacity:0;transition:opacity .7s ease .35s}
  #ua-partner.ua-in #ps-svg{opacity:1}
  @media (prefers-reduced-motion: reduce){
    #ua-partner .ps-card,#ua-partner .ps-hero,#ua-partner .ps-badge{opacity:1;transform:none;transition:none}
    #ua-partner #ps-svg{opacity:1;transition:none}
  }
</style>

<script is:inline define:vars={{ icons, nodePos }}>
  (function () {
    var root = document.getElementById("ua-partner");
    if (!root) return;

    function draw() {
      var panel = document.getElementById("ps-panel");
      var svg = document.getElementById("ps-svg");
      var stage = document.getElementById("ps-stage");
      if (!panel || !svg || !stage) return;
      if (!window.matchMedia("(min-width: 1024px)").matches) { svg.innerHTML = ""; return; }
      var pr = panel.getBoundingClientRect();
      if (!pr.width) return;
      svg.setAttribute("viewBox", "0 0 " + pr.width + " " + pr.height);
      var st = stage.getBoundingClientRect();
      var cx = st.left - pr.left + st.width / 2;
      var cy = st.top - pr.top + st.height / 2;
      var cards = panel.querySelectorAll(".ps-card");

      var linesHtml = "";
      var nodesHtml = "";
      cards.forEach(function (card, i) {
        var pos = nodePos[i];
        if (!pos) return;
        // Node coordinates — THE single source of truth for both line and node
        var nx = st.left - pr.left + (st.width * pos[0]) / 100;
        var ny = st.top - pr.top + (st.height * pos[1]) / 100;
        var r = card.getBoundingClientRect();
        var ex = (i < 4 ? r.right : r.left) - pr.left;
        var ey = r.top - pr.top + r.height / 2;
        linesHtml +=
          '<path fill="none" stroke="#C4B5FD" stroke-width="2" stroke-dasharray="5 6" stroke-linecap="round" stroke-linejoin="round" d="M' +
          cx + " " + cy + " L " + nx + " " + ny + " L " + ex + " " + ey + '"/>';
        nodesHtml +=
          '<g transform="translate(' + nx + " " + ny + ')" style="filter:drop-shadow(0 2px 6px rgba(124,58,237,.2))">' +
          '<circle r="24" fill="#ffffff" stroke="#EDE9FE" stroke-width="1.5"/>' +
          '<g transform="translate(-10.5 -10.5) scale(0.875)" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
          icons[i] +
          "</g></g>";
      });
      // Lines first, nodes second — nodes paint on top of their own lines
      svg.innerHTML = linesHtml + nodesHtml;
    }

    requestAnimationFrame(draw);
    window.addEventListener("load", draw);
    var rt;
    window.addEventListener("resize", function () { clearTimeout(rt); rt = setTimeout(draw, 120); });

    if (!("IntersectionObserver" in window)) { root.classList.add("ua-in"); draw(); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { root.classList.add("ua-in"); draw(); io.disconnect(); } });
    }, { threshold: 0.15 });
    io.observe(root);
  })();
</script>