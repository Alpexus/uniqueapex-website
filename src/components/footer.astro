---
import { Icon } from "astro-icon/components";

interface Props {
  lang?: "en" | "fr";
}

const { lang = "en" } = Astro.props;
const prefix = lang === "fr" ? "/fr" : "";

const t = {
  en: {
    tagline:
      "Helping families of neurodivergent children find, coordinate, and manage therapy access — all in one place.",
    quickLinks: "Quick Links",
    home: "Home",
    how: "How It Works",
    about: "About",
    pricing: "Pricing",
    contact: "Contact",
    waitlist: "Join Waitlist",
    privacy: "Privacy Policy",
    terms: "Terms of Service",
    contactUs: "Contact Us",
    location: "Montréal, Québec, Canada",
    follow: "Follow Us",
    rights: "All rights reserved.",
    privacyShort: "Privacy",
    termsShort: "Terms",
    languages: "Montréal · English & French",
  },
  fr: {
    tagline:
      "Aider les familles d'enfants neurodivergents à trouver, coordonner et gérer l'accès aux thérapies — en un seul endroit.",
    quickLinks: "Liens rapides",
    home: "Accueil",
    how: "Comment ça marche",
    about: "À propos",
    pricing: "Tarifs",
    contact: "Contact",
    waitlist: "Liste d'attente",
    privacy: "Politique de confidentialité",
    terms: "Conditions d'utilisation",
    contactUs: "Nous joindre",
    location: "Montréal, Québec, Canada",
    follow: "Suivez-nous",
    rights: "Tous droits réservés.",
    privacyShort: "Confidentialité",
    termsShort: "Conditions",
    languages: "Montréal · Français & English",
  },
}[lang];
---

<footer class="bg-slate-50 border-t border-slate-200 mt-20">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Left: Company -->
      <div>
        <a href={prefix + "/"} class="flex items-center gap-2">
          <img src="/Logo.png" alt="UniqueApex" class="h-10 w-auto" />
          <span class="text-lg"><span class="font-bold text-slate-800">Unique</span><span class="font-bold text-violet-700">Apex</span></span>
        </a>
        <p class="text-slate-500 mt-4 leading-relaxed max-w-xs">
          {t.tagline}
        </p>
      </div>

      <!-- Middle: Quick Links -->
      <div class="md:mx-auto">
        <h3 class="font-semibold text-slate-800 mb-4">{t.quickLinks}</h3>
        <ul class="space-y-3">
          <li><a href={prefix + "/"} class="text-slate-500 hover:text-violet-700 transition">{t.home}</a></li>
          <li><a href={prefix + "/howitworks"} class="text-slate-500 hover:text-violet-700 transition">{t.how}</a></li>
          <li><a href={prefix + "/about"} class="text-slate-500 hover:text-violet-700 transition">{t.about}</a></li>
          <li><a href={prefix + "/pricing"} class="text-slate-500 hover:text-violet-700 transition">{t.pricing}</a></li>
          <li><a href={prefix + "/contact"} class="text-slate-500 hover:text-violet-700 transition">{t.contact}</a></li>
          <li><a href={prefix + "/waitlist"} class="text-slate-500 hover:text-violet-700 transition">{t.waitlist}</a></li>
          <li><a href={prefix + "/privacy"} class="text-slate-500 hover:text-violet-700 transition">{t.privacy}</a></li>
          <li><a href={prefix + "/terms"} class="text-slate-500 hover:text-violet-700 transition">{t.terms}</a></li>
        </ul>
      </div>

      <!-- Right: Contact & Social -->
      <div>
        <h3 class="font-semibold text-slate-800 mb-4">{t.contactUs}</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:contact@uniqueapex.com" class="text-slate-500 hover:text-violet-700 transition flex items-center gap-2">
              <Icon name="uil:envelope" class="w-4 h-4" />
              contact@uniqueapex.com
            </a>
          </li>
          <li>
            <span class="text-slate-500 flex items-center gap-2">
              <Icon name="uil:map-marker" class="w-4 h-4" />
              {t.location}
            </span>
          </li>
        </ul>

        <h3 class="font-semibold text-slate-800 mt-8 mb-4">{t.follow}</h3>
        <div class="flex gap-4">
          <a href="https://www.facebook.com/people/UniqueApex/61590816952117/" target="_blank" rel="noopener" class="text-slate-400 hover:text-violet-700 transition">
            <Icon name="uil:facebook" class="w-6 h-6" />
          </a>
          <a href="https://www.instagram.com/unique_apex/" target="_blank" rel="noopener" class="text-slate-400 hover:text-violet-700 transition">
            <Icon name="uil:instagram" class="w-6 h-6" />
          </a>
          <a href="https://www.linkedin.com/company/uniqueapex" target="_blank" rel="noopener" class="text-slate-400 hover:text-violet-700 transition">
            <Icon name="uil:linkedin" class="w-6 h-6" />
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-200 mt-12 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-slate-400">
        © {new Date().getFullYear()} UniqueApex. {t.rights}
      </p>
      <p class="text-sm text-slate-400">
        <a href={prefix + "/privacy"} class="hover:text-violet-700 transition">{t.privacyShort}</a>
        &nbsp;·&nbsp;
        <a href={prefix + "/terms"} class="hover:text-violet-700 transition">{t.termsShort}</a>
        &nbsp;·&nbsp; {t.languages}
      </p>
    </div>
  </div>
</footer>
