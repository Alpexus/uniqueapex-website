// =============================================================================
// @ts-ignore
import { Icon } from "astro-icon/components";

const { lang = "en" } = Astro.props;

const t = {
  en: {
    story: {
      label: "Our Story",
      title1: "Built by a parent,",
      title2: "for every family",
      paras: [
        "Families are left to navigate fragmented systems alone — becoming researchers, schedulers, advocates, and coordinators on top of being caregivers.",
        "Behind every appointment, assessment, and waitlist is a family trying to build the best possible path forward for their child.",
        "UniqueApex was born from lived experience and a simple belief: families deserve better infrastructure, not just better intentions.",
      ],
      imgAlt: "Family climbing illustration",
    },
    founder: {
      label: "A Message From Our Founder",
      quote1: "\u201CBehind every waitlist is a family that",
      quote2: "needed help yesterday.\u201D",
      paras: [
        "UniqueApex was born from my own journey as a parent. I know what it's like to live inside a spreadsheet of clinic names — the voicemails, the callbacks, the same forms, telling your child's story from zero to every new stranger.",
        "So I set out to build the companion I wished we'd had: one place that carries your child's whole story, reaches out to the right providers, keeps every document and waitlist in view, and guides you through funding, school, and every transition — from the very first concern all the way to adulthood.",
        "Because no family should ever navigate this alone. Whatever stage you're at, we walk it with you.",
      ],
      tagline: "Every child's journey is different. Every family deserves better support.",
      name: "Pelin İpek Temurcan",
      role: "Founder & CEO",
      imgAlt: "Pelin İpek Temurcan",
    },
    vision: {
      badge: "Our Vision",
      title1: "A world where no family navigates",
      title2: "alone",
      body: "We envision a future where every family of a neurodivergent child has access to a connected, coordinated support system — regardless of language, location, or how overwhelmed they feel.",
      imgAlt: "Vision illustration",
    },
    mission: {
      badge: "Our Mission",
      title1: "Coordination infrastructure,",
      title2: "not just a directory",
      paras: [
        "UniqueApex is a support ecosystem designed to help families navigate complex care journeys with greater clarity and better coordination.",
        "We are starting with the most urgent pain point — connecting families with the right providers. Our long-term vision is to build a fully connected, accessible infrastructure for neurodivergent families everywhere.",
      ],
      imgAlt: "Mission illustration",
    },
    name: {
      label: "Behind The Name",
      title1: "What does",
      title2: "UniqueApex",
      title3: "mean?",
      unique: { title: "Unique", body: "Every neurodivergent child is unique — with their own strengths, their own timeline, and their own path. There is no one-size-fits-all support system." },
      apex: { title: "Apex", body: "Every family is climbing toward its own version of progress, growth, and wellbeing. UniqueApex exists to make that climb less isolating." },
    },
    values: {
      label: "Our Values",
      title: "What we stand for",
      items: [
        { icon: "bx:bxs-heart", title: "Empathy", body: "Every decision we make is grounded in the real experience of parents navigating an overwhelming system." },
        { icon: "bx:bxs-file-find", title: "Clarity", body: "We make complex systems simple so families can focus on their child — not on paperwork." },
        { icon: "bx:bxs-user-check", title: "Access", body: "Every child deserves support regardless of language, location, or how overwhelmed their parents feel." },
        { icon: "bx:bxs-group", title: "Community", body: "No family navigates alone. UniqueApex connects families with each other, with experts, and with the right providers." },
      ],
    },
  },
  fr: {
    story: {
      label: "Notre histoire",
      title1: "Créé par un parent,",
      title2: "pour chaque famille",
      paras: [
        "Les familles sont laissées à elles-mêmes pour naviguer des systèmes fragmentés — devenant chercheuses, planificatrices, plaideuses et coordinatrices en plus d'être aidantes.",
        "Derrière chaque rendez-vous, évaluation et liste d'attente, il y a une famille qui essaie de construire le meilleur chemin possible pour son enfant.",
        "UniqueApex est né d'une expérience vécue et d'une conviction simple : les familles méritent une meilleure infrastructure, pas seulement de meilleures intentions.",
      ],
      imgAlt: "Illustration d'une famille qui grimpe",
    },
    founder: {
      label: "Un message de notre fondatrice",
      quote1: "« Derrière chaque liste d'attente, il y a une famille qui avait",
      quote2: "besoin d'aide hier. »",
      paras: [
        "UniqueApex est né de mon propre parcours en tant que parent. Je sais ce que c'est que de vivre dans un tableur de noms de cliniques — les boîtes vocales, les rappels, les mêmes formulaires, raconter l'histoire de son enfant depuis le début à chaque nouvel inconnu.",
        "Alors j'ai voulu bâtir le compagnon que j'aurais aimé avoir : un seul endroit qui porte toute l'histoire de votre enfant, contacte les bons professionnels, garde chaque document et chaque liste d'attente en vue, et vous guide à travers le financement, l'école et chaque transition — des premières inquiétudes jusqu'à l'âge adulte.",
        "Parce qu'aucune famille ne devrait traverser ce parcours seule. Peu importe où vous en êtes, on marche avec vous.",
      ],
