      name: "Pelin İpek Temurcan",
      role: "Fondatrice et PDG",
      imgAlt: "Pelin İpek Temurcan",
    },
    vision: {
      badge: "Notre vision",
      title1: "Un monde où aucune famille ne navigue",
      title2: "seule",
      body: "Nous envisageons un avenir où chaque famille d'un enfant neurodivergent a accès à un système de soutien connecté et coordonné — peu importe la langue, la localisation ou le niveau de stress ressenti.",
      imgAlt: "Illustration de la vision",
    },
    mission: {
      badge: "Notre mission",
      title1: "Une infrastructure de coordination,",
      title2: "pas juste un répertoire",
      paras: [
        "UniqueApex est un écosystème de soutien conçu pour aider les familles à naviguer des parcours de soins complexes avec plus de clarté et une meilleure coordination.",
        "Nous commençons par le besoin le plus urgent — connecter les familles aux bons professionnels. Notre vision à long terme est de bâtir une infrastructure complète, connectée et accessible pour les familles neurodivergentes partout.",
      ],
      imgAlt: "Illustration de la mission",
    },
    name: {
      label: "Derrière le nom",
      title1: "Que signifie",
      title2: "UniqueApex",
      title3: "?",
      unique: { title: "Unique", body: "Chaque enfant neurodivergent est unique — avec ses propres forces, son propre rythme et son propre chemin. Il n'existe pas de solution universelle." },
      apex: { title: "Apex", body: "Chaque famille grimpe vers sa propre version du progrès, de la croissance et du bien-être. UniqueApex existe pour rendre cette ascension moins isolante." },
    },
    values: {
      label: "Nos valeurs",
      title: "Ce qui nous guide",
      items: [
        { icon: "bx:bxs-heart", title: "Empathie", body: "Chaque décision que nous prenons est ancrée dans l'expérience réelle des parents qui naviguent un système complexe." },
        { icon: "bx:bxs-file-find", title: "Clarté", body: "Nous simplifions les systèmes complexes pour que les familles puissent se concentrer sur leur enfant — pas sur la paperasse." },
        { icon: "bx:bxs-user-check", title: "Accessibilité", body: "Chaque enfant mérite du soutien, peu importe la langue, la localisation ou le niveau de stress de ses parents." },
        { icon: "bx:bxs-group", title: "Communauté", body: "Aucune famille ne navigue seule. UniqueApex connecte les familles entre elles, avec des experts et les bons professionnels." },
      ],
    },
  },
}[lang];
---

<div id="ua-about">
  <!-- Hero + Brand Story -->
  <div class="grid md:grid-cols-2 gap-16 items-center mt-16 mb-28">
    <div class="space-y-6 ab-hero">
      <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">{t.story.label}</p>
      <h1 class="text-5xl font-bold text-slate-800 leading-tight">
        {t.story.title1} <span class="text-violet-700">{t.story.title2}</span>
      </h1>
      {t.story.paras.map((p) => (
        <p class="text-slate-600 leading-relaxed text-lg">{p}</p>
      ))}
    </div>
    <div class="flex items-center justify-center ab-hero ab-hero-img">
      <img src="/climbing-family.png" alt={t.story.imgAlt} class="w-full max-w-[540px]" />
    </div>
  </div>

  <!-- Founder -->
  <div class="ab-rev relative bg-violet-50/60 border border-violet-100 rounded-3xl p-10 md:p-16 mb-32 overflow-hidden">
    <div class="relative grid md:grid-cols-3 gap-12 items-center">
      <div class="flex flex-col items-center text-center">
        <div class="relative w-56 h-56">
          <div class="absolute -inset-3 bg-violet-100" style="border-radius:56% 44% 48% 52% / 46% 54% 44% 56%"></div>
          <img src="/headshot.jpeg" alt={t.founder.imgAlt} class="relative w-56 h-56 rounded-full object-cover shadow-xl ring-4 ring-white" />
        </div>
        <h3 class="font-bold text-xl mt-5 text-slate-800">{t.founder.name}</h3>
        <p class="text-violet-700 font-medium m-0">{t.founder.role}</p>
      </div>
      <div class="md:col-span-2">
        <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">{t.founder.label}</p>
        <h2 class="text-3xl md:text-4xl font-bold mt-4 text-slate-800 leading-tight tracking-tight">
          {t.founder.quote1} <span class="text-violet-700">{t.founder.quote2}</span>
        </h2>
        {t.founder.paras.map((p, i) => (
          <p class={`text-slate-500 leading-relaxed text-lg ${i === 0 ? "mt-6" : "mt-4"}`}>{p}</p>
        ))}
        <p class="text-violet-700 mt-6 text-lg font-medium italic">{t.founder.tagline}</p>
        <p class="ab-sign m-0 mt-4 text-violet-700" style="transform:rotate(-1.5deg)">Pelin İpek Temurcan</p>
      </div>
    </div>
  </div>

  <!-- Vision -->
  <div class="ab-rev grid md:grid-cols-2 gap-16 items-center mb-24">
    <div class="flex items-center justify-center">
      <img src="/vision-illustration.png" alt={t.vision.imgAlt} class="w-full max-w-[500px]" />
    </div>
    <div>
      <span class="inline-block bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1 rounded-full mb-6">{t.vision.badge}</span>
      <h2 class="text-4xl font-bold text-slate-800 leading-tight mb-6">
        {t.vision.title1} <span class="text-violet-700">{t.vision.title2}</span>
      </h2>
      <p class="text-slate-500 leading-relaxed text-lg">{t.vision.body}</p>
    </div>
  </div>

  <!-- Mission -->
  <div class="ab-rev grid md:grid-cols-2 gap-16 items-center mb-32">
    <div>
      <span class="inline-block bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1 rounded-full mb-6">{t.mission.badge}</span>
      <h2 class="text-4xl font-bold text-slate-800 leading-tight mb-6">
        {t.mission.title1} <span class="text-violet-700">{t.mission.title2}</span>
      </h2>
      {t.mission.paras.map((p, i) => (
        <p class={`text-slate-500 leading-relaxed text-lg ${i === 0 ? "" : "mt-4"}`}>{p}</p>
      ))}
    </div>
    <div class="flex items-center justify-center">
      <img src="/mission-illustration.png" alt={t.mission.imgAlt} class="w-full max-w-[500px]" />
    </div>
  </div>

  <!-- Name meaning: clickable images -->
  <div class="ab-rev mb-32">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide mb-4">{t.name.label}</p>
      <h2 class="text-4xl font-bold text-slate-800 leading-tight">
        {t.name.title1} <span class="text-violet-700">{t.name.title2}</span> {t.name.title3}
      </h2>
    </div>
    <div class="grid md:grid-cols-2 gap-12 max-w-3xl mx-auto">
      <button type="button" class="nm-item group flex flex-col items-center bg-transparent border-0 p-0 cursor-pointer text-center" aria-expanded="false">
        <img src="/icon-unique.png" alt="" class="w-44 h-44 transition-transform duration-300 group-hover:scale-105 group-hover:-translate-y-1.5" />
        <span class="text-2xl font-bold text-violet-700 mt-4">{t.name.unique.title}</span>
        <span class="nm-body block overflow-hidden" style="max-height:0;opacity:0;margin-top:0;transition:max-height .45s ease,opacity .35s ease,margin-top .3s ease">
          <span class="block text-slate-500 text-lg leading-relaxed max-w-sm mx-auto">{t.name.unique.body}</span>
        </span>
      </button>
      <button type="button" class="nm-item group flex flex-col items-center bg-transparent border-0 p-0 cursor-pointer text-center" aria-expanded="false">
        <img src="/icon-apex.png" alt="" class="w-44 h-44 transition-transform duration-300 group-hover:scale-105 group-hover:-translate-y-1.5" />
        <span class="text-2xl font-bold text-violet-700 mt-4">{t.name.apex.title}</span>
        <span class="nm-body block overflow-hidden" style="max-height:0;opacity:0;margin-top:0;transition:max-height .45s ease,opacity .35s ease,margin-top .3s ease">
          <span class="block text-slate-500 text-lg leading-relaxed max-w-sm mx-auto">{t.name.apex.body}</span>
        </span>
      </button>
    </div>
  </div>

  <!-- Values -->
  <div class="ab-rev ab-values mb-28">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">{t.values.label}</p>
      <h2 class="text-4xl font-bold mt-3 text-slate-800">{t.values.title}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
      {t.values.items.map((item, vi) => (
        <div class="ab-card relative bg-white border border-violet-100 rounded-3xl px-5 py-7 text-center shadow-sm">
          <div class="relative w-24 h-24 mx-auto mb-5">
            <div class="ab-blob absolute inset-1.5" style={["border-radius:46% 54% 58% 42% / 52% 44% 56% 48%","border-radius:58% 42% 46% 54% / 44% 56% 48% 52%","border-radius:52% 48% 42% 58% / 56% 46% 54% 44%","border-radius:44% 56% 54% 46% / 48% 58% 42% 56%"][vi]}></div>
            {vi === 0 ? (
              <svg class="ab-acc absolute -top-1 right-0 w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2.5" stroke-linecap="round"><path d="M16 6l3-3M18 11h4M12 5V1"/></svg>
            ) : (
              <svg class="ab-acc ab-spark absolute -top-1 -right-1 w-4 h-4" viewBox="0 0 24 24"><path d="M12 2l2.2 6.6L21 12l-6.8 3.4L12 22l-2.2-6.6L3 12l6.8-3.4z" fill="#c4b5fd"/></svg>
            )}
            <svg class="ab-acc ab-spark ab-spark2 absolute bottom-0 -left-1 w-3 h-3" viewBox="0 0 24 24"><path d="M12 2l2.2 6.6L21 12l-6.8 3.4L12 22l-2.2-6.6L3 12l6.8-3.4z" fill="#ddd6fe"/></svg>
            <span class="ab-ic absolute inset-0 flex items-center justify-center text-violet-600">
              <Icon class="w-10 h-10" name={item.icon} />
            </span>
          </div>
          <span class="block text-lg font-bold text-slate-800 leading-snug">{item.title}</span>
          <span class="block text-sm text-slate-500 leading-relaxed mt-2">{item.body}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap');
  #ua-about .ab-sign{font-family:'Caveat','Segoe Script','Brush Script MT',cursive;font-size:2.5rem;line-height:1.1}
  #ua-about .ab-hero{animation:abUp .7s ease both}
  #ua-about .ab-hero-img{animation-delay:.15s}
  @keyframes abUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
  #ua-about .ab-rev{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
  #ua-about .ab-rev.ab-in{opacity:1;transform:none}
  #ua-about .ab-card{opacity:0;transition:transform .25s ease,box-shadow .25s ease,border-color .2s ease}
  #ua-about .ab-values.ab-in .ab-card{animation:abCardIn .5s ease both}
  #ua-about .ab-values.ab-in .ab-card:nth-child(1){animation-delay:.05s}
  #ua-about .ab-values.ab-in .ab-card:nth-child(2){animation-delay:.15s}
  #ua-about .ab-values.ab-in .ab-card:nth-child(3){animation-delay:.25s}
  #ua-about .ab-values.ab-in .ab-card:nth-child(4){animation-delay:.35s}
  @keyframes abCardIn{from{opacity:0;transform:translateY(14px) scale(.96)}to{opacity:1;transform:none}}
  #ua-about .ab-card:hover{transform:translateY(-6px);border-color:#c4b5fd;box-shadow:0 16px 32px -14px rgba(124,58,237,.28)}
  #ua-about .ab-card:active{transform:translateY(-2px) scale(.99)}
  #ua-about .ab-blob{background:#EDE9FE;transition:transform .5s cubic-bezier(.34,1.5,.64,1)}
  #ua-about .ab-card:hover .ab-blob{transform:scale(1.12) rotate(9deg)}
  #ua-about .ab-ic{transition:transform .35s cubic-bezier(.34,1.6,.64,1)}
  #ua-about .ab-card:hover .ab-ic{transform:scale(1.14) rotate(-5deg)}
  #ua-about .ab-acc{opacity:.85}
  #ua-about .ab-card:hover .ab-spark{animation:abTwinkle 1s ease infinite}
  #ua-about .ab-card:hover .ab-spark2{animation-delay:.3s}
  @keyframes abTwinkle{0%,100%{transform:scale(1);opacity:.85}50%{transform:scale(1.35);opacity:1}}
  @media (prefers-reduced-motion: reduce){
    #ua-about .ab-hero{animation:none}
    #ua-about .ab-rev{opacity:1;transform:none;transition:none}
    #ua-about .ab-card{opacity:1;animation:none;transition:none}
    #ua-about .ab-card:hover,#ua-about .ab-card:hover .ab-ic,#ua-about .ab-card:hover .ab-blob{transform:none}
    #ua-about .ab-spark,#ua-about .ab-card:hover .ab-spark,#ua-about .ab-card:hover .ab-spark2{animation:none}
    #ua-about .nm-item img{transition:none}
    #ua-about .nm-body{transition:none !important}
  }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById("ua-about");
    if (!root) return;

    // ---- Name images: click to reveal ----
    root.querySelectorAll(".nm-item").forEach(function (b) {
      var body = b.querySelector(".nm-body");
      b.addEventListener("click", function () {
        var open = b.getAttribute("aria-expanded") === "true";
        b.setAttribute("aria-expanded", open ? "false" : "true");
        if (!body) return;
        if (open) {
          body.style.maxHeight = "0"; body.style.opacity = "0"; body.style.marginTop = "0";
        } else {
          body.style.maxHeight = body.scrollHeight + "px"; body.style.opacity = "1"; body.style.marginTop = "14px";
        }
      });
    });

    // ---- Scroll reveals ----
    var els = root.querySelectorAll(".ab-rev");
    if (!("IntersectionObserver" in window)) {
      els.forEach(function (e) { e.classList.add("ab-in"); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add("ab-in"); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    els.forEach(function (e) { io.observe(e); });
  })();
</script>