---
// =============================================================================
// UniqueApex · Before / After — "doing it alone vs with UniqueApex"
// Save as: src/components/before-after.astro
// Use in a page:  <BeforeAfter lang="en" />   (or lang="fr")
// =============================================================================
const { lang = "en" } = Astro.props;

const t = {
  en: {
    label: "The difference",
    heading: "You've been doing the work of five people.",
    headingAccent: "Let us carry it.",
    beforeTitle: "Doing it alone",
    before: [
      "Dozens of calls, emails, and voicemails",
      "The same forms, filled out again and again",
      "Invisible waitlists with no answers",
      "Reports and advice scattered everywhere",
    ],
    afterTitle: "With UniqueApex",
    after: [
      "One profile, entered once",
      "We contact matched providers for you",
      "Every waitlist, document, and step in one place",
      "Plain-language guidance at every stage",
    ],
  },
  fr: {
    label: "La différence",
    heading: "Vous faites le travail de cinq personnes.",
    headingAccent: "Laissez-nous porter ce poids.",
    beforeTitle: "Seul·e face au système",
    before: [
      "Des dizaines d'appels, de courriels et de messages",
      "Les mêmes formulaires, remplis encore et encore",
      "Des listes d'attente invisibles, sans réponses",
      "Rapports et conseils éparpillés partout",
    ],
    afterTitle: "Avec UniqueApex",
    after: [
      "Un profil, saisi une seule fois",
      "On contacte les intervenants compatibles pour vous",
      "Chaque liste d'attente, document et étape au même endroit",
      "Des conseils en langage clair à chaque étape",
    ],
  },
}[lang] || {};
---

<section class="py-14 my-4" id="ua-diff">
  <div class="text-center max-w-3xl mx-auto mb-12">
    <p class="text-sm font-semibold text-violet-700 uppercase tracking-wide">{t.label}</p>
    <h2 class="text-3xl md:text-4xl font-bold mt-3 text-slate-800 leading-tight">
      {t.heading} <span class="text-violet-700">{t.headingAccent}</span>
    </h2>
  </div>

  <div class="relative grid md:grid-cols-2 gap-5 md:gap-8 max-w-4xl mx-auto items-stretch">
    <!-- Before -->
    <div class="ua-bf ua-bf-l bg-slate-50 border border-slate-200 rounded-3xl p-7">
      <p class="text-sm font-bold text-slate-500 uppercase tracking-wide mb-5">{t.beforeTitle}</p>
      <ul class="space-y-4 m-0 p-0 list-none">
        {t.before.map((item) => (
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center shrink-0 mt-0.5">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
            </span>
            <span class="text-slate-600 text-[15px] leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- arrow between (desktop only) -->
    <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-violet-700 text-white items-center justify-center shadow-lg shadow-violet-300/60">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </div>

    <!-- After -->
    <div class="ua-bf ua-bf-r bg-violet-50 border border-violet-200 rounded-3xl p-7">
      <p class="text-sm font-bold text-violet-700 uppercase tracking-wide mb-5">{t.afterTitle}</p>
      <ul class="space-y-4 m-0 p-0 list-none">
        {t.after.map((item) => (
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0 mt-0.5">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
            </span>
            <span class="text-slate-700 text-[15px] leading-relaxed font-medium">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style is:global>
  #ua-diff .ua-bf{opacity:0;transition:opacity .6s ease,transform .6s ease}
  #ua-diff .ua-bf-l{transform:translateX(-28px)}
  #ua-diff .ua-bf-r{transform:translateX(28px)}
  #ua-diff.ua-in .ua-bf{opacity:1;transform:none}
  @media (prefers-reduced-motion: reduce){
    #ua-diff .ua-bf{opacity:1;transform:none;transition:none}
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById("ua-diff");
    if (!el || !("IntersectionObserver" in window)) { if (el) el.classList.add("ua-in"); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { el.classList.add("ua-in"); io.disconnect(); } });
    }, { threshold: 0.2 });
    io.observe(el);
  })();
</script>
