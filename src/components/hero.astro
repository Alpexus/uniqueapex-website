---
import Link from "@/components/ui/link.astro";
---

<main
  class="grid lg:grid-cols-2 place-items-center items-center pt-16 pb-16 md:pt-12 md:pb-32">
  <div class="md:order-1 hidden md:flex md:items-center md:justify-end pl-12">
    <img
      src="/hero-family.png"
      alt="Family with neurodivergent children"
      class="w-full max-w-lg"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      Your child deserves support. <span class="text-violet-600">We help you find it.</span>
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      UniqueApex helps families of neurodivergent children coordinate therapy access — from first concern to ongoing care. No more waiting alone.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link href="/waitlist" class="flex gap-1 items-center justify-center">
        Join the Waitlist
      </Link>
      <Link
        size="lg"
        style="outline"
        href="/howitworks"
        class="flex gap-1 items-center justify-center border-violet-600 text-violet-700 hover:bg-violet-50">
        How It Works
      </Link>
    </div>
  </div>
</main>