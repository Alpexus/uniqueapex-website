---
// v2 · 2026-07-04 — messaging pass: sub-line closes on a feeling, not a feature list
import Link from "./ui/link.astro";

interface Props {
  lang?: "en" | "fr";
}

const { lang = "en" } = Astro.props;
const prefix = lang === "fr" ? "/fr" : "";

const t = {
  en: {
    heading: "Every child deserves support.",
    body: "And no parent should have to find it alone. Tell your child's story once — we'll help carry it from there.",
    cta: "Join the Waitlist",
  },
  fr: {
    heading: "Chaque enfant mérite du soutien.",
    body: "Et aucun parent ne devrait avoir à le trouver seul. Racontez l'histoire de votre enfant une seule fois — ensuite, nous la portons avec vous.",
    cta: "Rejoindre la liste d'attente",
  },
}[lang];
---

<div class="bg-violet-800 w-screen relative left-1/2 right-1/2 -mx-[50vw] mt-20 py-20 px-8 flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight max-w-3xl">
    {t.heading}
  </h2>
  <p class="text-violet-200 mt-4 text-lg md:text-xl max-w-2xl">
    {t.body}
  </p>
  <div class="flex mt-5">
    <Link href={prefix + "/waitlist"} style="inverted">{t.cta}</Link>
  </div>
</div>