---
import Link from "./ui/link.astro";
---

<div class="bg-violet-800 w-screen relative left-1/2 right-1/2 -mx-[50vw] mt-20 py-20 px-8 flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight max-w-3xl">
    Every child deserves support.
  </h2>
  <p class="text-violet-200 mt-4 text-lg md:text-xl max-w-2xl">
    UniqueApex helps families of neurodivergent children find, coordinate, and manage therapy access — all in one place.
  </p>
  <div class="flex mt-5">
    <Link href="/waitlist" style="inverted">Join the Waitlist</Link>
  </div>
</div>