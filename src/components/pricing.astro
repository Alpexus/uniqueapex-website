---
import Link from "@/components/ui/link.astro";

const { plan } = Astro.props;
---

<div class="relative flex flex-col w-full rounded-2xl p-8 bg-white border border-slate-200 shadow-sm">
  
  {plan.popular && (
    <div class="absolute -top-5 left-1/2 -translate-x-1/2">
      <span class="bg-violet-700 text-white text-sm font-bold px-6 py-2 rounded-full uppercase tracking-widest whitespace-nowrap shadow-md">
        Most Popular
      </span>
    </div>
  )}

  <h4 class="text-2xl font-bold text-slate-800 mt-2">
    {plan.name}
  </h4>

  <div class="mt-4 mb-6 border-t border-slate-200"></div>

  <div class="flex items-center gap-3">
    <p class="text-5xl font-bold text-slate-800">
      {plan.price}
    </p>
    {plan.onetime && (
      <span class="bg-violet-100 text-violet-700 text-xs font-semibold px-3 py-1 rounded-full">
        one-time
      </span>
    )}
  </div>

  <p class="text-slate-400 text-sm mt-3 mb-6">Features</p>

  <ul class="space-y-3 flex-grow">
    {plan.features.map((item) => (
      <li class="flex items-center gap-3">
        <span class="text-violet-700 shrink-0 w-5 text-lg leading-none">✓</span>
        <span class="text-slate-600 text-sm whitespace-nowrap">{item}</span>
      </li>
    ))}
  </ul>

  <div class="mt-10 flex justify-center">
    <Link
      href={plan.button.link || "#"}
      block
      style="primary">
      {plan.button.text || "Get Started"}
    </Link>
  </div>
</div>