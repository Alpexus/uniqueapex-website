---
/* GROWTH-V2 — the living record, now the richest page in the app:
   1 · WHERE THINGS STAND TODAY — the beloved development profile accordion
       (Communication, Social, Sensory, Daily living, Motor, Emotional,
       Interests) with can-do / working-on chips + wheel band bars
   2 · THEN vs NOW — per-domain band comparison since the first check-in
       (wheel engine untouched; ✦ marks improvements)
   3 · WHAT CHANGED — the diff feed since the last check-in; old answers
       are never forgotten
   4 · THE WINS JOURNAL — a real journal now: warm paper panel, rotating
       prompts, date-stamped entries with sparkle-burst save
   5 · THE STORY — the combined timeline (milestones + diagnosis + therapy
       starts + documents + your own moments, add/delete kept) moved here
       from Journey, with year chapters
   Check-ins auto-save via history.js (run snapshots_setup.sql once). */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Growth" activeNav="child">
  <div class="c3-tabs"><SectionTabs section="child" active="growth" /></div>

  <div id="gr-gate"></div>

  <div id="gr-main" style="display:none;max-width:920px">

    <div class="c3-ribbon cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Growth</h1>
        <p id="rb-sub">Where you were, where you are — the profile remembers, so you can see how far you've come.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <!-- ============ 1 · WHERE THINGS STAND TODAY ============ -->
    <div class="gr-sec cu-rev" style="--d:.05s">
      <p class="gr-h" id="gr-dev-title">Where things stand today <a class="gr-hlink" id="gr-dev-edit" href="/passport">Edit in passport →</a></p>
      <div id="gr-dev"></div>
    </div>

    <!-- ============ 2 · THEN vs NOW ============ -->
    <div class="gr-sec cu-rev" style="--d:.1s">
      <p class="gr-h">Then vs now <span class="gr-hsub" id="gr-since"></span></p>
      <div class="gr-card" id="gr-trends"></div>
    </div>

    <!-- ============ 3 · WHAT CHANGED ============ -->
    <div class="gr-sec cu-rev" id="gr-changes-sec" style="--d:.12s;display:none">
      <p class="gr-h">What changed <span class="gr-hsub" id="gr-changed-when"></span></p>
      <div id="gr-changes"></div>
    </div>

    <!-- ============ 4 · THE WINS JOURNAL ============ -->
    <div class="gr-sec cu-rev" style="--d:.14s">
      <div class="grj cu-sparkle-host">
        <span class="cu-spark" style="top:14px;right:26px">✦</span>
        <span class="cu-spark s2" style="top:32px;right:48px">✦</span>
        <div class="grj-head">
          <div>
            <p class="grj-title">The wins journal</p>
            <p class="grj-sub" id="grj-sub">Tiny victories add up — future you will want to read these.</p>
          </div>
          <div class="grj-mo">
            <div class="grj-days" id="grj-days" aria-label="Wins over the last 7 days"></div>
            <p class="grj-streak" id="grj-streak"></p>
          </div>
        </div>
        <div class="grj-addrow">
          <input type="text" id="win-input" class="grj-field" maxlength="200" placeholder="Something that went well today…" autocomplete="off" />
          <button class="grj-savebtn" id="win-save" type="button">
            <span class="grj-burst" id="win-burst" aria-hidden="true"><i>✦</i><i>✦</i><i>✦</i><i>✦</i><i>✦</i><i>✦</i></span>
            ✦ Save win
          </button>
        </div>
      </div>
      <div id="gr-wins"></div>
    </div>

    <!-- ============ 5 · THE STORY ============ -->
    <div class="gr-sec cu-rev" style="--d:.18s;margin-bottom:0">
      <p class="gr-h" id="gr-story-title">The story
        <button class="gr-addbtn" id="tl-addbtn"><span style="font-size:1.1em;line-height:1">+</span> Add a moment</button>
      </p>
      <div id="gr-mscta"></div>
      <div class="gr-form" id="tl-form">
        <div class="gr-form-grid">
          <input type="date" id="tl-date" class="gr-field2" />
          <select id="tl-cat" class="gr-field2">
            <option>Note</option><option>Medical</option><option>Education</option>
            <option>Therapy</option><option>Assessment</option><option>Funding</option><option>Milestone</option>
          </select>
          <input type="text" id="tl-title" class="gr-field2" placeholder="What happened?" />
          <input type="text" id="tl-note" class="gr-field2" placeholder="Add a note (optional)" />
        </div>
        <div class="gr-form-actions">
          <span id="tl-err" class="gr-err"></span>
          <button class="gr-ghost" id="tl-cancel">Cancel</button>
          <button class="gr-savebtn2" id="tl-save">Save</button>
        </div>
      </div>
      <div id="tl"></div>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  #gr-gate{max-width:920px}
  .gr-sec{margin-bottom:28px}
  .gr-h{font-size:.84rem;color:var(--muted);margin:0 0 12px;display:flex;align-items:center;gap:8px;font-weight:600}
  .gr-hsub{font-weight:500;color:var(--faint);font-size:.74rem}
  .gr-hlink{margin-left:auto;font-size:.78rem;font-weight:600;color:var(--violet-700);text-decoration:none}
  .gr-hlink:hover{text-decoration:underline}
  .gr-card{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow)}

  /* ---- 1 · development profile accordion ---- */
  .da-card{background:var(--card);border:1px solid var(--line);border-radius:16px;margin-bottom:10px;box-shadow:var(--shadow);transition:border-color .2s,box-shadow .2s}
  .da-card:hover{border-color:var(--line-2)}
  .da-card.open{box-shadow:var(--shadow-lg);border-color:#DDD6FE}
  .da-card.muted{background:#FBFAFE;box-shadow:none}
  .da-head{display:flex;align-items:center;gap:12px;padding:13px 16px;cursor:pointer;border-radius:16px}
  .da-blob{position:relative;width:40px;height:40px;display:grid;place-items:center;flex-shrink:0}
  .da-blob::before{content:"";position:absolute;inset:0;background:var(--blob,#EDE9FE);border-radius:46% 54% 58% 42%/52% 44% 56% 48%;transition:transform .5s cubic-bezier(.34,1.5,.64,1)}
  .da-card:hover .da-blob::before{transform:scale(1.1) rotate(8deg)}
  .da-blob svg{position:relative;z-index:1}
  .da-name{font-family:var(--display);font-size:.96rem;font-weight:700;color:var(--ink)}
  .da-sum{font-size:.79rem;color:var(--muted)}
  .da-bandrow{display:flex;align-items:center;gap:8px;margin-top:5px}
  .da-bandpill{font-size:.62rem;font-weight:700;padding:2px 8px;border-radius:9999px;white-space:nowrap;flex-shrink:0}
  .da-chev-svg{color:var(--faint);transition:transform .25s cubic-bezier(.22,1,.36,1);flex-shrink:0}
  .da-card.open .da-chev-svg{transform:rotate(180deg)}
  .da-body-wrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows .32s cubic-bezier(.22,1,.36,1)}
  .da-card.open .da-body-wrap{grid-template-rows:1fr}
  .da-body{overflow:hidden;padding:0 16px}
  .da-card.open .da-body{padding-bottom:18px}
  .da-lab{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--faint);margin:14px 0 8px}
  .da-chip{display:inline-flex;align-items:center;gap:6px;font-size:.83rem;font-weight:600;padding:6px 12px;border-radius:9999px;margin:0 6px 6px 0;line-height:1.25;transition:transform .15s}
  .da-chip:hover{transform:translateY(-1px)}
  .da-tiles{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:9px;margin-top:4px}
  .da-tile{border:1px solid var(--line);border-radius:12px;padding:11px 13px;transition:border-color .15s,transform .15s}
  .da-tile:hover{border-color:#DDD6FE;transform:translateY(-1px)}
  .da-tile-top{display:flex;align-items:center;justify-content:space-between;gap:8px}
  .da-tile-name{font-size:.85rem;font-weight:600;color:var(--ink)}
  .da-badge{font-size:.7rem;font-weight:700;padding:3px 9px;border-radius:9999px;white-space:nowrap}
  .da-sub{font-size:.78rem;color:var(--muted);margin:6px 0 0;line-height:1.4}
  .da-note{font-size:.84rem;font-style:italic;color:var(--muted);border-left:3px solid var(--violet-100);padding-left:11px;margin:14px 0 0}
  .da-empty{font-size:.85rem;color:var(--faint);margin:6px 0 0}
  .da-empty a{color:var(--violet-700);font-weight:600;text-decoration:none}
  .da-wheel{display:inline-flex;align-items:center;gap:4px;margin-top:12px;font-size:.78rem;font-weight:600;color:var(--violet-700);text-decoration:none}
  .da-wheel .arr{transition:transform .18s;display:inline-block}
  .da-wheel:hover .arr{transform:translateX(3px)}

  /* ---- 2 · then vs now ---- */
  .gr-trow{display:flex;align-items:center;gap:10px;padding:9px 16px;border-top:1px solid var(--line);text-decoration:none;transition:background .15s}
  .gr-trow:first-of-type{border-top:none}
  .gr-trow:hover{background:var(--violet-50)}
  .gr-tname{font-size:.8rem;width:118px;flex-shrink:0;color:var(--ink-2);display:flex;align-items:center;gap:7px;font-weight:600}
  .gr-tname .dd{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .gr-band{font-size:.68rem;font-weight:600;padding:2px 9px;border-radius:9999px;white-space:nowrap}
  .gr-arrow{color:var(--faint);flex-shrink:0}
  .gr-imp{margin-left:auto;font-size:.72rem;font-weight:700;color:var(--green);white-space:nowrap}
  .gr-tcap{font-size:.72rem;color:var(--faint);padding:10px 16px 12px;margin:0}
  .gr-seed{display:flex;gap:12px;align-items:flex-start;padding:18px}
  .gr-seed p{font-size:.86rem;color:var(--ink-2);line-height:1.55;margin:0}
  .gr-seed b{color:var(--violet-700)}

  /* ---- 3 · what changed ---- */
  .gr-chgroup{margin-bottom:10px}
  .gr-chlab{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin:0 0 7px}
  .gr-chlab.imp{color:var(--green)}
  .gr-chlab.flag{color:var(--amber)}
  .gr-chlab.oth{color:var(--faint)}
  .gr-chip{display:inline-flex;align-items:center;gap:7px;font-size:.78rem;font-weight:600;padding:6px 12px;border-radius:9999px;margin:0 6px 6px 0;line-height:1.3}
  .gr-chip.imp{background:var(--green-bg);color:#0a6b4d}
  .gr-chip.flag{background:var(--amber-bg);color:var(--amber)}
  .gr-chip.oth{background:var(--bg);color:var(--ink-2)}
  .gr-chip .fromto{font-weight:500;opacity:.85}

  /* ---- 4 · the wins journal ---- */
  .grj{position:relative;overflow:hidden;background:linear-gradient(135deg,#FFFDF6 0%,#FFF8E9 52%,#F8F5FF 100%);border:1px solid #F0E4C4;border-radius:18px;padding:16px 18px;box-shadow:var(--shadow)}
  .grj .cu-spark{font-style:normal;font-size:13px;color:#E3B23C}
  .grj .cu-spark.s2{font-size:10px;color:#8B5CF6}
  .grj-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:12px}
  .grj-title{font-family:var(--display);font-size:1.08rem;font-weight:700;color:var(--ink);margin:0}
  .grj-sub{font-size:.76rem;color:#A8874A;margin:3px 0 0}
  .grj-mo{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
  .grj-days{display:flex;gap:8px}
  .grj-day{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:.58rem;font-weight:700;color:#C9B37E}
  .grj-day i{width:11px;height:11px;border-radius:50%;background:#F0E4C4;font-style:normal}
  .grj-day.hit i{background:#E3A82C}
  .grj-day.today i{box-shadow:0 0 0 2px #F6E7BE}
  .grj-streak{font-size:.74rem;color:#B07F1E;font-weight:700;margin:0;white-space:nowrap}
  .grj-addrow{display:flex;gap:8px}
  .grj-field{flex:1;min-width:0;padding:11px 14px;border:1.5px solid #EBDCB4;border-radius:12px;font-size:.92rem;color:var(--ink);background:#fff;outline:none;font-family:inherit;transition:border-color .15s,box-shadow .15s}
  .grj-field::placeholder{color:#C2A96E}
  .grj-field:focus{border-color:#A78BFA;box-shadow:0 0 0 3px rgba(139,92,246,.14)}
  .grj-savebtn{position:relative;font-size:.84rem;font-weight:700;padding:10px 18px;border-radius:12px;border:none;background:var(--violet-700);color:#fff;cursor:pointer;white-space:nowrap;transition:filter .15s,transform .15s}
  .grj-savebtn:hover{filter:brightness(1.08);transform:translateY(-1px)}
  .grj-savebtn:disabled{opacity:.6}
  .grj-burst{position:absolute;inset:0;pointer-events:none}
  .grj-burst i{position:absolute;top:50%;left:50%;font-style:normal;font-size:11px;color:#FCD34D;opacity:0}
  .grj-burst i:nth-child(2n){color:#C4B5FD;font-size:9px}
  .grj-burst.go i{animation:grjB .8s cubic-bezier(.22,1,.36,1) both}
  .grj-burst.go i:nth-child(1){--bx:-30px;--by:-26px}
  .grj-burst.go i:nth-child(2){--bx:26px;--by:-30px;animation-delay:.04s}
  .grj-burst.go i:nth-child(3){--bx:-36px;--by:4px;animation-delay:.08s}
  .grj-burst.go i:nth-child(4){--bx:34px;--by:8px;animation-delay:.05s}
  .grj-burst.go i:nth-child(5){--bx:-14px;--by:-38px;animation-delay:.1s}
  .grj-burst.go i:nth-child(6){--bx:12px;--by:-40px;animation-delay:.12s}
  @keyframes grjB{0%{transform:translate(-50%,-50%) scale(.4);opacity:0}25%{opacity:1}100%{transform:translate(calc(-50% + var(--bx)),calc(-50% + var(--by))) scale(1.1);opacity:0}}

  /* journal entries */
  .gr-glab{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--faint);margin:16px 0 8px}
  .gr-entry{background:#FFFEFA;border:1px solid #F0E7CE;border-left:4px solid #F5CE58;border-radius:14px;padding:12px 14px;display:flex;gap:13px;align-items:flex-start;margin-bottom:9px;position:relative;box-shadow:var(--shadow);transition:transform .15s,box-shadow .15s}
  .gr-entry:hover{transform:translateY(-1px);box-shadow:0 8px 20px rgba(180,140,40,.12)}
  .gr-edate{width:42px;flex-shrink:0;text-align:center;background:#FBF2DC;border-radius:10px;padding:5px 2px}
  .gr-edate b{display:block;font-family:var(--display);font-size:1.05rem;font-weight:700;color:#B07F1E;line-height:1.1}
  .gr-edate span{display:block;font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#C9A557}
  .gr-etext{font-size:.93rem;color:var(--ink);flex:1;padding-right:16px;line-height:1.55;margin-top:2px}
  .gr-etext .st{color:#E3A82C;margin-right:6px}
  .gr-ewhen{font-size:.7rem;color:#C9B37E;white-space:nowrap;margin-top:4px}
  .gr-del{position:absolute;top:8px;right:10px;border:none;background:none;color:#E4D6B0;font-size:1.05rem;line-height:1;cursor:pointer;padding:2px}
  .gr-del:hover{color:#B14A66}
  .gr-cele{animation:grPop .5s cubic-bezier(.34,1.5,.64,1)}
  @keyframes grPop{from{transform:scale(.92);opacity:.4}to{transform:scale(1);opacity:1}}
  .gr-cele::before,.gr-cele::after{content:"✦";position:absolute;color:#E3A82C;font-size:14px;animation:grSpark 1s ease forwards;pointer-events:none}
  .gr-cele::before{top:-8px;left:18px}
  .gr-cele::after{top:-6px;right:26px;color:#8B5CF6;animation-delay:.12s}
  @keyframes grSpark{0%{opacity:0;transform:scale(.4) translateY(4px)}35%{opacity:1;transform:scale(1.3) translateY(-4px)}100%{opacity:0;transform:scale(.6) translateY(-14px)}}
  .gr-empty{font-size:.86rem;color:var(--faint);margin:0}
  .gr-empty a{color:var(--violet-700);font-weight:600;text-decoration:none}

  /* ---- 5 · the story ---- */
  .gr-addbtn{margin-left:auto;font-size:.82rem;font-weight:600;padding:7px 14px;border-radius:9999px;border:1px solid var(--violet-700);background:var(--card);color:var(--violet-700);cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:background .15s,transform .15s;font-family:inherit}
  .gr-addbtn:hover{background:var(--violet-50);transform:translateY(-1px)}
  .gr-mscta{display:inline-flex;align-items:center;gap:8px;border:1.5px dashed #C4B5FD;background:#FBFAFE;color:var(--violet-700);font-size:.78rem;font-weight:600;border-radius:9999px;padding:6px 14px;text-decoration:none;margin-bottom:12px;transition:background .15s}
  .gr-mscta:hover{background:var(--violet-50)}
  .gr-form{display:none;background:var(--card);border:1px solid var(--line);border-radius:16px;padding:16px;margin-bottom:14px;box-shadow:var(--shadow)}
  .gr-form.show{display:block;animation:grIn .25s cubic-bezier(.22,1,.36,1)}
  @keyframes grIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .gr-form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px}
  .gr-field2{width:100%;padding:9px 12px;border:1px solid var(--line-2);border-radius:10px;font-size:.88rem;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .gr-field2:focus{border-color:#A78BFA;box-shadow:0 0 0 3px rgba(139,92,246,.14)}
  .gr-form-actions{display:flex;align-items:center;gap:10px;margin-top:12px;justify-content:flex-end;flex-wrap:wrap}
  .gr-err{font-size:.8rem;color:#B14A66;margin-right:auto}
  .gr-ghost{font-size:.82rem;font-weight:600;padding:8px 14px;border-radius:9999px;border:1px solid var(--line-2);background:var(--card);color:var(--muted);cursor:pointer}
  .gr-savebtn2{font-size:.82rem;font-weight:600;padding:8px 16px;border-radius:9999px;border:none;background:var(--violet-700);color:#fff;cursor:pointer;transition:filter .15s}
  .gr-savebtn2:hover{filter:brightness(1.1)}
  .tl-year{position:relative;margin:8px 0 14px;display:flex;align-items:center;gap:8px}
  .tl-year b{font-family:var(--display);font-size:.78rem;font-weight:700;color:var(--violet-700);background:var(--violet-50);border:1px solid var(--violet-100);border-radius:9999px;padding:3px 14px;z-index:1}
  .tl-year span{font-size:.7rem;color:var(--faint);font-weight:600}
  .tl-item{display:flex;gap:14px;padding-bottom:16px;position:relative}
  .tl-item::before{content:"";position:absolute;left:17px;top:38px;bottom:-2px;width:2.5px;border-radius:2px;background:linear-gradient(to bottom,#DDD6FE,#EAE7F3)}
  .tl-item.last::before{display:none}
  .tl-dot{width:36px;height:36px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;z-index:1;border:3px solid var(--card);box-shadow:0 2px 8px rgba(34,27,54,.16)}
  .tl-card{flex:1;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:11px 14px;position:relative;box-shadow:var(--shadow);transition:transform .16s,box-shadow .16s,border-color .16s}
  .tl-item:hover .tl-card{transform:translateY(-2px);box-shadow:0 8px 22px rgba(109,40,217,.10);border-color:#DDD6FE}
  .tl-item.ms .tl-card{background:linear-gradient(135deg,#F7FBF4,#fff 60%);border-color:#DDEECF}
  .tl-meta{font-size:.72rem;color:var(--faint);margin-bottom:2px;display:flex;align-items:center;gap:6px}
  .tl-meta .cat{font-weight:700}
  .tl-title{font-size:.9rem;font-weight:600;color:var(--ink);margin-bottom:3px;padding-right:18px}
  .tl-note{font-size:.83rem;color:var(--muted);line-height:1.45}
  .tl-del{position:absolute;top:8px;right:10px;border:none;background:none;color:#D8D3E6;font-size:1.05rem;line-height:1;cursor:pointer;padding:2px}
  .tl-del:hover{color:#B14A66}
  .tl-empty,.gr-gate-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:28px 22px;text-align:center}
  .tl-empty p,.gr-gate-card p{color:var(--muted);font-size:.9rem;margin:0 0 14px}
  .gr-gate-card a{display:inline-block;background:var(--violet-700);color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
  @media (prefers-reduced-motion:reduce){
    .gr-cele,.gr-cele::before,.gr-cele::after,.grj-burst.go i{animation:none}
    .da-body-wrap,.da-chev-svg{transition:none}
    .gr-form.show{animation:none}
  }
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../../lib/ua-data.js";
  import { scoreWheel, DOMAINS, scoreToBand, snapshotWheel, HUES } from "../../lib/wheelScore.js";
  import { domainColor } from "../../lib/wheelSvg.js";
  import { ensureSnapshot, diffData } from "../../lib/history.js";
  import { notify } from "../../lib/notify.js";
  import { getPlan, PLANS, upsellHTML } from "../../lib/plan.js";

  const UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
