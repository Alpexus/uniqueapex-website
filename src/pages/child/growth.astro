      const b = d.behaviour || {}; const can = [], work = [];
      if (b.peersInterest === "Yes") can.push("Shows interest in other children");
      if (b.peersInteract === "Yes") can.push("Plays with peers"); else if (b.peersInteract === "Sometimes") can.push("Plays alongside others");
      if (b.followsInstructions === "Yes") can.push("Follows familiar instructions");
      if (b.peersInterest === "No") work.push("Connecting with other children");
      if (b.peersInteract === "No" || b.peersInteract === "Sometimes") work.push("Back-and-forth play");
      if (b.followsInstructions === "No" || b.followsInstructions === "Sometimes") work.push("Following instructions");
      const groups = []; if (can.length) groups.push({ label: "Can do", tone: "good", items: uniq(can) }); if (work.length) groups.push({ label: "Working on", tone: "work", items: uniq(work) });
      const sum = [b.peersInterest === "Yes" ? "interested in peers" : "", b.peersInteract ? ("plays " + (b.peersInteract === "Yes" ? "with others" : b.peersInteract === "Sometimes" ? "alongside" : "independently")) : ""].filter(Boolean).join(" · ");
      return { icon: "users", name: "Social interaction", sum: cap(sum), mode: "chips", groups, note: "", empty: !groups.length };
    }
    function sensoryCard() {
      const s = d.sensory || {};
      const SENSES = [["auditory", "Sound"], ["visual", "Sight"], ["tactile", "Touch"], ["oral", "Taste & mouth"], ["smell", "Smell"], ["movement", "Movement"], ["body", "Body awareness"]];
      const seekRe = /seek|fascinat|spinning|crav|crash|rough play|chew|mouth|constantly moving|makes noise/i;
      const avoidRe = /avoid|cover|bother|distress|dislike|fearful|overwhelm|misses|doesn't/i;
      const items = [], sensitive = [], seeking = [];
      SENSES.forEach(([k, label]) => {
        const o = s[k]; if (!o || typeof o !== "object") return;
        if (o.typical) { items.push({ name: label, badge: "Comfortable", tone: "good" }); return; }
        if (o.signs && o.signs.length) {
          const seek = o.signs.some((x) => seekRe.test(x)) && !o.signs.some((x) => avoidRe.test(x));
          if (seek) seeking.push(label.toLowerCase()); else sensitive.push(label.toLowerCase());
          items.push({ name: label, badge: seek ? "Seeking" : "Sensitive", tone: seek ? "info" : "work", sub: o.signs.slice(0, 2).join(", ") + (o.severity ? " (" + lc(o.severity) + ")" : "") });
        }
      });
      const parts = []; if (sensitive.length) parts.push("sensitive to " + listShort(sensitive, 2)); if (seeking.length) parts.push("seeks " + listShort(seeking, 2));
      const sum = cap(parts.join(" · ")) || (items.length ? "No concerns flagged" : "");
      return { icon: "waves", name: "Sensory profile", sum, mode: "grid", items, note: present(s.notes) ? s.notes : "", empty: !items.length };
    }
    function dailyCard() {
      const dl = d.dailyLiving || {};
      const toneFor = (v) => (["Independent", "Fully trained", "Good", "Strong", "None"].indexOf(v) > -1) ? "good" : (["Variable", "Developing", "Mild", "Not applicable"].indexOf(v) > -1) ? "neutral" : "work";
      const defs = [["eating", "Eating"], ["dressing", "Dressing"], ["toileting", "Toileting"], ["sleep", "Sleep"], ["safety", "Safety"]];
      const items = []; defs.forEach(([k, label]) => { const v = dl[k]; if (present(v)) items.push({ name: label, badge: v, tone: toneFor(v) }); });
      const indep = items.filter((i) => i.tone === "good"), sup = items.filter((i) => i.tone === "work");
      const sum = [indep.length ? (cap(indep[0].name) + " independent") : "", sup.length ? (sup[0].name.toLowerCase() + " with support") : ""].filter(Boolean).join(" · ");
      return { icon: "home", name: "Daily living", sum, mode: "grid", items, note: present(dl.dietaryRestrictions) ? ("Dietary needs: " + dl.dietaryRestrictions) : "", empty: !items.length };
    }
    function motorCard() {
      const m = d.motor || {};
      const clean2 = (x) => cap(String(x).replace(/^Difficulty (with |using )?/i, "").trim());
      const work = []; (m.gross || []).forEach((x) => work.push(clean2(x))); (m.fine || []).forEach((x) => work.push(clean2(x)));
      const hasData = (m.gross && m.gross.length) || (m.fine && m.fine.length) || present(m.notes);
      const can = []; if (hasData) { if (!(m.gross && m.gross.length)) can.push("Gross motor on track"); if (!(m.fine && m.fine.length)) can.push("Fine motor on track"); }
      const groups = []; if (can.length) groups.push({ label: "On track", tone: "good", items: can }); if (work.length) groups.push({ label: "Working on", tone: "work", items: uniq(work) });
      const sum = hasData ? [(m.gross && m.gross.length) ? "gross motor support" : "strong gross motor", (m.fine && m.fine.length) ? "fine motor support" : "strong fine motor"].join(" · ") : "";
      return { icon: "run", name: "Motor skills", sum: cap(sum), mode: "chips", groups, note: present(m.notes) ? m.notes : "", empty: !hasData };
    }
    function emotionalCard() {
      const b = d.behaviour || {}, ch = b.challenges || {};
      const settled = !isHigh(ch.meltdowns) && !isHigh(ch.emotional) && !isHigh(ch.anxiety);
      const helps = textToList(b.strategies), trig = textToList(b.triggers);
      const wmap = { meltdowns: "Big reactions / meltdowns", emotional: "Regulating emotions", anxiety: "Anxiety", rigidity: "Coping with change", aggression: "Aggression", selfInjury: "Self-injury", repetitive: "Repetitive behaviours", defiance: "Following directions", hyperactivity: "Focus and impulsivity", elopement: "Safety / flight risk" };
      const work = Object.keys(wmap).filter((k) => isHigh(ch[k])).map((k) => wmap[k]);
      const hasData = helps.length || trig.length || work.length || Object.keys(ch).some((k) => present(ch[k]));
      const groups = [];
      if (helps.length) groups.push({ label: "What helps", tone: "good", items: helps });
      else if (settled && hasData) groups.push({ label: "Strengths", tone: "good", items: ["Generally calm and settled"] });
      if (trig.length) groups.push({ label: "Triggers", tone: "work", items: trig });
      if (work.length) groups.push({ label: "Working on", tone: "work", items: work });
      const sum = !hasData ? "" : (settled ? "Generally settled" : "Working on big reactions");
      return { icon: "heart", name: "Emotional regulation", sum, mode: "chips", groups, note: "", empty: !hasData || !groups.length };
    }
    function interestsCard() {
      const s = d.strengths || {};
      const loves = textToList(s.interests), avoid = textToList(s.dislikes);
      const groups = []; if (loves.length) groups.push({ label: "Loves", tone: "good", items: loves.map(cap) }); if (avoid.length) groups.push({ label: "Things to avoid", tone: "warn", items: avoid.map(cap) });
      const sum = loves.length ? loves.slice(0, 4).map(cap).join(", ") : "";
      return { icon: "star", name: "Interests & motivators", sum, mode: "chips", groups, note: "", empty: !groups.length };
    }

    const cards = [commCard(), socialCard(), sensoryCard(), dailyCard(), motorCard(), emotionalCard(), interestsCard()];
    const WHEEL_OF = { "Communication": "Communication", "Social interaction": "Social Connection", "Sensory profile": "Sensory Processing", "Daily living": "Daily Living Skills", "Motor skills": "Daily Living Skills", "Emotional regulation": "Emotional Regulation", "Interests & motivators": "Learning & Play" };
    const chipHtml = (items, tone) => { const t = TONE[tone]; return items.map((x) => `<span class="da-chip" style="background:${t.bg};color:${t.fg}">${TIC[tone]}${esc(x)}</span>`).join(""); };
    const emptyBody = () => `<p class="da-empty">Not recorded yet. <a href="${passportLink}">Add in passport →</a></p>`;
    const bodyChips = (c) => { if (c.empty) return emptyBody(); let h = ""; c.groups.forEach((g) => { h += `<p class="da-lab">${g.label}</p><div>${chipHtml(g.items, g.tone)}</div>`; }); if (c.note) h += `<p class="da-note">${esc(c.note)}</p>`; return h; };
    const bodyGrid = (c) => { if (c.empty) return emptyBody(); let h = '<div class="da-tiles">'; c.items.forEach((it) => { const t = TONE[it.tone]; h += `<div class="da-tile"><div class="da-tile-top"><span class="da-tile-name">${esc(it.name)}</span><span class="da-badge" style="background:${t.bg};color:${t.fg}">${esc(it.badge)}</span></div>${it.sub ? `<p class="da-sub">${esc(it.sub)}</p>` : ""}</div>`; }); h += "</div>"; if (c.note) h += `<p class="da-note">${esc(c.note)}</p>`; return h; };
    const bandBar = (wheelDomain) => {
      if (!wheelDomain) return "";
      const dm = scored[wheelDomain];
      const b = bandInfo(dm ? dm.score : null);
      if (!b) return "";
      let segs = "";
      for (let k = 1; k <= 5; k++) segs += `<i>${k <= b.rings ? `<b style="background:${b.seg};--d:${(0.1 + k * 0.06).toFixed(2)}s"></b>` : ""}</i>`;
      return `<span class="da-bandrow"><span class="c3-bar5" style="max-width:110px">${segs}</span><span class="da-bandpill" style="background:${b.bg};color:${b.fg}">${b.label}</span></span>`;
    };
    let opened = false;
    $("gr-dev").innerHTML = cards.map((c, ci) => {
      const body = c.mode === "grid" ? bodyGrid(c) : bodyChips(c);
      const isOpen = !c.empty && !opened; if (isOpen) opened = true;
      const sum = c.empty ? "Not recorded yet" : (c.sum || "");
      const wheelDomain = WHEEL_OF[c.name];
      const dc = wheelDomain ? domainColor(wheelDomain) : "#6D28D9";
      const blobTint = wheelDomain ? tintOf(wheelDomain, 0.12) : "rgba(109,40,217,.12)";
      return `<div class="da-card cu-rev ${isOpen ? "open" : ""} ${c.empty ? "muted" : ""}" style="--d:${(ci * 0.05).toFixed(2)}s">
        <div class="da-head" role="button" tabindex="0" aria-expanded="${isOpen ? "true" : "false"}">
          <span class="da-blob" style="--blob:${c.empty ? "var(--bg)" : blobTint};color:${c.empty ? "var(--faint)" : dc}">${IC[c.icon]}</span>
          <span style="flex:1;min-width:0"><span class="da-name" style="display:block">${esc(c.name)}</span><span class="da-sum" style="display:block">${esc(sum)}</span>${c.empty ? "" : bandBar(wheelDomain)}</span>
          ${IC.chev}
        </div>
        <div class="da-body-wrap"><div class="da-body">${body}${!c.empty && wheelDomain ? `<a class="da-wheel" href="/child/support-wheel?domain=${encodeURIComponent(wheelDomain)}">See in Support Wheel <span class="arr">→</span></a>` : ""}</div></div>
      </div>`;
    }).join("");
    $("gr-dev").querySelectorAll(".da-head").forEach((h) => {
      const toggle = () => {
        const card = h.parentElement;
        card.classList.toggle("open");
        h.setAttribute("aria-expanded", card.classList.contains("open") ? "true" : "false");
      };
      h.addEventListener("click", toggle);
      h.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggle(); } });
    });

    /* ============ 2+3 · check-ins: trends + diff ============ */
    const snap = await ensureSnapshot(p, snapshotWheel(scored)).catch(() => ({ rows: [], created: false }));
    const rows = snap.rows || [];
    if (snap.created && rows.length >= 2) notify("info", "Check-in recorded — then-vs-now just updated");
    const planKey = await getPlan();
    const allowHistory = PLANS[planKey].history;
    if (!allowHistory && rows.length >= 2) {
      /* history is RECORDING for everyone — reading it back is a plan perk */
      $("gr-since").textContent = "";
      $("gr-trends").innerHTML = `<div style="padding:14px 16px">` + upsellHTML(
        first + "'s history is safely recording ✦",
        rows.length + " check-ins saved. Then-vs-now comparisons and the what-changed feed are part of the monthly plans — nothing is lost, it unlocks the moment you upgrade.",
        "Unlock the history"
      ) + `</div>`;
      $("gr-changes-sec").style.display = "none";
    } else {

    function bandPill(sc) {
      if (sc == null) return `<span class="gr-band" style="background:#F4F3F8;color:#7B7491">No data</span>`;
      const b = scoreToBand(sc);
      let bg = "#E8F6F0", fg = "#0E8F66";
      if (b.key === "moderate") { bg = "#FBF2E2"; fg = "#A8650A"; }
      else if (b.key === "high" || b.key === "intensive") { bg = "#EDE9FE"; fg = "#6D28D9"; }
      return `<span class="gr-band" style="background:${bg};color:${fg}">${b.label.split(" ")[0]}</span>`;
    }
    if (rows.length >= 2) {
      const base = rows[0];
      const baseWheel = base.wheel || {};
      $("gr-since").textContent = "since " + fmtD(base.taken_at);
      const trendRows = DOMAINS.map((n) => {
        const bw = baseWheel.domains && baseWheel.domains[n] ? baseWheel.domains[n] : baseWheel[n];
        const oldSc = bw ? bw.score : null;
        const nowSc = scored[n].score;
        const improved = oldSc != null && nowSc != null && scoreToBand(nowSc).rings < scoreToBand(oldSc).rings;
        const worse = oldSc != null && nowSc != null && scoreToBand(nowSc).rings > scoreToBand(oldSc).rings;
        return `<a class="gr-trow" href="/child/support-wheel?domain=${encodeURIComponent(n)}">
          <span class="gr-tname"><span class="dd" style="background:${domainColor(n)}"></span>${esc(SHORT[n])}</span>
          ${bandPill(oldSc)}
          <svg class="gr-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 8h10M9.5 4.5L13 8l-3.5 3.5"/></svg>
          ${bandPill(nowSc)}
          ${improved ? `<span class="gr-imp">✦ less support needed</span>` : worse ? `<span class="gr-imp" style="color:var(--amber)">needs more right now</span>` : ""}
        </a>`;
      }).join("");
      $("gr-trends").innerHTML = trendRows + `<p class="gr-tcap">Bands come from the same wheel engine as everywhere else — tap a row to explore. "Needs more right now" isn't a setback; it's the profile getting more honest.</p>`;
    } else {
      $("gr-since").textContent = "";
      $("gr-trends").innerHTML = `<div class="gr-seed">
        <span class="cu-blob" style="--blob:#EDE9FE;color:#6D28D9;width:40px;height:40px"><svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg></span>
        <p><b>Today became ${esc(first)}'s baseline. ✦</b> The profile now remembers where you started — after the next passport update, this turns into a then-vs-now picture of every area. ${rows.length === 0 ? "(If nothing appears after updating, run <b>snapshots_setup.sql</b> in Supabase once.)" : ""}</p>
      </div>`;
    }
    if (rows.length >= 2) {
      const prev = rows[rows.length - 2], cur = rows[rows.length - 1];
      const diff = diffData(prev.data, cur.data);
      $("gr-changed-when").textContent = "since your check-in on " + fmtD(prev.taken_at);
      const chip = (e, cls) => `<span class="gr-chip ${cls}">${esc(e.label)}${e.from || e.to ? `<span class="fromto">${e.from ? esc(e.from) + " → " : ""}${esc(e.to)}</span>` : ""}</span>`;
      let h = "";
      if (diff.improved.length) h += `<div class="gr-chgroup"><p class="gr-chlab imp">✦ Improvements to celebrate</p>${diff.improved.map((e) => chip(e, "imp")).join("")}</div>`;
      if (diff.flags.length) h += `<div class="gr-chgroup"><p class="gr-chlab flag">Newly flagged — worth a look</p>${diff.flags.map((e) => chip(e, "flag")).join("")}</div>`;
      if (diff.other.length) h += `<div class="gr-chgroup"><p class="gr-chlab oth">Updated</p>${diff.other.map((e) => chip(e, "oth")).join("")}</div>`;
      if (h) {
        $("gr-changes").innerHTML = h;
        $("gr-changes-sec").style.display = "block";
      }
    }
    } /* end history plan gate */

    /* ============ 4 · wins ============ */
    const w = await restGet("wins?select=id,text,created_at&passport_id=eq." + p.id + "&order=created_at.desc").catch(() => []);
    wins = (w || []).map((x) => ({ id: x.id, text: x.text, when: UA.relTime(x.created_at), created_at: x.created_at }));
    renderWins();
    renderMomentum();
    $("win-save").addEventListener("click", saveWin);
    $("win-input").addEventListener("keydown", (e) => { if (e.key === "Enter") saveWin(); });

    /* ============ 5 · the story (milestones live inside it) ============ */
    const msData = (d.birth && d.birth.milestones) || {};
    const MLAB2 = { sit: 1, crawl: 1, walk: 1, firstWord: 1, phrases: 1, sentences: 1, toiletDay: 1, toiletNight: 1 };
    const naLike = (v) => /^(n\/?a|na|-+|none|\?+)$/i.test(String(v).trim());
    const msRecorded = Object.keys(MLAB2).filter((k) => present(msData[k]) && !naLike(msData[k])).length;
    const msMissing = Object.keys(MLAB2).length - msRecorded;
    if (msMissing > 0) {
      $("gr-mscta").innerHTML = `<a class="gr-mscta" href="${passportLink}"><svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 3v10M3 8h10"/></svg>${msMissing} early milestone${msMissing === 1 ? "" : "s"} still to record — add ages in the passport and they appear in the story</a>`;
    }
    allEvents = autoEvents(d);
    const docRows = await restGet("documents?select=id,file_name,created_at&passport_id=eq." + p.id + "&order=created_at.desc&limit=25").catch(() => []);
    (docRows || []).forEach((doc) => { const dt = new Date(doc.created_at); if (!isNaN(dt)) allEvents.push({ cat: "Assessment", title: (doc.file_name || "Document") + " added", note: "Uploaded to documents", ts: dt.getTime(), display: fmtMY(dt), y: dt.getFullYear(), auto: true }); });
    const ev = await restGet("timeline_events?select=id,event_date,category,title,note&passport_id=eq." + p.id + "&order=event_date.desc").catch(() => []);
    (ev || []).forEach((e) => { const dt = new Date(e.event_date); allEvents.push({ id: e.id, cat: e.category || "Note", title: e.title, note: e.note || "", ts: isNaN(dt) ? 0 : dt.getTime(), display: isNaN(dt) ? e.event_date : fmtMY(dt), y: isNaN(dt) ? "Earlier" : dt.getFullYear(), auto: false }); });
    renderStory();
    $("tl-addbtn").addEventListener("click", () => { const f = $("tl-form"); f.classList.toggle("show"); if (f.classList.contains("show")) $("tl-title").focus(); });
    $("tl-cancel").addEventListener("click", () => { $("tl-form").classList.remove("show"); $("tl-err").textContent = ""; });
    $("tl-save").addEventListener("click", saveEvent);

    /* ============ ribbon ============ */
    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${wins.length}</b><span>wins in the journal</span></span>`,
      `<span class="c3-rstat"><b>${rows.length}</b><span>check-in${rows.length === 1 ? "" : "s"} saved</span></span>`,
      `<span class="c3-rstat"><b>${allEvents.length}</b><span>story moments</span></span>`,
    ].join("");
  })().catch((e) => console.error("[growth] hydrate failed", e));
</script>
