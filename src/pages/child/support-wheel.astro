---
/* SUPPORT-WHEEL-V5 — layout redesign of the instrument (logic untouched):
   · STAGE ON TOP: one big wheel (or two properly-sized wheels in Compare,
     with real breathing room), domain CHIP NAV underneath — no more
     cramped side-by-side squeeze
   · DETAIL PANEL FULL-WIDTH below, two columns inside: levels/trend/
     confidence on the left, strengths–supports–strategies chips on the right
   · Keeps V4's three modes, ▶ Tour, ← → keyboard, then→now trend pill,
     confidence meter, one-tap Copy. Calculation: same engine as ever. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Support Wheel" titleFr="Roue de soutien" activeNav="child">
  <div class="c3-tabs"><SectionTabs section="child" active="support-wheel" /></div>

  <div class="sw-wrap">

    <div class="c3-ribbon cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:76px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Support Wheel</h1>
        <p id="rb-sub" data-i18n="ribSub">The full instrument — three views, a guided tour, and the story behind every petal.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div id="sw-warning"></div>

    <!-- ============ THE STAGE ============ -->
    <div class="sw-card cu-rev" style="--d:.06s">
      <div class="sw-tophead">
        <div id="sw-toggle" class="c3-seg" role="tablist"></div>
        <button class="sw-tourbtn" id="sw-tour" type="button" title="Auto-walk through all eight areas">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor"><path d="M4 2.5l9 5.5-9 5.5z"/></svg> <span data-i18n="tourBtn">Tour</span>
        </button>
      </div>
      <p id="sw-caption" class="sw-caption"></p>

      <div class="sw-stage c3-stage" id="sw-wrap1">
        <span class="sw-float" style="top:8px;left:4%">✦</span>
        <span class="sw-float f2" style="top:34px;right:6%">✦</span>
        <span class="sw-float f3" style="bottom:46px;left:10%">✦</span>
        <div class="sw-wheelbox">
          <div id="sw-wheel" class="c3-anim"></div>
          <svg id="sw-overlay" class="sw-overlay" viewBox="0 0 480 420" preserveAspectRatio="xMidYMid meet" aria-hidden="true"></svg>
        </div>
      </div>

      <div class="sw-compare c3-stage" id="sw-compare" style="display:none">
        <div class="sw-cmp-col"><p class="sw-cmp-lab" style="color:var(--violet-700)" data-i18n="needsBtn">Support needs</p><div id="sw-cmp-needs" class="c3-anim"></div></div>
        <div class="sw-cmp-mid" aria-hidden="true"><span>⇄</span></div>
        <div class="sw-cmp-col"><p class="sw-cmp-lab" style="color:var(--green)" data-i18n="strengthsBtn">Strengths</p><div id="sw-cmp-str" class="c3-anim"></div></div>
      </div>

      <div class="sw-domnav" id="sw-domnav"></div>

      <div class="sw-legend">
        <span class="sw-leg-rings">
          <i style="width:5px;height:5px"></i><i style="width:7px;height:7px"></i><i style="width:9px;height:9px"></i><i style="width:11px;height:11px"></i><i style="width:13px;height:13px"></i>
        </span>
        <span id="sw-leg-text">1 ring = minimal · 5 rings = intensive</span>
        <span class="sw-kbd" data-i18n="kbdHint">· ← → to walk the wheel</span>
      </div>
    </div>

    <!-- ============ THE DETAIL ============ -->
    <div id="sw-detail" class="sw-detail cu-rev" style="--d:.1s"></div>

    <div class="sw-card sw-disc cu-rev" style="--d:.14s">
      <p><strong data-i18n="disclaimerTitle">Preliminary profile — not a diagnosis.</strong> <span data-i18n="disclaimerBody">Generated from your passport answers. Confidence reflects how many related questions you've completed. For any concerns, speak with a qualified professional.</span></p>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  .sw-wrap{display:flex;flex-direction:column;gap:14px;max-width:1000px}
  .sw-card{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:20px 22px;box-shadow:var(--shadow)}
  .sw-tophead{display:flex;justify-content:center;align-items:center;gap:10px;flex-wrap:wrap}
  .sw-tourbtn{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--violet-100);background:var(--violet-50);color:var(--violet-700);font-size:.76rem;font-weight:700;padding:7px 14px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:background .15s,transform .15s}
  .sw-tourbtn:hover{background:var(--violet-100);transform:translateY(-1px)}
  .sw-tourbtn.on{background:var(--violet-700);color:#fff;border-color:var(--violet-700)}
  .sw-caption{text-align:center;font-size:.82rem;color:var(--muted);margin:8px 0 4px}

  /* the stage */
  .sw-stage{position:relative;border-radius:18px}
  .sw-wheelbox{position:relative;width:100%;max-width:460px;margin:0 auto}
  .sw-float{position:absolute;font-style:normal;font-size:12px;color:#C4B5FD;pointer-events:none;animation:c3Twk 2.8s ease infinite;z-index:1}
  .sw-float.f2{font-size:9px;color:#5EEAD4;animation-delay:.8s}
  .sw-float.f3{font-size:10px;color:#F9A8D4;animation-delay:1.5s}
  .sw-overlay{position:absolute;inset:0;width:100%;height:100%;z-index:2}
  .sw-wedge{cursor:pointer;fill:transparent;transition:fill .15s}
  .sw-wedge:hover{fill:rgba(109,40,217,0.07)}
  .sw-compare{display:grid;grid-template-columns:1fr auto 1fr;gap:18px;align-items:center;border-radius:18px;padding:4px 6px}
  .sw-cmp-col{min-width:0}
  .sw-cmp-col > div{max-width:400px;margin:0 auto}
  .sw-cmp-lab{text-align:center;font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;margin:0 0 6px}
  .sw-cmp-mid{display:grid;place-items:center}
  .sw-cmp-mid span{width:34px;height:34px;border-radius:50%;background:var(--violet-50);border:1px solid var(--violet-100);color:var(--violet-700);display:grid;place-items:center;font-weight:700}
  .sw-compare [data-domain]{cursor:pointer}
  @media (max-width:820px){.sw-compare{grid-template-columns:1fr}.sw-cmp-mid{display:none}}

  /* domain chip nav */
  .sw-domnav{display:flex;flex-wrap:wrap;justify-content:center;gap:7px;margin-top:14px}
  .sw-dn{display:inline-flex;align-items:center;gap:7px;font-size:.74rem;font-weight:700;padding:6px 13px;border-radius:9999px;border:1px solid var(--line);background:var(--card);color:var(--ink-2);cursor:pointer;font-family:inherit;transition:transform .15s,border-color .15s,box-shadow .15s}
  .sw-dn i{width:8px;height:8px;border-radius:50%;font-style:normal;flex-shrink:0}
  .sw-dn:hover{transform:translateY(-1px);border-color:#DDD6FE}
  .sw-dn.on{box-shadow:0 4px 12px rgba(34,27,54,.12);border-color:transparent}
  .sw-legend{display:flex;align-items:center;justify-content:center;gap:9px;margin-top:12px;flex-wrap:wrap}
  .sw-leg-rings{display:inline-flex;align-items:center;gap:3px}
  .sw-leg-rings i{display:inline-block;border-radius:50%;background:var(--violet-500);opacity:.75}
  .sw-legend span{font-size:.7rem;color:var(--faint)}
  .sw-kbd{font-size:.66rem}

  /* detail — full width, two columns inside */
  .sw-detail{background:var(--card);border:1px solid var(--line);border-top-width:3px;border-radius:18px;padding:20px 22px;box-shadow:var(--shadow);transition:border-color .3s}
  .swd-in{animation:swdIn .3s cubic-bezier(.22,1,.36,1) both}
  @keyframes swdIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .swd-cols{display:grid;grid-template-columns:290px 1fr;gap:24px}
  @media (max-width:760px){.swd-cols{grid-template-columns:1fr}}
  .swd-head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
  .swd-dot{width:30px;height:30px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;flex-shrink:0;display:grid;place-items:center}
  .swd-dot i{width:11px;height:11px;border-radius:50%;font-style:normal}
  .swd-name{font-family:var(--display);font-size:1.08rem;font-weight:700;color:var(--ink);flex:1}
  .swd-pill{font-size:.72rem;font-weight:700;padding:3px 11px;border-radius:9999px;white-space:nowrap}
  .swd-trend{display:inline-flex;align-items:center;gap:7px;font-size:.72rem;font-weight:600;background:#FBFDFC;border:1px solid #E3F2EB;border-radius:9999px;padding:4px 12px;margin:0 0 12px;color:var(--ink-2)}
  .swd-trend .up{color:var(--green);font-weight:700}
  .swd-trend .dn{color:var(--amber);font-weight:700}
  .swd-meta{display:flex;align-items:center;gap:10px;margin-bottom:9px}
  .swd-meta .l{font-size:.74rem;color:var(--muted);min-width:82px}
  .swd-segs{display:flex;gap:4px;flex:1}
  .swd-seg{height:9px;border-radius:4px;flex:1;background:var(--bg);position:relative;overflow:hidden}
  .swd-seg b{position:absolute;inset:0;border-radius:4px;transform:scaleX(0);transform-origin:left;animation:swdSeg .5s cubic-bezier(.22,1,.36,1) var(--d,0s) both}
  @keyframes swdSeg{to{transform:scaleX(1)}}
  .swd-confbar{flex:1;height:7px;border-radius:4px;background:var(--bg);overflow:hidden}
  .swd-confbar b{display:block;height:100%;border-radius:4px;background:linear-gradient(90deg,#A78BFA,#6D28D9);width:0;animation:swdConf .7s cubic-bezier(.22,1,.36,1) .15s both}
  @keyframes swdConf{to{width:var(--w,0%)}}
  .swd-ctx{font-size:.82rem;color:var(--muted);font-style:italic;margin:12px 0 0;line-height:1.5}
  .swd-lab{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--faint);margin:0 0 8px;display:flex;align-items:center;justify-content:space-between;gap:8px}
  .swd-group{margin-bottom:15px}
  .swd-group:last-child{margin-bottom:0}
  .swd-copy{border:1px solid var(--line);background:var(--card);color:var(--ink-2);font-size:.66rem;font-weight:700;padding:3px 10px;border-radius:9999px;cursor:pointer;font-family:inherit;letter-spacing:0;text-transform:none;transition:border-color .15s,color .15s}
  .swd-copy:hover{border-color:var(--violet-500);color:var(--violet-700)}
  .swd-chips{display:flex;flex-wrap:wrap;gap:7px}
  .swd-chip{display:inline-flex;align-items:center;gap:6px;font-size:.83rem;font-weight:600;padding:6px 11px;border-radius:9999px;line-height:1.25;transition:transform .15s}
  .swd-chip:hover{transform:translateY(-1px)}
  .swd-chip.str{background:var(--green-bg);color:var(--green)}
  .swd-chip.sup{background:var(--amber-bg);color:var(--amber)}
  .swd-chip.tip{background:var(--violet-50);color:var(--violet-700)}
  .swd-none{font-size:.83rem;color:var(--faint)}
  .sw-disc{background:var(--amber-bg);border-color:#EBDCC3}
  .sw-disc p{color:var(--amber);font-size:.74rem;line-height:1.5;margin:0}
  .sw-prompt{text-align:center;padding:28px 16px}
  .sw-prompt p{color:var(--muted);font-size:.9rem;margin:0 0 14px}
  .sw-prompt a{display:inline-block;background:var(--violet-700);color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
  .sw-warn{background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:12px;padding:12px 16px}
  .sw-warn p{color:var(--amber);font-size:.8rem;line-height:1.5;margin:0}
  .sw-warn a{color:var(--amber);font-weight:600;text-decoration:underline}
  @media (prefers-reduced-motion:reduce){
    .swd-in,.swd-seg b,.swd-confbar b{animation:none}
    .swd-seg b{transform:none}
    .swd-confbar b{width:var(--w,0%)}
    .sw-float{animation:none}
  }
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../../lib/ua-data.js";
  import { scoreWheel, DOMAINS, wheelCompleteness, scoreToBand, HUES } from "../../lib/wheelScore.js";
  import { generateWheelSVG, domainColor } from "../../lib/wheelSvg.js";
  import { domainName, domainShort, bandLabel } from "../../lib/libI18n.js";
  import { domainDetail } from "../../lib/domainInsights.js";
  import { getSnapshots } from "../../lib/history.js";
  import DICT from "../../i18n/child-wheel.js";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const tintOf = (nm, a) => { const i = DOMAINS.indexOf(nm); return i === -1 ? "rgba(109,40,217," + a + ")" : "hsla(" + HUES[i] + ",70%,45%," + a + ")"; };
  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ---------- i18n (string codes from src/i18n/child-wheel.js) ---------- */
  const T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
  const tpl = (s, v) => String(s).replace(/\{(\w+)\}/g, (m, k) => (v && v[k] != null ? v[k] : ""));
  const ofName = (n) => (window.uaLang === "fr"
    ? (/^[aeiouyàâäéèêëìîïòôöùûüh]/i.test(String(n || "")) ? "d'" : "de ")
    : "");
  /* Script-owned labels (JS fills these with data later — translate the
     fallbacks here, never via data-i18n, to avoid overwrite races). */
  $("rb-title").textContent = T.pageTitle;
  $("sw-leg-text").textContent = T.legDefault;
  $("sw-tour").title = T.tourTitle;

  const icCheck = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" style="flex-shrink:0"><path d="M3 8.5l3.2 3L13 4.5"/></svg>';
  const icBang = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" style="flex-shrink:0"><path d="M8 3.2v6M8 12.3v.2"/></svg>';
  const icStar = '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg>';
  /* display names resolve per language (libI18n) — EN values unchanged */
  const SHORTD = Object.fromEntries(DOMAINS.map((d) => [d, domainShort(d)]));

  function levelInfo(score) {
    if (score == null) return { label: T.notEnoughData, bg: "#F4F3F8", fg: "#7B7491", seg: "#D8D3E6" };
    const b = scoreToBand(score);
    if (b.key === "minimal" || b.key === "low") return { label: bandLabel(b), bg: "#E8F6F0", fg: "#0E8F66", seg: "#0E8F66" };
    if (b.key === "high" || b.key === "intensive") return { label: bandLabel(b), bg: "#EDE9FE", fg: "#6D28D9", seg: "#7C3AED" };
    return { label: bandLabel(b), bg: "#FBF2E2", fg: "#A8650A", seg: "#D97706" };
  }

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    const data = (p && p.data) || {};
    const id = UA.childIdentity(data);
    const first = id.first || T.yourChild;
    const scored = scoreWheel(data);
    const n = DOMAINS.length;
    const scoredCount = DOMAINS.filter((nm) => scored[nm].score != null).length;
    const passportLink = "/passport" + (p ? "?id=" + p.id : "");

    let baseline = null;
    if (p) {
      const snaps = await getSnapshots(p.id).catch(() => []);
      if (snaps.length >= 2) {
        const bw = snaps[0].wheel || {};
        baseline = { at: snaps[0].taken_at, domains: bw.domains || bw };
      }
    }

    $("rb-av").textContent = (id.first || id.name || "·")[0].toUpperCase();
    if (id.first) $("rb-title").textContent = tpl(T.wheelTitleNamed, { name: id.first, of: ofName(id.first) });
    const wc = wheelCompleteness(data);
    const topNeed = DOMAINS.filter((nm) => scored[nm].score != null).sort((a, b) => scored[b].score - scored[a].score)[0];
    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${wc.pct}%</b><span>${esc(T.statWheelComplete)}</span></span>`,
      `<span class="c3-rstat"><b>${scoredCount}/8</b><span>${esc(T.statAreasScored)}</span></span>`,
      topNeed ? `<span class="c3-rstat"><b style="font-size:.82rem">${esc(SHORTD[topNeed] || topNeed)}</b><span>${esc(T.statMostSupport)}</span></span>` : "",
    ].join("");

    if (scoredCount < 3) {
      $("sw-toggle").innerHTML = "";
      $("sw-tour").style.display = "none";
      $("sw-caption").textContent = "";
      $("sw-wheel").innerHTML = `<div class="sw-prompt"><p>${tpl(esc(T.promptFill), { of: ofName(first), name: esc(first) })}</p><a href="${passportLink}">${esc(T.continuePassportArrow)}</a></div>`;
      $("sw-detail").style.display = "none";
      $("sw-domnav").style.display = "none";
      document.querySelector(".sw-legend").style.display = "none";
      return;
    }

    const lowConf = DOMAINS.filter((nm) => scored[nm].confidence === "low");
    $("sw-warning").innerHTML = (wc.pct < 70)
      ? `<div class="sw-warn cu-rev"><p>${tpl(T.wheelWarn, { p: wc.pct, a: wc.answered, t: wc.total })}${lowConf.length ? tpl(esc(T.lowerConf), { list: esc(lowConf.join(", ")) }) : ""} <a href="${passportLink}">${esc(T.completeMore)}</a></p></div>`
      : "";

    let sel = 0;
    for (let i = 0; i < n; i++) { if (scored[DOMAINS[i]].score != null) { sel = i; break; } }
    const qd = new URLSearchParams(location.search).get("domain");
    if (qd) { const qi = DOMAINS.findIndex((nm) => nm.toLowerCase().startsWith(qd.toLowerCase())); if (qi > -1) sel = qi; }
    let mode = "needs";
    let touring = false, tourTimer = null;

    const MODES = [["needs", T.needsBtn], ["strengths", T.strengthsBtn], ["compare", T.compareBtn]];
    function renderToggle() {
      const seg = $("sw-toggle");
      seg.innerHTML = `<span class="thumb"></span>` + MODES.map(([m, lbl]) =>
        `<button data-mode="${m}" class="${m === mode ? "on" : ""}" role="tab" aria-selected="${m === mode}">${esc(lbl)}</button>`).join("");
      const onBtn = seg.querySelector("button.on"), thumb = seg.querySelector(".thumb");
      requestAnimationFrame(() => { thumb.style.left = onBtn.offsetLeft + "px"; thumb.style.width = onBtn.offsetWidth + "px"; });
      seg.querySelectorAll("button").forEach((b) =>
        b.addEventListener("click", () => { mode = b.dataset.mode; stopTour(); renderToggle(); renderWheel(); renderDetail(); }));
      $("sw-caption").innerHTML = mode === "strengths"
        ? T.captionStrengths
        : mode === "compare"
          ? T.captionCompare
          : T.captionNeeds;
      $("sw-leg-text").textContent = mode === "strengths"
        ? T.legStrengths
        : mode === "compare"
          ? T.legCompare
          : T.legNeeds;
    }

    /* domain chip nav */
    function renderNav() {
      $("sw-domnav").innerHTML = DOMAINS.map((nm, i) =>
        `<button type="button" class="sw-dn${i === sel ? " on" : ""}" data-i="${i}" style="${i === sel ? "background:" + tintOf(nm, 0.12) + ";color:" + domainColor(nm) : ""}"><i style="background:${domainColor(nm)}"></i>${esc(SHORTD[nm])}</button>`).join("");
      $("sw-domnav").querySelectorAll(".sw-dn").forEach((b) =>
        b.addEventListener("click", () => { stopTour(); sel = +b.dataset.i; onSelect(); }));
    }
    function markNav() {
      $("sw-domnav").querySelectorAll(".sw-dn").forEach((b) => {
        const i = +b.dataset.i, nm = DOMAINS[i], on = i === sel;
        b.classList.toggle("on", on);
        b.style.background = on ? tintOf(nm, 0.12) : "";
        b.style.color = on ? domainColor(nm) : "";
      });
    }
    function onSelect() {
      renderDetail();
      markNav();
      if (mode === "compare") renderCompare(false); else buildOverlay();
    }

    function wirePetals(host2) {
      host2.querySelectorAll("[data-domain]").forEach((g) => {
        const pick = () => { const qi = DOMAINS.indexOf(g.dataset.domain); if (qi > -1) { stopTour(); sel = qi; onSelect(); } };
        g.addEventListener("click", pick);
        g.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); pick(); } });
      });
    }
    function renderSingle() {
      $("sw-wrap1").style.display = "block";
      $("sw-compare").style.display = "none";
      const host2 = $("sw-wheel");
      host2.classList.remove("play");
      host2.innerHTML = generateWheelSVG(scored, mode);
      void host2.offsetWidth;
      host2.classList.add("play");
      wirePetals(host2);
      buildOverlay();
    }
    function renderCompare(replay = true) {
      $("sw-wrap1").style.display = "none";
      $("sw-compare").style.display = "grid";
      const hn = $("sw-cmp-needs"), hs = $("sw-cmp-str");
      [hn, hs].forEach((h) => h.classList.remove("play"));
      hn.innerHTML = generateWheelSVG(scored, "needs", DOMAINS[sel]);
      hs.innerHTML = generateWheelSVG(scored, "strengths", DOMAINS[sel]);
      if (replay) { void hn.offsetWidth; hn.classList.add("play"); hs.classList.add("play"); }
      wirePetals(hn); wirePetals(hs);
    }
    function renderWheel() {
      if (mode === "compare") renderCompare(true);
      else renderSingle();
      markNav();
    }

    const cx = 240, cy = 210, ir = 24, or_ = 138, seg = (2 * Math.PI) / n;
    const pt = (r, a) => [(cx + r * Math.cos(a)).toFixed(2), (cy + r * Math.sin(a)).toFixed(2)];
    function sector(a0, a1) {
      const p0 = pt(ir, a0), p1 = pt(or_, a0), p2 = pt(or_, a1), p3 = pt(ir, a1);
      return "M" + p0[0] + "," + p0[1] + " L" + p1[0] + "," + p1[1] + " A" + or_ + "," + or_ + " 0 0 1 " + p2[0] + "," + p2[1] + " L" + p3[0] + "," + p3[1] + " A" + ir + "," + ir + " 0 0 0 " + p0[0] + "," + p0[1] + " Z";
    }
    function buildOverlay() {
      let s = "";
      for (let i = 0; i < n; i++) {
        const a0 = -Math.PI / 2 + i * seg, a1 = a0 + seg, hue = HUES[i], on = i === sel;
        const attrs = on ? `fill="hsla(${hue},65%,52%,0.12)" stroke="hsl(${hue},65%,45%)" stroke-width="2.5"` : `stroke="none" stroke-width="0"`;
        s += '<path class="sw-wedge" data-i="' + i + '" d="' + sector(a0, a1) + '" ' + attrs + '></path>';
      }
      $("sw-overlay").innerHTML = s;
      $("sw-overlay").querySelectorAll(".sw-wedge").forEach((el) =>
        el.addEventListener("click", () => { stopTour(); sel = +el.getAttribute("data-i"); onSelect(); }));
    }

    function trendPill(name) {
      if (!baseline || !baseline.domains) return "";
      const bd = baseline.domains[name];
      const oldSc = bd ? bd.score : null;
      const nowSc = scored[name].score;
      if (oldSc == null || nowSc == null) return "";
      const ob = scoreToBand(oldSc), nb = scoreToBand(nowSc);
      if (!ob || !nb || ob.key === nb.key) return "";
      const better = nb.rings < ob.rings;
      const when = new Date(baseline.at);
      const whenTxt = isNaN(when) ? T.firstCheckin : when.toLocaleDateString(window.uaLocale || "en-CA", { month: "short", year: "numeric" });
      return `<span class="swd-trend">${tpl(esc(T.trendSince), { when: esc(whenTxt) })} ${esc(bandLabel(ob))} → <span class="${better ? "up" : "dn"}">${esc(bandLabel(nb))} ${better ? "✦" : ""}</span></span>`;
    }
    function block(title, items, cls, dBase, copyBtn) {
      const icon = cls === "str" ? icCheck : cls === "sup" ? icBang : icStar;
      const inner = items.length
        ? items.map((t, i) => `<span class="swd-chip ${cls} cu-pop" style="--d:${(dBase + i * 0.045).toFixed(2)}s">${icon}${esc(t)}</span>`).join("")
        : `<span class="swd-none">${cls === "sup" ? esc(T.noneFlagged) : esc(T.noneAdd)}</span>`;
      return `<div class="swd-group"><p class="swd-lab"><span>${esc(title)}</span>${copyBtn && items.length ? `<button class="swd-copy" id="swd-copy" type="button">${esc(T.copy)}</button>` : ""}</p><div class="swd-chips">${inner}</div></div>`;
    }
    function renderDetail() {
      const name = DOMAINS[sel], dm = scored[name];
      const L = levelInfo(dm.score), det = domainDetail(name, data);
      const dc = domainColor(name);
      const segCount = dm.score == null ? 0 : (dm.score === 0 ? 0 : scoreToBand(dm.score).rings);
      const strCount = dm.strength == null ? 0 : (dm.strength === 0 ? 0 : scoreToBand(dm.strength, "strength").rings);
      let segs = ""; for (let k = 1; k <= 5; k++) segs += `<span class="swd-seg">${k <= segCount ? `<b style="background:${L.seg};--d:${(k * 0.07).toFixed(2)}s"></b>` : ""}</span>`;
      let ssegs = ""; for (let k = 1; k <= 5; k++) ssegs += `<span class="swd-seg">${k <= strCount ? `<b style="background:#0E8F66;--d:${(k * 0.07).toFixed(2)}s"></b>` : ""}</span>`;
      const confPct = dm.coverage != null ? Math.round(dm.coverage * 100) : 0;
      const confLbl = dm.confidence === "high" ? T.confHigh : dm.confidence === "medium" ? T.confMedium : dm.confidence === "low" ? T.confLow : T.confNone;
      $("sw-detail").style.borderTopColor = dc;
      $("sw-detail").innerHTML = `<div class="swd-in"><div class="swd-cols">
        <div>
          <div class="swd-head"><span class="swd-dot" style="background:${tintOf(name, 0.14)}"><i style="background:${dc}"></i></span><span class="swd-name">${esc(domainName(name))}</span><span class="swd-pill" style="background:${L.bg};color:${L.fg}">${L.label}</span></div>
          ${trendPill(name)}
          ${dm.score == null ? `<p class="swd-none">${esc(T.addMorePassport)}</p>` :
            `<div class="swd-meta"><span class="l">${esc(T.supportLevel)}</span><span class="swd-segs">${segs}</span></div>`
            + (dm.strength != null ? `<div class="swd-meta"><span class="l">${esc(T.strengthsLabel)}</span><span class="swd-segs">${ssegs}</span></div>` : "")
            + `<div class="swd-meta"><span class="l">${esc(T.confidence)}</span><span class="swd-confbar"><b style="--w:${confPct}%"></b></span><span style="font-size:.72rem;color:var(--muted);white-space:nowrap">${esc(confLbl)} · ${dm.answered}/${dm.total}</span></div>`}
          ${det.context ? `<p class="swd-ctx">${esc(det.context)}</p>` : ""}
        </div>
        <div>
          ${block(T.strengthsLabel, det.strengths, "str", 0.08)}
          ${block(T.groupSupporting, det.support, "sup", 0.16)}
          ${block(T.groupStrategies, det.strategies, "tip", 0.24, true)}
        </div>
      </div></div>`;
      const cbtn = document.getElementById("swd-copy");
      if (cbtn) cbtn.addEventListener("click", () => {
        const txt = tpl(T.copyStrategiesHead, { domain: domainName(name), who: id.first ? " (" + id.first + ")" : "" }) + "\n"
          + det.strategies.map((s2) => "• " + s2).join("\n");
        navigator.clipboard && navigator.clipboard.writeText(txt).then(() => {
          cbtn.textContent = T.copied;
          setTimeout(() => { cbtn.textContent = T.copy; }, 1600);
        }).catch(() => {});
      });
    }

    function stepTour() {
      sel = (sel + 1) % n;
      onSelect();
    }
    function startTour() {
      if (reduceMotion) { stepTour(); return; }
      touring = true;
      $("sw-tour").classList.add("on");
      $("sw-tour").innerHTML = `<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor"><path d="M4 3h3v10H4zM9 3h3v10H9z"/></svg> ${esc(T.stopBtn)}`;
      onSelect();
      tourTimer = setInterval(stepTour, 2800);
    }
    function stopTour() {
      if (!touring) return;
      touring = false;
      clearInterval(tourTimer);
      $("sw-tour").classList.remove("on");
      $("sw-tour").innerHTML = `<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor"><path d="M4 2.5l9 5.5-9 5.5z"/></svg> ${esc(T.tourBtn)}`;
    }
    $("sw-tour").addEventListener("click", () => { touring ? stopTour() : startTour(); });

    document.addEventListener("keydown", (e) => {
      const tag = (e.target && e.target.tagName) || "";
      if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return;
      if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
        e.preventDefault();
        stopTour();
        sel = (sel + (e.key === "ArrowRight" ? 1 : n - 1)) % n;
        onSelect();
      }
    });

    renderToggle();
    renderNav();
    renderWheel();
    renderDetail();
  })().catch((e) => console.error("[support wheel] hydrate failed", e));
</script>
