---
/* ASSESSMENTS-V3 â€” "evaluation library" rethink (Dashboard-V3 language):
   Â· gradient ribbon with live stats (reports on file Â· records captured Â·
     recommendations gathered) + morphing avatar
   Â· AI Report Reader card is now HONEST: clearly marked "Rolling out" (the
     extraction engine isn't deployed yet) â€” no overpromising; uploading now
     still pays off because summaries will appear automatically at launch
   Â· report rows with type pills, record cards with type-tinted blob + left
     accent, recommendations hub (numbered, violet gradient) with Copy list
   Records CRUD (assessments table) and documents read unchanged. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Assessments" titleFr="Ã‰valuations" activeNav="child">
  <div class="c3-tabs"><SectionTabs section="child" active="assessments" /></div>

  <div id="as-gate"></div>

  <div id="as-main" style="display:none;max-width:920px">

    <div class="c3-ribbon cu-rev">
      <span class="c3-spark" style="top:12px;right:118px">âœ¦</span>
      <span class="c3-spark s2" style="bottom:14px;right:72px">âœ¦</span>
      <span class="c3-rib-av" id="rb-av">Â·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Assessments</h1>
        <p id="rb-sub" data-i18n="ribbonSub">Every evaluation in one library â€” reports, key findings, and all the recommendations.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div class="as-ai cu-rev cu-sparkle-host" style="--d:.05s">
      <span class="cu-spark" style="top:12px;right:74px">âœ¦</span>
      <span class="cu-spark s2" style="top:30px;right:52px">âœ¦</span>
      <div class="as-ai-ic">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h8l4 4v14H7z"/><path d="M15 3v4h4"/><path d="M12 11l.9 2.1L15 14l-2.1.9L12 17l-.9-2.1L9 14l2.1-.9z"/></svg>
      </div>
      <div class="as-ai-tx">
        <b><span data-i18n="aiTitle">AI Report Reader</span> <span class="as-soon" data-i18n="aiBadge">Rolling out</span></b>
        <p data-i18n="aiBody">Assessment reports are dense. The reader will turn any uploaded report into a plain-language summary â€” what was found, what's recommended, what to do next. Reports you upload now will be summarized automatically when it launches.</p>
      </div>
      <a class="as-ai-btn" href="/documents" data-i18n="aiCta">Open the vault</a>
    </div>

    <div class="asc cu-rev" style="--d:.1s">
      <div class="asc-head">
        <span class="cu-blob" style="--blob:#EDE9FE;color:#6D28D9;width:36px;height:36px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 1.8h5.2L12.4 5v9.2H4z"/><path d="M9 1.8V5h3.4"/></svg></span>
        <span class="asc-t"><b data-i18n="reportsTitle">Reports</b><span data-i18n="reportsSub">The files themselves â€” PDFs, scans and originals, straight from the vault.</span></span>
        <a class="as-link" href="/documents"><span data-i18n="uploadReport">Upload a report</span> <span class="arr">â†’</span></a>
      </div>
      <div id="as-docs"></div>
    </div>

    <div class="asc cu-rev" style="--d:.16s">
      <div class="asc-head">
        <span class="cu-blob" style="--blob:#E6F4F2;color:#0E8C82;width:36px;height:36px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4.5" y="3" width="7" height="10" rx="1.2"/><path d="M6.3 3V2.2h3.4V3"/><path d="M6.5 6.5h3M6.5 9h3"/></svg></span>
        <span class="asc-t"><b data-i18n="recordsTitle">Assessment records</b><span data-i18n="recordsSub">The key findings and recommendations, captured so nothing gets lost.</span></span>
        <button class="as-addbtn" id="as-addbtn"><span style="font-size:1.1em;line-height:1">+</span> <span data-i18n="addAssessment">Add assessment</span></button>
      </div>
      <div class="as-form" id="as-form">
        <div class="as-form-grid">
          <select id="as-type" class="as-field">
            <option value="Speech / language" data-i18n="typeSpeech">Speech / language</option><option value="Occupational therapy" data-i18n="typeOT">Occupational therapy</option><option value="Psychoeducational" data-i18n="typePsychoEd">Psychoeducational</option>
            <option value="Behavioural / ABA" data-i18n="typeABA">Behavioural / ABA</option><option value="Developmental pediatric" data-i18n="typeDevPed">Developmental pediatric</option><option value="Physiotherapy" data-i18n="typePhysio">Physiotherapy</option><option value="Other" data-i18n="typeOther">Other</option>
          </select>
          <input type="text" id="as-provider" class="as-field" placeholder="Provider or clinic" data-i18n-ph="providerPh" />
          <input type="date" id="as-date" class="as-field" />
        </div>
        <textarea id="as-findings" class="as-field as-area" placeholder="Key findings (paste or summarize from the report)â€¦" data-i18n-ph="findingsPh"></textarea>
        <textarea id="as-recs" class="as-field as-area" placeholder="Recommendations â€” one per lineâ€¦" data-i18n-ph="recsPh"></textarea>
        <div class="as-form-actions">
          <span id="as-err" class="as-err"></span>
          <button class="as-ghost" id="as-cancel" data-i18n="cancel">Cancel</button>
          <button class="as-savebtn" id="as-save" data-i18n="saveAssessment">Save assessment</button>
        </div>
      </div>
      <div id="as-records"></div>
    </div>

    <div class="asc cu-rev" style="--d:.22s;margin-bottom:0">
      <div class="asc-head">
        <span class="cu-blob" style="--blob:#FBF2E2;color:#A8650A;width:36px;height:36px"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg></span>
        <span class="asc-t"><b data-i18n="hubTitle">All recommendations</b><span data-i18n="hubSub">Every recommendation from every record â€” one ready-made list for IEP meetings and applications.</span></span>
        <button class="as-copybtn" id="as-copy" style="display:none" data-i18n="copyList">Copy list</button>
      </div>
      <div class="as-card as-hubcard" id="as-hub" style="box-shadow:none"></div>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  #as-gate{max-width:920px}
  .as-sec{margin-bottom:24px}
  .asc{background:var(--card);border:1px solid var(--line);border-radius:18px;box-shadow:var(--shadow);padding:16px 18px;margin-bottom:16px}
  .asc-head{display:flex;align-items:center;gap:12px;margin-bottom:12px;flex-wrap:wrap}
  .asc-t{flex:1;min-width:180px}
  .asc-t b{display:block;font-family:var(--display);font-size:.96rem;font-weight:700;color:var(--ink)}
  .asc-t span{display:block;font-size:.74rem;color:var(--muted);margin-top:2px;line-height:1.4}
  .as-emptybox{display:flex;align-items:center;gap:12px;border:1.5px dashed var(--line-2);border-radius:14px;padding:16px;background:#FBFAFE}
  .as-emptybox p{font-size:.83rem;color:var(--muted);line-height:1.5;margin:0;flex:1}
  .as-emptybox a{color:var(--violet-700);font-weight:700;text-decoration:none;white-space:nowrap}
  .as-h{font-size:.84rem;color:var(--muted);margin:0 0 12px;display:flex;align-items:center;justify-content:space-between;gap:8px;font-weight:600}
  .as-sub2{font-size:.76rem;color:var(--faint);margin:-8px 0 10px}
  .as-link{font-size:.8rem;font-weight:600;color:var(--violet-700);text-decoration:none}
  .as-link .arr{display:inline-block;transition:transform .18s}
  .as-link:hover .arr{transform:translateX(3px)}
  .as-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:16px 18px;box-shadow:var(--shadow)}

  /* AI pitch card â€” honest status */
  .as-ai{position:relative;display:flex;align-items:center;gap:16px;background:linear-gradient(120deg,var(--violet-50),#F9F7FE 55%,#F0FBF9),var(--card);border:1px solid var(--violet-100);border-radius:18px;padding:18px 20px;margin-bottom:22px;flex-wrap:wrap;box-shadow:var(--shadow)}
  .as-ai-ic{width:48px;height:48px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#8B5CF6,#6D28D9);color:#fff;display:grid;place-items:center;flex-shrink:0;box-shadow:0 6px 16px rgba(109,40,217,.28)}
  .as-ai-tx{flex:1;min-width:220px}
  .as-ai-tx b{font-family:var(--display);font-size:1rem;color:var(--ink);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .as-soon{font-size:.62rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;background:#FBF2E2;color:#A8650A;border:1px solid #F3E2C0;padding:2px 9px;border-radius:9999px}
  .as-ai-tx p{font-size:.84rem;color:var(--ink-2);line-height:1.5;margin:3px 0 0;max-width:56ch}
  .as-ai-btn{background:var(--violet-700);color:#fff;font-size:.84rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none;white-space:nowrap;transition:filter .15s,transform .15s}
  .as-ai-btn:hover{filter:brightness(1.1);transform:translateY(-1px)}
  .as-ai .cu-spark{font-style:normal;font-size:13px;color:#8B5CF6}
  .as-ai .cu-spark.s2{font-size:10px;color:#5EEAD4}

  .as-doc{display:flex;align-items:center;gap:11px;background:var(--card);border:1px solid var(--line);border-radius:12px;padding:11px 14px;margin-bottom:8px;box-shadow:var(--shadow);transition:transform .15s,border-color .15s}
  .as-doc:hover{transform:translateY(-1px);border-color:#DDD6FE}
  .as-doc .nm{font-size:.86rem;font-weight:600;color:var(--ink)}
  .as-doc .mt{font-size:.74rem;color:var(--faint)}
  .as-pill{font-size:.68rem;font-weight:700;padding:3px 9px;border-radius:9999px;background:var(--bg);color:var(--muted);margin-left:auto;white-space:nowrap}
  .as-addbtn,.as-copybtn{font-size:.82rem;font-weight:600;padding:7px 14px;border-radius:9999px;border:1px solid var(--violet-700);background:var(--card);color:var(--violet-700);cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:background .15s,transform .15s;font-family:inherit}
  .as-addbtn:hover,.as-copybtn:hover{background:var(--violet-50);transform:translateY(-1px)}
  .as-form{display:none;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px;margin-bottom:14px;box-shadow:var(--shadow)}
  .as-form.show{display:block;animation:asIn .25s cubic-bezier(.22,1,.36,1)}
  @keyframes asIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .as-form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px;margin-bottom:10px}
  .as-field{width:100%;padding:9px 12px;border:1px solid var(--line-2);border-radius:10px;font-size:.88rem;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .as-field:focus{border-color:#A78BFA;box-shadow:0 0 0 3px rgba(139,92,246,.14)}
  .as-area{min-height:64px;margin-bottom:10px;resize:vertical;line-height:1.5}
  .as-form-actions{display:flex;align-items:center;gap:10px;justify-content:flex-end;flex-wrap:wrap}
  .as-err{font-size:.8rem;color:#B14A66;margin-right:auto}
  .as-ghost{font-size:.82rem;font-weight:600;padding:8px 14px;border-radius:9999px;border:1px solid var(--line-2);background:var(--card);color:var(--muted);cursor:pointer}
  .as-savebtn{font-size:.82rem;font-weight:600;padding:8px 16px;border-radius:9999px;border:none;background:var(--violet-700);color:#fff;cursor:pointer;transition:filter .15s}
  .as-savebtn:hover{filter:brightness(1.1)}
  .as-rec-card{background:var(--card);border:1px solid var(--line);border-left-width:4px;border-radius:14px;padding:14px 16px;margin-bottom:10px;position:relative;box-shadow:var(--shadow);transition:transform .15s,box-shadow .15s}
  .as-rec-card:hover{transform:translateY(-1px);box-shadow:var(--shadow-lg)}
  .as-rec-head{display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap}
  .as-rec-blob{width:32px;height:32px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;display:grid;place-items:center;flex-shrink:0}
  .as-rec-type{font-family:var(--display);font-size:.94rem;font-weight:700;color:var(--ink)}
  .as-rec-meta{font-size:.76rem;color:var(--faint)}
  .as-rec-lab{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--faint);margin:10px 0 5px}
  .as-rec-text{font-size:.86rem;color:var(--ink-2);line-height:1.5;white-space:pre-line}
  .as-rec-list{margin:0;padding-left:18px}
  .as-rec-list li{font-size:.86rem;color:var(--ink-2);line-height:1.5;margin-bottom:3px}
  .as-del{position:absolute;top:10px;right:12px;border:none;background:none;color:#D8D3E6;font-size:1.1rem;line-height:1;cursor:pointer;padding:2px}
  .as-del:hover{color:#B14A66}
  .as-hubcard{background:linear-gradient(135deg,var(--violet-50),#F9F7FE 60%,var(--violet-50));border-color:var(--violet-100)}
  .as-hub-item{display:flex;gap:10px;align-items:flex-start;margin-bottom:9px}
  .as-hub-item .n{width:20px;height:20px;border-radius:7px;background:#fff;color:var(--violet-700);font-size:.7rem;font-weight:700;display:grid;place-items:center;flex-shrink:0;border:1px solid var(--violet-100)}
  .as-hub-item .tx{font-size:.86rem;color:#3b2a63;line-height:1.45}
  .as-hub-item .src{font-size:.72rem;color:#9d8bc4}
  .as-empty{font-size:.86rem;color:var(--faint);margin:0}
  .as-empty a{color:var(--violet-700);font-weight:600;text-decoration:none}
  .as-gate-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:28px 22px;text-align:center}
  .as-gate-card p{color:var(--muted);font-size:.9rem;margin:0 0 14px}
  .as-gate-card a{display:inline-block;background:var(--violet-700);color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
  @media (prefers-reduced-motion:reduce){.as-form.show{animation:none}}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../../lib/ua-data.js";
  import DICT from "../../i18n/child-records.js";

  const UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const textToList = (s) => String(s || "").split(/[\n;â€¢]+/).map((x) => x.replace(/^[-*]\s*/, "").trim()).filter(Boolean);

  /* ---------- i18n (string codes from src/i18n/child-records.js) ---------- */
  const T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
  const tpl = (s, v) => String(s).replace(/\{(\w+)\}/g, (m, k) => (v && v[k] != null ? v[k] : ""));
  const ofName = (n) => (window.uaLang === "fr"
    ? (/^[aeiouyÃ Ã¢Ã¤Ã©Ã¨ÃªÃ«Ã¬Ã®Ã¯Ã²Ã´Ã¶Ã¹Ã»Ã¼h]/i.test(String(n || "")) ? "d'" : "de ")
    : "");
  /* Script-owned labels â€” translate the fallback before data arrives. */
  $("rb-title").textContent = T.ribbonTitle;

  function getSession() { try { return JSON.parse(localStorage.getItem("ua_session") || "null"); } catch { return null; } }
  function isValid(s) { return s && s.access_token && Math.floor(Date.now() / 1000) < (s.expires_at || 0) - 60; }
  function authHeaders(t) { return { apikey: ANON, Authorization: "Bearer " + t, "Content-Type": "application/json" }; }
  async function getValidSession() {
    let s = getSession();
    if (isValid(s)) return s;
    if (s && s.refresh_token) {
      const r = await fetch(UA_URL + "/auth/v1/token?grant_type=refresh_token", { method: "POST", headers: { apikey: ANON, "Content-Type": "application/json" }, body: JSON.stringify({ refresh_token: s.refresh_token }) });
      if (r.ok) { const d = await r.json(); d.expires_at = Math.floor(Date.now() / 1000) + (d.expires_in || 3600); localStorage.setItem("ua_session", JSON.stringify(d)); return d; }
    }
    return s && s.access_token ? s : null;
  }
  async function restGet(path) { const s = await getValidSession(); if (!s) return []; const r = await fetch(UA_URL + "/rest/v1/" + path, { headers: authHeaders(s.access_token) }); return r.ok ? r.json() : []; }

  const fileSvg = '<svg width="17" height="17" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 1.8h5.2L12.4 5v9.2H4z"/><path d="M9 1.8V5h3.4"/></svg>';
  const clipSvg = '<svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4.5" y="3" width="7" height="10" rx="1.2"/><path d="M6.3 3V2.2h3.4V3"/><path d="M6.5 6.5h3M6.5 9h3"/></svg>';
  const fmtDate = (iso) => { const d = new Date(iso); return isNaN(d) ? "" : d.toLocaleDateString(window.uaLocale || "en-CA", { month: "short", day: "numeric", year: "numeric" }); };
  const TYPE_COLOR = {
    "Speech / language": "#7C3AED", "Occupational therapy": "#0E8C82", "Psychoeducational": "#2563EB",
    "Behavioural / ABA": "#D85A30", "Developmental pediatric": "#D4537E", "Physiotherapy": "#4C9A2A", "Other": "#7B7491",
  };
  /* proper translucent tint (hex + alpha byte works on 6-digit hex) */
  const hexTint = (hex, ab) => hex + ab;
  /* Display labels for the canonical English type VALUES (DB + TYPE_COLOR
     keys stay English â€” see child-records.js). Unknown values pass through. */
  const TYPE_LABEL = {
    "Speech / language": T.typeSpeech, "Occupational therapy": T.typeOT, "Psychoeducational": T.typePsychoEd,
    "Behavioural / ABA": T.typeABA, "Developmental pediatric": T.typeDevPed, "Physiotherapy": T.typePhysio, "Other": T.typeOther,
  };
  const typeLabel = (v) => (v ? (TYPE_LABEL[v] || v) : T.assessmentFallback);

  let records = [], activeP = null, docCount = 0;

  function renderRibbon() {
    const recCount = records.reduce((a, r) => a + textToList(r.recommendations).length, 0);
    $("rb-stats").innerHTML = [
      `<a class="c3-rstat" href="/documents"><b>${docCount}</b><span>${esc(T.statReports)}</span></a>`,
      `<span class="c3-rstat"><b>${records.length}</b><span>${esc(T.statRecords)}</span></span>`,
      `<span class="c3-rstat"><b>${recCount}</b><span>${esc(T.statRecs)}</span></span>`,
    ].join("");
  }

  function renderRecords() {
    if (!records.length) { $("as-records").innerHTML = `<div class="as-emptybox"><span class="cu-blob" style="--blob:#E6F4F2;color:#0E8C82;width:34px;height:34px">${clipSvg}</span><p>${esc(T.recordsEmpty)}</p></div>`; renderRibbon(); return; }
    $("as-records").innerHTML = records.map((r, i) => {
      const recs = textToList(r.recommendations);
      const tc = TYPE_COLOR[r.assessment_type] || TYPE_COLOR.Other;
      return `<div class="as-rec-card cu-pop" style="--d:${(i * 0.06).toFixed(2)}s;border-left-color:${tc}"><button class="as-del" data-id="${r.id}" aria-label="${esc(T.delAria)}">Ã—</button>`
        + `<div class="as-rec-head"><span class="as-rec-blob" style="background:${hexTint(tc, "1f")};color:${tc}">${clipSvg}</span><span class="as-rec-type" style="color:${tc}">${esc(typeLabel(r.assessment_type))}</span><span class="as-rec-meta">${[esc(r.provider || ""), r.assessment_date ? esc(fmtDate(r.assessment_date)) : ""].filter(Boolean).join(" Â· ")}</span></div>`
        + (r.findings ? `<p class="as-rec-lab">${esc(T.keyFindings)}</p><div class="as-rec-text">${esc(r.findings)}</div>` : "")
        + (recs.length ? `<p class="as-rec-lab">${esc(T.recsLabel)}</p><ul class="as-rec-list">${recs.map((x) => `<li>${esc(x)}</li>`).join("")}</ul>` : "")
        + `</div>`;
    }).join("");
    $("as-records").querySelectorAll(".as-del").forEach((b) => b.addEventListener("click", () => delRecord(b.dataset.id)));
    renderRibbon();
  }

  function renderHub() {
    const all = [];
    records.forEach((r) => textToList(r.recommendations).forEach((x) => all.push({ tx: x, src: typeLabel(r.assessment_type) })));
    $("as-copy").style.display = all.length ? "" : "none";
    $("as-hub").innerHTML = all.length
      ? all.map((a, i) => `<div class="as-hub-item"><span class="n">${i + 1}</span><span><span class="tx" style="display:block">${esc(a.tx)}</span><span class="src">${esc(tpl(T.fromSrc, { src: a.src }))}</span></span></div>`).join("")
      : `<p class="as-empty" style="color:#9d8bc4">${esc(T.hubEmpty)}</p>`;
    window.__asHubList = all;
  }

  async function delRecord(id) {
    if (!confirm(T.confirmDelete)) return;
    const s = await getValidSession(); if (!s) return;
    const r = await fetch(UA_URL + "/rest/v1/assessments?id=eq." + id, { method: "DELETE", headers: authHeaders(s.access_token) });
    if (r.ok) { records = records.filter((x) => String(x.id) !== String(id)); renderRecords(); renderHub(); }
  }

  async function saveRecord() {
    const type = $("as-type").value, provider = $("as-provider").value.trim(), date = $("as-date").value, findings = $("as-findings").value.trim(), recs = $("as-recs").value.trim();
    if (!findings && !recs) { $("as-err").textContent = T.errNeedContent; return; }
    $("as-err").textContent = ""; const btn = $("as-save"); btn.disabled = true; btn.textContent = T.saving;
    const s = await getValidSession(); if (!s) { location.href = "/login"; return; }
    const body = { user_id: s.user.id, passport_id: activeP.id, assessment_type: type, provider, assessment_date: date || null, findings, recommendations: recs };
    try {
      const r = await fetch(UA_URL + "/rest/v1/assessments", { method: "POST", headers: Object.assign({}, authHeaders(s.access_token), { Prefer: "return=representation" }), body: JSON.stringify(body) });
      if (r.ok) {
        const rows = await r.json(), row = rows && rows[0];
        records.unshift(row || body);
        $("as-provider").value = ""; $("as-date").value = ""; $("as-findings").value = ""; $("as-recs").value = "";
        $("as-form").classList.remove("show"); renderRecords(); renderHub();
      } else { $("as-err").textContent = T.errSaveTable; }
    } catch (e) { $("as-err").textContent = T.errSaveNet; }
    btn.disabled = false; btn.textContent = T.saveAssessment;
  }

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("as-gate").innerHTML = `<div class="as-gate-card"><p>${esc(T.gateText)}</p><a href="/passport">${esc(T.gateCta)}</a></div>`;
      return;
    }
    activeP = p;
    $("as-main").style.display = "block";

    const id = UA.childIdentity(p.data || {});
    $("rb-av").textContent = (id.first || id.name || "Â·")[0].toUpperCase();
    if (id.first) $("rb-title").textContent = tpl(T.ribbonTitleNamed, { name: id.first, of: ofName(id.first) });

    const docs = await restGet("documents?select=id,file_name,file_type,created_at&passport_id=eq." + p.id + "&order=created_at.desc&limit=30").catch(() => []);
    docCount = (docs || []).length;
    $("as-docs").innerHTML = (docs && docs.length)
      ? docs.map((doc, i) => `<div class="as-doc cu-pop" style="--d:${(i * 0.05).toFixed(2)}s"><span class="cu-blob" style="--blob:#EDE9FE;width:36px;height:36px;color:#6D28D9">${fileSvg}</span><span><span class="nm" style="display:block">${esc(doc.file_name || T.documentFallback)}</span><span class="mt">${esc(tpl(T.uploadedOn, { date: fmtDate(doc.created_at) }))}</span></span><span class="as-pill">${esc((doc.file_type || T.fileFallback).toUpperCase())}</span></div>`).join("")
      : `<div class="as-emptybox"><span class="cu-blob" style="--blob:#EDE9FE;color:#6D28D9;width:34px;height:34px">${fileSvg}</span><p>${esc(T.docsEmpty)}</p><a href="/documents">${esc(T.uploadFirst)}</a></div>`;

    const recs = await restGet("assessments?select=id,assessment_type,provider,assessment_date,findings,recommendations&passport_id=eq." + p.id + "&order=assessment_date.desc.nullslast").catch(() => []);
    records = recs || [];
    renderRecords();
    renderHub();

    $("as-addbtn").addEventListener("click", () => { const f = $("as-form"); f.classList.toggle("show"); if (f.classList.contains("show")) $("as-provider").focus(); });
    $("as-cancel").addEventListener("click", () => { $("as-form").classList.remove("show"); $("as-err").textContent = ""; });
    $("as-save").addEventListener("click", saveRecord);
    $("as-copy").addEventListener("click", () => {
      const all = window.__asHubList || [];
      const txt = all.map((a, i) => (i + 1) + ". " + a.tx + " (" + a.src + ")").join("\n");
      navigator.clipboard.writeText(txt).then(() => {
        const b = $("as-copy"); const old = b.textContent;
        b.textContent = T.copied;
        setTimeout(() => { b.textContent = old; }, 1600);
      });
    });
  })().catch((e) => console.error("[assessments] hydrate failed", e));
</script>
