---
/* JOURNEY-V2 — the family roadmap, warmer and interactive:
   · Starts with the ROADMAP (no money-first): a stage stepper you can tap,
     stages as smooth accordions with the current one open
   · Every step shows its PROVENANCE — "From the passport: you answered
     'Limited Verbal' · no speech therapy on the team" — so the path is
     visibly built from THIS child's answers
   · Family-first ordering: understanding and the care team lead;
     funding and paperwork follow
   · The story timeline moved to Growth (where the memory lives). */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Journey" activeNav="child">
  <div class="c3-tabs"><SectionTabs section="child" active="journey" /></div>

  <div id="jy-gate"></div>

  <div id="jy-main" style="display:none;max-width:880px">

    <div class="c3-ribbon cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">The Journey</h1>
        <p id="rb-sub">A path built from your answers — one step at a time, in the order that helps most.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <!-- ============ STAGE STEPPER ============ -->
    <div class="jy-stepper cu-rev" id="jy-stepper" style="--d:.05s"></div>

    <!-- ============ ROADMAP ============ -->
    <div id="jy-road" class="cu-rev" style="--d:.1s"></div>

    <!-- ============ GENTLE FOOTER ============ -->
    <div class="jy-foot cu-rev cu-sparkle-host" style="--d:.15s">
      <span class="cu-spark" style="top:12px;right:24px">✦</span>
      <span class="cu-spark s2" style="top:28px;right:46px">✦</span>
      <p id="jy-foot-text">You don't have to do it all today — one step is enough. The path updates itself as the passport grows.</p>
      <a class="btn btn-ghost btn-sm" href="/child/growth">See how far you've come →</a>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  #jy-gate{max-width:880px}

  /* stepper */
  .jy-stepper{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:18px}
  .jy-tab{display:flex;align-items:center;gap:9px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:10px 12px;cursor:pointer;text-align:left;font-family:inherit;transition:border-color .15s,transform .15s,box-shadow .15s}
  .jy-tab:hover{border-color:#DDD6FE;transform:translateY(-1px)}
  .jy-tab.cur{border-color:#C4B5FD;box-shadow:0 6px 18px rgba(109,40,217,.12);background:linear-gradient(135deg,var(--violet-50),#fff 70%)}
  .jy-tab .n{width:28px;height:28px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#A78BFA,#6D28D9);color:#fff;display:grid;place-items:center;font-family:var(--display);font-weight:700;font-size:.78rem;flex-shrink:0}
  .jy-tab.all-done .n{background:var(--green-bg);color:var(--green)}
  .jy-tab .m{min-width:0}
  .jy-tab .t{display:block;font-size:.72rem;font-weight:700;color:var(--ink);line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .jy-tab .p{display:block;font-size:.62rem;color:var(--muted);margin-top:2px}
  .jy-tab .bar{display:block;height:4px;border-radius:3px;background:var(--bg);margin-top:5px;overflow:hidden}
  .jy-tab .bar b{display:block;height:100%;border-radius:3px;background:linear-gradient(90deg,#8B5CF6,#6D28D9);width:var(--w,0%)}
  @media (max-width:760px){.jy-stepper{grid-template-columns:1fr 1fr}}

  /* stage accordions */
  .jy-stage{background:var(--card);border:1px solid var(--line);border-radius:18px;box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;transition:border-color .2s,box-shadow .2s}
  .jy-stage.open{border-color:#DDD6FE;box-shadow:var(--shadow-lg)}
  .jy-shead{display:flex;align-items:center;gap:12px;padding:15px 18px;cursor:pointer}
  .jy-shead .n{width:34px;height:34px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#A78BFA,#6D28D9);color:#fff;display:grid;place-items:center;font-family:var(--display);font-weight:700;font-size:.9rem;flex-shrink:0;box-shadow:0 4px 12px rgba(109,40,217,.22)}
  .jy-stage.all-done .jy-shead .n{background:var(--green-bg);color:var(--green);box-shadow:none}
  .jy-shead .m{flex:1;min-width:0}
  .jy-shead b{font-family:var(--display);font-size:1.02rem;font-weight:700;color:var(--ink);display:block}
  .jy-shead .bl{font-size:.75rem;color:var(--muted);margin-top:2px;line-height:1.4;display:block}
  .jy-shead .pr{font-size:.68rem;font-weight:700;color:var(--violet-700);background:var(--violet-50);border-radius:9999px;padding:3px 10px;white-space:nowrap;flex-shrink:0}
  .jy-stage.all-done .jy-shead .pr{background:var(--green-bg);color:var(--green)}
  .jy-chev{color:var(--faint);transition:transform .25s cubic-bezier(.22,1,.36,1);flex-shrink:0}
  .jy-stage.open .jy-chev{transform:rotate(180deg)}
  .jy-bodywrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows .34s cubic-bezier(.22,1,.36,1)}
  .jy-stage.open .jy-bodywrap{grid-template-rows:1fr}
  .jy-body{overflow:hidden;padding:0 18px}
  .jy-stage.open .jy-body{padding-bottom:16px}
  .jy-steps{display:flex;flex-direction:column;gap:9px}

  /* steps */
  .jy-step{display:flex;gap:11px;align-items:flex-start;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:13px 15px;transition:border-color .15s,box-shadow .15s}
  .jy-step:hover{border-color:#DDD6FE;box-shadow:var(--shadow)}
  .jy-step.done{background:#FBFDFC;border-color:#E3F2EB}
  .jy-step.now{border-color:#C4B5FD;background:linear-gradient(135deg,#FDFCFF,#fff 55%);box-shadow:0 4px 14px rgba(109,40,217,.08)}
  .jy-step .bd{flex:1;min-width:0}
  .jy-step .tt{font-size:.88rem;font-weight:700;color:var(--ink);line-height:1.3}
  .jy-step.done .tt{color:var(--ink-2)}
  .jy-step .why{font-size:.78rem;color:var(--muted);margin-top:3px;line-height:1.5}
  .jy-step .because{display:inline-flex;align-items:flex-start;gap:6px;font-size:.7rem;color:#7c6bab;background:var(--violet-50);border:1px solid var(--violet-100);border-radius:10px;padding:5px 10px;margin-top:8px;line-height:1.4}
  .jy-step .because svg{flex-shrink:0;margin-top:1px}
  .jy-step .acts{display:flex;gap:12px;align-items:center;margin-top:9px;flex-wrap:wrap}
  .jy-step .cta{display:inline-flex;align-items:center;background:var(--violet-700);color:#fff;font-size:.74rem;font-weight:700;padding:6px 13px;border-radius:9999px;text-decoration:none;transition:filter .15s,transform .15s}
  .jy-step .cta:hover{filter:brightness(1.08);transform:translateY(-1px)}
  .jy-step.done .cta,.jy-step.later .cta{background:var(--card);color:var(--ink-2);border:1px solid var(--line-2)}
  .jy-step.done .cta:hover,.jy-step.later .cta:hover{color:var(--violet-700);border-color:var(--violet-500);filter:none}
  .jy-step .cta2{font-size:.74rem;font-weight:600;color:var(--muted);text-decoration:none}
  .jy-step .cta2:hover{color:var(--violet-700)}
  .jy-step .pill2{margin-left:auto;flex-shrink:0;font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:3px 9px;border-radius:9999px;white-space:nowrap}
  .jy-step .pill2.done{background:var(--green-bg);color:var(--green)}
  .jy-step .pill2.now{background:var(--violet-100);color:var(--violet-700)}
  .jy-step .pill2.next{background:var(--amber-bg);color:var(--amber)}
  .jy-step .pill2.later{background:var(--bg);color:var(--faint)}

  /* footer */
  .jy-foot{position:relative;display:flex;align-items:center;gap:14px;flex-wrap:wrap;background:linear-gradient(135deg,var(--violet-50),#F9F7FE 60%,#EFF9F6);border:1px solid var(--violet-100);border-radius:16px;padding:14px 18px;margin-top:6px}
  .jy-foot p{flex:1;font-size:.85rem;color:#5b21b6;line-height:1.5;margin:0;min-width:220px}
  .jy-foot .cu-spark{font-style:normal;font-size:12px;color:#8B5CF6}
  .jy-foot .cu-spark.s2{font-size:9px;color:#5EEAD4}
  .jy-gate-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:28px 22px;text-align:center}
  .jy-gate-card p{color:var(--muted);font-size:.9rem;margin:0 0 14px}
  .jy-gate-card a{display:inline-block;background:var(--violet-700);color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
  @media (prefers-reduced-motion:reduce){.jy-bodywrap{transition:none}.jy-chev{transition:none}}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../../lib/ua-data.js";
  import { scoreWheel } from "../../lib/wheelScore.js";
  import { buildJourney } from "../../lib/journey.js";

  const UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

  function getSession() { try { return JSON.parse(localStorage.getItem("ua_session") || "null"); } catch { return null; } }
  function isValid(s) { return s && s.access_token && Math.floor(Date.now() / 1000) < (s.expires_at || 0) - 60; }
  function authHeaders(t) { return { apikey: ANON, Authorization: "Bearer " + t, "Content-Type": "application/json" }; }
  async function getValidSession() {
    let s = getSession();
    if (isValid(s)) return s;
    if (s && s.refresh_token) {
      const r = await fetch(UA_URL + "/auth/v1/token?grant_type=refresh_token", { method: "POST", headers: { apikey: ANON, "Content-Type": "application/json" }, body: JSON.stringify({ refresh_token: s.refresh_token }) });
      if (r.ok) { const d = await r.json(); d.expires_at = Math.floor(Date.now() / 1000) + (d.expires_in || 3600); localStorage.setItem("ua_session", JSON.stringify(d)); return d; }
    }
    return s && s.access_token ? s : null;
  }
  async function restGet(path) { const s = await getValidSession(); if (!s) return []; const r = await fetch(UA_URL + "/rest/v1/" + path, { headers: authHeaders(s.access_token) }); return r.ok ? r.json() : []; }

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("jy-gate").innerHTML = `<div class="jy-gate-card"><p>The journey starts with the passport — a few minutes about your child, and a personalized path appears here.</p><a href="/passport">Start the passport →</a></div>`;
      return;
    }
    $("jy-main").style.display = "block";
    const data = p.data || {};
    const id = UA.childIdentity(data);
    const first = id.first || "";
    const scored = scoreWheel(data);

    $("rb-av").textContent = (first || id.name || "·")[0].toUpperCase();
    if (first) {
      $("rb-title").textContent = first + "'s Journey";
      $("jy-foot-text").textContent = "You don't have to do it all today — one step is enough. The path updates itself as " + first + "'s passport grows.";
    }

    /* ---------- context for the engine ---------- */
    const comp = UA.completion(data);
    const docs = await UA.getRecentDocuments(p.id).catch(() => []);
    const wl = await UA.getWaitlist().catch(() => []);
    const apps = await UA.getFundingApplications(p.id).catch(() => []);
    const fo = UA.fundingOverview(apps);
    let lastWinDays = null;
    try {
      const w = await restGet("wins?select=created_at&passport_id=eq." + p.id + "&order=created_at.desc&limit=1");
      if (w && w[0]) lastWinDays = Math.floor((Date.now() - new Date(w[0].created_at)) / 864e5);
    } catch (e) {}
    const daysSince = p.updated_at ? Math.floor((Date.now() - new Date(p.updated_at)) / 864e5) : null;

    const journey = buildJourney(data, scored, {
      firstName: first || "your child",
      passportLink: "/passport?id=" + p.id,
      completion: comp,
      docsCount: docs.length,
      onWaitlists: wl.length > 0,
      dtcStarted: fo.rows.some((r) => r.key === "dtc" && r.status !== "not_started"),
      fundingStarted: fo.started,
      daysSinceUpdate: daysSince,
      lastWinDays,
    });

    /* ---------- ribbon: personalized, warm ---------- */
    $("rb-sub").textContent = "Built from " + comp.done + " passport section" + (comp.done === 1 ? "" : "s") + (first ? " about " + first : "") + " — every step below exists because of something you told us.";
    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${journey.counts.done}</b><span>steps done</span></span>`,
      `<span class="c3-rstat"><b>${journey.counts.now}</b><span>to do now</span></span>`,
      `<span class="c3-rstat"><b>${journey.counts.later}</b><span>coming up</span></span>`,
    ].join("");

    /* ---------- stepper ---------- */
    const stepperHtml = journey.stages.map((st, si) => {
      const cur = st.key === journey.currentStage;
      const allDone = st.done === st.total;
      const pct = st.total ? Math.round((st.done / st.total) * 100) : 0;
      return `<button type="button" class="jy-tab${cur ? " cur" : ""}${allDone ? " all-done" : ""}" data-stage="${st.key}">
        <span class="n">${allDone ? "✓" : si + 1}</span>
        <span class="m"><span class="t">${esc(st.title)}</span><span class="p">${st.done}/${st.total} done${cur ? " · you are here" : ""}</span><span class="bar"><b style="--w:${pct}%"></b></span></span>
      </button>`;
    }).join("");
    $("jy-stepper").innerHTML = stepperHtml;

    /* ---------- roadmap (interactive accordions) ---------- */
    const DOT = {
      done: `<span class="c3-dot done"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M3 8.5l3.2 3L13 4.5"/></svg></span>`,
      now: `<span class="c3-dot now"><svg viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="3.5"/></svg></span>`,
      next: `<span class="c3-dot next"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>`,
      later: `<span class="c3-dot later"><svg viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="2.5"/></svg></span>`,
    };
    const becauseIc = `<svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M8 10.5V7.2M8 5v-.2"/><circle cx="8" cy="8" r="6.2"/></svg>`;
    $("jy-road").innerHTML = journey.stages.map((st, si) => {
      const open = st.key === journey.currentStage;
      const allDone = st.done === st.total;
      const stepsHtml = st.steps.map((s) => `
        <div class="jy-step ${s.status}">
          ${DOT[s.status]}
          <div class="bd">
            <div class="tt">${esc(s.title)}</div>
            <div class="why">${esc(s.why)}</div>
            ${s.because ? `<span class="because">${becauseIc}<span>From the passport: ${esc(s.because)}</span></span>` : ""}
            <div class="acts">
              <a class="cta" href="${s.href}">${esc(s.cta)}</a>
              ${s.also ? `<a class="cta2" href="${s.also.href}">${esc(s.also.label)} →</a>` : ""}
            </div>
          </div>
          <span class="pill2 ${s.status}">${s.status === "done" ? "Done ✓" : s.status === "now" ? "Now" : s.status === "next" ? "Next" : "Later"}</span>
        </div>`).join("");
      return `<div class="jy-stage${open ? " open" : ""}${allDone ? " all-done" : ""}" data-stage="${st.key}">
        <div class="jy-shead" role="button" tabindex="0" aria-expanded="${open ? "true" : "false"}">
          <span class="n">${allDone ? "✓" : si + 1}</span>
          <span class="m"><b>${esc(st.title)}</b><span class="bl">${esc(st.blurb)}</span></span>
          <span class="pr">${st.done}/${st.total}</span>
          <svg class="jy-chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </div>
        <div class="jy-bodywrap"><div class="jy-body"><div class="jy-steps">${stepsHtml}</div></div></div>
      </div>`;
    }).join("");

    /* accordion + stepper wiring */
    const stagesEls = Array.from(document.querySelectorAll(".jy-stage"));
    stagesEls.forEach((el) => {
      const head = el.querySelector(".jy-shead");
      const toggle = () => {
        el.classList.toggle("open");
        head.setAttribute("aria-expanded", el.classList.contains("open") ? "true" : "false");
      };
      head.addEventListener("click", toggle);
      head.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggle(); } });
    });
    document.querySelectorAll(".jy-tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const el = stagesEls.find((x) => x.dataset.stage === tab.dataset.stage);
        if (!el) return;
        if (!el.classList.contains("open")) {
          el.classList.add("open");
          el.querySelector(".jy-shead").setAttribute("aria-expanded", "true");
        }
        el.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  })().catch((e) => console.error("[journey] hydrate failed", e));
</script>
