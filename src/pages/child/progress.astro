---
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Progress" activeNav="child">
  <SectionTabs section="child" active="progress" />

  <h1 class="page-title">Progress</h1>
  <p class="page-sub">A place to see growth and celebrate the wins — big and small.</p>

  <div id="pg-gate"></div>

  <div id="pg-main" style="display:none">
    <div class="pg-sec">
      <p class="pg-h">Milestones reached</p>
      <div class="pg-ms" id="pg-ms"></div>
    </div>

    <div class="pg-sec">
      <p class="pg-h">Wins journal <button class="pg-addbtn" id="pg-addbtn"><span style="font-size:1.1em;line-height:1">+</span> Add a win</button></p>
      <div class="pg-form" id="pg-form">
        <input type="text" id="pg-input" class="pg-field" placeholder="Something that went well…" />
        <button class="pg-savebtn" id="pg-save">Save</button>
      </div>
      <div id="pg-wins"></div>
    </div>

    <div class="pg-sec" style="margin-bottom:0">
      <p class="pg-h">Growth over time</p>
      <div class="pg-chart" id="pg-chart"></div>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  #pg-main, #pg-gate{max-width:820px}
  .pg-sec{margin-bottom:24px}
  .pg-h{font-size:.84rem;color:#64748b;margin:0 0 12px;display:flex;align-items:center;justify-content:space-between;gap:8px;font-weight:600}
  .pg-ms{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px}
  .pg-mcard{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:12px;display:flex;gap:10px;align-items:center}
  a.pg-miss{border-style:dashed;background:#fbfcfe;text-decoration:none}
  a.pg-miss:hover{background:#f5f3ff;border-color:#c4b5fd}
  .pg-mic{width:34px;height:34px;border-radius:9px;background:#ECFDF5;color:#15803d;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .pg-mname{font-size:.84rem;font-weight:600;color:#1e293b}
  .pg-mwhen{font-size:.78rem;color:#64748b}
  .pg-addbtn{font-size:.82rem;font-weight:600;padding:7px 14px;border-radius:9999px;border:1px solid #6d28d9;background:#fff;color:#6d28d9;cursor:pointer;display:inline-flex;align-items:center;gap:6px}
  .pg-addbtn:hover{background:#F5F3FF}
  .pg-form{display:none;gap:8px;margin-bottom:12px}
  .pg-form.show{display:flex}
  .pg-field{flex:1;padding:9px 12px;border:1px solid #e2e8f0;border-radius:10px;font-size:.88rem;color:#1e293b;background:#fff;outline:none}
  .pg-field:focus{border-color:#a78bfa;box-shadow:0 0 0 2px #ede9fe}
  .pg-savebtn{font-size:.82rem;font-weight:600;padding:8px 16px;border-radius:9999px;border:none;background:#6d28d9;color:#fff;cursor:pointer;white-space:nowrap}
  .pg-savebtn:hover{background:#5b21b6}
  .pg-win{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:11px 14px;display:flex;gap:11px;align-items:flex-start;margin-bottom:8px;position:relative}
  .pg-wic{color:#16a34a;flex-shrink:0;margin-top:1px}
  .pg-wtext{font-size:.9rem;color:#1e293b;flex:1;padding-right:18px}
  .pg-wdate{font-size:.74rem;color:#94a3b8;white-space:nowrap}
  .pg-del{position:absolute;top:8px;right:10px;border:none;background:none;color:#cbd5e1;font-size:1.05rem;line-height:1;cursor:pointer;padding:2px}
  .pg-del:hover{color:#dc2626}
  .pg-chart{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:18px 16px}
  .pg-empty{font-size:.86rem;color:#94a3b8;margin:0}
  .pg-empty a{color:#6d28d9;font-weight:600;text-decoration:none}
  .pg-chart-empty{text-align:center;padding:18px 10px}
  .pg-chart-empty .ic{color:#cbd5e1;margin-bottom:8px}
  .pg-chart-empty p{font-size:.86rem;color:#94a3b8;margin:0;line-height:1.5}
  .pg-gate-card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:28px 22px;text-align:center}
  .pg-gate-card p{color:#64748b;font-size:.9rem;margin:0 0 14px}
  .pg-gate-card a{display:inline-block;background:#6d28d9;color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../../lib/ua-data.js";
  import { scoreWheel, DOMAINS, scoreToBand } from "../../lib/wheelScore.js";

  const UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const present = (v) => v != null && v !== "";
  const SHORT = { "Communication": "Communication", "Social Connection": "Social", "Sensory Processing": "Sensory", "Flexibility & Transitions": "Flexibility", "Emotional Regulation": "Emotional", "Executive Function": "Executive", "Daily Living Skills": "Daily living", "Learning & Play": "Learning & play" };
  const barColor = (sc) => { if (sc == null) return "#cbd5e1"; const k = scoreToBand(sc).key; return (k === "minimal" || k === "low") ? "#16a34a" : k === "moderate" ? "#d97706" : "#7c3aed"; };

  function getSession() { try { return JSON.parse(localStorage.getItem("ua_session") || "null"); } catch { return null; } }
  function isValid(s) { return s && s.access_token && Math.floor(Date.now() / 1000) < (s.expires_at || 0) - 60; }
  function authHeaders(t) { return { apikey: ANON, Authorization: "Bearer " + t, "Content-Type": "application/json" }; }
  async function getValidSession() {
    let s = getSession();
    if (isValid(s)) return s;
    if (s && s.refresh_token) {
      const r = await fetch(UA_URL + "/auth/v1/token?grant_type=refresh_token", { method: "POST", headers: { apikey: ANON, "Content-Type": "application/json" }, body: JSON.stringify({ refresh_token: s.refresh_token }) });
      if (r.ok) { const d = await r.json(); d.expires_at = Math.floor(Date.now() / 1000) + (d.expires_in || 3600); localStorage.setItem("ua_session", JSON.stringify(d)); return d; }
    }
    return s && s.access_token ? s : null;
  }
  async function restGet(path) { const s = await getValidSession(); if (!s) return []; const r = await fetch(UA_URL + "/rest/v1/" + path, { headers: authHeaders(s.access_token) }); return r.ok ? r.json() : []; }

  const MIC = {
    sit: '<path d="M5 12h6M8 12V7M5 7h6"/>',
    crawl: '<circle cx="6" cy="6" r="1.4"/><path d="M3 12c1-2 3-3 5-3s2-2 4-2"/>',
    walk: '<circle cx="9" cy="3.5" r="1.3"/><path d="M9 5l-1.2 3 2 1 1 3M7.8 8L6 9"/>',
    firstWord: '<path d="M3.5 4h9v6H6l-2.5 2z"/>',
    phrases: '<path d="M3 4h7v5H5.5L3.5 11V9H3z"/><path d="M7 9.5h6V5"/>',
    sentences: '<path d="M3 4h7v5H5.5L3.5 11V9H3z"/><path d="M7 9.5h6V5"/>',
    toiletDay: '<path d="M8 3s4 4 4 6.4A4 4 0 0 1 4 9.4C4 7 8 3 8 3z"/>',
    toiletNight: '<path d="M11 9.5A4 4 0 1 1 7 4a3.2 3.2 0 0 0 4 5.5z"/>',
  };
  const starSvg = '<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.6l1.7 4.4 4.6.4-3.5 3 .9 4.5L8 11.9 3.8 14.3l.9-4.5L1.2 6.4l4.6-.4z"/></svg>';

  let wins = [], activeP = null;

  function renderWins() {
    if (!wins.length) { $("pg-wins").innerHTML = `<p class="pg-empty">No wins recorded yet — add the first one above. Every small step counts.</p>`; return; }
    $("pg-wins").innerHTML = wins.map((w) => `<div class="pg-win"><span class="pg-wic">${starSvg}</span><span class="pg-wtext">${esc(w.text)}</span><span class="pg-wdate">${esc(w.when)}</span><button class="pg-del" data-id="${w.id}" aria-label="Delete win">×</button></div>`).join("");
    $("pg-wins").querySelectorAll(".pg-del").forEach((b) => b.addEventListener("click", () => delWin(b.dataset.id)));
  }

  async function delWin(id) {
    if (!confirm("Remove this win?")) return;
    const s = await getValidSession(); if (!s) return;
    const r = await fetch(UA_URL + "/rest/v1/wins?id=eq." + id, { method: "DELETE", headers: authHeaders(s.access_token) });
    if (r.ok) { wins = wins.filter((w) => w.id !== id); renderWins(); }
  }

  async function saveWin() {
    const v = $("pg-input").value.trim(); if (!v) return;
    const btn = $("pg-save"); btn.disabled = true; btn.textContent = "Saving…";
    const s = await getValidSession(); if (!s) { location.href = "/login"; return; }
    try {
      const r = await fetch(UA_URL + "/rest/v1/wins", { method: "POST", headers: Object.assign({}, authHeaders(s.access_token), { Prefer: "return=representation" }), body: JSON.stringify({ user_id: s.user.id, passport_id: activeP.id, text: v }) });
      if (r.ok) {
        const rows = await r.json(), row = rows && rows[0];
        wins.unshift({ id: row ? row.id : Date.now(), text: v, when: "Just now" });
        $("pg-input").value = ""; $("pg-form").classList.remove("show"); renderWins();
      }
    } catch (e) { /* leave input for retry */ }
    btn.disabled = false; btn.textContent = "Save";
  }

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("pg-gate").innerHTML = `<div class="pg-gate-card"><p>Create your child's passport to start tracking progress.</p><a href="/passport">Start the passport →</a></div>`;
      return;
    }
    activeP = p;
    $("pg-main").style.display = "block";
    const data = p.data || {};

    const ms = (data.birth && data.birth.milestones) || {};
    const MLAB = { sit: "Sat unsupported", crawl: "Crawled", walk: "Walked", firstWord: "First words", phrases: "First phrases", sentences: "First sentences", toiletDay: "Toilet trained (day)", toiletNight: "Toilet trained (night)" };
    const naLike = (v) => /^(n\/?a|na|-+|none|\?+)$/i.test(String(v).trim());
    const recKeys = Object.keys(MLAB).filter((k) => present(ms[k]) && !naLike(ms[k]));
    const missing = Object.keys(MLAB).length - recKeys.length;
    const mItems = recKeys.map((k) => ({ name: MLAB[k], when: "around " + ms[k], ic: MIC[k] || MIC.firstWord }));
    let msHtml = mItems.map((m) => `<div class="pg-mcard"><span class="pg-mic"><svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${m.ic}</svg></span><span><span class="pg-mname" style="display:block">${esc(m.name)}</span><span class="pg-mwhen">${esc(m.when)}</span></span></div>`).join("");
    if (missing > 0) msHtml += `<a class="pg-mcard pg-miss" href="/passport?id=${p.id}"><span class="pg-mic" style="background:#f1f5f9;color:#94a3b8"><svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M8 4v8M4 8h8"/></svg></span><span><span class="pg-mname" style="display:block;color:#64748b">${missing} more to record</span><span class="pg-mwhen">Add ages in the passport →</span></span></a>`;
    $("pg-ms").innerHTML = (mItems.length || missing)
      ? msHtml
      : `<p class="pg-empty">No milestones recorded yet. <a href="/passport?id=${p.id}">Add them in the passport →</a></p>`;

    const w = await restGet("wins?select=id,text,created_at&passport_id=eq." + p.id + "&order=created_at.desc").catch(() => []);
    wins = (w || []).map((x) => ({ id: x.id, text: x.text, when: UA.relTime(x.created_at) }));
    renderWins();

    const first = UA.childIdentity(data).first || "your child";
    const scored = scoreWheel(data);
    const scoredCount = DOMAINS.filter((n) => scored[n].score != null).length;
    if (scoredCount < 3) {
      $("pg-chart").innerHTML = `<div class="pg-chart-empty"><div class="ic"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 19V5M4 19h16M8 15l3-4 3 2 4-6"/></svg></div><p>This fills in once more of the passport is completed (communication, sensory, behaviour, daily living).</p></div>`;
    } else {
      const rows = DOMAINS.map((n) => { const sc = scored[n].score, w = sc == null ? 0 : sc; return `<div style="display:flex;align-items:center;gap:10px;margin-bottom:9px"><span style="font-size:.8rem;width:104px;flex-shrink:0;color:#64748b">${esc(SHORT[n] || n)}</span><span style="flex:1;height:9px;border-radius:5px;background:#eef2f7;position:relative;overflow:hidden"><span style="position:absolute;left:0;top:0;bottom:0;width:${w}%;background:${barColor(sc)};border-radius:5px"></span></span></div>`; }).join("");
      $("pg-chart").innerHTML = `<p style="font-size:.8rem;color:#64748b;margin:0 0 14px">Where things stand today — a fuller bar means more support is helpful right now.</p>${rows}<p class="pg-cap" style="margin-top:14px">This becomes a trend chart as ${esc(first)}'s profile is updated over time.</p>`;
    }

    $("pg-addbtn").addEventListener("click", () => { const f = $("pg-form"); f.classList.toggle("show"); if (f.classList.contains("show")) $("pg-input").focus(); });
    $("pg-save").addEventListener("click", saveWin);
    $("pg-input").addEventListener("keydown", (e) => { if (e.key === "Enter") saveWin(); });
  })().catch((e) => console.error("[progress] hydrate failed", e));
</script>