---
/* STRENGTHS-V2 — visual redesign: strengths as icon cards (shared keyword→
   icon dictionary, star fallback), growth-opportunity cards that link into
   the Support Wheel's strategies, gradient insights panel with sparkles.
   Data logic unchanged. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Strengths & Challenges" activeNav="child">
  <SectionTabs section="child" active="strengths" />

  <h1 class="page-title">Strengths & Challenges</h1>
  <p class="page-sub">What makes your child shine — and the areas they're growing in, framed as opportunities.</p>

  <div id="sc-gate"></div>

  <div id="sc-main" style="display:none">
    <div class="sc-sec cu-rev">
      <p class="sc-h"><span class="sc-hdot" style="background:#0E8F66"></span><span id="sc-strs-title">Strengths</span></p>
      <div class="sc-strs" id="sc-strs"></div>
    </div>

    <div class="sc-sec cu-rev" style="--d:.1s">
      <p class="sc-h"><span class="sc-hdot" style="background:#7C3AED"></span>Growth opportunities</p>
      <p class="sc-subh">Tap any card to see strategies that help in the Support Wheel.</p>
      <div class="sc-opps" id="sc-opps"></div>
    </div>

    <div class="sc-sec cu-rev" style="--d:.18s;margin-bottom:0">
      <div class="sc-card sc-insights cu-sparkle-host">
        <span class="cu-spark" style="top:14px;right:22px">✦</span>
        <span class="cu-spark s2" style="top:34px;right:44px">✦</span>
        <p class="sc-ins-title"><svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg> Pattern insights</p>
        <div id="sc-ins"></div>
        <p class="sc-note">Warm observations from the passport — not medical advice.</p>
      </div>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  #sc-main, #sc-gate{max-width:900px}
  .sc-sec{margin-bottom:24px}
  .sc-h{font-family:var(--display);font-size:.98rem;font-weight:700;color:var(--ink);margin:0 0 12px;display:flex;align-items:center;gap:9px}
  .sc-hdot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
  .sc-subh{font-size:.76rem;color:var(--faint);margin:-8px 0 12px 19px}
  .sc-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:18px 20px;box-shadow:var(--shadow)}
  .sc-strs{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px}
  .sc-str{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 10px 13px;text-align:center;box-shadow:var(--shadow);transition:transform .16s,box-shadow .16s,border-color .16s}
  .sc-str:hover{transform:translateY(-3px);box-shadow:0 10px 24px rgba(14,143,102,.14);border-color:#BBE8D5}
  .sc-str .t{font-size:.83rem;font-weight:600;color:var(--ink);margin-top:8px;line-height:1.3;overflow-wrap:break-word;padding:0 4px}
  .sc-opps{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:10px}
  .sc-opp{display:flex;gap:12px;align-items:flex-start;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:14px 16px;text-decoration:none;box-shadow:var(--shadow);transition:transform .16s,box-shadow .16s,border-color .16s}
  a.sc-opp:hover{transform:translateY(-3px);box-shadow:0 10px 24px rgba(109,40,217,.14);border-color:#DDD6FE}
  .sc-opp .t{font-size:.9rem;font-weight:600;color:var(--ink)}
  .sc-opp .s{font-size:.82rem;color:var(--muted);margin-top:3px;line-height:1.45}
  .sc-opp .go{margin-left:auto;color:var(--violet-700);font-weight:700;opacity:0;transform:translateX(-4px);transition:opacity .18s,transform .18s;flex-shrink:0;align-self:center}
  a.sc-opp:hover .go{opacity:1;transform:none}
  .sc-insights{position:relative;background:linear-gradient(135deg,var(--violet-50),#F9F7FE 55%,var(--violet-50));border-color:var(--violet-100)}
  .sc-insights .cu-spark{font-style:normal;font-size:13px;color:#8B5CF6}
  .sc-insights .cu-spark.s2{font-size:10px;color:#5EEAD4}
  .sc-ins-title{display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:700;color:var(--violet-700);margin:0 0 10px}
  .sc-ins-li{display:flex;gap:9px;align-items:flex-start;font-size:.9rem;line-height:1.5;color:#5b21b6;margin-bottom:8px}
  .sc-ins-li .dot{width:6px;height:6px;border-radius:50%;background:var(--violet-600);margin-top:7px;flex-shrink:0}
  .sc-note{font-size:.72rem;color:#9d8bc4;margin:4px 0 0}
  .sc-empty{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:18px;font-size:.86rem;color:var(--faint)}
  .sc-empty a{color:var(--violet-700);font-weight:600;text-decoration:none}
  .sc-good{background:var(--green-bg);border:1px solid #BBE8D5;border-radius:14px;padding:16px 18px;font-size:.88rem;color:var(--green)}
  .sc-gate-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:28px 22px;text-align:center}
  .sc-gate-card p{color:var(--muted);font-size:.9rem;margin:0 0 14px}
  .sc-gate-card a{display:inline-block;background:var(--violet-700);color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../../lib/ua-data.js";
  import { scoreWheel, DOMAINS } from "../../lib/wheelScore.js";
  import { iconFor } from "../../lib/interestIcons.js";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const lc = (s) => String(s || "").toLowerCase();
  const cap = (s) => { s = String(s || ""); return s.charAt(0).toUpperCase() + s.slice(1); };
  const clean = (s) => cap(String(s || "").trim().replace(/[.,;:!]+$/, ""));
  const uniq = (a) => [...new Set(a)];
  const textToList = (s) => String(s || "").split(/[,\n;•]+/).map((x) => x.trim()).filter(Boolean);
  const listPhrase = (arr) => { arr = arr.filter(Boolean); if (!arr.length) return ""; if (arr.length === 1) return arr[0]; if (arr.length === 2) return arr[0] + " and " + arr[1]; return arr.slice(0, -1).join(", ") + ", and " + arr[arr.length - 1]; };
  const SHORT = { "Communication": "communication", "Social Connection": "social connection", "Sensory Processing": "sensory processing", "Flexibility & Transitions": "flexibility", "Emotional Regulation": "emotional regulation", "Executive Function": "focus and planning", "Daily Living Skills": "daily living", "Learning & Play": "learning and play" };

  const upSvg = '<svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11L11 4M11 4H6M11 4v5"/></svg>';

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("sc-gate").innerHTML = `<div class="sc-gate-card"><p>Create your child's passport to see their strengths and growth areas.</p><a href="/passport">Start the passport →</a></div>`;
      return;
    }
    $("sc-main").style.display = "block";
    const d = p.data || {};
    const scored = scoreWheel(d);
    const id = UA.childIdentity(d);
    const first = id.first || "Your child";
    const passportLink = "/passport?id=" + p.id;
    $("sc-strs-title").textContent = first + " shines at";

    /* ---- strengths as icon cards ---- */
    const str = [];
    textToList(d.strengths && d.strengths.strengths).forEach((x) => str.push(clean(x)));
    textToList(d.strengths && d.strengths.interests).forEach((x) => { if (str.length < 12) str.push("Loves " + lc(clean(x))); });
    const c = d.communication || {};
    if (c.style === "Fluent Verbal" || c.style === "Verbal") str.push("Communicates verbally");
    if (c.canExpressNeeds === "Consistently") str.push("Expresses needs clearly");
    const dl = d.dailyLiving || {};
    if (dl.eating === "Independent") str.push("Independent with eating");
    if (dl.dressing === "Independent") str.push("Independent with dressing");
    if (dl.toileting === "Fully trained") str.push("Toilet trained");
    if ((d.behaviour || {}).peersInterest === "Yes") str.push("Interested in other children");
    DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 55).sort((a, b) => scored[b].strength - scored[a].strength).forEach((n) => { if (str.length < 12) str.push("Strong " + SHORT[n]); });
    const strengths = uniq(str).slice(0, 10);
    $("sc-strs").innerHTML = strengths.length
      ? strengths.map((s, i) => `<div class="sc-str cu-pop" style="--d:${(0.05 + i * 0.05).toFixed(2)}s"><span class="cu-blob" style="--blob:#E8F6F0;margin:0 auto;color:#0E8F66">${iconFor(s)}</span><span class="t" style="display:block">${esc(s)}</span></div>`).join("")
      : `<div class="sc-empty">No strengths recorded yet. <a href="${passportLink}">Add ${esc(first)}'s strengths and interests →</a></div>`;

    /* ---- growth opportunities (cards link into the wheel's strategies) ---- */
    const DOMOPP = {
      "Communication": ["Strengthening communication", "Building more ways to share thoughts and needs"],
      "Social Connection": ["Growing friendships", "Building back-and-forth play and connection"],
      "Sensory Processing": ["Finding sensory strategies", "Discovering what helps them feel regulated"],
      "Flexibility & Transitions": ["Growing with change", "Building comfort with transitions and new routines"],
      "Emotional Regulation": ["Managing big feelings", "Developing tools to calm and recover"],
      "Executive Function": ["Building focus and planning", "Growing attention, organization and follow-through"],
      "Daily Living Skills": ["Building daily independence", "Growing confidence with everyday routines"],
      "Learning & Play": ["Expanding learning and play", "Building on natural curiosity and interests"],
    };
    const opps = [];
    DOMAINS.filter((n) => scored[n].score != null && scored[n].score >= 50).sort((a, b) => scored[b].score - scored[a].score).slice(0, 4).forEach((n) => { const o = DOMOPP[n]; if (o) opps.push({ t: o[0], s: o[1], domain: n }); });
    const cm = { "Requesting": ["Asking for help", "Building confidence to ask for what they need", "Communication"], "Conversation": ["Back-and-forth conversation", "Growing turn-taking and connection in chat", "Communication"] };
    ((c.challenges) || []).forEach((x) => { if (cm[x] && opps.length < 6) opps.push({ t: cm[x][0], s: cm[x][1], domain: cm[x][2] }); });
    $("sc-opps").innerHTML = opps.length
      ? opps.slice(0, 6).map((o, i) => {
          const inner = `<span class="cu-blob" style="--blob:#EDE9FE;width:38px;height:38px;color:#6D28D9">${upSvg}</span><span style="min-width:0"><span class="t" style="display:block">${esc(o.t)}</span><span class="s" style="display:block">${esc(o.s)}</span></span><span class="go">→</span>`;
          return o.domain
            ? `<a class="sc-opp cu-pop" style="--d:${(0.08 + i * 0.06).toFixed(2)}s" href="/child/support-wheel?domain=${encodeURIComponent(o.domain)}" title="See strategies for ${esc(o.t.toLowerCase())}">${inner}</a>`
            : `<div class="sc-opp cu-pop" style="--d:${(0.08 + i * 0.06).toFixed(2)}s">${inner}</div>`;
        }).join("")
      : `<div class="sc-good">No specific support areas are flagged right now — a lovely place to be. Keep celebrating the wins.</div>`;

    /* ---- pattern insights ---- */
    const needs = DOMAINS.filter((n) => scored[n].score != null).sort((a, b) => scored[b].score - scored[a].score);
    const ins = [];
    if (needs.length >= 3) {
      const shineD = DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 45).sort((a, b) => scored[b].strength - scored[a].strength);
      const shine = (shineD.length ? shineD : needs.slice().reverse()).slice(0, 2).map((n) => SHORT[n]);
      const grow = needs.slice(0, 2).map((n) => SHORT[n]);
      ins.push(cap(first) + " shines in " + listPhrase(shine) + ", and is growing in " + listPhrase(grow) + ".");
    }
    const interests = textToList(d.strengths && d.strengths.interests);
    if (interests.length) ins.push(cap(first) + " engages most when learning is built around " + listPhrase(interests.slice(0, 3).map(lc)) + ".");
    const sen = d.sensory || {};
    if (["auditory", "visual", "tactile", "oral", "smell", "movement", "body"].some((k) => sen[k] && sen[k].signs && sen[k].signs.length))
      ins.push("Visual supports and predictable routines tend to help most, alongside small sensory-friendly adjustments.");
    $("sc-ins").innerHTML = ins.length
      ? ins.map((t, i) => `<div class="sc-ins-li cu-pop" style="--d:${(0.1 + i * 0.08).toFixed(2)}s"><span class="dot"></span><span>${esc(t)}</span></div>`).join("")
      : `<p style="font-size:.86rem;color:#9d8bc4;margin:0">Complete more of the passport to see patterns for ${esc(first)}.</p>`;
  })().catch((e) => console.error("[strengths] hydrate failed", e));
</script>
