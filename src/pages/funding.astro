---
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
import AiPanel from "@/components/AiPanel.astro";
import "@/styles/mock.css";
---
<AppFormLayout title="Funding" activeNav="funding">
  <SectionTabs section="funding" active="opportunities" />
  <h1 class="page-title">Funding Opportunities</h1>
  <p class="page-sub">Programs, credits and benefits your family may be eligible for in Québec.</p>

  <AiPanel section="funding" />

  <div class="mk-grid">
    <div class="mk-card"><h3>Disability Tax Credit</h3><p>Federal &amp; Québec credit for eligible families.</p><div class="mk-meta"><span class="mk-tag amt">up to $3,000/yr</span><span class="mk-tag warn">Not applied</span></div></div>
    <div class="mk-card"><h3>Supplement for Handicapped Children</h3><p>Retraite Québec monthly supplement.</p><div class="mk-meta"><span class="mk-tag amt">$229/mo</span><span class="mk-tag">Likely eligible</span></div></div>
    <div class="mk-card"><h3>Exceptional Care Supplement</h3><p>For children with exceptional needs.</p><div class="mk-meta"><span class="mk-tag amt">$1,158/mo</span><span class="mk-tag muted">Check eligibility</span></div></div>
    <div class="mk-card"><h3>Respite &amp; Répit Funding</h3><p>Support for family caregivers.</p><div class="mk-meta"><span class="mk-tag">Regional</span></div></div>
  </div>
</AppFormLayout>
