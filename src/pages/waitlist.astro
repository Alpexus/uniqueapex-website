---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Join the Waitlist">
  <Container>

    <!-- Hero -->
    <div class="text-center max-w-3xl mx-auto mt-16 mb-16">
      <p class="text-2xl font-semibold text-violet-700 uppercase tracking-wide">Join the Waitlist</p>
      <h1 class="text-5xl font-bold text-slate-800 leading-tight mt-3">
        Be among the first <span class="text-violet-700">families in Montréal</span>
      </h1>
      <p class="text-slate-600 leading-relaxed text-lg mt-6">
        UniqueApex is launching its pilot in Montréal. Join the waitlist and we will reach out as soon as access opens in your area.
      </p>
    </div>

    <!-- Form -->
    <div class="max-w-2xl mx-auto mb-24">
      <form
        id="waitlist-form"
        class="space-y-6"
        novalidate>

        <!-- About You -->
        <div class="bg-slate-50 rounded-2xl p-8 space-y-4">
          <h2 class="text-lg font-bold text-slate-800">About you</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <input
                type="text"
                name="full_name"
                placeholder="Full Name"
                class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
              />
              <p id="error-full_name" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
            <div>
              <input
                type="email"
                name="email"
                placeholder="Email Address"
                class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
              />
              <p id="error-email" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
          </div>
          <input
            type="tel"
            name="phone"
            placeholder="Phone Number (optional)"
            class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
          />
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-3">Preferred Language</label>
            <div class="flex gap-6">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="language" value="English" class="accent-violet-700" />
                <span class="text-slate-600">English</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="language" value="French" class="accent-violet-700" />
                <span class="text-slate-600">French</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="language" value="Both" class="accent-violet-700" />
                <span class="text-slate-600">Both</span>
              </label>
            </div>
            <p id="error-language" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
          </div>
        </div>

        <!-- About Your Child -->
        <div class="bg-slate-50 rounded-2xl p-8 space-y-4">
          <h2 class="text-lg font-bold text-slate-800">About your child</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <select
                name="child_age"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 text-slate-500 bg-white">
                <option value="" disabled selected>Age Range</option>
                <option value="0-3">0 – 3 years</option>
                <option value="4-6">4 – 6 years</option>
                <option value="7-10">7 – 10 years</option>
                <option value="11+">11 years and older</option>
              </select>
              <p id="error-child_age" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
            <div>
              <select
                name="diagnosis"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 text-slate-500 bg-white">
                <option value="" disabled selected>Area of Concern</option>
                <option value="Autism">Autism</option>
                <option value="ADHD">ADHD</option>
                <option value="Speech delay">Speech delay</option>
                <option value="Language delay">Language delay</option>
                <option value="Developmental delay">Developmental delay</option>
                <option value="Other">Other</option>
              </select>
              <p id="error-diagnosis" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-3">Services Needed</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_slp" value="Speech-Language Therapy" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Speech-Language Therapy</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_ot" value="Occupational Therapy" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Occupational Therapy</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_aba" value="Behavioural Therapy" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Behavioural Therapy</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_other" value="Other" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Other</span>
              </label>
            </div>
            <p id="error-services" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
          </div>
        </div>

        <!-- Location & Additional -->
        <div class="bg-slate-50 rounded-2xl p-8 space-y-4">
          <h2 class="text-lg font-bold text-slate-800">Location & additional info</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <input
                type="text"
                name="location"
                placeholder="City / Borough in Montréal"
                class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
              />
              <p id="error-location" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
            <select
              name="referral"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 text-slate-500 bg-white">
              <option value="" disabled selected>How did you hear about us?</option>
              <option value="Social media">Social media</option>
              <option value="Google">Google</option>
              <option value="Friend or family">Friend or family</option>
              <option value="Healthcare provider">Healthcare provider</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <textarea
            name="additional_info"
            placeholder="Anything else you'd like us to know? (optional)"
            class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none h-32 focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
          ></textarea>
        </div>

        <!-- Submit -->
        <div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-4 px-8 rounded-full transition-colors duration-200 text-lg">
            Join the Waitlist
          </button>
          <p class="text-slate-400 text-sm text-center mt-4">We will never share your information. You can unsubscribe at any time.</p>
          <div id="waitlist-result" class="mt-4 text-center"></div>
        </div>

      </form>
    </div>

  </Container>
</Layout>

<script is:inline>
  const SUPABASE_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";

  var form = document.getElementById("waitlist-form");
  var result = document.getElementById("waitlist-result");
  var submitBtn = document.getElementById("submit-btn");

  function showError(id, msg) {
    var el = document.getElementById(id);
    if (el) {
      el.textContent = msg;
      el.style.display = "block";
    }
  }

  function clearErrors() {
    var ids = ["error-full_name","error-email","error-language","error-child_age","error-diagnosis","error-services","error-location"];
    for (var i = 0; i < ids.length; i++) {
      var el = document.getElementById(ids[i]);
      if (el) { el.textContent = ""; el.style.display = "none"; }
    }
  }

  form.addEventListener("submit", function(e) {
    e.preventDefault();
    e.stopPropagation();
    clearErrors();

    var formData = new FormData(form);
    var valid = true;

    var fullName = formData.get("full_name");
    if (!fullName || fullName.trim() === "") {
      showError("error-full_name", "Please enter your full name.");
      valid = false;
    }

    var email = formData.get("email");
    if (!email || email.trim() === "" || email.indexOf("@") === -1) {
      showError("error-email", "Please enter a valid email address.");
      valid = false;
    }

    var language = formData.get("language");
    if (!language) {
      showError("error-language", "Please select a preferred language.");
      valid = false;
    }

    var childAge = formData.get("child_age");
    if (!childAge) {
      showError("error-child_age", "Please select an age range.");
      valid = false;
    }

    var diagnosis = formData.get("diagnosis");
    if (!diagnosis) {
      showError("error-diagnosis", "Please select an area of concern.");
      valid = false;
    }

    var slp = formData.get("service_slp");
    var ot = formData.get("service_ot");
    var aba = formData.get("service_aba");
    var other = formData.get("service_other");
    if (!slp && !ot && !aba && !other) {
      showError("error-services", "Please select at least one service.");
      valid = false;
    }

    var location = formData.get("location");
    if (!location || location.trim() === "") {
      showError("error-location", "Please enter your city or borough.");
      valid = false;
    }

    if (!valid) {
      return false;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting...";
    result.innerHTML = "";

    var data = {
      full_name: formData.get("full_name") || null,
      email: formData.get("email") || null,
      phone: formData.get("phone") || null,
      language: formData.get("language") || null,
      child_age: formData.get("child_age") || null,
      diagnosis: formData.get("diagnosis") || null,
      service_slp: formData.get("service_slp") || null,
      service_ot: formData.get("service_ot") || null,
      service_aba: formData.get("service_aba") || null,
      service_other: formData.get("service_other") || null,
      location: formData.get("location") || null,
      referral: formData.get("referral") || null,
      additional_info: formData.get("additional_info") || null,
      status: "New"
    };

    fetch(SUPABASE_URL + "/rest/v1/waitlist", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "apikey": SUPABASE_KEY,
        "Authorization": "Bearer " + SUPABASE_KEY,
        "Prefer": "return=minimal"
      },
      body: JSON.stringify(data),
    }).then(function(response) {
      if (response.ok) {
        result.innerHTML = "<span style='color:#22c55e;font-weight:500'>You are on the waitlist! We will be in touch soon.</span>";
        form.reset();
        submitBtn.textContent = "Submitted!";
      } else {
        result.innerHTML = "<span style='color:#ef4444'>Something went wrong. Please try again.</span>";
        submitBtn.disabled = false;
        submitBtn.textContent = "Join the Waitlist";
      }
    }).catch(function() {
      result.innerHTML = "<span style='color:#ef4444'>Something went wrong. Please try again.</span>";
      submitBtn.disabled = false;
      submitBtn.textContent = "Join the Waitlist";
    });
  });
</script>