---
/* PROVIDERS-MATCHES-V1 — from mock to REAL personalized matching.
   Each service type gets an animated MATCH RING computed straight from the
   child's wheel (need score = match strength), provenance chips ("why this
   match"), what-they-do, copyable first-call questions, and honest state
   (in place ✓ / on waitlist / explore). Sorted by match. Rose identity. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Providers" activeNav="providers">
  <SectionTabs section="providers" active="matches" />

  <div class="pv-wrap">
    <div class="c3-ribbon rib-rose cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Provider Matches</h1>
        <p id="rb-sub">Matched from the wheel — the ring shows how strongly each service fits right now.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div class="pv-note cu-rev" style="--d:.05s">
      <span class="cu-blob" style="--blob:#F9EDF1;color:#B14A66;width:34px;height:34px"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="6.5" cy="6.5" r="4.2"/><path d="M9.8 9.8L14 14"/></svg></span>
      <p><b>The live provider directory is rolling out city by city.</b> Matching already works — it reads the wheel. Join waitlists now and you keep your place when the directory opens in Montréal.</p>
    </div>

    <div class="pv-loc cu-rev" style="--d:.08s">
      <span class="cu-blob" style="--blob:#F9EDF1;color:#B14A66;width:34px;height:34px;flex-shrink:0"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M8 14.5s-4.8-4.6-4.8-8a4.8 4.8 0 019.6 0c0 3.4-4.8 8-4.8 8z"/><circle cx="8" cy="6.3" r="1.7"/></svg></span>
      <div class="pv-loc-tx">
        <b>Match by distance</b>
        <span>Enter your postal code and pick how far you'd travel — batches go to the closest providers first.</span>
      </div>
      <input class="pv-postal" id="pv-postal" maxlength="7" placeholder="H2V 2K3" autocomplete="postal-code" />
      <div class="pv-radius" id="pv-radius">
        <button type="button" data-km="5">5 km</button>
        <button type="button" data-km="10">10 km</button>
        <button type="button" data-km="20">20 km</button>
        <button type="button" data-km="30">30 km</button>
        <button type="button" data-km="50">50 km</button>
        <button type="button" data-km="0" class="on">Anywhere</button>
      </div>
      <button type="button" class="btn btn-ghost btn-sm" id="pv-mapbtn">🗺 Map</button>
    </div>
    <p class="pv-loc-hint" id="pv-loc-hint">Distances are approximate (postal-code area), private, and never shared with providers.</p>
    <div id="pv-nopostal"></div>
    <div id="pv-map" class="pv-map" style="display:none"></div>

    <div id="pv-gate"></div>
    <div class="pv-grid" id="pv-grid"></div>
    <div id="pv-upsell"></div>
  </div>
</AppFormLayout>

<style is:global>
  .pv-wrap{display:flex;flex-direction:column;gap:14px;max-width:980px}
  .pv-note{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid #F3D8E1;border-radius:16px;padding:12px 16px;box-shadow:var(--shadow)}
  .pv-note p{font-size:.83rem;color:var(--ink-2);line-height:1.5;margin:0}
  .pv-note b{color:var(--rose)}
  .pv-loc{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:var(--card);border:1px solid var(--line);border-radius:16px;padding:12px 16px;box-shadow:var(--shadow)}
  .pv-loc-tx{flex:1;min-width:210px}
  .pv-loc-tx b{display:block;font-family:var(--display);font-size:.88rem;color:var(--ink)}
  .pv-loc-tx span{display:block;font-size:.72rem;color:var(--muted);margin-top:2px;line-height:1.4}
  .pv-postal{width:104px;padding:8px 11px;border:1px solid var(--line-2);border-radius:10px;font-size:.86rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .pv-postal:focus{border-color:#F9A8D4;box-shadow:0 0 0 3px rgba(177,74,102,.12)}
  .pv-radius{display:flex;gap:4px;background:var(--bg);border:1px solid var(--line);border-radius:9999px;padding:3px}
  .pv-radius button{border:none;background:none;font-size:.72rem;font-weight:700;color:var(--muted);padding:5px 12px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:background .15s,color .15s;white-space:nowrap}
  .pv-radius button:hover{color:var(--ink)}
  .pv-radius button.on{background:var(--rose);color:#fff}
  .pv-loc-hint{font-size:.66rem;color:var(--faint);margin:-6px 0 0 4px}
  .pv-geonote{font-size:.7rem;font-weight:600;color:var(--teal);margin:7px 0 0}
  .pv-geonote:empty{display:none}
  .pv-map{height:400px;border-radius:16px;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden;position:relative;z-index:1}
  .pv-warn{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:14px;padding:12px 16px}
  .pv-warn p{flex:1;font-size:.82rem;color:var(--amber);line-height:1.5;margin:0;min-width:220px}
  #pv-nopostal:empty{display:none}
  .pv-mappop{font-family:'Inter',sans-serif;font-size:.8rem;line-height:1.4}
  .pv-mappop b{display:block;font-size:.84rem}
  .pv-mappop .svc{font-weight:700;text-transform:uppercase;font-size:.64rem;letter-spacing:.05em}
  .pv-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:12px}
  .pv-card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:16px 18px;box-shadow:var(--shadow);display:flex;flex-direction:column;transition:transform .18s,box-shadow .18s,border-color .18s}
  .pv-card:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(177,74,102,.12);border-color:#F3D8E1}
  .pv-head{display:flex;align-items:center;gap:12px;margin-bottom:10px}
  .pv-ring{position:relative;width:56px;height:56px;flex-shrink:0}
  .pv-ring svg{transform:rotate(-90deg)}
  .pv-ring .pc{position:absolute;inset:0;display:grid;place-items:center;font-family:var(--display);font-size:.82rem;font-weight:700;color:var(--ink)}
  .pv-name{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--ink);line-height:1.25}
  .pv-fr{font-size:.72rem;color:var(--muted);margin-top:1px}
  .pv-state{margin-left:auto;flex-shrink:0;font-size:.64rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:3px 10px;border-radius:9999px;white-space:nowrap}
  .pv-state.inplace{background:var(--green-bg);color:var(--green)}
  .pv-state.explore{background:#F9EDF1;color:var(--rose)}
  .pv-state.consider{background:var(--bg);color:var(--muted)}
  .pv-why{display:flex;flex-wrap:wrap;gap:6px;margin:2px 0 9px}
  .pv-whychip{display:inline-flex;align-items:center;gap:6px;font-size:.7rem;font-weight:600;background:var(--violet-50);border:1px solid var(--violet-100);color:#7c6bab;border-radius:9999px;padding:4px 10px;line-height:1.3}
  .pv-desc{font-size:.8rem;color:var(--muted);line-height:1.55;margin:0 0 10px}
  .pv-qs{background:var(--bg);border-radius:12px;padding:10px 12px;margin-bottom:12px}
  .pv-qs p{font-size:.66rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);margin:0 0 6px;display:flex;justify-content:space-between;align-items:center}
  .pv-qs button{border:1px solid var(--line);background:var(--card);color:var(--ink-2);font-size:.64rem;font-weight:700;padding:2px 9px;border-radius:9999px;cursor:pointer;font-family:inherit;letter-spacing:0;text-transform:none}
  .pv-qs button:hover{border-color:var(--violet-500);color:var(--violet-700)}
  .pv-qs li{font-size:.76rem;color:var(--ink-2);line-height:1.5;margin-left:16px}
  .pv-acts{display:flex;gap:8px;margin-top:auto;flex-wrap:wrap}
  .pv-sentnote{font-size:.68rem;color:var(--faint);margin:7px 0 0;min-height:0}
  .pv-sentnote:empty{display:none}
  .pv-send:disabled{opacity:.55;cursor:default}
  #pv-upsell{margin-top:2px}
  #pv-upsell:empty{display:none}
  .pv-gate-card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:28px 22px;text-align:center}
  .pv-gate-card p{color:var(--muted);font-size:.9rem;margin:0 0 14px}
  .pv-gate-card a{display:inline-block;background:var(--violet-700);color:#fff;font-size:.85rem;font-weight:600;padding:9px 18px;border-radius:9999px;text-decoration:none}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../lib/ua-data.js";
  import { scoreWheel, DOMAINS, scoreToBand } from "../lib/wheelScore.js";
  import { notify } from "../lib/notify.js";
  import { getPlan, PLANS, upsellHTML } from "../lib/plan.js";
  import { coordsForPostal, haversineKm } from "../lib/geo.js";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("pv-gate").innerHTML = `<div class="pv-gate-card"><p>Fill in the passport first — the matches on this page are computed from your child's wheel, not a generic list.</p><a href="/passport">Start the passport →</a></div>`;
      return;
    }
    const data = p.data || {};
    const id = UA.childIdentity(data);
    const first = id.first || "your child";
    const scored = scoreWheel(data);
    const wl = await UA.getWaitlist().catch(() => []);
    const therapies = (data.therapy || []).filter((t) => t && t.type).map((t) => String(t.type).toLowerCase());
    const has = (re) => therapies.some((t) => re.test(t));
    const sc = (nm) => (scored[nm] && scored[nm].score != null ? scored[nm].score : null);
    const band = (v) => (v == null ? null : scoreToBand(v));
    const lc = (s) => String(s || "").toLowerCase();

    $("rb-av").textContent = (id.first || id.name || "·")[0].toUpperCase();
    if (id.first) $("rb-title").textContent = "Matches for " + id.first;

    /* ---------- build the match list from the wheel ---------- */
    const hasDx = ((data.diagnosis || {}).diagnoses || []).length > 0;
    const TYPES = [
      {
        key: "slp", name: "Speech-Language Pathologist", fr: "Orthophoniste · pediatric",
        need: sc("Communication"), inPlace: has(/speech|slp|ortho|language/),
        whyDomain: "Communication",
        desc: "Works on requesting, back-and-forth exchange, being understood — at the exact level " + first + " is at today.",
        qs: ["Do you work with children at " + first + "'s communication level?", "What does a typical session look like, and what do we practice at home?", "How long is your waitlist, and is there a cancellation list?"],
      },
      {
        key: "ot", name: "Occupational Therapist", fr: "Ergothérapeute · sensory & daily living",
        need: Math.max(sc("Sensory Processing") ?? -1, sc("Daily Living Skills") ?? -1) < 0 ? null : Math.max(sc("Sensory Processing") ?? 0, sc("Daily Living Skills") ?? 0),
        inPlace: has(/occupational|\bot\b|ergo/),
        whyDomain: (sc("Sensory Processing") ?? 0) >= (sc("Daily Living Skills") ?? 0) ? "Sensory Processing" : "Daily Living Skills",
        desc: "Sensory regulation, routines that stick, feeding and dressing independence, fine-motor confidence.",
        qs: ["Do you build sensory diets families can run at home?", "Can you help with eating and dressing routines?", "Do you coordinate with daycares or schools?"],
      },
      {
        key: "beh", name: "Behaviour Support", fr: "Psychoéducateur · behaviour consultant",
        need: Math.max(sc("Emotional Regulation") ?? -1, sc("Flexibility & Transitions") ?? -1) < 0 ? null : Math.max(sc("Emotional Regulation") ?? 0, sc("Flexibility & Transitions") ?? 0),
        inPlace: has(/behav|aba|psycho[eé]d/),
        whyDomain: (sc("Emotional Regulation") ?? 0) >= (sc("Flexibility & Transitions") ?? 0) ? "Emotional Regulation" : "Flexibility & Transitions",
        desc: "Calm-down plans, transition strategies, and a consistent playbook the whole family can follow.",
        qs: ["Do you create plans parents can follow at home, not just in-clinic?", "How do you handle meltdowns and transitions?", "Do you offer parent coaching sessions?"],
      },
      {
        key: "psy", name: "Child Psychologist", fr: "Psychologue · assessment & support",
        need: hasDx ? (sc("Emotional Regulation") != null ? Math.min(sc("Emotional Regulation"), 55) : null) : 78,
        inPlace: has(/psycholog/),
        whyDomain: hasDx ? "Emotional Regulation" : null,
        whyOverride: hasDx ? null : "No formal diagnosis on file yet — a psychologist can do the assessment",
        desc: hasDx ? "Deeper emotional and cognitive support once the diagnostic picture is clear." : "Runs the formal assessment that unlocks funding, school support and services.",
        qs: ["Do you assess children of " + first + "'s age?", "What is included in the assessment report?", "Is any part covered by RAMQ or insurance?"],
      },
      {
        key: "social", name: "Social Skills Group", fr: "Groupes d'habiletés sociales",
        need: sc("Social Connection"), inPlace: has(/social|group/),
        whyDomain: "Social Connection",
        desc: "Small, structured groups where back-and-forth play is practiced with peers — connection at " + first + "'s pace.",
        qs: ["How are the groups matched by age and profile?", "How many children per facilitator?", "Do you share what was practiced so we can echo it at home?"],
      },
    ];
    const cards = TYPES
      .map((t) => ({ ...t, match: t.need == null ? null : Math.max(15, Math.min(96, Math.round(t.need))) }))
      .filter((t) => t.match != null)
      .sort((a, b) => (b.match || 0) - (a.match || 0));

    /* ---------- ribbon ---------- */
    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${cards.length}</b><span>matched services</span></span>`,
      `<span class="c3-rstat"><b>${therapies.length}</b><span>on the team</span></span>`,
      `<a class="c3-rstat" href="/providers/waitlists"><b>${wl.length}</b><span>waitlist${wl.length === 1 ? "" : "s"}</span></a>`,
    ].join("");

    /* ---------- render match cards ---------- */
    const C = 2 * Math.PI * 23;
    const ringColor = (m) => { const b = band(m); if (!b) return "#D8D3E6"; if (b.key === "high" || b.key === "intensive") return "#B14A66"; if (b.key === "moderate") return "#D97706"; return "#0E8F66"; };
    $("pv-grid").innerHTML = cards.map((t, i) => {
      const state = t.inPlace ? ["inplace", "In place ✓"] : (t.match >= 60 ? ["explore", "Worth exploring"] : ["consider", "Keep in mind"]);
      const b = band(t.need);
      const why = t.whyOverride
        ? `<span class="pv-whychip">✦ ${esc(t.whyOverride)}</span>`
        : (t.whyDomain && b ? `<span class="pv-whychip">✦ ${esc(t.whyDomain)} shows ${esc(lc(b.label))} on the wheel</span>` : "");
      const team = t.inPlace ? `<span class="pv-whychip" style="background:var(--green-bg);border-color:#D5EDDD;color:var(--green)">Already on ${esc(first)}'s team</span>` : "";
      return `<div class="pv-card cu-rev" style="--d:${(0.06 + i * 0.06).toFixed(2)}s">
        <div class="pv-head">
          <span class="pv-ring">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
              <circle cx="28" cy="28" r="23" stroke="var(--line)" stroke-width="5"/>
              <circle class="pv-arc" cx="28" cy="28" r="23" stroke="${ringColor(t.match)}" stroke-width="5" stroke-linecap="round" stroke-dasharray="0 ${C.toFixed(1)}" data-target="${((t.match / 100) * C).toFixed(1)}" style="transition:stroke-dasharray 1s cubic-bezier(.22,1,.36,1)"/>
            </svg>
            <span class="pc">${t.match}%</span>
          </span>
          <span style="min-width:0"><span class="pv-name" style="display:block">${esc(t.name)}</span><span class="pv-fr" style="display:block">${esc(t.fr)}</span></span>
          <span class="pv-state ${state[0]}">${state[1]}</span>
        </div>
        <div class="pv-why">${why}${team}</div>
        <p class="pv-desc">${esc(t.desc)}</p>
        <div class="pv-qs">
          <p><span>Ask on the first call</span><button type="button" data-copy="${i}">Copy</button></p>
          <ul style="margin:0;padding:0">${t.qs.map((q) => `<li>${esc(q)}</li>`).join("")}</ul>
        </div>
        <div class="pv-acts">
          <button type="button" class="btn btn-primary btn-sm pv-send" data-svc="${t.key}">✦ Send intro batch</button>
          <a class="btn btn-ghost btn-sm" href="/resources/guides">How to reach out</a>
        </div>
        <p class="pv-geonote" data-geo="${t.key}"></p>
        <p class="pv-sentnote" data-note="${t.key}"></p>
      </div>`;
    }).join("") || `<div class="pv-gate-card" style="grid-column:1/-1"><p>Answer the wheel questions in the passport and matched services appear here.</p><a href="/passport?id=${p.id}">Continue passport →</a></div>`;

    /* animate the rings in */
    requestAnimationFrame(() => requestAnimationFrame(() => {
      document.querySelectorAll(".pv-arc").forEach((a) => a.setAttribute("stroke-dasharray", a.dataset.target + " " + C.toFixed(1)));
    }));

    /* copy first-call questions */
    document.querySelectorAll("[data-copy]").forEach((btn) => btn.addEventListener("click", () => {
      const t = cards[+btn.dataset.copy];
      const txt = "Questions for " + t.name + " (" + first + "):\n" + t.qs.map((q) => "• " + q).join("\n");
      navigator.clipboard && navigator.clipboard.writeText(txt).then(() => notify("ok", "First-call questions copied ✓")).catch(() => {});
    }));

    /* ================= AUTOMATED OUTREACH ================= */
    const FN_URL = "https://eghqufgiudxjkbsddtnx.supabase.co/functions/v1/send-outreach";
    const SVCMAP = { slp: "slp", ot: "ot", beh: "aba", psy: "psych", social: "social" };
    const SVCNICE = { slp: "speech therapy", ot: "occupational therapy", aba: "behaviour support", psych: "psychology", social: "social groups" };
    const planKey = await getPlan();
    let requests = [];
    try {
      const s0 = await UA.getValidSession();
      if (s0) {
        const rq = await fetch("https://eghqufgiudxjkbsddtnx.supabase.co/rest/v1/outreach_requests?select=service_type,created_at,sent_count&passport_id=eq." + p.id + "&order=created_at.desc", { headers: UA.authHeaders(s0.access_token) });
        if (rq.ok) requests = await rq.json();
      }
    } catch (e) {}
    function annotate() {
      document.querySelectorAll(".pv-send").forEach((btn) => {
        const svc = SVCMAP[btn.dataset.svc];
        const prior = requests.filter((r) => r.service_type === svc);
        const note = document.querySelector('[data-note="' + btn.dataset.svc + '"]');
        if (prior.length) {
          const last = prior[0];
          if (note) note.textContent = "Last batch " + new Date(last.created_at).toLocaleDateString("en-CA", { month: "short", day: "numeric" }) + " · sent to " + last.sent_count + " provider" + (last.sent_count === 1 ? "" : "s");
          if (planKey === "free") {
            btn.disabled = true;
            btn.textContent = "Free batch used ✓";
            const up = document.getElementById("pv-upsell");
            if (up && !up.innerHTML) up.innerHTML = upsellHTML("Your automated intro went out ✦", "The free plan includes one batch per service type. Monthly plans send a fresh batch every 30 days — and the concierge follows up for you.", "Upgrade for follow-ups");
          }
        } else if (note) {
          note.textContent = planKey === "free" ? "Free plan: 1 automated batch included for this service" : "Sends to up to 5 matched providers · replies go to your inbox";
        }
      });
    }
    annotate();

    /* ---------- distance matching (postal-area based) ---------- */
    const GEO_KEY = "ua_home_geo_" + (((await UA.getValidSession()) || {}).user || {}).id;
    let home = { postal: "", km: 0 };
    try { home = Object.assign(home, JSON.parse(localStorage.getItem(GEO_KEY) || "{}")); } catch (e) {}
    /* the address ON FILE lives in the passport (household.postal) —
       it wins over the device-local value and syncs across devices */
    let passportPostal = String(((data.household || {}).postal) || ((data.childProfile || {}).postalCode) || "").trim().toUpperCase();
    if (passportPostal) home.postal = passportPostal;
    async function savePostalToPassport(postal) {
      try {
        const s2 = await UA.getValidSession();
        if (!s2) return;
        const newData = Object.assign({}, data);
        newData.household = Object.assign({}, data.household || {}, { postal });
        const r2 = await fetch("https://eghqufgiudxjkbsddtnx.supabase.co/rest/v1/passports?id=eq." + p.id, {
          method: "PATCH",
          headers: Object.assign({}, UA.authHeaders(s2.access_token), { Prefer: "return=minimal" }),
          body: JSON.stringify({ data: newData }),
        });
        if (r2.ok) {
          passportPostal = postal;
          data.household = newData.household;
          renderWarn();
          notify("ok", "Postal code saved to " + first + "'s passport ✓ — matching now works on every device");
        }
      } catch (e) {}
    }
    function renderWarn() {
      $("pv-nopostal").innerHTML = passportPostal ? "" :
        `<div class="pv-warn cu-rev"><span class="cu-blob" style="--blob:#FBF2E2;color:#A8650A;width:34px;height:34px;flex-shrink:0"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 3.2v6M8 12.3v.2"/></svg></span><p><b>No address on file for ${esc(first)}.</b> Type your postal code above — we'll save it to the passport so distance matching and outreach know where you are, on every device.</p></div>`;
    }
    renderWarn();
    let dirProviders = [];
    try {
      const sg = await UA.getValidSession();
      if (sg) {
        const rg = await fetch("https://eghqufgiudxjkbsddtnx.supabase.co/rest/v1/providers?select=name,city,service_type,lat,lng,email&active=eq.true", { headers: UA.authHeaders(sg.access_token) });
        if (rg.ok) dirProviders = await rg.json();
      }
    } catch (e) {}
    const homeCoords = () => coordsForPostal(home.postal);

    /* ---------- map view (Leaflet + OpenStreetMap, loaded on demand) ---------- */
    const SVCCOLOR = { slp: "#6D28D9", ot: "#0E8C82", aba: "#B14A66", psych: "#2563EB", social: "#4C9A2A" };
    let map = null, homeLayer = null;
    function loadLeaflet() {
      return new Promise((res, rej) => {
        if (window.L) return res(window.L);
        const css = document.createElement("link");
        css.rel = "stylesheet";
        css.href = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css";
        document.head.appendChild(css);
        const js = document.createElement("script");
        js.src = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js";
        js.onload = () => res(window.L);
        js.onerror = rej;
        document.head.appendChild(js);
      });
    }
    function drawHome() {
      if (!map || !window.L) return;
      if (homeLayer) { map.removeLayer(homeLayer); homeLayer = null; }
      const hc = homeCoords();
      if (!hc) return;
      homeLayer = window.L.layerGroup();
      homeLayer.addLayer(window.L.circleMarker(hc, { radius: 8, color: "#221B36", weight: 2, fillColor: "#FCD34D", fillOpacity: 1 }).bindPopup("<div class='pv-mappop'><b>Home ✦</b>approximate — postal area</div>"));
      if (home.km > 0) homeLayer.addLayer(window.L.circle(hc, { radius: home.km * 1000, color: "#B14A66", weight: 1.5, fillColor: "#B14A66", fillOpacity: 0.06, dashArray: "6 6" }));
      homeLayer.addTo(map);
      if (home.km > 0) map.fitBounds(window.L.circle(hc, { radius: home.km * 1000 }).getBounds().pad(0.1));
    }
    async function openMap() {
      const box = $("pv-map");
      const showing = box.style.display !== "none";
      if (showing) { box.style.display = "none"; $("pv-mapbtn").textContent = "🗺 Map"; return; }
      box.style.display = "block";
      $("pv-mapbtn").textContent = "Hide map";
      try {
        const L = await loadLeaflet();
        if (!map) {
          map = L.map("pv-map").setView([45.53, -73.65], 10);
          L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 18, attribution: "© OpenStreetMap contributors",
          }).addTo(map);
          dirProviders.filter((d2) => typeof d2.lat === "number" && typeof d2.lng === "number").forEach((d2) => {
            const col = SVCCOLOR[d2.service_type] || "#6D28D9";
            L.circleMarker([d2.lat, d2.lng], { radius: 7, color: "#fff", weight: 1.5, fillColor: col, fillOpacity: d2.email ? 0.95 : 0.35 })
              .bindPopup(`<div class='pv-mappop'><b>${esc(d2.name || "Provider")}</b><span class='svc' style='color:${col}'>${esc(SVCNICE[d2.service_type] || d2.service_type)}</span> · ${esc(d2.city || "")}${d2.email ? "" : "<br><i>awaiting email — not contactable yet</i>"}</div>`)
              .addTo(map);
          });
        }
        setTimeout(() => { map.invalidateSize(); drawHome(); }, 60);
      } catch (e) {
        notify("warn", "The map couldn't load — check your connection.");
        box.style.display = "none";
        $("pv-mapbtn").textContent = "🗺 Map";
      }
    }
    $("pv-mapbtn").addEventListener("click", openMap);
    function updateGeo() {
      const hc = homeCoords();
      document.querySelectorAll("[data-geo]").forEach((el) => {
        const svc = SVCMAP[el.dataset.geo];
        const all = dirProviders.filter((d) => d.service_type === svc && d.email);
        if (!all.length) { el.textContent = ""; return; }
        if (hc && home.km > 0) {
          const near = all.filter((d) => typeof d.lat === "number" && haversineKm(hc[0], hc[1], d.lat, d.lng) <= home.km).length;
          el.textContent = near + " of " + all.length + " contactable provider" + (all.length === 1 ? "" : "s") + " within " + home.km + " km";
        } else {
          el.textContent = all.length + " contactable provider" + (all.length === 1 ? "" : "s") + " in the directory";
        }
      });
      $("pv-loc-hint").textContent = home.postal && !hc
        ? "That postal code isn't in our map yet — batches will ignore distance until it is."
        : "Distances are approximate (postal-code area), private, and never shared with providers.";
      drawHome();
    }
    $("pv-postal").value = home.postal;
    document.querySelectorAll("#pv-radius button").forEach((b) => {
      b.classList.toggle("on", +b.dataset.km === home.km);
      b.addEventListener("click", () => {
        document.querySelectorAll("#pv-radius button").forEach((x) => x.classList.remove("on"));
        b.classList.add("on");
        home.km = +b.dataset.km;
        localStorage.setItem(GEO_KEY, JSON.stringify(home));
        updateGeo();
      });
    });
    $("pv-postal").addEventListener("input", () => {
      home.postal = $("pv-postal").value.trim().toUpperCase();
      localStorage.setItem(GEO_KEY, JSON.stringify(home));
      updateGeo();
    });
    /* when they finish typing a real postal code, put it ON FILE in the passport */
    $("pv-postal").addEventListener("change", () => {
      const v = $("pv-postal").value.trim().toUpperCase();
      if (coordsForPostal(v) && v !== passportPostal) savePostalToPassport(v);
    });
    updateGeo();

    document.querySelectorAll(".pv-send").forEach((btn) => btn.addEventListener("click", async () => {
      if (btn.disabled) return;
      const svc = SVCMAP[btn.dataset.svc];
      const hc = homeCoords();
      const withKm = hc && home.km > 0;
      if (!confirm("Send an automated introduction about " + first + " to up to 5 matched " + (SVCNICE[svc] || "service") + " providers" + (withKm ? " within " + home.km + " km" : "") + "? Replies go straight to your email.")) return;
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = "Sending…";
      try {
        const s1 = await UA.getValidSession();
        const payload = { passport_id: p.id, service_type: svc };
        if (withKm) { payload.lat = hc[0]; payload.lng = hc[1]; payload.radius_km = home.km; }
        const r = await fetch(FN_URL, {
          method: "POST",
          headers: { Authorization: "Bearer " + s1.access_token, "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const out = await r.json().catch(() => ({}));
        if (r.ok && out.ok) {
          notify("ok", "Introductions sent to " + out.sent + " provider" + (out.sent === 1 ? "" : "s") + " ✦ Replies land in your inbox.");
          requests.unshift({ service_type: svc, created_at: new Date().toISOString(), sent_count: out.sent });
          btn.textContent = old;
          annotate();
        } else if (r.status === 402) {
          notify("warn", out.message || "The free plan includes one batch per service type.");
          btn.textContent = "Free batch used ✓";
          const up = document.getElementById("pv-upsell");
          if (up && !up.innerHTML) up.innerHTML = upsellHTML("That's the free batch ✦", out.message || "Monthly plans send a fresh batch every 30 days.", "See the plans");
        } else if (r.status === 429) {
          notify("info", out.message || "The next batch for this service unlocks soon.");
          btn.disabled = false; btn.textContent = old;
        } else if (r.status === 503) {
          notify("info", out.message || "The directory for this service is still filling — you're noted.");
          btn.disabled = false; btn.textContent = old;
        } else {
          notify("err", out.message || "Couldn't send — is the outreach setup deployed?");
          btn.disabled = false; btn.textContent = old;
        }
      } catch (e) {
        notify("err", "Couldn't reach the outreach service — try again in a moment.");
        btn.disabled = false; btn.textContent = old;
      }
    }));
  })().catch((e) => console.error("[providers] hydrate failed", e));
</script>
