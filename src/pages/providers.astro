---
/* PROVIDERS-MATCHES-V3 — staged matching flow with Google Maps.
   Screen 1 · pick service + distance → "Find matches"
   Screen 2 · the 5 matches revealed: ranked cards + Google map,
              clickable pins with clinic info + directions.
   Screen 3 · review & edit the email → send → success state.
   Sent-batch log at the bottom. Matching = distance for now;
   acceptance/waitlist/schedule factors slot into candidatesFor()
   once providers onboard. Server (send-outreach) still enforces
   quotas + 90-day protection. NOTE: no literal curly braces in the
   template markup — Astro parses them as expressions. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Providers" titleFr="Professionnels" activeNav="providers">
  <SectionTabs section="providers" active="matches" />

  <div class="pv-wrap">
    <div class="c3-ribbon rib-rose cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Find Providers</h1>
        <p data-i18n="ribSub">Tell us what you need — we match you with the 5 closest clinics, you approve the email, we send it.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div id="pv-gate"></div>

    <!-- crumbs -->
    <div class="pv-crumbs cu-rev" id="pv-crumbs" style="--d:.04s">
      <span class="pv-crumb cur" data-s="1"><i>1</i><span data-i18n="crumb1">Your search</span></span>
      <span class="pv-cline"></span>
      <span class="pv-crumb" data-s="2"><i>2</i><span data-i18n="crumb2">Your matches</span></span>
      <span class="pv-cline"></span>
      <span class="pv-crumb" data-s="3"><i>3</i><span data-i18n="crumb3">Review &amp; send</span></span>
    </div>

    <!-- ============ SCREEN 1 · SEARCH ============ -->
    <section class="pv-scr on" id="scr-1">
      <div class="pv-card cu-rev" style="--d:.08s">
        <h2 class="pv-h" data-i18n="selectService">Select a service below</h2>
        <div class="pv-svcs" id="pv-svcs"></div>
        <h2 class="pv-h" style="margin-top:18px" data-i18n="howFar">How far would you travel?</h2>
        <div class="pv-loc">
          <input class="pv-postal" id="pv-postal" maxlength="7" placeholder="H2V 2K3" data-i18n-ph="phPostal" autocomplete="postal-code" />
          <div class="pv-kmwrap">
            <input type="range" id="pv-km" min="0" max="4" step="1" value="2" />
            <div class="pv-kmticks"><span>5</span><span>10</span><span>20</span><span>30</span><span>50</span></div>
          </div>
          <span class="pv-kmval" id="pv-kmval">20 km</span>
        </div>
        <p class="pv-loc-hint" id="pv-loc-hint"></p>
        <div class="pv-findrow">
          <span class="pv-findnote" id="pv-findnote"></span>
          <button type="button" class="btn btn-primary" id="pv-find" data-i18n="findMatches">✦ Find matches</button>
        </div>
      </div>
    </section>

    <!-- ============ SCREEN 2 · MATCHES ============ -->
    <section class="pv-scr" id="scr-2">
      <div class="pv-card pv-searching" id="pv-searching" style="display:none">
        <div class="pv-orb"></div>
        <p class="pv-s-line" id="pv-s1" data-i18n="s1Searching">Searching the clinic directory…</p>
        <p class="pv-s-line" id="pv-s2" data-i18n="s2Measuring">Measuring distances from home…</p>
        <p class="pv-s-line" id="pv-s3" data-i18n="s3Protection">Applying the 90-day protection…</p>
      </div>
      <div id="pv-results" style="display:none">
        <div class="pv-card">
          <div class="pv-res-head">
            <h2 class="pv-h" id="pv-res-title" style="margin:0">Your matches</h2>
            <span class="pv-res-sub" id="pv-res-sub"></span>
          </div>
          <div id="pv-cap" class="pv-cap"></div>
          <div class="pv-results-grid">
            <div class="pv-mlist" id="pv-mlist"></div>
            <div class="pv-mapcol">
              <div id="pv-map" class="pv-map"></div>
              <p class="pv-maphint" data-i18n="mapHint">Tap a pin for the clinic's details and directions ✦ the gold star is home.</p>
            </div>
          </div>
          <div id="pv-res-notes"></div>
          <div class="pv-navrow">
            <button type="button" class="btn btn-ghost" id="pv-back1" data-i18n="adjustSearch">← Adjust search</button>
            <button type="button" class="btn btn-primary" id="pv-to3" data-i18n="reviewEmailBtn">Review the email →</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SCREEN 3 · REVIEW & SEND ============ -->
    <section class="pv-scr" id="scr-3">
      <div class="pv-card">
        <div id="pv-review">
          <h2 class="pv-h" data-i18n="reviewEmailTitle">Review the email</h2>
          <div class="pv-recap" id="pv-recap"></div>
          <p class="pv-subject" id="pv-subject"></p>
          <textarea class="pv-msg" id="pv-msg" maxlength="2000" rows="11"></textarea>
          <p class="pv-footpeek" data-i18n="footPeek">Added automatically: a personal "Hello" with each clinic's name on top · a short UniqueApex footer with the 90-day no-repeat promise · Reply-To set to your email, so answers land in your inbox.</p>
          <label class="pv-consent">
            <input type="checkbox" id="pv-consent" />
            <span><span data-i18n="consentText">I am this child's parent or legal guardian, and I consent to sharing their first name, age and diagnosis with the clinics selected above so they can respond about services.</span> <a href="/privacy" target="_blank" rel="noopener" data-i18n="privacyPolicy">Privacy policy</a></span>
          </label>
          <div class="pv-navrow">
            <button type="button" class="btn btn-ghost" id="pv-back2" data-i18n="backToMatches">← Back to matches</button>
            <span class="pv-quota" id="pv-quota"></span>
            <button type="button" class="btn btn-primary" id="pv-send" disabled data-i18n="sendBtn">✦ Send</button>
          </div>
          <div id="pv-upsell"></div>
        </div>
        <div id="pv-sent" style="display:none"></div>
      </div>
    </section>

  </div>
</AppFormLayout>

<style is:global>
  .pv-wrap{display:flex;flex-direction:column;gap:14px;max-width:1020px}
  .pv-wrap .rib-rose{background:linear-gradient(120deg,#F6F2FE,#ECE4FC 60%,#FDFCFF) !important;border-color:#E6DDF8 !important}
  .pv-wrap .rib-rose .c3-rib-av{background:#EDE9FE !important;color:#6D28D9 !important}
  .pv-card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:18px 20px;box-shadow:var(--shadow)}
  .pv-h{font-family:var(--display);font-size:1rem;color:var(--ink);margin:0 0 12px}
  .pv-empty2{font-size:.83rem;color:var(--faint);margin:0;line-height:1.55}

  .pv-crumbs{display:flex;align-items:center;gap:10px;padding:2px 6px}
  .pv-crumb{display:inline-flex;align-items:center;gap:10px;font-size:.94rem;font-weight:800;color:var(--faint);white-space:nowrap}
  .pv-crumb i{font-style:normal;width:32px;height:32px;border-radius:50%;background:var(--bg);border:2px solid var(--line);display:grid;place-items:center;font-size:.84rem;transition:all .25s}
  .pv-crumb.cur{color:var(--ink)}
  .pv-crumb.cur i{background:#6D28D9;border-color:#6D28D9;color:#fff}
  .pv-crumb.done{color:var(--teal)}
  .pv-crumb.done i{background:var(--teal-bg);border-color:var(--teal);color:var(--teal)}
  .pv-cline{flex:1;height:1.5px;background:var(--line);border-radius:1px;min-width:18px}

  .pv-scr{display:none}
  .pv-scr.on{display:block;animation:pvIn .3s ease both}
  @keyframes pvIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

  .pv-svcs{display:grid;grid-template-columns:repeat(auto-fit,minmax(205px,1fr));gap:12px}
  .pv-svc{position:relative;display:flex;flex-direction:column;align-items:flex-start;border:2px solid var(--line);border-radius:18px;padding:20px 18px 16px;background:var(--card);cursor:pointer;text-align:left;font-family:inherit;min-height:152px;box-shadow:0 2px 0 rgba(34,27,54,.05),0 8px 18px rgba(34,27,54,.05);transition:border-color .18s,transform .18s,box-shadow .18s,background .18s}
  .pv-svc:hover{transform:translateY(-3px);border-color:#C9B8F5;box-shadow:0 4px 0 rgba(34,27,54,.06),0 16px 30px rgba(34,27,54,.12)}
  .pv-svc:active{transform:translateY(0);box-shadow:0 1px 0 rgba(34,27,54,.06),0 6px 12px rgba(34,27,54,.1)}
  .pv-svc.on{border-color:#6D28D9;background:#fff;background:color-mix(in srgb,#6D28D9 7%,#fff);box-shadow:0 4px 0 #6D28D9,0 16px 32px rgba(34,27,54,.16);transform:translateY(-2px)}
  .pv-svc.on::after{content:"✓";position:absolute;top:12px;right:12px;width:26px;height:26px;border-radius:50%;background:#6D28D9;color:#fff;font-size:.82rem;font-weight:800;display:grid;place-items:center}
  .pv-svc .nm{display:block;font-size:1.08rem;font-weight:800;color:var(--ink);line-height:1.25;padding-right:30px}
  .pv-svc .fr{display:block;font-size:.78rem;color:var(--muted);margin-top:4px}
  .pv-svc .sug{display:inline-flex;align-items:center;gap:4px;font-size:.66rem;font-weight:700;background:var(--violet-50);border:1px solid var(--violet-100);color:#7c6bab;border-radius:9999px;padding:4px 10px;margin-top:auto}
  .pv-loc{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .pv-postal{width:104px;padding:8px 11px;border:1px solid var(--line-2);border-radius:10px;font-size:.86rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .pv-postal:focus{border-color:#C4B5FD;box-shadow:0 0 0 3px rgba(109,40,217,.14)}
  .pv-kmwrap{flex:1;min-width:220px;max-width:360px;padding-top:6px}
  #pv-km{width:100%;accent-color:#6D28D9;cursor:pointer;height:6px}
  .pv-kmticks{display:flex;justify-content:space-between;font-size:.68rem;color:var(--faint);font-weight:700;padding:3px 2px 0}
  .pv-kmval{font-family:var(--display);font-size:1.1rem;font-weight:800;color:#6D28D9;min-width:66px}
  .pv-loc-hint{font-size:.66rem;color:var(--faint);margin:8px 0 0}
  .pv-loc-hint:empty{display:none}
  .pv-findrow{display:flex;align-items:center;gap:12px;margin-top:16px;flex-wrap:wrap}
  .pv-findnote{flex:1;font-size:.72rem;color:var(--muted);min-width:180px}
  .pv-cap{display:none;align-items:center;gap:10px;background:var(--amber-bg);border:2px solid var(--amber);color:var(--amber);font-size:.94rem;font-weight:800;border-radius:14px;padding:13px 17px;margin-bottom:12px}
  .pv-cap.show{display:flex;animation:pvShake .4s ease}
  @keyframes pvShake{0%,100%{transform:none}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}

  .pv-searching{text-align:center;padding:38px 20px}
  .pv-orb{width:46px;height:46px;margin:0 auto 16px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#C4B5FD,#6D28D9);animation:pvOrb 1.1s ease-in-out infinite}
  @keyframes pvOrb{0%,100%{transform:scale(1) rotate(0deg)}50%{transform:scale(1.14) rotate(8deg)}}
  .pv-s-line{font-size:.84rem;color:var(--muted);margin:5px 0;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s}
  .pv-s-line.show{opacity:1;transform:none}

  .pv-res-head{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:12px}
  .pv-res-sub{font-size:.72rem;color:var(--muted)}
  .pv-results-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:14px;align-items:start}
  @media (max-width:860px){.pv-results-grid{grid-template-columns:1fr}}
  .pv-mlist{display:flex;flex-direction:column;gap:8px}
  .pv-m{display:flex;align-items:center;gap:12px;border:2px solid var(--line);border-radius:15px;padding:13px 15px;cursor:pointer;transition:border-color .15s,background .15s;opacity:0;animation:pvCard .4s ease forwards;animation-delay:var(--cd,0s)}
  @keyframes pvCard{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .pv-m:hover{border-color:#DDD2F5}
  .pv-m.on{border-color:#6D28D9;background:linear-gradient(135deg,#FBFAFF,#fff 65%)}
  .pv-m input{width:19px;height:19px;accent-color:#6D28D9;flex-shrink:0;cursor:pointer}
  .pv-m .rk{width:28px;height:28px;border-radius:50%;display:grid;place-items:center;color:#fff;font-size:.8rem;font-weight:800;flex-shrink:0;background:#C6C0D4;transition:background .15s}
  .pv-m.on .rk{background:#6D28D9}
  .pv-m .bd{flex:1;min-width:0}
  .pv-m .nm{display:block;font-size:.94rem;font-weight:700;color:var(--ink);line-height:1.3}
  .pv-m .mt{display:block;font-size:.76rem;color:var(--muted);margin-top:2px}
  .pv-m .dist{flex-shrink:0;font-family:var(--display);font-size:.85rem;font-weight:700;color:var(--muted);background:var(--bg);border-radius:9999px;padding:5px 13px;white-space:nowrap;transition:color .15s,background .15s}
  .pv-m.on .dist{color:var(--teal);background:var(--teal-bg)}
  .pv-m.on .dist.far,.pv-m .dist.far{color:var(--muted);background:var(--bg)}
  .pv-protected{font-size:.7rem;color:var(--amber);background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:10px;padding:7px 11px;margin-top:12px;line-height:1.45}
  .pv-mnote{font-size:.72rem;color:var(--faint);margin:12px 0 0;line-height:1.5}
  .pv-mapcol{position:sticky;top:12px}
  .pv-map{height:420px;border-radius:16px;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden;background:var(--bg)}
  .pv-maphint{font-size:.66rem;color:var(--faint);margin:7px 2px 0}
  .pv-mapmiss{display:grid;place-items:center;height:100%;padding:20px;text-align:center;font-size:.78rem;color:var(--muted);line-height:1.6}
  .pv-navrow{display:flex;align-items:center;gap:12px;margin-top:16px;flex-wrap:wrap;justify-content:space-between}

  .pv-iw{font-family:'Inter',sans-serif;font-size:.8rem;line-height:1.5;max-width:240px;color:#221B36}
  .pv-iw b{display:block;font-size:.86rem;margin-bottom:2px}
  .pv-iw .svc{font-weight:700;text-transform:uppercase;font-size:.62rem;letter-spacing:.05em}
  .pv-iw .row{color:#6A6478;font-size:.74rem;margin-top:3px}
  .pv-iw a{color:#B14A66;font-weight:700;text-decoration:none}
  .pv-iw .dir{display:inline-block;margin-top:7px}

  .pv-recap{margin-bottom:14px}
  .pv-tohead{display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap}
  .pv-tohead span{font-size:.64rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--faint)}
  .pv-tohead b{font-family:var(--display);font-size:.94rem;color:var(--ink)}
  .pv-tohead em{font-style:normal;font-size:.74rem;color:var(--muted)}
  .pv-tolist{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:7px}
  .pv-to{display:flex;align-items:center;gap:9px;background:var(--bg);border:1px solid var(--line);border-radius:12px;padding:8px 11px;min-width:0}
  .pv-to i{font-style:normal;width:20px;height:20px;border-radius:50%;background:#6D28D9;color:#fff;font-size:.64rem;font-weight:800;display:grid;place-items:center;flex-shrink:0}
  .pv-to .tn{font-size:.78rem;font-weight:700;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pv-to .tm{margin-left:auto;font-size:.68rem;color:var(--muted);white-space:nowrap;flex-shrink:0;padding-left:8px}
  .pv-subject{font-size:.78rem;color:var(--muted);background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:8px 12px;margin:0 0 8px}
  .pv-subject b{color:var(--ink)}
  .pv-msg{width:100%;border:1px solid var(--line-2);border-radius:12px;padding:12px 14px;font-size:.86rem;line-height:1.6;color:var(--ink);background:var(--card);outline:none;font-family:inherit;resize:vertical}
  .pv-msg:focus{border-color:#C4B5FD;box-shadow:0 0 0 3px rgba(109,40,217,.14)}
  .pv-footpeek{font-size:.68rem;color:var(--faint);font-style:italic;margin:7px 0 0;line-height:1.5}
  .pv-consent{display:flex;align-items:flex-start;gap:10px;margin-top:12px;background:var(--bg);border:1.5px dashed var(--line-2);border-radius:12px;padding:11px 14px;cursor:pointer}
  .pv-consent input{width:18px;height:18px;accent-color:#6D28D9;flex-shrink:0;margin-top:1px;cursor:pointer}
  .pv-consent span{font-size:.76rem;color:var(--ink-2);line-height:1.55}
  .pv-consent a{color:var(--violet-700);font-weight:700;text-decoration:none}
  .pv-quota{flex:1;font-size:.72rem;color:var(--muted);text-align:right;min-width:160px}
  #pv-send:disabled,#pv-find:disabled{opacity:.55;cursor:default}
  #pv-upsell{margin-top:10px}
  #pv-upsell:empty{display:none}
  .pv-sentbox{text-align:center;padding:26px 14px}
  .pv-sentbox .big{font-size:2rem}
  .pv-sentbox h3{font-family:var(--display);font-size:1.06rem;color:var(--ink);margin:8px 0 6px}
  .pv-sentbox p{font-size:.82rem;color:var(--muted);line-height:1.6;margin:0 auto 6px;max-width:460px}
  .pv-sentbox .names{font-size:.74rem;color:var(--teal);font-weight:700}

</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../lib/ua-data.js";
  import { scoreWheel, scoreToBand } from "../lib/wheelScore.js";
  import { domainName } from "../lib/libI18n.js";
  import { notify } from "../lib/notify.js";
  import { getPlan, upsellHTML } from "../lib/plan.js";
  import { coordsForPostal, haversineKm } from "../lib/geo.js";
  import DICT from "../i18n/providers.js";

  /* Google Maps key — paste yours between the quotes.
     Full setup guide: GOOGLE_MAPS_SETUP.md in the repo root. */
  const GMAPS_KEY = "PASTE_YOUR_GOOGLE_MAPS_KEY_HERE";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

  /* ---------- i18n (string codes from src/i18n/providers.js) ---------- */
  const T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
  const tpl = (s, v) => String(s).replace(/\{(\w+)\}/g, (m, k) => (v && v[k] != null ? v[k] : ""));
  const ofName = (n) => (window.uaLang === "fr" ? (/^[aeiouyàâäéèêëìîïòôöùûüh]/i.test(String(n || "")) ? "d'" : "de ") : "");
  const km1 = (d) => Number(d).toLocaleString(window.uaLocale || "en-CA", { minimumFractionDigits: 1, maximumFractionDigits: 1 });
  /* Script-owned labels — translate the fallbacks before data arrives. */
  $("rb-title").textContent = T.findProviders;
  $("pv-res-title").textContent = T.yourMatches;

  const BASE = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const FN_URL = BASE + "/functions/v1/send-outreach";
  const BATCH = 5;
  const SVCS = [
    { code: "slp", name: "Speech-language therapy", fr: "Orthophonie", wheel: ["Communication"] },
    { code: "ot", name: "Occupational therapy", fr: "Ergothérapie", wheel: ["Sensory Processing", "Daily Living Skills"] },
    { code: "aba", name: "Behaviour support", fr: "Psychoéducation / ABA", wheel: ["Emotional Regulation", "Flexibility & Transitions"] },
    { code: "psych", name: "Child psychologist", fr: "Psychologue", wheel: [] },
    { code: "social", name: "Social skills groups", fr: "Habiletés sociales", wheel: ["Social Connection"] },
  ];
  const SVCCOLOR = { slp: "#6D28D9", ot: "#0E8C82", aba: "#B14A66", psych: "#2563EB", social: "#4C9A2A" };

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("pv-gate").innerHTML = `<div class="pv-card" style="text-align:center"><p class="pv-empty2" style="margin-bottom:12px">${esc(T.gateText)}</p><a class="btn btn-primary btn-sm" href="/passport">${esc(T.gateCta)}</a></div>`;
      $("pv-crumbs").style.display = "none";
      document.querySelectorAll(".pv-scr").forEach((el) => { el.style.display = "none"; });
      return;
    }
    const data = p.data || {};
    const id = UA.childIdentity(data);
    const first = id.first || T.ourChild;
    const scored = scoreWheel(data);
    const parent = String((data.household || {}).g1name || "").replace(/\s*\([^)]*\)\s*$/, "").trim();
    const dxTxt = id.dx || "";
    const planKey = await getPlan();

    $("rb-av").textContent = (id.first || id.name || "·")[0].toUpperCase();
    if (id.first) $("rb-title").textContent = tpl(T.findProvidersFor, { name: id.first });

    const sess = await UA.getValidSession();
    const H = sess ? UA.authHeaders(sess.access_token) : null;
    const j = async (path) => { try { const r = await fetch(BASE + "/rest/v1/" + path, { headers: H }); return r.ok ? await r.json() : []; } catch (e) { return []; } };
    const [providers, contacts, requests, wl] = await Promise.all([
      j("providers?select=id,name,city,borough,address,languages,phone,website,service_type,lat,lng,email&active=eq.true"),
      j("outreach_contacts?select=provider_id,sent_at&passport_id=eq." + p.id),
      j("outreach_requests?select=id,service_type,status,sent_count,created_at&passport_id=eq." + p.id + "&order=created_at.desc"),
      UA.getWaitlist().catch(() => []),
    ]);
    const protectedIds = new Set(contacts.filter((c) => Date.now() - new Date(c.sent_at).getTime() < 90 * 864e5).map((c) => c.provider_id));

    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${requests.length}</b><span>${esc(T.statBatches)}</span></span>`,
      `<a class="c3-rstat" href="/providers/waitlists"><b>${wl.length}</b><span>${esc(wl.length === 1 ? T.waitlist1 : T.waitlistN)}</span></a>`,
    ].join("");

    const GEO_KEY = "ua_home_geo_" + ((sess || {}).user || {}).id;
    let home = { postal: "", km: 0 };
    try { home = Object.assign(home, JSON.parse(localStorage.getItem(GEO_KEY) || "{}")); } catch (e) {}
    let passportPostal = String(((data.household || {}).postal) || ((data.childProfile || {}).postalCode) || "").trim().toUpperCase();
    if (passportPostal) home.postal = passportPostal;
    const homeCoords = () => coordsForPostal(home.postal);
    async function savePostalToPassport(postal) {
      try {
        const s2 = await UA.getValidSession();
        if (!s2) return;
        const newData = Object.assign({}, data);
        newData.household = Object.assign({}, data.household || {}, { postal });
        const r2 = await fetch(BASE + "/rest/v1/passports?id=eq." + p.id, {
          method: "PATCH",
          headers: Object.assign({}, UA.authHeaders(s2.access_token), { Prefer: "return=minimal" }),
          body: JSON.stringify({ data: newData }),
        });
        if (r2.ok) {
          passportPostal = postal;
          data.household = newData.household;
          notify("ok", tpl(T.postalSaved, { name: first, of: ofName(first) }));
        }
      } catch (e) {}
    }

    let step = 1;
    function goStep(n) {
      step = n;
      [1, 2, 3].forEach((i) => {
        $("scr-" + i).classList.toggle("on", i === n);
        const c = document.querySelector(`.pv-crumb[data-s="${i}"]`);
        c.classList.toggle("cur", i === n);
        c.classList.toggle("done", i < n);
      });
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    let svc = null;
    const suggestions = {};
    SVCS.forEach((s) => {
      const flagged = s.wheel.map((d) => scored[d]).filter((dm) => dm && dm.score != null && scoreToBand(dm.score).rings >= 3);
      if (flagged.length) suggestions[s.code] = s.wheel.find((d) => scored[d] && scored[d].score != null && scoreToBand(scored[d].score).rings >= 3);
      if (s.code === "psych" && !(((data.diagnosis || {}).diagnoses || []).length)) suggestions[s.code] = "No diagnosis on file yet";
    });
    function quotaFor(code) {
      const prior = requests.filter((r) => r.service_type === code);
      if (!prior.length) return { ok: true, note: planKey === "free" ? T.quotaFreeIncluded : "" };
      if (planKey === "free") return { ok: false, note: tpl(T.quotaFreeUsed, { date: new Date(prior[0].created_at).toLocaleDateString(window.uaLocale || "en-CA", { month: "short", day: "numeric" }) }) };
      const left = 30 * 864e5 - (Date.now() - new Date(prior[0].created_at).getTime());
      if (left > 0) { const d2 = Math.ceil(left / 864e5); return { ok: false, note: tpl(d2 === 1 ? T.quotaNext1 : T.quotaNextN, { n: d2 }) }; }
      return { ok: true, note: "" };
    }
    function renderSvcs() {
      $("pv-svcs").innerHTML = SVCS.map((s) => {
        const L = T.svcs[s.code] || {};
        const sug = suggestions[s.code];
        return `<button type="button" class="pv-svc${svc === s.code ? " on" : ""}" data-svc="${s.code}">
          <span class="nm">${esc(L.name || s.name)}</span>
          <span class="fr">${esc(L.sub || s.fr)}</span>
          ${sug ? `<span class="sug">✦ ${sug === "No diagnosis on file yet" ? esc(T.noDxYet) : tpl(esc(T.flaggedOnWheel), { domain: esc(domainName(sug)) })}</span>` : ""}
        </button>`;
      }).join("");
      $("pv-svcs").querySelectorAll(".pv-svc").forEach((b) => b.addEventListener("click", () => {
        svc = b.dataset.svc;
        renderSvcs();
        updateFind();
      }));
    }
    function updateFind() {
      const btn = $("pv-find");
      if (!svc) { btn.disabled = true; $("pv-findnote").textContent = T.pickService; return; }
      btn.disabled = false;
      const q = quotaFor(svc);
      $("pv-findnote").textContent = q.ok ? "" : q.note + " " + T.stillView;
    }

    let matches = [], selection = new Set();
    function candidatesFor(code) {
      const hc = homeCoords();
      let list = providers.filter((x) => x.service_type === code && x.email && !protectedIds.has(x.id))
        .map((x) => ({ ...x, _d: (hc && typeof x.lat === "number" && typeof x.lng === "number") ? haversineKm(hc[0], hc[1], x.lat, x.lng) : null }));
      if (hc && home.km > 0) list = list.filter((x) => x._d != null && x._d <= home.km);
      list.sort((a, b) => (a._d ?? 1e9) - (b._d ?? 1e9));
      return list;
    }
    $("pv-find").addEventListener("click", () => {
      if (!svc) return;
      if (home.km > 0 && !homeCoords()) {
        notify("warn", T.needPostal);
        $("pv-postal").focus();
        return;
      }
      goStep(2);
      $("pv-results").style.display = "none";
      $("pv-searching").style.display = "block";
      ["pv-s1", "pv-s2", "pv-s3"].forEach((sid, i) => {
        $(sid).classList.remove("show");
        setTimeout(() => $(sid).classList.add("show"), 150 + i * 320);
      });
      setTimeout(() => {
        $("pv-searching").style.display = "none";
        $("pv-results").style.display = "block";
        renderMatches();
      }, 1250);
    });

    function renderMatches() {
      const all = candidatesFor(svc);
      matches = home.km > 0 ? all : all.slice(0, 15);
      selection = new Set(matches.slice(0, BATCH).map((x) => x.id));
      const nProt = providers.filter((x) => x.service_type === svc && x.email && protectedIds.has(x.id)).length;
      $("pv-res-title").textContent = matches.length
        ? tpl(matches.length === 1 ? (home.km > 0 ? T.clinicsWithin1 : T.clinicsFound1) : (home.km > 0 ? T.clinicsWithinN : T.clinicsFoundN), { n: matches.length, km: home.km, svc: svcNice() })
        : tpl(home.km > 0 ? T.noMatchesWithin : T.noMatchesYet, { km: home.km });
      $("pv-res-sub").textContent = matches.length ? tpl(T.resSub, { n: Math.min(BATCH, matches.length) }) : "";
      if (!matches.length) {
        $("pv-mlist").innerHTML = `<p class="pv-empty2">${esc(home.km > 0 ? T.tryWider : T.noneYet)}</p>`;
        $("pv-res-notes").innerHTML = nProt ? `<p class="pv-protected">${tpl(esc(nProt === 1 ? T.protectedNear1 : T.protectedNearN), { n: nProt, name: esc(first) })}</p>` : "";
        $("pv-to3").style.display = "none";
        drawMap();
        return;
      }
      $("pv-to3").style.display = "";
      $("pv-mlist").innerHTML = matches.map((x, i) => `
        <label class="pv-m${i < BATCH ? " on" : ""}" data-id="${x.id}" style="--cd:${Math.min(i, 8) * 0.07}s">
          <input type="checkbox" ${i < BATCH ? "checked" : ""} />
          <span class="rk">${i + 1}</span>
          <span class="bd">
            <span class="nm">${esc(x.name)}</span>
            <span class="mt">${esc(x.borough || x.city || "")}${x.languages ? " · " + esc(x.languages) : ""}${x.phone ? " · " + esc(x.phone) : ""}</span>
          </span>
          <span class="dist${x._d == null ? " far" : ""}">${x._d == null ? esc(T.distNA) : x._d < 1 ? "< 1 km" : km1(x._d) + " km"}</span>
        </label>`).join("");
      $("pv-res-notes").innerHTML =
        `<p class="pv-mnote">${tpl(esc(T.mnoteMain), { n: BATCH })} ${home.km === 0 && all.length > 15 ? esc(T.mnoteNearest15) + " " : ""}${esc(T.mnoteMatched)}</p>`
        + (nProt ? `<p class="pv-protected">${tpl(esc(nProt === 1 ? T.protected1 : T.protectedN), { n: nProt })}</p>` : "");
      const relabel = () => { $("pv-to3").textContent = T.reviewEmailBtn; };
      $("pv-mlist").querySelectorAll(".pv-m").forEach((row) => {
        const cb = row.querySelector("input");
        cb.addEventListener("change", () => {
          const pid = row.dataset.id;
          if (cb.checked) {
            if (selection.size >= BATCH) {
              cb.checked = false;
              const cap = $("pv-cap");
              cap.textContent = T.capMax;
              cap.classList.remove("show");
              void cap.offsetWidth;
              cap.classList.add("show");
              clearTimeout(cap._t);
              cap._t = setTimeout(() => cap.classList.remove("show"), 3500);
              return;
            }
            selection.add(pid);
            row.classList.add("on");
          } else {
            selection.delete(pid);
            row.classList.remove("on");
          }
          relabel();
          if (gmap) syncPins();
        });
      });
      relabel();
      drawMap();
    }

    let gmap = null, gInfo = null, gPins = [], gHome = [], gm = null;
    function loadGoogle() {
      return new Promise((res, rej) => {
        if (window.google && window.google.maps) return res(window.google.maps);
        if (!GMAPS_KEY || GMAPS_KEY.indexOf("PASTE_") === 0) return rej(new Error("nokey"));
        window.__uaGmapsReady = () => res(window.google.maps);
        const sc = document.createElement("script");
        sc.src = "https://maps.googleapis.com/maps/api/js?key=" + encodeURIComponent(GMAPS_KEY) + "&loading=async&callback=__uaGmapsReady";
        sc.onerror = () => rej(new Error("load"));
        document.head.appendChild(sc);
      });
    }
    function iwHTML(x, rank) {
      const L = T.svcs[x.service_type];
      const q = x.address ? x.address + ", " + (x.city || "Montréal") : x.lat + "," + x.lng;
      const dir = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(q);
      return `<div class="pv-iw"><b>${rank ? rank + " · " : ""}${esc(x.name)}</b>
        <span class="svc" style="color:${SVCCOLOR[x.service_type] || "#6D28D9"}">${esc(L ? L.name : x.service_type)}</span>
        ${x.address ? `<div class="row">${esc(x.address)}${x.borough ? " · " + esc(x.borough) : ""}</div>` : (x.borough || x.city) ? `<div class="row">${esc(x.borough || x.city)}</div>` : ""}
        ${x.phone ? `<div class="row">☎ ${esc(x.phone)}</div>` : ""}
        ${x.languages ? `<div class="row">🗣 ${esc(x.languages)}</div>` : ""}
        ${x._d != null ? `<div class="row">✦ ${tpl(esc(T.kmFromHome), { d: x._d < 1 ? esc(T.under1) : km1(x._d) })}</div>` : ""}
        ${x.website ? `<div class="row"><a href="${esc(x.website)}" target="_blank" rel="noopener">${esc(T.website)}</a></div>` : ""}
        <a class="dir" href="${dir}" target="_blank" rel="noopener">${esc(T.openGmaps)}</a></div>`;
    }
    function clearPins() { gPins.forEach((m2) => m2.setMap(null)); gPins = []; gHome.forEach((m2) => m2.setMap(null)); gHome = []; }
    function syncPins() {
      gPins.forEach((m2) => m2.setOpacity(selection.has(m2.__uaId) ? 1 : 0.35));
    }
    function drawPins() {
      if (!gmap || !gm) return;
      clearPins();
      const bounds = new gm.LatLngBounds();
      matches.forEach((x, i) => {
        if (typeof x.lat !== "number" || typeof x.lng !== "number") return;
        const mk = new gm.Marker({
          map: gmap, position: { lat: x.lat, lng: x.lng },
          icon: { path: gm.SymbolPath.CIRCLE, scale: 13, fillColor: "#6D28D9", fillOpacity: 1, strokeColor: "#fff", strokeWeight: 2.5 },
          label: { text: String(i + 1), color: "#fff", fontSize: "12px", fontWeight: "800" },
          title: x.name,
        });
        mk.__uaId = x.id;
        mk.addListener("click", () => { gInfo.setContent(iwHTML(x, i + 1)); gInfo.open({ map: gmap, anchor: mk }); });
        gPins.push(mk);
        bounds.extend(mk.getPosition());
      });
      const hc = homeCoords();
      if (hc) {
        const star = new gm.Marker({
          map: gmap, position: { lat: hc[0], lng: hc[1] },
          icon: { path: "M 0,-12 L 3.5,-4 12,-4 5,1.5 7.5,10 0,5 -7.5,10 -5,1.5 -12,-4 -3.5,-4 Z", scale: 1, fillColor: "#FCD34D", fillOpacity: 1, strokeColor: "#221B36", strokeWeight: 1.5 },
          title: T.homeApprox, zIndex: 999,
        });
        star.addListener("click", () => { gInfo.setContent(`<div class="pv-iw"><b>${esc(T.homeTitle)}</b><div class="row">${esc(T.homeNote)}</div></div>`); gInfo.open({ map: gmap, anchor: star }); });
        gHome.push(star);
        bounds.extend(star.getPosition());
        if (home.km > 0) {
          const circ = new gm.Circle({ map: gmap, center: { lat: hc[0], lng: hc[1] }, radius: home.km * 1000, strokeColor: "#6D28D9", strokeOpacity: 0.4, strokeWeight: 1.5, fillColor: "#6D28D9", fillOpacity: 0.05 });
          gHome.push({ setMap: (v) => circ.setMap(v) });
        }
      }
      if (!bounds.isEmpty()) {
        gmap.fitBounds(bounds, 48);
        if (gPins.length <= 1) gm.event.addListenerOnce(gmap, "idle", () => { if (gmap.getZoom() > 13) gmap.setZoom(13); });
      }
      syncPins();
    }
    async function drawMap() {
      const box = $("pv-map");
      try {
        gm = (await loadGoogle());
        if (!gmap) {
          gmap = new gm.Map(box, {
            center: { lat: 45.53, lng: -73.65 }, zoom: 10,
            mapTypeControl: false, streetViewControl: false, fullscreenControl: true,
            styles: [{ featureType: "poi", elementType: "labels", stylers: [{ visibility: "off" }] }],
          });
          gInfo = new gm.InfoWindow();
        }
        drawPins();
      } catch (e) {
        box.innerHTML = e && e.message === "nokey"
          ? `<div class="pv-mapmiss">${T.mapNoKey}</div>`
          : `<div class="pv-mapmiss">${esc(T.mapFail)}</div>`;
      }
    }

    function svcNice() { const m = T.svcs[svc]; return m ? m.cat : T.servicesFallback; }
    let seededFor = null;
    function seedEmail() {
      if (seededFor === svc && $("pv-msg").value.trim()) return;
      seededFor = svc;
      const L = T.svcs[svc] || {};
      $("pv-msg").value = tpl(T.emailBody, {
        parent: parent || "…",
        svc: L.seek || T.servicesFallback,
        child: id.age != null ? tpl(T.childAged, { age: id.age }) : T.childPlain,
        name: first,
        dx: dxTxt ? " (" + dxTxt + ")" : "",
        travel: home.km > 0 ? tpl(T.travelUpTo, { km: home.km }) : "",
        parent2: parent || "",
      });
    }
    function renderReview() {
      const sel = matches.map((x, i2) => ({ x, rank: i2 + 1 })).filter((o) => selection.has(o.x.id));
      const names = sel.map((o) => o.x.name);
      $("pv-recap").innerHTML =
        `<div class="pv-tohead"><span>${esc(T.sendingTo)}</span><b>${tpl(esc(names.length === 1 ? T.clinics1 : T.clinicsN), { n: names.length })}</b><em>${esc(svcNice())} · ${esc(T.oneEmailEach)}</em></div>`
        + `<div class="pv-tolist">`
        + sel.map((o) => `<div class="pv-to"><i>${o.rank}</i><span class="tn">${esc(o.x.name)}</span><span class="tm">${o.x._d != null ? (o.x._d < 1 ? "&lt; 1 km" : km1(o.x._d) + " km") : ""}${o.x.borough ? (o.x._d != null ? " · " : "") + esc(o.x.borough) : ""}</span></div>`).join("")
        + `</div>`;
      $("pv-subject").innerHTML = `${esc(T.subjectLabel)} <b>${esc(tpl(T.emailSubject, { svc: (T.svcs[svc] || {}).subj || T.servicesFallback, name: first, age: id.age != null ? tpl(T.subjAge, { age: id.age }) : "" }))}</b> <span style="color:var(--faint)">${esc(T.setAuto)}</span>`;
      seedEmail();
      const q = quotaFor(svc);
      const btn = $("pv-send");
      const consent = $("pv-consent").checked;
      btn.textContent = T.sendBtn;
      btn.disabled = !q.ok || names.length === 0 || !consent;
      $("pv-quota").textContent = !q.ok ? q.note
        : names.length === 0 ? T.selectOne
        : !consent ? T.tickConsent
        : T.quotaReady;
      $("pv-upsell").innerHTML = (!q.ok && planKey === "free")
        ? upsellHTML(T.upsellTitle, T.upsellMsg, T.upsellCta)
        : "";
    }
    $("pv-to3").addEventListener("click", () => {
      if (!selection.size) { notify("info", T.selectFirst); return; }
      $("pv-review").style.display = "";
      $("pv-sent").style.display = "none";
      renderReview();
      goStep(3);
    });
    $("pv-back1").addEventListener("click", () => goStep(1));
    $("pv-back2").addEventListener("click", () => goStep(2));
    $("pv-consent").addEventListener("change", renderReview);

    $("pv-send").addEventListener("click", async () => {
      if ($("pv-send").disabled || !svc || !selection.size) return;
      const n = selection.size;
      if (!confirm(tpl(n === 1 ? T.confirmSend1 : T.confirmSendN, { name: first, of: ofName(first), n }))) return;
      const btn = $("pv-send");
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = T.sending;
      try {
        const s1 = await UA.getValidSession();
        const r = await fetch(FN_URL, {
          method: "POST",
          headers: { Authorization: "Bearer " + s1.access_token, "Content-Type": "application/json" },
          body: JSON.stringify({ passport_id: p.id, service_type: svc, provider_ids: [...selection], message: $("pv-msg").value }),
        });
        const out = await r.json().catch(() => ({}));
        if (r.ok && out.ok) {
          const names = matches.filter((x) => selection.has(x.id)).map((x) => x.name);
          requests.unshift({ id: out.request_id, service_type: svc, status: "sent", sent_count: out.sent, created_at: new Date().toISOString() });
          [...selection].forEach((pid) => protectedIds.add(pid));
          $("pv-review").style.display = "none";
          $("pv-sent").style.display = "block";
          $("pv-sent").innerHTML = `<div class="pv-sentbox">
            <div class="big">✦</div>
            <h3>${tpl(esc(out.sent === 1 ? T.sentTo1 : T.sentToN), { n: out.sent })}</h3>
            <p class="names">${names.map(esc).join(" · ")}</p>
            <p>${esc(T.sentNote)}</p>
            <p style="font-size:.7rem;color:var(--faint)">${tpl(esc(T.sentLogged), { date: new Date().toLocaleDateString(window.uaLocale || "en-CA", { month: "short", day: "numeric", year: "numeric" }) })}</p>
            <button type="button" class="btn btn-primary btn-sm" id="pv-again">${esc(T.newSearch)}</button>
          </div>`;
          $("pv-consent").checked = false;
          $("pv-again").addEventListener("click", () => { seededFor = null; renderSvcs(); updateFind(); goStep(1); });
          notify("ok", T.sentToast);
        } else if (r.status === 402) {
          notify("warn", out.message || T.err402);
          renderReview();
        } else if (r.status === 429 || r.status === 409 || r.status === 503) {
          notify("info", out.message || T.errBusy);
          renderReview();
        } else {
          notify("err", out.message || T.errSend);
          renderReview();
        }
      } catch (e) {
        notify("err", T.errNetwork);
        renderReview();
      }
      btn.textContent = old;
    });

    $("pv-postal").value = home.postal;
    const KMSTEPS = [5, 10, 20, 30, 50];
    if (KMSTEPS.indexOf(home.km) < 0) home.km = 20;
    $("pv-km").value = String(KMSTEPS.indexOf(home.km));
    $("pv-kmval").textContent = tpl(T.kmVal, { km: home.km });
    $("pv-km").addEventListener("input", () => {
      home.km = KMSTEPS[+$("pv-km").value] || 20;
      $("pv-kmval").textContent = tpl(T.kmVal, { km: home.km });
      localStorage.setItem(GEO_KEY, JSON.stringify(home));
    });
    $("pv-postal").addEventListener("input", () => {
      home.postal = $("pv-postal").value.trim().toUpperCase();
      localStorage.setItem(GEO_KEY, JSON.stringify(home));
      $("pv-loc-hint").textContent = home.postal && !homeCoords()
        ? T.postalUnknown
        : "";
    });
    $("pv-postal").addEventListener("change", () => {
      const v = $("pv-postal").value.trim().toUpperCase();
      if (coordsForPostal(v) && v !== passportPostal) savePostalToPassport(v);
    });

    const topSug = SVCS.find((s) => suggestions[s.code]);
    svc = topSug ? topSug.code : null;
    renderSvcs();
    updateFind();
  })().catch((e) => console.error("[providers] hydrate failed", e));
</script>
