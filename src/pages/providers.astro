---
/* PROVIDERS-MATCHES-V2 — the matching WIZARD:
   1 · pick the service (wheel-suggested ones are badged)
   2 · address on file + radius (5–50 km / anywhere) + map
   3 · see the ACTUAL nearest clinics (up to 5, named, with distances)
       — recently-contacted ones are excluded by the 90-day protection
   4 · tick who to contact, edit the email draft, send
   The log of sent batches lives at the bottom (and in Applications).
   Matching is DISTANCE-based today; acceptance/waitlist/schedule data
   refine it once providers are onboard. Server still enforces plan
   quotas + 90-day protection — the UI only mirrors them. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Providers" activeNav="providers">
  <SectionTabs section="providers" active="matches" />

  <div class="pv-wrap">
    <div class="c3-ribbon rib-rose cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Find Providers</h1>
        <p>Pick a service, set your distance, choose the clinics — we write the email and keep the log.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div id="pv-gate"></div>

    <!-- ============ STEP 1 · SERVICE ============ -->
    <div class="pv-step cu-rev" style="--d:.04s">
      <div class="pv-step-head"><span class="pv-n">1</span><b>What are you looking for?</b><span class="pv-step-sub" id="pv-svc-sub">Matching is distance-based today — acceptance and waitlist data join as clinics come onboard.</span></div>
      <div class="pv-svcs" id="pv-svcs"></div>
    </div>

    <!-- ============ STEP 2 · LOCATION ============ -->
    <div class="pv-step cu-rev" style="--d:.08s">
      <div class="pv-step-head"><span class="pv-n">2</span><b>How far would you travel?</b></div>
      <div class="pv-loc">
        <input class="pv-postal" id="pv-postal" maxlength="7" placeholder="H2V 2K3" autocomplete="postal-code" />
        <div class="pv-radius" id="pv-radius">
          <button type="button" data-km="5">5 km</button>
          <button type="button" data-km="10">10 km</button>
          <button type="button" data-km="20">20 km</button>
          <button type="button" data-km="30">30 km</button>
          <button type="button" data-km="50">50 km</button>
          <button type="button" data-km="0" class="on">Anywhere</button>
        </div>
        <button type="button" class="btn btn-ghost btn-sm" id="pv-mapbtn">🗺 Map</button>
      </div>
      <p class="pv-loc-hint" id="pv-loc-hint">Distances are approximate (postal-code area), private, and never shared with providers.</p>
      <div id="pv-nopostal"></div>
      <div id="pv-map" class="pv-map" style="display:none"></div>
    </div>

    <!-- ============ STEP 3 · MATCHES ============ -->
    <div class="pv-step cu-rev" style="--d:.12s">
      <div class="pv-step-head"><span class="pv-n">3</span><b id="pv-m-title">Your closest matches</b><span class="pv-step-sub" id="pv-m-sub"></span></div>
      <div id="pv-matches"></div>
    </div>

    <!-- ============ STEP 4 · EMAIL + SEND ============ -->
    <div class="pv-step cu-rev" style="--d:.16s">
      <div class="pv-step-head"><span class="pv-n">4</span><b>The email</b><span class="pv-step-sub">Edit anything — each clinic automatically gets "Hello {their name}," on top, and replies go straight to your inbox.</span></div>
      <p class="pv-subject" id="pv-subject"></p>
      <textarea class="pv-msg" id="pv-msg" maxlength="2000" rows="11"></textarea>
      <p class="pv-footpeek" id="pv-footpeek"></p>
      <div class="pv-sendrow">
        <span class="pv-quota" id="pv-quota"></span>
        <button type="button" class="btn btn-primary" id="pv-send" disabled>✦ Send</button>
      </div>
      <div id="pv-upsell"></div>
    </div>

    <!-- ============ LOG ============ -->
    <div class="pv-step cu-rev" style="--d:.2s">
      <div class="pv-step-head"><span class="pv-n">✦</span><b>Sent batches</b><span class="pv-step-sub">Also in Providers → Applications.</span></div>
      <div id="pv-log"><p class="pv-empty2">Nothing sent yet.</p></div>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  .pv-wrap{display:flex;flex-direction:column;gap:14px;max-width:920px}
  .pv-step{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:16px 18px;box-shadow:var(--shadow)}
  .pv-step-head{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:12px}
  .pv-n{width:26px;height:26px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#F9A8D4,#B14A66);color:#fff;display:grid;place-items:center;font-family:var(--display);font-weight:700;font-size:.78rem;flex-shrink:0;align-self:center}
  .pv-step-head b{font-family:var(--display);font-size:1rem;color:var(--ink)}
  .pv-step-sub{font-size:.72rem;color:var(--muted);line-height:1.4}

  /* step 1 · services */
  .pv-svcs{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:8px}
  .pv-svc{position:relative;border:1.5px solid var(--line);border-radius:14px;padding:11px 13px;background:var(--card);cursor:pointer;text-align:left;font-family:inherit;transition:border-color .15s,transform .15s,box-shadow .15s}
  .pv-svc:hover{transform:translateY(-1px);border-color:#F3D8E1}
  .pv-svc.on{border-color:var(--rose);box-shadow:0 6px 18px rgba(177,74,102,.14);background:linear-gradient(135deg,#FFFDFD,#fff 60%)}
  .pv-svc .nm{display:block;font-size:.84rem;font-weight:700;color:var(--ink)}
  .pv-svc .fr{display:block;font-size:.68rem;color:var(--muted);margin-top:2px}
  .pv-svc .sug{display:inline-flex;align-items:center;gap:4px;font-size:.62rem;font-weight:700;background:var(--violet-50);border:1px solid var(--violet-100);color:#7c6bab;border-radius:9999px;padding:2px 8px;margin-top:7px}
  .pv-svc .cnt{position:absolute;top:9px;right:11px;font-size:.64rem;font-weight:700;color:var(--faint)}
  .pv-svc.on .cnt{color:var(--rose)}

  /* step 2 · location */
  .pv-loc{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .pv-postal{width:104px;padding:8px 11px;border:1px solid var(--line-2);border-radius:10px;font-size:.86rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .pv-postal:focus{border-color:#F9A8D4;box-shadow:0 0 0 3px rgba(177,74,102,.12)}
  .pv-radius{display:flex;gap:4px;background:var(--bg);border:1px solid var(--line);border-radius:9999px;padding:3px;flex-wrap:wrap}
  .pv-radius button{border:none;background:none;font-size:.72rem;font-weight:700;color:var(--muted);padding:5px 12px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:background .15s,color .15s;white-space:nowrap}
  .pv-radius button:hover{color:var(--ink)}
  .pv-radius button.on{background:var(--rose);color:#fff}
  .pv-loc-hint{font-size:.66rem;color:var(--faint);margin:8px 0 0}
  .pv-map{height:400px;border-radius:16px;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden;position:relative;z-index:1;margin-top:10px}
  .pv-warn{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:14px;padding:12px 16px;margin-top:10px}
  .pv-warn p{flex:1;font-size:.82rem;color:var(--amber);line-height:1.5;margin:0;min-width:220px}
  #pv-nopostal:empty{display:none}
  .pv-mappop{font-family:'Inter',sans-serif;font-size:.8rem;line-height:1.4}
  .pv-mappop b{display:block;font-size:.84rem}
  .pv-mappop .svc{font-weight:700;text-transform:uppercase;font-size:.64rem;letter-spacing:.05em}

  /* step 3 · match cards */
  .pv-mlist{display:flex;flex-direction:column;gap:8px}
  .pv-m{display:flex;align-items:center;gap:12px;border:1.5px solid var(--line);border-radius:14px;padding:11px 14px;cursor:pointer;transition:border-color .15s,background .15s}
  .pv-m:hover{border-color:#F3D8E1}
  .pv-m.on{border-color:var(--rose);background:linear-gradient(135deg,#FFFDFD,#fff 65%)}
  .pv-m input{width:17px;height:17px;accent-color:#B14A66;flex-shrink:0;cursor:pointer}
  .pv-m .bd{flex:1;min-width:0}
  .pv-m .nm{font-size:.88rem;font-weight:700;color:var(--ink);line-height:1.3}
  .pv-m .mt{font-size:.72rem;color:var(--muted);margin-top:2px}
  .pv-m .dist{flex-shrink:0;font-family:var(--display);font-size:.82rem;font-weight:700;color:var(--teal);background:var(--teal-bg);border-radius:9999px;padding:4px 12px;white-space:nowrap}
  .pv-m .dist.far{color:var(--muted);background:var(--bg)}
  .pv-mnote{font-size:.72rem;color:var(--faint);margin:10px 0 0;line-height:1.5}
  .pv-empty2{font-size:.83rem;color:var(--faint);margin:0;line-height:1.55}
  .pv-protected{font-size:.7rem;color:var(--amber);background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:10px;padding:7px 11px;margin-top:10px;line-height:1.45}

  /* step 4 · email */
  .pv-subject{font-size:.78rem;color:var(--muted);background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:8px 12px;margin:0 0 8px}
  .pv-subject b{color:var(--ink)}
  .pv-msg{width:100%;border:1px solid var(--line-2);border-radius:12px;padding:12px 14px;font-size:.86rem;line-height:1.6;color:var(--ink);background:var(--card);outline:none;font-family:inherit;resize:vertical}
  .pv-msg:focus{border-color:#F9A8D4;box-shadow:0 0 0 3px rgba(177,74,102,.12)}
  .pv-footpeek{font-size:.68rem;color:var(--faint);font-style:italic;margin:7px 0 0;line-height:1.5}
  .pv-sendrow{display:flex;align-items:center;gap:12px;margin-top:12px;flex-wrap:wrap}
  .pv-quota{flex:1;font-size:.72rem;color:var(--muted);min-width:200px}
  #pv-send:disabled{opacity:.55;cursor:default}
  #pv-upsell{margin-top:10px}
  #pv-upsell:empty{display:none}

  /* log */
  .pv-lrow{border-top:1px solid var(--line);padding:10px 0}
  .pv-lrow:first-child{border-top:none;padding-top:2px}
  .pv-ltop{display:flex;align-items:center;gap:10px;flex-wrap:wrap;font-size:.82rem}
  .pv-ltop .sv{font-weight:700;color:var(--ink)}
  .pv-ltop .dt{font-size:.72rem;color:var(--faint)}
  .pv-lpill{margin-left:auto;font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:3px 9px;border-radius:9999px}
  .pv-lpill.sent{background:var(--green-bg);color:var(--green)}
  .pv-lpill.partial{background:var(--amber-bg);color:var(--amber)}
  .pv-lpill.failed{background:#F9EDF1;color:var(--rose)}
  .pv-lpill.queued{background:var(--violet-50);color:var(--violet-700)}
  .pv-lnames{font-size:.74rem;color:var(--muted);margin-top:4px;line-height:1.5}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../lib/ua-data.js";
  import { scoreWheel, DOMAINS, scoreToBand } from "../lib/wheelScore.js";
  import { notify } from "../lib/notify.js";
  import { getPlan, PLANS, upsellHTML } from "../lib/plan.js";
  import { coordsForPostal, haversineKm } from "../lib/geo.js";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const BASE = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const FN_URL = BASE + "/functions/v1/send-outreach";
  const BATCH = 5;
  const SVCS = [
    { code: "slp", name: "Speech-language therapy", fr: "Orthophonie", wheel: ["Communication"] },
    { code: "ot", name: "Occupational therapy", fr: "Ergothérapie", wheel: ["Sensory Processing", "Daily Living Skills"] },
    { code: "aba", name: "Behaviour support", fr: "Psychoéducation / ABA", wheel: ["Emotional Regulation", "Flexibility & Transitions"] },
    { code: "psych", name: "Child psychologist", fr: "Psychologue", wheel: [] },
    { code: "social", name: "Social skills groups", fr: "Habiletés sociales", wheel: ["Social Connection"] },
  ];
  const SVCCOLOR = { slp: "#6D28D9", ot: "#0E8C82", aba: "#B14A66", psych: "#2563EB", social: "#4C9A2A" };

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("pv-gate").innerHTML = `<div class="pv-step" style="text-align:center"><p class="pv-empty2" style="margin-bottom:12px">Fill in the passport first — matching starts from your child's needs and your address.</p><a class="btn btn-primary btn-sm" href="/passport">Start the passport →</a></div>`;
      ["pv-svcs", "pv-matches", "pv-log"].forEach((i) => { $(i).innerHTML = ""; });
      $("pv-send").disabled = true;
      return;
    }
    const data = p.data || {};
    const id = UA.childIdentity(data);
    const first = id.first || "our child";
    const scored = scoreWheel(data);
    const parent = String((data.household || {}).g1name || "").replace(/\s*\([^)]*\)\s*$/, "").trim();
    const dxTxt = id.dx || "";
    const planKey = await getPlan();

    $("rb-av").textContent = (id.first || id.name || "·")[0].toUpperCase();
    if (id.first) $("rb-title").textContent = "Find Providers for " + id.first;

    /* ---------- data: directory, my contacts (90-day), my requests ---------- */
    const sess = await UA.getValidSession();
    const H = sess ? UA.authHeaders(sess.access_token) : null;
    const j = async (path) => { try { const r = await fetch(BASE + "/rest/v1/" + path, { headers: H }); return r.ok ? await r.json() : []; } catch (e) { return []; } };
    const [providers, contacts, requests, wl] = await Promise.all([
      j("providers?select=id,name,city,borough,languages,phone,service_type,lat,lng,email&active=eq.true"),
      j("outreach_contacts?select=provider_id,sent_at&passport_id=eq." + p.id),
      j("outreach_requests?select=id,service_type,status,sent_count,created_at&passport_id=eq." + p.id + "&order=created_at.desc"),
      UA.getWaitlist().catch(() => []),
    ]);
    const protectedIds = new Set(contacts.filter((c) => Date.now() - new Date(c.sent_at).getTime() < 90 * 864e5).map((c) => c.provider_id));

    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${providers.filter((x) => x.email).length}</b><span>contactable clinics</span></span>`,
      `<span class="c3-rstat"><b>${requests.length}</b><span>batches sent</span></span>`,
      `<a class="c3-rstat" href="/providers/waitlists"><b>${wl.length}</b><span>waitlist${wl.length === 1 ? "" : "s"}</span></a>`,
    ].join("");

    /* ---------- home location (address on file) ---------- */
    const GEO_KEY = "ua_home_geo_" + ((sess || {}).user || {}).id;
    let home = { postal: "", km: 0 };
    try { home = Object.assign(home, JSON.parse(localStorage.getItem(GEO_KEY) || "{}")); } catch (e) {}
    let passportPostal = String(((data.household || {}).postal) || ((data.childProfile || {}).postalCode) || "").trim().toUpperCase();
    if (passportPostal) home.postal = passportPostal;
    const homeCoords = () => coordsForPostal(home.postal);
    async function savePostalToPassport(postal) {
      try {
        const s2 = await UA.getValidSession();
        if (!s2) return;
        const newData = Object.assign({}, data);
        newData.household = Object.assign({}, data.household || {}, { postal });
        const r2 = await fetch(BASE + "/rest/v1/passports?id=eq." + p.id, {
          method: "PATCH",
          headers: Object.assign({}, UA.authHeaders(s2.access_token), { Prefer: "return=minimal" }),
          body: JSON.stringify({ data: newData }),
        });
        if (r2.ok) {
          passportPostal = postal;
          data.household = newData.household;
          renderWarn();
          notify("ok", "Postal code saved to " + first + "'s passport ✓");
        }
      } catch (e) {}
    }
    function renderWarn() {
      $("pv-nopostal").innerHTML = passportPostal ? "" :
        `<div class="pv-warn cu-rev"><span class="cu-blob" style="--blob:#FBF2E2;color:#A8650A;width:34px;height:34px;flex-shrink:0"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 3.2v6M8 12.3v.2"/></svg></span><p><b>No address on file for ${esc(first)}.</b> Type your postal code above — we'll save it to the passport so matching and outreach know where you are.</p></div>`;
    }
    renderWarn();

    /* ---------- step 1: services ---------- */
    let svc = null;
    const suggestions = {};
    SVCS.forEach((s) => {
      const flagged = s.wheel.map((d) => scored[d]).filter((dm) => dm && dm.score != null && scoreToBand(dm.score).rings >= 3);
      if (flagged.length) suggestions[s.code] = s.wheel.find((d) => scored[d] && scored[d].score != null && scoreToBand(scored[d].score).rings >= 3);
      if (s.code === "psych" && !(((data.diagnosis || {}).diagnoses || []).length)) suggestions[s.code] = "No diagnosis on file yet";
    });
    function renderSvcs() {
      $("pv-svcs").innerHTML = SVCS.map((s) => {
        const n = providers.filter((x) => x.service_type === s.code && x.email).length;
        const sug = suggestions[s.code];
        return `<button type="button" class="pv-svc${svc === s.code ? " on" : ""}" data-svc="${s.code}">
          <span class="cnt">${n} clinic${n === 1 ? "" : "s"}</span>
          <span class="nm">${s.name}</span>
          <span class="fr">${s.fr}</span>
          ${sug ? `<span class="sug">✦ ${esc(sug === "No diagnosis on file yet" ? sug : sug + " flagged on the wheel")}</span>` : ""}
        </button>`;
      }).join("");
      $("pv-svcs").querySelectorAll(".pv-svc").forEach((b) => b.addEventListener("click", () => {
        svc = b.dataset.svc;
        renderSvcs();
        seedEmail();
        renderMatches();
      }));
    }

    /* ---------- step 3: matches ---------- */
    let selection = new Set();
    function candidatesFor(code) {
      const hc = homeCoords();
      let list = providers.filter((x) => x.service_type === code && x.email && !protectedIds.has(x.id))
        .map((x) => ({ ...x, _d: (hc && typeof x.lat === "number" && typeof x.lng === "number") ? haversineKm(hc[0], hc[1], x.lat, x.lng) : null }));
      if (hc && home.km > 0) list = list.filter((x) => x._d != null && x._d <= home.km);
      list.sort((a, b) => (a._d ?? 1e9) - (b._d ?? 1e9));
      return list;
    }
    function renderMatches() {
      const host = $("pv-matches");
      if (!svc) {
        $("pv-m-title").textContent = "Your closest matches";
        $("pv-m-sub").textContent = "";
        host.innerHTML = `<p class="pv-empty2">Pick a service above and the five closest clinics appear here, ready to select.</p>`;
        selection = new Set();
        updateSend();
        return;
      }
      const meta = SVCS.find((s) => s.code === svc);
      const all = candidatesFor(svc);
      const list = all.slice(0, BATCH);
      const nProt = providers.filter((x) => x.service_type === svc && x.email && protectedIds.has(x.id)).length;
      $("pv-m-title").textContent = "Closest " + meta.name.toLowerCase() + " matches";
      $("pv-m-sub").textContent = home.km > 0 ? "within " + home.km + " km · nearest first" : "nearest first";
      if (!list.length) {
        host.innerHTML = `<p class="pv-empty2">${home.km > 0 ? "No contactable clinics within " + home.km + " km — try a wider radius or Anywhere." : "No contactable clinics for this service yet — the directory is filling."}</p>`
          + (nProt ? `<p class="pv-protected">${nProt} nearby clinic${nProt === 1 ? " was" : "s were"} contacted for ${esc(first)} in the last 90 days — they're excluded to protect the relationship.</p>` : "");
        selection = new Set();
        updateSend();
        return;
      }
      selection = new Set(list.map((x) => x.id));
      host.innerHTML = `<div class="pv-mlist">` + list.map((x) => `
        <label class="pv-m on" data-id="${x.id}">
          <input type="checkbox" checked />
          <span class="bd">
            <span class="nm" style="display:block">${esc(x.name)}</span>
            <span class="mt" style="display:block">${esc(x.borough || x.city || "")}${x.languages ? " · " + esc(x.languages) : ""}${x.phone ? " · " + esc(x.phone) : ""}</span>
          </span>
          <span class="dist${x._d == null ? " far" : ""}">${x._d == null ? "distance unknown" : x._d < 1 ? "< 1 km" : x._d.toFixed(1) + " km"}</span>
        </label>`).join("") + `</div>`
        + `<p class="pv-mnote">${all.length > BATCH ? all.length + " clinics match — showing the closest " + BATCH + ". " : ""}Distance-based matching for now ✦ acceptance &amp; waitlist data refine this as clinics join.</p>`
        + (nProt ? `<p class="pv-protected">${nProt} clinic${nProt === 1 ? "" : "s"} contacted in the last 90 days ${nProt === 1 ? "is" : "are"} excluded — providers stay protected from repeat emails.</p>` : "");
      host.querySelectorAll(".pv-m").forEach((row) => {
        const cb = row.querySelector("input");
        cb.addEventListener("change", () => {
          const pid = row.dataset.id;
          if (cb.checked) { selection.add(pid); row.classList.add("on"); }
          else { selection.delete(pid); row.classList.remove("on"); }
          updateSend();
        });
      });
      updateSend();
    }

    /* ---------- step 4: email ---------- */
    function svcNice() { const m = SVCS.find((s) => s.code === svc); return m ? m.name.toLowerCase() : "services"; }
    function seedEmail() {
      const ageTxt = id.age != null ? id.age + "-year-old " : "";
      $("pv-subject").innerHTML = `Subject: <b>Family seeking ${esc(svcNice())} — ${esc(first)}${id.age != null ? ", " + id.age + " y/o" : ""} (Montréal)</b> <span style="color:var(--faint)">· set automatically</span>`;
      $("pv-msg").value = `${parent ? parent + " here — " : ""}I'm looking for ${svcNice()} for my ${ageTxt}child, ${first}${dxTxt ? " (" + dxTxt + ")" : ""}, in the Montréal area.

Could you tell me:
• whether you're accepting new clients (or how long the waitlist is),
• your availability and rates,
• what you'd need from us for an intake.

I can share a one-page family profile with ${first}'s strengths, needs and history right away — it answers most intake questions.

Thank you so much,
${parent || ""}`;
      $("pv-footpeek").textContent = `Added automatically: "Hello {clinic name}," on top · a short UniqueApex footer with the 90-day no-repeat promise · Reply-To set to your email.`;
    }

    /* ---------- quota + send ---------- */
    function quotaFor(code) {
      const prior = requests.filter((r) => r.service_type === code);
      if (!prior.length) return { ok: true, note: planKey === "free" ? "Free plan: this is your included batch for " + svcNice() + "." : "" };
      if (planKey === "free") return { ok: false, note: "Free batch for this service already used " + new Date(prior[0].created_at).toLocaleDateString("en-CA", { month: "short", day: "numeric" }) + "." };
      const last = new Date(prior[0].created_at).getTime();
      const left = 30 * 864e5 - (Date.now() - last);
      if (left > 0) return { ok: false, note: "Next batch for this service unlocks in " + Math.ceil(left / 864e5) + " day" + (Math.ceil(left / 864e5) === 1 ? "" : "s") + "." };
      return { ok: true, note: "" };
    }
    function updateSend() {
      const btn = $("pv-send");
      if (!svc) { btn.disabled = true; btn.textContent = "✦ Send"; $("pv-quota").textContent = "Pick a service first."; return; }
      const q = quotaFor(svc);
      const n = selection.size;
      btn.textContent = "✦ Send to " + n + " clinic" + (n === 1 ? "" : "s");
      btn.disabled = !q.ok || n === 0;
      $("pv-quota").textContent = !q.ok ? q.note : (n === 0 ? "Select at least one clinic above." : q.note || "Sends one personalized email per clinic · replies come straight to you.");
      if (q.ok) $("pv-upsell").innerHTML = "";
      if (!q.ok && planKey === "free" && !$("pv-upsell").innerHTML) {
        $("pv-upsell").innerHTML = upsellHTML("That was the free batch ✦", "Monthly plans send a fresh batch per service every 30 days — and the concierge follows up for you.", "See the plans");
      }
    }
    $("pv-send").addEventListener("click", async () => {
      if ($("pv-send").disabled || !svc || !selection.size) return;
      const n = selection.size;
      if (!confirm("Send your email about " + first + " to the " + n + " selected clinic" + (n === 1 ? "" : "s") + "? Replies go straight to your inbox.")) return;
      const btn = $("pv-send");
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = "Sending…";
      try {
        const s1 = await UA.getValidSession();
        const r = await fetch(FN_URL, {
          method: "POST",
          headers: { Authorization: "Bearer " + s1.access_token, "Content-Type": "application/json" },
          body: JSON.stringify({ passport_id: p.id, service_type: svc, provider_ids: [...selection], message: $("pv-msg").value }),
        });
        const out = await r.json().catch(() => ({}));
        if (r.ok && out.ok) {
          notify("ok", "Sent to " + out.sent + " clinic" + (out.sent === 1 ? "" : "s") + " ✦ Replies land in your inbox.");
          requests.unshift({ id: out.request_id, service_type: svc, status: "sent", sent_count: out.sent, created_at: new Date().toISOString() });
          [...selection].forEach((pid) => protectedIds.add(pid));
          renderMatches();
          renderLog([...selection]);
        } else if (r.status === 402) {
          notify("warn", out.message || "The free plan includes one batch per service type.");
          updateSend();
        } else if (r.status === 429) {
          notify("info", out.message || "The next batch for this service unlocks soon.");
        } else if (r.status === 409 || r.status === 503) {
          notify("info", out.message || "Those clinics can't be contacted right now.");
        } else {
          notify("err", out.message || "Couldn't send — is the outreach function deployed?");
        }
      } catch (e) {
        notify("err", "Couldn't reach the outreach service — try again in a moment.");
      }
      btn.textContent = old;
      updateSend();
    });

    /* ---------- log ---------- */
    const nameOf = {};
    providers.forEach((x) => { nameOf[x.id] = x.name; });
    let logNames = {}; /* request_id -> [names] */
    async function loadLogNames() {
      const ids = requests.slice(0, 10).map((r) => r.id).filter(Boolean);
      if (!ids.length) return;
      const rows = await j("outreach_contacts?select=request_id,provider_id&request_id=in.(" + ids.join(",") + ")");
      rows.forEach((c) => { (logNames[c.request_id] = logNames[c.request_id] || []).push(nameOf[c.provider_id] || "clinic"); });
    }
    function renderLog(justSentNames) {
      const host = $("pv-log");
      if (!requests.length) { host.innerHTML = `<p class="pv-empty2">Nothing sent yet — your batches and their dates will appear here.</p>`; return; }
      host.innerHTML = requests.slice(0, 10).map((r, i) => {
        const meta = SVCS.find((s) => s.code === r.service_type);
        let names = logNames[r.id] || [];
        if (i === 0 && justSentNames && !names.length) names = justSentNames.map((pid) => nameOf[pid] || "clinic");
        return `<div class="pv-lrow">
          <div class="pv-ltop"><span class="sv">${esc(meta ? meta.name : r.service_type)}</span><span class="dt">${new Date(r.created_at).toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "numeric" })} · ${r.sent_count} clinic${r.sent_count === 1 ? "" : "s"}</span><span class="pv-lpill ${r.status}">${r.status}</span></div>
          ${names.length ? `<p class="pv-lnames">${names.map(esc).join(" · ")}</p>` : ""}
        </div>`;
      }).join("");
    }

    /* ---------- map ---------- */
    let map = null, homeLayer = null;
    function loadLeaflet() {
      return new Promise((res, rej) => {
        if (window.L) return res(window.L);
        const css = document.createElement("link");
        css.rel = "stylesheet";
        css.href = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css";
        document.head.appendChild(css);
        const js2 = document.createElement("script");
        js2.src = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js";
        js2.onload = () => res(window.L);
        js2.onerror = rej;
        document.head.appendChild(js2);
      });
    }
    function drawHome() {
      if (!map || !window.L) return;
      if (homeLayer) { map.removeLayer(homeLayer); homeLayer = null; }
      const hc = homeCoords();
      if (!hc) return;
      homeLayer = window.L.layerGroup();
      homeLayer.addLayer(window.L.circleMarker(hc, { radius: 8, color: "#221B36", weight: 2, fillColor: "#FCD34D", fillOpacity: 1 }).bindPopup("<div class='pv-mappop'><b>Home ✦</b>approximate — postal area</div>"));
      if (home.km > 0) homeLayer.addLayer(window.L.circle(hc, { radius: home.km * 1000, color: "#B14A66", weight: 1.5, fillColor: "#B14A66", fillOpacity: 0.06, dashArray: "6 6" }));
      homeLayer.addTo(map);
      if (home.km > 0) map.fitBounds(window.L.circle(hc, { radius: home.km * 1000 }).getBounds().pad(0.1));
    }
    async function openMap() {
      const box = $("pv-map");
      const showing = box.style.display !== "none";
      if (showing) { box.style.display = "none"; $("pv-mapbtn").textContent = "🗺 Map"; return; }
      box.style.display = "block";
      $("pv-mapbtn").textContent = "Hide map";
      try {
        const L = await loadLeaflet();
        if (!map) {
          map = L.map("pv-map").setView([45.53, -73.65], 10);
          L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 18, attribution: "© OpenStreetMap contributors" }).addTo(map);
          providers.filter((d2) => typeof d2.lat === "number" && typeof d2.lng === "number").forEach((d2) => {
            const col = SVCCOLOR[d2.service_type] || "#6D28D9";
            const meta = SVCS.find((s) => s.code === d2.service_type);
            L.circleMarker([d2.lat, d2.lng], { radius: 7, color: "#fff", weight: 1.5, fillColor: col, fillOpacity: d2.email ? 0.95 : 0.35 })
              .bindPopup(`<div class='pv-mappop'><b>${esc(d2.name || "Provider")}</b><span class='svc' style='color:${col}'>${esc(meta ? meta.name : d2.service_type)}</span> · ${esc(d2.borough || d2.city || "")}${d2.email ? "" : "<br><i>awaiting email — not contactable yet</i>"}</div>`)
              .addTo(map);
          });
        }
        setTimeout(() => { map.invalidateSize(); drawHome(); }, 60);
      } catch (e) {
        notify("warn", "The map couldn't load — check your connection.");
        box.style.display = "none";
        $("pv-mapbtn").textContent = "🗺 Map";
      }
    }
    $("pv-mapbtn").addEventListener("click", openMap);

    /* ---------- location wiring ---------- */
    function updateLoc() {
      const hc = homeCoords();
      $("pv-loc-hint").textContent = home.postal && !hc
        ? "That postal code isn't in our map yet — matches will show without distances until it is."
        : "Distances are approximate (postal-code area), private, and never shared with providers.";
      drawHome();
      renderMatches();
    }
    $("pv-postal").value = home.postal;
    document.querySelectorAll("#pv-radius button").forEach((b) => {
      b.classList.toggle("on", +b.dataset.km === home.km);
      b.addEventListener("click", () => {
        document.querySelectorAll("#pv-radius button").forEach((x) => x.classList.remove("on"));
        b.classList.add("on");
        home.km = +b.dataset.km;
        localStorage.setItem(GEO_KEY, JSON.stringify(home));
        updateLoc();
      });
    });
    $("pv-postal").addEventListener("input", () => {
      home.postal = $("pv-postal").value.trim().toUpperCase();
      localStorage.setItem(GEO_KEY, JSON.stringify(home));
      updateLoc();
    });
    $("pv-postal").addEventListener("change", () => {
      const v = $("pv-postal").value.trim().toUpperCase();
      if (coordsForPostal(v) && v !== passportPostal) savePostalToPassport(v);
    });

    /* ---------- boot: preselect the wheel's top suggestion ---------- */
    const topSug = SVCS.find((s) => suggestions[s.code]);
    svc = topSug ? topSug.code : null;
    renderSvcs();
    if (svc) seedEmail(); else { $("pv-subject").textContent = "Pick a service and the email writes itself — fully editable."; $("pv-msg").value = ""; $("pv-footpeek").textContent = ""; }
    renderMatches();
    await loadLogNames();
    renderLog();
  })().catch((e) => console.error("[providers] hydrate failed", e));
</script>
