---
/* PROVIDERS-MATCHES-V3 — staged matching flow with Google Maps.
   Screen 1 · pick service + distance → "Find matches"
   (searching animation — the platform's magic moment)
   Screen 2 · THE 5 MATCHES revealed: ranked cards + Google map,
              clickable pins with full clinic info + directions.
              Family unticks any clinic they don't want.
   Screen 3 · review & edit the email → send → success state.
   Sent-batch log lives at the bottom of every screen.
   Matching = distance for now; acceptance/waitlist/schedule factors
   slot into candidatesFor() once providers onboard.
   Server (send-outreach) still enforces quotas + 90-day protection. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Providers" activeNav="providers">
  <SectionTabs section="providers" active="matches" />

  <div class="pv-wrap">
    <div class="c3-ribbon rib-rose cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av" id="rb-av">·</span>
      <div class="c3-rib-id">
        <h1 id="rb-title">Find Providers</h1>
        <p>Tell us what you need — we match you with the 5 closest clinics, you approve the email, we send it.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div id="pv-gate"></div>

    <!-- crumbs -->
    <div class="pv-crumbs cu-rev" id="pv-crumbs" style="--d:.04s">
      <span class="pv-crumb cur" data-s="1"><i>1</i>Your search</span>
      <span class="pv-cline"></span>
      <span class="pv-crumb" data-s="2"><i>2</i>Your matches</span>
      <span class="pv-cline"></span>
      <span class="pv-crumb" data-s="3"><i>3</i>Review &amp; send</span>
    </div>

    <!-- ============ SCREEN 1 · SEARCH ============ -->
    <section class="pv-scr on" id="scr-1">
      <div class="pv-card cu-rev" style="--d:.08s">
        <h2 class="pv-h">What are you looking for?</h2>
        <div class="pv-svcs" id="pv-svcs"></div>
        <h2 class="pv-h" style="margin-top:18px">How far would you travel?</h2>
        <div class="pv-loc">
          <input class="pv-postal" id="pv-postal" maxlength="7" placeholder="H2V 2K3" autocomplete="postal-code" />
          <div class="pv-radius" id="pv-radius">
            <button type="button" data-km="5">5 km</button>
            <button type="button" data-km="10">10 km</button>
            <button type="button" data-km="20">20 km</button>
            <button type="button" data-km="30">30 km</button>
            <button type="button" data-km="50">50 km</button>
            <button type="button" data-km="0" class="on">Anywhere</button>
          </div>
        </div>
        <p class="pv-loc-hint" id="pv-loc-hint">Distances are approximate (postal-code area), private, and never shared with providers.</p>
        <div id="pv-nopostal"></div>
        <div class="pv-findrow">
          <span class="pv-findnote" id="pv-findnote"></span>
          <button type="button" class="btn btn-primary" id="pv-find">✦ Find matches</button>
        </div>
      </div>
    </section>

    <!-- ============ SCREEN 2 · MATCHES ============ -->
    <section class="pv-scr" id="scr-2">
      <div class="pv-card pv-searching" id="pv-searching" style="display:none">
        <div class="pv-orb"></div>
        <p class="pv-s-line" id="pv-s1">Searching the clinic directory…</p>
        <p class="pv-s-line" id="pv-s2">Measuring distances from home…</p>
        <p class="pv-s-line" id="pv-s3">Applying the 90-day protection…</p>
      </div>
      <div id="pv-results" style="display:none">
        <div class="pv-card">
          <div class="pv-res-head">
            <h2 class="pv-h" id="pv-res-title" style="margin:0">Your matches</h2>
            <span class="pv-res-sub" id="pv-res-sub"></span>
          </div>
          <div class="pv-results-grid">
            <div class="pv-mlist" id="pv-mlist"></div>
            <div class="pv-mapcol">
              <div id="pv-map" class="pv-map"></div>
              <p class="pv-maphint">Tap a pin for the clinic's details and directions ✦ the gold star is home.</p>
            </div>
          </div>
          <div id="pv-res-notes"></div>
          <div class="pv-navrow">
            <button type="button" class="btn btn-ghost" id="pv-back1">← Adjust search</button>
            <button type="button" class="btn btn-primary" id="pv-to3">Review the email →</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SCREEN 3 · REVIEW & SEND ============ -->
    <section class="pv-scr" id="scr-3">
      <div class="pv-card">
        <div id="pv-review">
          <h2 class="pv-h">Review the email</h2>
          <div class="pv-recap" id="pv-recap"></div>
          <p class="pv-subject" id="pv-subject"></p>
          <textarea class="pv-msg" id="pv-msg" maxlength="2000" rows="11"></textarea>
          <p class="pv-footpeek">Added automatically: "Hello {clinic name}," on top · a short UniqueApex footer with the 90-day no-repeat promise · Reply-To set to your email, so answers land in your inbox.</p>
          <div class="pv-navrow">
            <button type="button" class="btn btn-ghost" id="pv-back2">← Back to matches</button>
            <span class="pv-quota" id="pv-quota"></span>
            <button type="button" class="btn btn-primary" id="pv-send" disabled>✦ Send</button>
          </div>
          <div id="pv-upsell"></div>
        </div>
        <div id="pv-sent" style="display:none"></div>
      </div>
    </section>

    <!-- ============ LOG ============ -->
    <div class="pv-card cu-rev" style="--d:.12s">
      <div class="pv-log-head"><h2 class="pv-h" style="margin:0">Sent batches</h2><span class="pv-res-sub">every outreach is logged — also in Providers → Applications</span></div>
      <div id="pv-log"><p class="pv-empty2">Nothing sent yet.</p></div>
    </div>
  </div>
</AppFormLayout>

<style is:global>
  .pv-wrap{display:flex;flex-direction:column;gap:14px;max-width:1020px}
  .pv-card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:18px 20px;box-shadow:var(--shadow)}
  .pv-h{font-family:var(--display);font-size:1rem;color:var(--ink);margin:0 0 12px}
  .pv-empty2{font-size:.83rem;color:var(--faint);margin:0;line-height:1.55}

  /* crumbs */
  .pv-crumbs{display:flex;align-items:center;gap:10px;padding:2px 6px}
  .pv-crumb{display:inline-flex;align-items:center;gap:7px;font-size:.74rem;font-weight:700;color:var(--faint);white-space:nowrap}
  .pv-crumb i{font-style:normal;width:22px;height:22px;border-radius:50%;background:var(--bg);border:1.5px solid var(--line);display:grid;place-items:center;font-size:.66rem;transition:all .25s}
  .pv-crumb.cur{color:var(--ink)}
  .pv-crumb.cur i{background:var(--rose);border-color:var(--rose);color:#fff}
  .pv-crumb.done{color:var(--teal)}
  .pv-crumb.done i{background:var(--teal-bg);border-color:var(--teal);color:var(--teal)}
  .pv-cline{flex:1;height:1.5px;background:var(--line);border-radius:1px;min-width:18px}

  /* screens */
  .pv-scr{display:none}
  .pv-scr.on{display:block;animation:pvIn .3s ease both}
  @keyframes pvIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

  /* screen 1 */
  .pv-svcs{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:8px}
  .pv-svc{position:relative;border:1.5px solid var(--line);border-radius:14px;padding:11px 13px;background:var(--card);cursor:pointer;text-align:left;font-family:inherit;transition:border-color .15s,transform .15s,box-shadow .15s}
  .pv-svc:hover{transform:translateY(-1px);border-color:#F3D8E1}
  .pv-svc.on{border-color:var(--rose);box-shadow:0 6px 18px rgba(177,74,102,.14);background:linear-gradient(135deg,#FFFDFD,#fff 60%)}
  .pv-svc .nm{display:block;font-size:.84rem;font-weight:700;color:var(--ink)}
  .pv-svc .fr{display:block;font-size:.68rem;color:var(--muted);margin-top:2px}
  .pv-svc .sug{display:inline-flex;align-items:center;gap:4px;font-size:.62rem;font-weight:700;background:var(--violet-50);border:1px solid var(--violet-100);color:#7c6bab;border-radius:9999px;padding:2px 8px;margin-top:7px}
  .pv-svc .cnt{position:absolute;top:9px;right:11px;font-size:.64rem;font-weight:700;color:var(--faint)}
  .pv-svc.on .cnt{color:var(--rose)}
  .pv-loc{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .pv-postal{width:104px;padding:8px 11px;border:1px solid var(--line-2);border-radius:10px;font-size:.86rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .pv-postal:focus{border-color:#F9A8D4;box-shadow:0 0 0 3px rgba(177,74,102,.12)}
  .pv-radius{display:flex;gap:4px;background:var(--bg);border:1px solid var(--line);border-radius:9999px;padding:3px;flex-wrap:wrap}
  .pv-radius button{border:none;background:none;font-size:.72rem;font-weight:700;color:var(--muted);padding:5px 12px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:background .15s,color .15s;white-space:nowrap}
  .pv-radius button:hover{color:var(--ink)}
  .pv-radius button.on{background:var(--rose);color:#fff}
  .pv-loc-hint{font-size:.66rem;color:var(--faint);margin:8px 0 0}
  .pv-warn{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:14px;padding:12px 16px;margin-top:10px}
  .pv-warn p{flex:1;font-size:.82rem;color:var(--amber);line-height:1.5;margin:0;min-width:220px}
  #pv-nopostal:empty{display:none}
  .pv-findrow{display:flex;align-items:center;gap:12px;margin-top:16px;flex-wrap:wrap}
  .pv-findnote{flex:1;font-size:.72rem;color:var(--muted);min-width:180px}

  /* searching moment */
  .pv-searching{text-align:center;padding:38px 20px}
  .pv-orb{width:46px;height:46px;margin:0 auto 16px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#F9A8D4,#B14A66);animation:pvOrb 1.1s ease-in-out infinite}
  @keyframes pvOrb{0%,100%{transform:scale(1) rotate(0deg)}50%{transform:scale(1.14) rotate(8deg)}}
  .pv-s-line{font-size:.84rem;color:var(--muted);margin:5px 0;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s}
  .pv-s-line.show{opacity:1;transform:none}

  /* screen 2 · results */
  .pv-res-head{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:12px}
  .pv-res-sub{font-size:.72rem;color:var(--muted)}
  .pv-results-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:14px;align-items:start}
  @media (max-width:860px){.pv-results-grid{grid-template-columns:1fr}}
  .pv-mlist{display:flex;flex-direction:column;gap:8px}
  .pv-m{display:flex;align-items:center;gap:11px;border:1.5px solid var(--line);border-radius:14px;padding:10px 13px;cursor:pointer;transition:border-color .15s,background .15s;opacity:0;animation:pvCard .4s ease forwards;animation-delay:var(--cd,0s)}
  @keyframes pvCard{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .pv-m:hover{border-color:#F3D8E1}
  .pv-m.on{border-color:var(--rose);background:linear-gradient(135deg,#FFFDFD,#fff 65%)}
  .pv-m input{width:17px;height:17px;accent-color:#B14A66;flex-shrink:0;cursor:pointer}
  .pv-m .rk{width:24px;height:24px;border-radius:50%;display:grid;place-items:center;color:#fff;font-size:.7rem;font-weight:800;flex-shrink:0}
  .pv-m .bd{flex:1;min-width:0}
  .pv-m .nm{display:block;font-size:.86rem;font-weight:700;color:var(--ink);line-height:1.3}
  .pv-m .mt{display:block;font-size:.7rem;color:var(--muted);margin-top:2px}
  .pv-m .dist{flex-shrink:0;font-family:var(--display);font-size:.78rem;font-weight:700;color:var(--teal);background:var(--teal-bg);border-radius:9999px;padding:4px 11px;white-space:nowrap}
  .pv-m .dist.far{color:var(--muted);background:var(--bg)}
  .pv-protected{font-size:.7rem;color:var(--amber);background:var(--amber-bg);border:1px solid #EBDCC3;border-radius:10px;padding:7px 11px;margin-top:12px;line-height:1.45}
  .pv-mnote{font-size:.72rem;color:var(--faint);margin:12px 0 0;line-height:1.5}
  .pv-mapcol{position:sticky;top:12px}
  .pv-map{height:420px;border-radius:16px;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden;background:var(--bg)}
  .pv-maphint{font-size:.66rem;color:var(--faint);margin:7px 2px 0}
  .pv-mapmiss{display:grid;place-items:center;height:100%;padding:20px;text-align:center;font-size:.78rem;color:var(--muted);line-height:1.6}
  .pv-navrow{display:flex;align-items:center;gap:12px;margin-top:16px;flex-wrap:wrap;justify-content:space-between}

  /* google infowindow card */
  .pv-iw{font-family:'Inter',sans-serif;font-size:.8rem;line-height:1.5;max-width:240px;color:#221B36}
  .pv-iw b{display:block;font-size:.86rem;margin-bottom:2px}
  .pv-iw .svc{font-weight:700;text-transform:uppercase;font-size:.62rem;letter-spacing:.05em}
  .pv-iw .row{color:#6A6478;font-size:.74rem;margin-top:3px}
  .pv-iw a{color:#B14A66;font-weight:700;text-decoration:none}
  .pv-iw .dir{display:inline-block;margin-top:7px}

  /* screen 3 */
  .pv-recap{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
  .pv-chip{font-size:.68rem;font-weight:700;background:var(--bg);border:1px solid var(--line);color:var(--muted);border-radius:9999px;padding:4px 11px}
  .pv-chip.hl{background:var(--teal-bg);border-color:transparent;color:var(--teal)}
  .pv-subject{font-size:.78rem;color:var(--muted);background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:8px 12px;margin:0 0 8px}
  .pv-subject b{color:var(--ink)}
  .pv-msg{width:100%;border:1px solid var(--line-2);border-radius:12px;padding:12px 14px;font-size:.86rem;line-height:1.6;color:var(--ink);background:var(--card);outline:none;font-family:inherit;resize:vertical}
  .pv-msg:focus{border-color:#F9A8D4;box-shadow:0 0 0 3px rgba(177,74,102,.12)}
  .pv-footpeek{font-size:.68rem;color:var(--faint);font-style:italic;margin:7px 0 0;line-height:1.5}
  .pv-quota{flex:1;font-size:.72rem;color:var(--muted);text-align:right;min-width:160px}
  #pv-send:disabled,#pv-find:disabled{opacity:.55;cursor:default}
  #pv-upsell{margin-top:10px}
  #pv-upsell:empty{display:none}
  .pv-sentbox{text-align:center;padding:26px 14px}
  .pv-sentbox .big{font-size:2rem}
  .pv-sentbox h3{font-family:var(--display);font-size:1.06rem;color:var(--ink);margin:8px 0 6px}
  .pv-sentbox p{font-size:.82rem;color:var(--muted);line-height:1.6;margin:0 auto 6px;max-width:460px}
  .pv-sentbox .names{font-size:.74rem;color:var(--teal);font-weight:700}

  /* log */
  .pv-log-head{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:10px}
  .pv-lrow{border-top:1px solid var(--line);padding:10px 0}
  .pv-lrow:first-child{border-top:none;padding-top:2px}
  .pv-ltop{display:flex;align-items:center;gap:10px;flex-wrap:wrap;font-size:.82rem}
  .pv-ltop .sv{font-weight:700;color:var(--ink)}
  .pv-ltop .dt{font-size:.72rem;color:var(--faint)}
  .pv-lpill{margin-left:auto;font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:3px 9px;border-radius:9999px}
  .pv-lpill.sent{background:var(--green-bg);color:var(--green)}
  .pv-lpill.partial{background:var(--amber-bg);color:var(--amber)}
  .pv-lpill.failed{background:#F9EDF1;color:var(--rose)}
  .pv-lpill.queued{background:var(--violet-50);color:var(--violet-700)}
  .pv-lnames{font-size:.74rem;color:var(--muted);margin-top:4px;line-height:1.5}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../lib/ua-data.js";
  import { scoreWheel, DOMAINS, scoreToBand } from "../lib/wheelScore.js";
  import { notify } from "../lib/notify.js";
  import { getPlan, PLANS, upsellHTML } from "../lib/plan.js";
  import { coordsForPostal, haversineKm } from "../lib/geo.js";

  /* ── Google Maps key ─────────────────────────────────────────────
     Paste your key between the quotes. Full setup guide:
     GOOGLE_MAPS_SETUP.md (repo root). Restrict the key to your
     domains + the Maps JavaScript API before going live. */
  const GMAPS_KEY = "PASTE_YOUR_GOOGLE_MAPS_KEY_HERE";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const BASE = "https://eghqufgiudxjkbsddtnx.supabase.co";
  const FN_URL = BASE + "/functions/v1/send-outreach";
  const BATCH = 5;
  const SVCS = [
    { code: "slp", name: "Speech-language therapy", fr: "Orthophonie", wheel: ["Communication"] },
    { code: "ot", name: "Occupational therapy", fr: "Ergothérapie", wheel: ["Sensory Processing", "Daily Living Skills"] },
    { code: "aba", name: "Behaviour support", fr: "Psychoéducation / ABA", wheel: ["Emotional Regulation", "Flexibility & Transitions"] },
    { code: "psych", name: "Child psychologist", fr: "Psychologue", wheel: [] },
    { code: "social", name: "Social skills groups", fr: "Habiletés sociales", wheel: ["Social Connection"] },
  ];
  const SVCCOLOR = { slp: "#6D28D9", ot: "#0E8C82", aba: "#B14A66", psych: "#2563EB", social: "#4C9A2A" };

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    if (!p) {
      $("pv-gate").innerHTML = `<div class="pv-card" style="text-align:center"><p class="pv-empty2" style="margin-bottom:12px">Fill in the passport first — matching starts from your child's needs and your address.</p><a class="btn btn-primary btn-sm" href="/passport">Start the passport →</a></div>`;
      $("pv-crumbs").style.display = "none";
      document.querySelectorAll(".pv-scr").forEach((el) => { el.style.display = "none"; });
      return;
    }
    const data = p.data || {};
    const id = UA.childIdentity(data);
    const first = id.first || "our child";
    const scored = scoreWheel(data);
    const parent = String((data.household || {}).g1name || "").replace(/\s*\([^)]*\)\s*$/, "").trim();
    const dxTxt = id.dx || "";
    const planKey = await getPlan();

    $("rb-av").textContent = (id.first || id.name || "·")[0].toUpperCase();
    if (id.first) $("rb-title").textContent = "Find Providers for " + id.first;

    /* ---------- data ---------- */
    const sess = await UA.getValidSession();
    const H = sess ? UA.authHeaders(sess.access_token) : null;
    const j = async (path) => { try { const r = await fetch(BASE + "/rest/v1/" + path, { headers: H }); return r.ok ? await r.json() : []; } catch (e) { return []; } };
    const [providers, contacts, requests, wl] = await Promise.all([
      j("providers?select=id,name,city,borough,address,languages,phone,website,service_type,lat,lng,email&active=eq.true"),
      j("outreach_contacts?select=provider_id,sent_at&passport_id=eq." + p.id),
      j("outreach_requests?select=id,service_type,status,sent_count,created_at&passport_id=eq." + p.id + "&order=created_at.desc"),
      UA.getWaitlist().catch(() => []),
    ]);
    const protectedIds = new Set(contacts.filter((c) => Date.now() - new Date(c.sent_at).getTime() < 90 * 864e5).map((c) => c.provider_id));

    $("rb-stats").innerHTML = [
      `<span class="c3-rstat"><b>${providers.filter((x) => x.email).length}</b><span>contactable clinics</span></span>`,
      `<span class="c3-rstat"><b>${requests.length}</b><span>batches sent</span></span>`,
      `<a class="c3-rstat" href="/providers/waitlists"><b>${wl.length}</b><span>waitlist${wl.length === 1 ? "" : "s"}</span></a>`,
    ].join("");

    /* ---------- home ---------- */
    const GEO_KEY = "ua_home_geo_" + ((sess || {}).user || {}).id;
    let home = { postal: "", km: 0 };
    try { home = Object.assign(home, JSON.parse(localStorage.getItem(GEO_KEY) || "{}")); } catch (e) {}
    let passportPostal = String(((data.household || {}).postal) || ((data.childProfile || {}).postalCode) || "").trim().toUpperCase();
    if (passportPostal) home.postal = passportPostal;
    const homeCoords = () => coordsForPostal(home.postal);
    async function savePostalToPassport(postal) {
      try {
        const s2 = await UA.getValidSession();
        if (!s2) return;
        const newData = Object.assign({}, data);
        newData.household = Object.assign({}, data.household || {}, { postal });
        const r2 = await fetch(BASE + "/rest/v1/passports?id=eq." + p.id, {
          method: "PATCH",
          headers: Object.assign({}, UA.authHeaders(s2.access_token), { Prefer: "return=minimal" }),
          body: JSON.stringify({ data: newData }),
        });
        if (r2.ok) {
          passportPostal = postal;
          data.household = newData.household;
          renderWarn();
          notify("ok", "Postal code saved to " + first + "'s passport ✓");
        }
      } catch (e) {}
    }
    function renderWarn() {
      $("pv-nopostal").innerHTML = passportPostal ? "" :
        `<div class="pv-warn cu-rev"><p><b>No address on file for ${esc(first)}.</b> Type your postal code above — we'll save it to the passport so matching knows where home is.</p></div>`;
    }
    renderWarn();

    /* ---------- crumbs + screens ---------- */
    let step = 1;
    function goStep(n) {
      step = n;
      [1, 2, 3].forEach((i) => {
        $("scr-" + i).classList.toggle("on", i === n);
        const c = document.querySelector(`.pv-crumb[data-s="${i}"]`);
        c.classList.toggle("cur", i === n);
        c.classList.toggle("done", i < n);
      });
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    /* ---------- screen 1 · service + distance ---------- */
    let svc = null;
    const suggestions = {};
    SVCS.forEach((s) => {
      const flagged = s.wheel.map((d) => scored[d]).filter((dm) => dm && dm.score != null && scoreToBand(dm.score).rings >= 3);
      if (flagged.length) suggestions[s.code] = s.wheel.find((d) => scored[d] && scored[d].score != null && scoreToBand(scored[d].score).rings >= 3);
      if (s.code === "psych" && !(((data.diagnosis || {}).diagnoses || []).length)) suggestions[s.code] = "No diagnosis on file yet";
    });
    function quotaFor(code) {
      const prior = requests.filter((r) => r.service_type === code);
      if (!prior.length) return { ok: true, note: planKey === "free" ? "Free plan: one included batch for this service." : "" };
      if (planKey === "free") return { ok: false, note: "Free batch for this service used " + new Date(prior[0].created_at).toLocaleDateString("en-CA", { month: "short", day: "numeric" }) + " — upgrade for monthly rounds." };
      const left = 30 * 864e5 - (Date.now() - new Date(prior[0].created_at).getTime());
      if (left > 0) { const d2 = Math.ceil(left / 864e5); return { ok: false, note: "Next batch for this service unlocks in " + d2 + " day" + (d2 === 1 ? "" : "s") + "." }; }
      return { ok: true, note: "" };
    }
    function renderSvcs() {
      $("pv-svcs").innerHTML = SVCS.map((s) => {
        const n = providers.filter((x) => x.service_type === s.code && x.email).length;
        const sug = suggestions[s.code];
        return `<button type="button" class="pv-svc${svc === s.code ? " on" : ""}" data-svc="${s.code}">
          <span class="cnt">${n} clinic${n === 1 ? "" : "s"}</span>
          <span class="nm">${s.name}</span>
          <span class="fr">${s.fr}</span>
          ${sug ? `<span class="sug">✦ ${esc(sug === "No diagnosis on file yet" ? sug : sug + " flagged on the wheel")}</span>` : ""}
        </button>`;
      }).join("");
      $("pv-svcs").querySelectorAll(".pv-svc").forEach((b) => b.addEventListener("click", () => {
        svc = b.dataset.svc;
        renderSvcs();
        updateFind();
      }));
    }
    function updateFind() {
      const btn = $("pv-find");
      if (!svc) { btn.disabled = true; $("pv-findnote").textContent = "Pick a service to start matching."; return; }
      btn.disabled = false;
      const q = quotaFor(svc);
      $("pv-findnote").textContent = q.ok
        ? "We'll show the " + BATCH + " closest clinics — you approve everything before anything is sent."
        : q.note + " You can still view your matches.";
    }

    /* ---------- matching ---------- */
    let matches = [], selection = new Set();
    function candidatesFor(code) {
      const hc = homeCoords();
      let list = providers.filter((x) => x.service_type === code && x.email && !protectedIds.has(x.id))
        .map((x) => ({ ...x, _d: (hc && typeof x.lat === "number" && typeof x.lng === "number") ? haversineKm(hc[0], hc[1], x.lat, x.lng) : null }));
      if (hc && home.km > 0) list = list.filter((x) => x._d != null && x._d <= home.km);
      list.sort((a, b) => (a._d ?? 1e9) - (b._d ?? 1e9));
      return list;
    }
    $("pv-find").addEventListener("click", () => {
      if (!svc) return;
      if (home.km > 0 && !homeCoords()) {
        notify("warn", "Add a valid postal code for distance matching — or choose Anywhere.");
        $("pv-postal").focus();
        return;
      }
      goStep(2);
      $("pv-results").style.display = "none";
      $("pv-searching").style.display = "block";
      ["pv-s1", "pv-s2", "pv-s3"].forEach((sid, i) => {
        $(sid).classList.remove("show");
        setTimeout(() => $(sid).classList.add("show"), 150 + i * 320);
      });
      setTimeout(() => {
        $("pv-searching").style.display = "none";
        $("pv-results").style.display = "block";
        renderMatches();
      }, 1250);
    });

    function renderMatches() {
      const meta = SVCS.find((s) => s.code === svc);
      const all = candidatesFor(svc);
      matches = all.slice(0, BATCH);
      selection = new Set(matches.map((x) => x.id));
      const nProt = providers.filter((x) => x.service_type === svc && x.email && protectedIds.has(x.id)).length;
      $("pv-res-title").textContent = matches.length
        ? matches.length + " match" + (matches.length === 1 ? "" : "es") + " for " + meta.name.toLowerCase()
        : "No matches " + (home.km > 0 ? "within " + home.km + " km" : "yet");
      $("pv-res-sub").textContent = matches.length ? (home.km > 0 ? "within " + home.km + " km of home · nearest first" : "nearest first") : "";
      if (!matches.length) {
        $("pv-mlist").innerHTML = `<p class="pv-empty2">${home.km > 0 ? "Try a wider radius or Anywhere — the directory is still growing." : "No contactable clinics for this service yet — the directory is filling."}</p>`;
        $("pv-res-notes").innerHTML = nProt ? `<p class="pv-protected">${nProt} nearby clinic${nProt === 1 ? " was" : "s were"} contacted for ${esc(first)} in the last 90 days — they're excluded to protect the relationship.</p>` : "";
        $("pv-to3").style.display = "none";
        drawMap();
        return;
      }
      $("pv-to3").style.display = "";
      $("pv-mlist").innerHTML = matches.map((x, i) => `
        <label class="pv-m on" data-id="${x.id}" style="--cd:${i * 0.09}s">
          <input type="checkbox" checked />
          <span class="rk" style="background:${SVCCOLOR[svc]}">${i + 1}</span>
          <span class="bd">
            <span class="nm">${esc(x.name)}</span>
            <span class="mt">${esc(x.borough || x.city || "")}${x.languages ? " · " + esc(x.languages) : ""}${x.phone ? " · " + esc(x.phone) : ""}</span>
          </span>
          <span class="dist${x._d == null ? " far" : ""}">${x._d == null ? "distance n/a" : x._d < 1 ? "< 1 km" : x._d.toFixed(1) + " km"}</span>
        </label>`).join("");
      $("pv-res-notes").innerHTML =
        `<p class="pv-mnote">${all.length > BATCH ? all.length + " clinics matched — these are the closest " + BATCH + ". " : ""}Matched by distance today ✦ acceptance &amp; waitlist data refine this as clinics join. Untick any clinic you'd rather skip.</p>`
        + (nProt ? `<p class="pv-protected">${nProt} clinic${nProt === 1 ? "" : "s"} contacted in the last 90 days ${nProt === 1 ? "is" : "are"} excluded — providers stay protected from repeat emails.</p>` : "");
      $("pv-mlist").querySelectorAll(".pv-m").forEach((row) => {
        const cb = row.querySelector("input");
        cb.addEventListener("change", () => {
          const pid = row.dataset.id;
          if (cb.checked) { selection.add(pid); row.classList.add("on"); }
          else { selection.delete(pid); row.classList.remove("on"); }
          $("pv-to3").textContent = "Review the email → (" + selection.size + ")";
          if (gmap) syncPins();
        });
      });
      $("pv-to3").textContent = "Review the email → (" + selection.size + ")";
      drawMap();
    }

    /* ---------- Google Map ---------- */
    let gmap = null, gInfo = null, gPins = [], gHome = [], gm = null;
    function loadGoogle() {
      return new Promise((res, rej) => {
        if (window.google && window.google.maps) return res(window.google.maps);
        if (!GMAPS_KEY || GMAPS_KEY.indexOf("PASTE_") === 0) return rej(new Error("nokey"));
        window.__uaGmapsReady = () => res(window.google.maps);
        const sc = document.createElement("script");
        sc.src = "https://maps.googleapis.com/maps/api/js?key=" + encodeURIComponent(GMAPS_KEY) + "&loading=async&callback=__uaGmapsReady";
        sc.onerror = () => rej(new Error("load"));
        document.head.appendChild(sc);
      });
    }
    function iwHTML(x, rank) {
      const meta = SVCS.find((s) => s.code === x.service_type);
      const q = x.address ? x.address + ", " + (x.city || "Montréal") : x.lat + "," + x.lng;
      const dir = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(q);
      return `<div class="pv-iw"><b>${rank ? rank + " · " : ""}${esc(x.name)}</b>
        <span class="svc" style="color:${SVCCOLOR[x.service_type] || "#6D28D9"}">${esc(meta ? meta.name : x.service_type)}</span>
        ${x.address ? `<div class="row">${esc(x.address)}${x.borough ? " · " + esc(x.borough) : ""}</div>` : (x.borough || x.city) ? `<div class="row">${esc(x.borough || x.city)}</div>` : ""}
        ${x.phone ? `<div class="row">☎ ${esc(x.phone)}</div>` : ""}
        ${x.languages ? `<div class="row">🗣 ${esc(x.languages)}</div>` : ""}
        ${x._d != null ? `<div class="row">✦ ${x._d < 1 ? "under 1" : x._d.toFixed(1)} km from home</div>` : ""}
        ${x.website ? `<div class="row"><a href="${esc(x.website)}" target="_blank" rel="noopener">Website ↗</a></div>` : ""}
        <a class="dir" href="${dir}" target="_blank" rel="noopener">Open in Google Maps ↗</a></div>`;
    }
    function clearPins() { gPins.forEach((m2) => m2.setMap(null)); gPins = []; gHome.forEach((m2) => m2.setMap(null)); gHome = []; }
    function syncPins() {
      gPins.forEach((m2) => m2.setOpacity(selection.has(m2.__uaId) ? 1 : 0.35));
    }
    function drawPins() {
      if (!gmap || !gm) return;
      clearPins();
      const bounds = new gm.LatLngBounds();
      matches.forEach((x, i) => {
        if (typeof x.lat !== "number" || typeof x.lng !== "number") return;
        const mk = new gm.Marker({
          map: gmap, position: { lat: x.lat, lng: x.lng },
          icon: { path: gm.SymbolPath.CIRCLE, scale: 13, fillColor: SVCCOLOR[svc] || "#6D28D9", fillOpacity: 1, strokeColor: "#fff", strokeWeight: 2.5 },
          label: { text: String(i + 1), color: "#fff", fontSize: "12px", fontWeight: "800" },
          title: x.name,
        });
        mk.__uaId = x.id;
        mk.addListener("click", () => { gInfo.setContent(iwHTML(x, i + 1)); gInfo.open({ map: gmap, anchor: mk }); });
        gPins.push(mk);
        bounds.extend(mk.getPosition());
      });
      const hc = homeCoords();
      if (hc) {
        const star = new gm.Marker({
          map: gmap, position: { lat: hc[0], lng: hc[1] },
          icon: { path: "M 0,-12 L 3.5,-4 12,-4 5,1.5 7.5,10 0,5 -7.5,10 -5,1.5 -12,-4 -3.5,-4 Z", scale: 1, fillColor: "#FCD34D", fillOpacity: 1, strokeColor: "#221B36", strokeWeight: 1.5 },
          title: "Home (approximate)", zIndex: 999,
        });
        star.addListener("click", () => { gInfo.setContent(`<div class="pv-iw"><b>Home ✦</b><div class="row">Approximate — postal-code area. Never shared with providers.</div></div>`); gInfo.open({ map: gmap, anchor: star }); });
        gHome.push(star);
        bounds.extend(star.getPosition());
        if (home.km > 0) {
          const circ = new gm.Circle({ map: gmap, center: { lat: hc[0], lng: hc[1] }, radius: home.km * 1000, strokeColor: "#B14A66", strokeOpacity: 0.4, strokeWeight: 1.5, fillColor: "#B14A66", fillOpacity: 0.05 });
          gHome.push({ setMap: (v) => circ.setMap(v) });
        }
      }
      if (!bounds.isEmpty()) {
        gmap.fitBounds(bounds, 48);
        if (gPins.length <= 1) gm.event.addListenerOnce(gmap, "idle", () => { if (gmap.getZoom() > 13) gmap.setZoom(13); });
      }
      syncPins();
    }
    async function drawMap() {
      const box = $("pv-map");
      try {
        gm = (await loadGoogle());
        if (!gmap) {
          gmap = new gm.Map(box, {
            center: { lat: 45.53, lng: -73.65 }, zoom: 10,
            mapTypeControl: false, streetViewControl: false, fullscreenControl: true,
            styles: [{ featureType: "poi", elementType: "labels", stylers: [{ visibility: "off" }] }],
          });
          gInfo = new gm.InfoWindow();
        }
        drawPins();
      } catch (e) {
        box.innerHTML = e && e.message === "nokey"
          ? `<div class="pv-mapmiss">🗺 The map needs its Google Maps key.<br>Open <b>GOOGLE_MAPS_SETUP.md</b> in the project folder for the 10-minute setup, then paste the key into providers.astro.</div>`
          : `<div class="pv-mapmiss">The map couldn't load — check your connection (your matches above still work).</div>`;
      }
    }

    /* ---------- screen 3 · review & send ---------- */
    function svcNice() { const m = SVCS.find((s) => s.code === svc); return m ? m.name.toLowerCase() : "services"; }
    let seededFor = null;
    function seedEmail() {
      if (seededFor === svc && $("pv-msg").value.trim()) return; /* keep the parent's edits */
      seededFor = svc;
      $("pv-msg").value = `${parent ? parent + " here — " : ""}I'm looking for ${svcNice()} for my ${id.age != null ? id.age + "-year-old " : ""}child, ${first}${dxTxt ? " (" + dxTxt + ")" : ""}, in the Montréal area.

Could you tell me:
• whether you're accepting new clients (or how long the waitlist is),
• your availability and rates,
• what you'd need from us for an intake.

I can share a one-page family profile with ${first}'s strengths, needs and history right away — it answers most intake questions.

Thank you so much,
${parent || ""}`;
    }
    function renderReview() {
      const names = matches.filter((x) => selection.has(x.id)).map((x) => x.name);
      $("pv-recap").innerHTML =
        `<span class="pv-chip hl">${esc(svcNice())}</span>`
        + `<span class="pv-chip hl">${names.length} clinic${names.length === 1 ? "" : "s"}</span>`
        + names.map((n) => `<span class="pv-chip">${esc(n)}</span>`).join("");
      $("pv-subject").innerHTML = `Subject: <b>Family seeking ${esc(svcNice())} — ${esc(first)}${id.age != null ? ", " + id.age + " y/o" : ""} (Montréal)</b> <span style="color:var(--faint)">· set automatically</span>`;
      seedEmail();
      const q = quotaFor(svc);
      const btn = $("pv-send");
      btn.textContent = "✦ Send to " + names.length + " clinic" + (names.length === 1 ? "" : "s");
      btn.disabled = !q.ok || names.length === 0;
      $("pv-quota").textContent = !q.ok ? q.note : (names.length === 0 ? "Go back and select at least one clinic." : "One personalized email per clinic · replies come straight to you.");
      $("pv-upsell").innerHTML = (!q.ok && planKey === "free")
        ? upsellHTML("That was the free batch ✦", "Monthly plans send a fresh batch per service every 30 days — and the concierge follows up for you.", "See the plans")
        : "";
    }
    $("pv-to3").addEventListener("click", () => {
      if (!selection.size) { notify("info", "Select at least one clinic first."); return; }
      $("pv-review").style.display = "";
      $("pv-sent").style.display = "none";
      renderReview();
      goStep(3);
    });
    $("pv-back1").addEventListener("click", () => goStep(1));
    $("pv-back2").addEventListener("click", () => goStep(2));

    $("pv-send").addEventListener("click", async () => {
      if ($("pv-send").disabled || !svc || !selection.size) return;
      const n = selection.size;
      if (!confirm("Send your email about " + first + " to the " + n + " selected clinic" + (n === 1 ? "" : "s") + "? Replies go straight to your inbox.")) return;
      const btn = $("pv-send");
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = "Sending…";
      try {
        const s1 = await UA.getValidSession();
        const r = await fetch(FN_URL, {
          method: "POST",
          headers: { Authorization: "Bearer " + s1.access_token, "Content-Type": "application/json" },
          body: JSON.stringify({ passport_id: p.id, service_type: svc, provider_ids: [...selection], message: $("pv-msg").value }),
        });
        const out = await r.json().catch(() => ({}));
        if (r.ok && out.ok) {
          const names = matches.filter((x) => selection.has(x.id)).map((x) => x.name);
          requests.unshift({ id: out.request_id, service_type: svc, status: "sent", sent_count: out.sent, created_at: new Date().toISOString() });
          if (out.request_id) logNames[out.request_id] = names;
          [...selection].forEach((pid) => protectedIds.add(pid));
          renderLog();
          $("pv-review").style.display = "none";
          $("pv-sent").style.display = "block";
          $("pv-sent").innerHTML = `<div class="pv-sentbox">
            <div class="big">✦</div>
            <h3>Sent to ${out.sent} clinic${out.sent === 1 ? "" : "s"}</h3>
            <p class="names">${names.map(esc).join(" · ")}</p>
            <p>Replies land straight in your inbox. Clinics move fastest when you answer within a day — and the Family Passport PDF covers most intake questions.</p>
            <p style="font-size:.7rem;color:var(--faint)">Logged ${new Date().toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "numeric" })} · these clinics are now protected from repeat emails for 90 days.</p>
            <button type="button" class="btn btn-primary btn-sm" id="pv-again">Start a new search</button>
          </div>`;
          $("pv-again").addEventListener("click", () => { seededFor = null; renderSvcs(); updateFind(); goStep(1); });
          notify("ok", "Sent ✦ replies go straight to your inbox.");
        } else if (r.status === 402) {
          notify("warn", out.message || "The free plan includes one batch per service type.");
          renderReview();
        } else if (r.status === 429 || r.status === 409 || r.status === 503) {
          notify("info", out.message || "Those clinics can't be contacted right now.");
          renderReview();
        } else {
          notify("err", out.message || "Couldn't send — is the outreach function deployed?");
          renderReview();
        }
      } catch (e) {
        notify("err", "Couldn't reach the outreach service — try again in a moment.");
        renderReview();
      }
      btn.textContent = old;
    });

    /* ---------- log ---------- */
    const nameOf = {};
    providers.forEach((x) => { nameOf[x.id] = x.name; });
    let logNames = {};
    async function loadLogNames() {
      const ids = requests.slice(0, 10).map((r) => r.id).filter(Boolean);
      if (!ids.length) return;
      const rows = await j("outreach_contacts?select=request_id,provider_id&request_id=in.(" + ids.join(",") + ")");
      rows.forEach((c) => { (logNames[c.request_id] = logNames[c.request_id] || []).push(nameOf[c.provider_id] || "clinic"); });
    }
    function renderLog() {
      const host = $("pv-log");
      if (!requests.length) { host.innerHTML = `<p class="pv-empty2">Nothing sent yet — every batch is logged here with its date and clinics.</p>`; return; }
      host.innerHTML = requests.slice(0, 10).map((r) => {
        const meta = SVCS.find((s) => s.code === r.service_type);
        const names = logNames[r.id] || [];
        return `<div class="pv-lrow">
          <div class="pv-ltop"><span class="sv">${esc(meta ? meta.name : r.service_type)}</span><span class="dt">${new Date(r.created_at).toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "numeric" })} · ${r.sent_count} clinic${r.sent_count === 1 ? "" : "s"}</span><span class="pv-lpill ${r.status}">${r.status}</span></div>
          ${names.length ? `<p class="pv-lnames">${names.map(esc).join(" · ")}</p>` : ""}
        </div>`;
      }).join("");
    }

    /* ---------- location wiring ---------- */
    $("pv-postal").value = home.postal;
    document.querySelectorAll("#pv-radius button").forEach((b) => {
      b.classList.toggle("on", +b.dataset.km === home.km);
      b.addEventListener("click", () => {
        document.querySelectorAll("#pv-radius button").forEach((x) => x.classList.remove("on"));
        b.classList.add("on");
        home.km = +b.dataset.km;
        localStorage.setItem(GEO_KEY, JSON.stringify(home));
      });
    });
    $("pv-postal").addEventListener("input", () => {
      home.postal = $("pv-postal").value.trim().toUpperCase();
      localStorage.setItem(GEO_KEY, JSON.stringify(home));
      $("pv-loc-hint").textContent = home.postal && !homeCoords()
        ? "That postal code isn't in our map yet — matches will show without distances until it is."
        : "Distances are approximate (postal-code area), private, and never shared with providers.";
    });
    $("pv-postal").addEventListener("change", () => {
      const v = $("pv-postal").value.trim().toUpperCase();
      if (coordsForPostal(v) && v !== passportPostal) savePostalToPassport(v);
    });

    /* ---------- boot ---------- */
    const topSug = SVCS.find((s) => suggestions[s.code]);
    svc = topSug ? topSug.code : null;
    renderSvcs();
    updateFind();
    await loadLogNames();
    renderLog();
  })().catch((e) => console.error("[providers] hydrate failed", e));
</script>
