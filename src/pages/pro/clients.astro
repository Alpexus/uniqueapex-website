---
/* PRO-CLIENTS-V1 — the families this provider serves. Click a family
   for the working view: next session, documents exchanged, questions.
   Preview data; TODO-LIVE: derive from accepted bookings + shares. */
import ProviderLayout from "@/layouts/ProviderLayout.astro";
---
<ProviderLayout title="Clients — UniqueApex Pro" active="clients">
  <div class="pgrid">
    <div class="pkpis">
      <div class="pkpi teal"><b id="ck-active">·</b><span>active families</span></div>
      <div class="pkpi"><b id="ck-week">·</b><span>seen this week</span></div>
      <div class="pkpi amber"><b id="ck-wait">·</b><span>on your waitlist</span></div>
    </div>

    <div class="pc">
      <div class="pc-h"><b>Your families</b><span>click a row for details · families share only what they choose to share</span></div>
      <div id="cl-list"></div>
      <p class="pnote">When a family you serve updates their child's shared profile, you'll see it here first — no more chasing paperwork by email.</p>
    </div>
  </div>
</ProviderLayout>

<script is:inline>
  (function () {
    var esc = function (s) { return String(s == null ? "" : s).replace(/[&<>"]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]; }); };
    var COLORS = ["#0E8C82", "#6D28D9", "#A8650A", "#B14A66", "#2F9E63", "#2563EB"];
    var FAMILIES = [
      { child: "Liam", age: 4, since: "Feb 2026", next: "Today 9:00", docs: 3, q: 1, status: "active", note: "Working on two-word phrases · parents very engaged" },
      { child: "Noor", age: 6, since: "Mar 2026", next: "Today 10:30", docs: 2, q: 0, status: "active", note: "School collaboration — plan d'intervention shared" },
      { child: "Éloi", age: 5, since: "Nov 2025", next: "Today 13:00", docs: 5, q: 1, status: "active", note: "Re-assessment planned for September" },
      { child: "Maya", age: 7, since: "Jan 2026", next: "Today 15:00", docs: 4, q: 0, status: "active", note: "Assessment phase — report due next week" },
      { child: "Zoé", age: 3, since: "—", next: "Pending request", docs: 0, q: 0, status: "waitlist", note: "Initial consultation requested" },
      { child: "Adam", age: 8, since: "—", next: "Pending request", docs: 0, q: 0, status: "waitlist", note: "After-school slot needed" },
    ];

    document.getElementById("ck-active").textContent = FAMILIES.filter(function (f) { return f.status === "active"; }).length;
    document.getElementById("ck-week").textContent = 4;
    document.getElementById("ck-wait").textContent = FAMILIES.filter(function (f) { return f.status === "waitlist"; }).length;

    var host = document.getElementById("cl-list");
    host.innerHTML = FAMILIES.map(function (f, i) {
      return "<div class='prow' data-i='" + i + "' style='cursor:pointer;flex-wrap:wrap'>" +
        "<span class='av' style='background:" + COLORS[i % COLORS.length] + "'>" + esc(f.child[0]) + "</span>" +
        "<span class='tx'><b>" + esc(f.child) + ", " + f.age + "</b><span>Client since " + esc(f.since) + " · next: " + esc(f.next) + "</span></span>" +
        (f.docs ? "<span class='ppill grey'>" + f.docs + " docs</span>" : "") +
        (f.q ? "<span class='ppill rose'>" + f.q + " question</span>" : "") +
        "<span class='ppill " + (f.status === "active" ? "teal" : "amber") + "'>" + f.status + "</span>" +
        "<span class='cl-detail' style='display:none;flex-basis:100%;font-size:.78rem;color:var(--p-mut);padding:8px 0 2px 46px;line-height:1.5'>" + esc(f.note) + " · <a href='/pro/documents' style='color:var(--p-teal);font-weight:700;text-decoration:none'>documents</a> · <a href='/pro/questions' style='color:var(--p-teal);font-weight:700;text-decoration:none'>questions</a></span>" +
        "</div>";
    }).join("");
    host.querySelectorAll(".prow").forEach(function (row) {
      row.addEventListener("click", function (e) {
        if (e.target.closest("a")) return;
        var d = row.querySelector(".cl-detail");
        d.style.display = d.style.display === "none" ? "block" : "none";
      });
    });
  })();
</script>
