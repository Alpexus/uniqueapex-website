---
/* PRO-PROFILE-V1 — the provider's public card, editable. This is
   also where the FUTURE MATCHING FACTORS live: accepting new
   clients, waitlist weeks, booking on/off — exactly the data the
   family-side matching will use beyond distance.
   Preview: saves to localStorage (ua_pro_profile); TODO-LIVE:
   providers table columns (see provider_portal_setup.sql). */
import ProviderLayout from "@/layouts/ProviderLayout.astro";
import DICT from "@/i18n/pro-portal.js";
---
<ProviderLayout title="Profile — UniqueApex Pro" titleFr="Profil de la clinique" active="profile">
  <div class="pro-prof">

    <div class="pc">
      <div class="pc-h"><b data-i18n="profile_cardTitle">Clinic profile</b><span><span data-i18n="profile_subA">one profile per practice — your </span><a href="/pro/team" style="color:var(--p-teal);font-weight:700;text-decoration:none" data-i18n="profile_subTeam">team</a><span data-i18n="profile_subB"> appears on it. Solo practice? You're a clinic of one.</span></span></div>

      <label class="pfield"><span data-i18n="profile_nameLabel">Clinic / practice name</span><input class="pin" id="pf-name" type="text" placeholder="e.g. Clinique Orthophonie Plateau" data-i18n-ph="profile_namePh" /></label>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <label class="pfield"><span data-i18n="profile_serviceLabel">Service</span>
          <select class="pin" id="pf-service">
            <option data-i18n="profile_svcSlp">Speech-language therapy</option>
            <option data-i18n="profile_svcOt">Occupational therapy</option>
            <option data-i18n="profile_svcBehaviour">Behaviour support</option>
            <option data-i18n="profile_svcPsych">Child psychology</option>
            <option data-i18n="profile_svcSocial">Social skills groups</option>
          </select>
        </label>
        <label class="pfield"><span data-i18n="profile_langsLabel">Languages</span><input class="pin" id="pf-langs" type="text" placeholder="FR, EN" data-i18n-ph="profile_langsPh" /></label>
        <label class="pfield"><span data-i18n="profile_boroughLabel">Borough / area</span><input class="pin" id="pf-borough" type="text" placeholder="Le Plateau-Mont-Royal" data-i18n-ph="profile_boroughPh" /></label>
        <label class="pfield"><span data-i18n="profile_phoneLabel">Phone</span><input class="pin" id="pf-phone" type="text" placeholder="(514) 555-0123" data-i18n-ph="profile_phonePh" /></label>
        <label class="pfield"><span data-i18n="profile_webLabel">Website</span><input class="pin" id="pf-web" type="text" placeholder="https://…" data-i18n-ph="profile_webPh" /></label>
        <label class="pfield"><span data-i18n="profile_feesLabel">Session fee (range)</span><input class="pin" id="pf-fees" type="text" placeholder="e.g. 120–150 $ / session" data-i18n-ph="profile_feesPh" /></label>
      </div>
      <label class="pfield"><span data-i18n="profile_bioLabel">About your practice</span><textarea class="pin" id="pf-bio" rows="4" placeholder="Two or three warm sentences — who you help, how you work, what a first visit looks like." data-i18n-ph="profile_bioPh"></textarea></label>

      <div class="pc-h" style="margin-top:6px"><b data-i18n="profile_matchTitle">Matching & booking</b><span data-i18n="profile_matchSub">families see this — and matching will use it</span></div>
      <div style="display:flex;gap:22px;flex-wrap:wrap;align-items:center">
        <label class="pswitch"><input type="checkbox" id="pf-accepting" checked /> <span data-i18n="profile_accepting">Accepting new clients</span></label>
        <label class="pswitch" style="gap:7px"><span data-i18n="profile_waitLabel">Waitlist</span>&nbsp;
          <select class="pin" id="pf-wait" style="width:auto;padding:6px 10px">
            <option value="0" data-i18n="profile_waitNone">none</option><option value="2" data-i18n="profile_wait2">~2 weeks</option><option value="4" data-i18n="profile_wait4">~4 weeks</option><option value="8" data-i18n="profile_wait8">~8 weeks</option><option value="12" data-i18n="profile_wait12">3+ months</option>
          </select>
        </label>
        <label class="pswitch"><input type="checkbox" id="pf-booking" /> <span data-i18n="profile_booking">Let families book my open slots (when booking launches)</span></label>
      </div>

      <div style="display:flex;align-items:center;gap:12px;margin-top:16px">
        <button class="pbtn" id="pf-save" type="button" data-i18n="profile_saveBtn">Save profile</button>
        <span id="pf-saved" style="font-size:.76rem;color:var(--p-green);font-weight:700;display:none" data-i18n="profile_savedOk">Saved ✓</span>
      </div>
    </div>

    <div>
      <div class="pc" style="position:sticky;top:52px">
        <div class="pc-h"><b data-i18n="profile_previewTitle">Live preview</b><span data-i18n="profile_previewSub">the family's view</span></div>
        <div class="pf-card">
          <div class="pf-card-top">
            <span class="pf-av" id="pv-av">C</span>
            <span class="pf-id"><b id="pv-name">Your clinic name</b><span id="pv-meta">Service · Borough</span></span>
            <span class="ppill teal" id="pv-accept">accepting</span>
          </div>
          <p class="pf-bio" id="pv-bio">Your description appears here — warm, short, human.</p>
          <div class="pf-tags" id="pv-tags"></div>
          <button class="pbtn sm" style="width:100%;justify-content:center" type="button" disabled data-i18n="profile_requestBtn">Request a spot (families see this)</button>
        </div>
      </div>
    </div>

  </div>
</ProviderLayout>

<style is:global>
  .pro-prof{display:grid;grid-template-columns:3fr 2fr;gap:14px;align-items:start}
  @media (max-width:880px){.pro-prof{grid-template-columns:1fr}}
  .pf-card{border:1px solid var(--p-line);border-radius:16px;padding:16px;background:linear-gradient(160deg,#FDFFFE,#F4FAF9)}
  .pf-card-top{display:flex;align-items:center;gap:11px;margin-bottom:10px}
  .pf-av{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,#5EEAD4,#0E8C82);color:#fff;display:grid;place-items:center;font-size:1rem;font-weight:800;flex-shrink:0}
  .pf-id{flex:1;min-width:0}
  .pf-id b{display:block;font-size:.92rem;color:var(--p-ink)}
  .pf-id span{display:block;font-size:.7rem;color:var(--p-mut)}
  .pf-bio{font-size:.8rem;color:var(--p-ink2);line-height:1.6;margin:0 0 10px}
  .pf-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
</style>

<script is:inline define:vars={{ DICT }}>
  (function () {
    var T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
    var tpl = function (s, v) { return String(s).replace(/\{(\w+)\}/g, function (m, k) { return v && v[k] != null ? v[k] : ""; }); };
    var esc = function (s) { return String(s == null ? "" : s).replace(/[&<>"]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]; }); };
    var F = ["name", "service", "langs", "borough", "phone", "web", "fees", "bio"];
    var $f = function (k) { return document.getElementById("pf-" + k); };

    var saved = null;
    try { saved = JSON.parse(localStorage.getItem("ua_pro_profile") || "null"); } catch (e) {}
    if (saved) {
      F.forEach(function (k) { if (saved[k] != null && $f(k)) $f(k).value = saved[k]; });
      $f("accepting").checked = saved.accepting !== false;
      $f("booking").checked = !!saved.booking;
      if (saved.wait != null) $f("wait").value = String(saved.wait);
    }

    function preview() {
      var name = $f("name").value.trim() || T.profile_pvNameFallback;
      document.getElementById("pv-name").textContent = name;
      document.getElementById("pv-av").textContent = name[0].toUpperCase();
      document.getElementById("pv-meta").textContent = $f("service").value + ($f("borough").value.trim() ? " · " + $f("borough").value.trim() : "");
      document.getElementById("pv-bio").textContent = $f("bio").value.trim() || T.profile_pvBioFallback;
      var acc = $f("accepting").checked;
      var wait = +$f("wait").value;
      var pvA = document.getElementById("pv-accept");
      pvA.textContent = acc ? (wait ? tpl(T.profile_pillWaitWk, { n: wait }) : T.profile_pillAccepting) : T.profile_pillFull;
      pvA.className = "ppill " + (acc ? (wait ? "amber" : "teal") : "grey");
      var tags = [];
      var teamN = 0;
      try { var tm = JSON.parse(localStorage.getItem("ua_pro_team") || "null"); if (tm) teamN = tm.length; } catch (e) {}
      if (teamN > 1) tags.push(tpl(T.profile_tagTeam, { n: teamN }));
      if ($f("langs").value.trim()) tags.push("🗣 " + esc($f("langs").value.trim()));
      if ($f("fees").value.trim()) tags.push("💳 " + esc($f("fees").value.trim()));
      if ($f("booking").checked) tags.push(T.profile_tagBooking);
      document.getElementById("pv-tags").innerHTML = tags.map(function (t) { return "<span class='ppill grey' style='text-transform:none;letter-spacing:0'>" + t + "</span>"; }).join("");
    }

    ["input", "change"].forEach(function (ev) {
      document.querySelectorAll(".pin, .pswitch input").forEach(function (el) { el.addEventListener(ev, preview); });
    });

    document.getElementById("pf-save").addEventListener("click", function () {
      var out = {};
      F.forEach(function (k) { out[k] = $f(k).value.trim(); });
      out.accepting = $f("accepting").checked;
      out.booking = $f("booking").checked;
      out.wait = +$f("wait").value;
      localStorage.setItem("ua_pro_profile", JSON.stringify(out));
      var ok = document.getElementById("pf-saved");
      ok.style.display = "inline";
      setTimeout(function () { ok.style.display = "none"; }, 2200);
    });

    preview();
    /* Re-run once the [data-i18n] swap has localized the <option> labels
       (an option's value feeds pv-meta); English is unchanged, so it's a no-op there. */
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", preview);
  })();
</script>
