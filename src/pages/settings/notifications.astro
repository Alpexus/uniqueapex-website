---
/* SETTINGS-NOTIFICATIONS-V1 — functional notification preferences.
   Toggles persist to the Supabase account (user metadata) and mirror to
   localStorage, so they survive sign-out/sign-in and other devices. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
import "@/styles/settings.css";
---
<AppFormLayout title="Settings" activeNav="settings">
  <SectionTabs section="settings" active="notifications" />
  <div class="set-wrap">
    <h1 class="page-title">Notifications</h1>
    <p class="page-sub">Choose what lands in your inbox. You can change any of this at any time.</p>

    <div class="set-section">
      <h2>Your child's journey</h2>
      <p class="desc">Updates about matching, waitlists and providers.</p>
      <div class="set-row">
        <div class="l"><h3>Provider &amp; waitlist updates</h3><p>When a provider responds, a spot opens, or your waitlist position changes.</p></div>
        <label class="toggle"><input type="checkbox" data-npref="providerUpdates" checked /><span class="tk"></span></label>
      </div>
      <div class="set-row">
        <div class="l"><h3>New matches</h3><p>When a new provider matching your child's profile joins the network.</p></div>
        <label class="toggle"><input type="checkbox" data-npref="newMatches" checked /><span class="tk"></span></label>
      </div>
      <div class="set-row">
        <div class="l"><h3>Document reminders</h3><p>Gentle nudges when a report is aging or a renewal date approaches.</p></div>
        <label class="toggle"><input type="checkbox" data-npref="docReminders" /><span class="tk"></span></label>
      </div>
    </div>

    <div class="set-section">
      <h2>Learning &amp; community</h2>
      <div class="set-row">
        <div class="l"><h3>Workshop invitations</h3><p>Expert sessions and Q&amp;As relevant to your child's profile.</p></div>
        <label class="toggle"><input type="checkbox" data-npref="workshops" checked /><span class="tk"></span></label>
      </div>
      <div class="set-row">
        <div class="l"><h3>Monthly progress digest</h3><p>A short monthly summary of your child's wheel, wins and next steps.</p></div>
        <label class="toggle"><input type="checkbox" data-npref="digest" checked /><span class="tk"></span></label>
      </div>
      <div class="set-row">
        <div class="l"><h3>Product news</h3><p>New features and improvements to UniqueApex. Occasional.</p></div>
        <label class="toggle"><input type="checkbox" data-npref="productNews" /><span class="tk"></span></label>
      </div>
    </div>

    <div class="set-section">
      <h2>Account</h2>
      <div class="set-row">
        <div class="l"><h3>Security &amp; account emails</h3><p>Password resets, sign-in confirmations, billing receipts. These keep your account safe.</p></div>
        <span class="always">Always on</span>
      </div>
    </div>

    <div class="set-actions">
      <button class="set-btn" type="button" id="ntf-save">Save changes</button>
      <span class="set-hint" id="ntf-msg" style="align-self:center"></span>
    </div>
  </div>
</AppFormLayout>

<script is:inline>
  (function () {
    var UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
    var ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
    var s = null;
    try { s = JSON.parse(localStorage.getItem("ua_session")); } catch(e){}
    if (!s || !s.access_token) { location.href = "/login"; return; }
    var saved = ((s.user && s.user.user_metadata) || {}).notifications || null;

    var boxes = document.querySelectorAll("[data-npref]");
    /* prefill: account value wins; fall back to localStorage; else the default in the HTML */
    boxes.forEach(function(c){
      var k = c.dataset.npref;
      if (saved && typeof saved[k] === "boolean") c.checked = saved[k];
      else { var v = localStorage.getItem("ua_ntf_" + k); if (v !== null) c.checked = v === "1"; }
      c.addEventListener("change", function(){ localStorage.setItem("ua_ntf_" + k, c.checked ? "1" : "0"); });
    });

    document.getElementById("ntf-save").addEventListener("click", function(){
      var msg = document.getElementById("ntf-msg");
      msg.textContent = "Saving…"; msg.style.color = "";
      var prefs = {};
      boxes.forEach(function(c){ prefs[c.dataset.npref] = c.checked; });
      fetch(UA_URL + "/auth/v1/user", {
        method: "PUT",
        headers: { apikey: ANON, Authorization: "Bearer " + s.access_token, "Content-Type": "application/json" },
        body: JSON.stringify({ data: { notifications: prefs } })
      }).then(function(r){ return r.json().then(function(j){ return { ok: r.ok, j: j }; }); })
        .then(function(res){
          if (res.ok) {
            try { var cur = JSON.parse(localStorage.getItem("ua_session")); if (cur) { cur.user = res.j; localStorage.setItem("ua_session", JSON.stringify(cur)); } } catch(e){}
            msg.textContent = "Saved."; msg.style.color = "#15803D";
          } else { msg.textContent = "Couldn't save — try again."; msg.style.color = "#B42318"; }
        })
        .catch(function(){ msg.textContent = "Couldn't reach the server."; msg.style.color = "#B42318"; });
    });
  })();
</script>
