---
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import { SCALE_QUESTIONS, SCALE_IDS } from "@/config/wheelConfig.js";
import DICT from "@/i18n/passport.js";
import TERMS from "@/i18n/lib-terms.js";
/* sq_* display map per language for the 36 scored questions (frozen
   wheelConfig labels stay canonical; this is display only) */
const SQMAP = {};
for (const lang of Object.keys(TERMS)) {
  if (lang === "en") continue;
  SQMAP[lang] = {};
  for (const [k, v] of Object.entries(TERMS[lang])) if (k.startsWith("sq_")) SQMAP[lang][k.slice(3)] = v;
}
const inputCls = "w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white";
const cardCls = "bg-white border border-slate-200 rounded-2xl p-6 md:p-8 space-y-5";
const labelCls = "block text-sm font-medium text-slate-600 mb-2";
const chip = "flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors text-slate-600 text-sm";
const sel = inputCls + " text-slate-500";
const sub = "text-sm text-slate-500 -mt-2";
// [value, i18n-code] — value stays canonical English (radio value=); label swapped
const ynOpts = [["Yes", "optYes"], ["No", "optNo"]];
// Section names for the step-jump dropdown [en, fr]; the numeric option value
// (1..14) is what the logic uses, so the label is swapped via data-label-fr.
const SECTION_NAMES = [["Child","Enfant"],["Household","Foyer"],["Diagnosis","Diagnostic"],["Birth","Naissance"],["Communication","Communication"],["Sensory","Sensoriel"],["Daily & Motor","Quotidien et moteur"],["Health","Santé"],["Behaviour","Comportement"],["Strengths","Forces"],["Education","Éducation"],["Therapy","Thérapie"],["Goals","Objectifs"],["Review","Révision"]];
// Scale answers: value stays "0".."4" (read by the wheel scorer); label swapped.
const scale4 = [
  { v: "0", l: "Never", c: "scaleNever" }, { v: "1", l: "Rarely", c: "scaleRarely" },
  { v: "2", l: "Sometimes", c: "scaleSometimes" }, { v: "3", l: "Often", c: "scaleOften" },
  { v: "4", l: "Consistently", c: "scaleConsistently" },
];
// Daily-living <select> option value (English, scored) → its i18n label code.
const OPT_CODE = {
  "Independent":"optIndependent","With support":"optWithSupport","Not yet":"optNotYet",
  "Fully trained":"optFullyTrained","In progress":"optInProgress","Not started":"optNotStarted","Not applicable":"optNotApplicable",
  "Good":"optGood","Variable":"optVariable","Poor":"optPoor",
  "Strong":"optStrong","Developing":"optDeveloping","Limited":"optLimited",
  "Yes":"optYes","Sometimes":"optSometimes","No":"optNo",
  "None":"optNone","Mild":"optMild","Significant":"optSignificant",
};
---
<AppFormLayout title="Family Passport" titleFr="Passeport familial" activeNav="profiles">
  <div class="form-canvas">
    <div class="max-w-3xl mx-auto mt-2 mb-24">
      <div class="mb-10 text-center">
        <h1 class="text-3xl font-bold text-slate-800">
          <span data-i18n="hdrTitleLead">Family</span> <span class="text-violet-700" data-i18n="hdrTitleKey">Passport</span>
        </h1>
        <p class="text-slate-500 mt-3 leading-relaxed max-w-xl mx-auto" data-i18n="hdrIntro">
          Fill this in once and keep it updated. Export a PDF for any provider, therapist, or school — share only what's relevant.
        </p>
      </div>
      <!-- Progress -->
      <div class="bg-white border border-slate-200 rounded-xl px-5 py-4 mb-8">
        <div class="flex items-center justify-between mb-2.5">
          <span id="step-label" class="text-sm font-semibold text-slate-700">Step 1 of 13 · Child Profile</span>
          <span id="step-pct" class="text-sm font-medium text-violet-700">8%</span>
        </div>
        <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
          <div id="progress-bar" class="h-full bg-violet-600 rounded-full transition-all duration-300" style="width:8%"></div>
        </div>
        <div class="mt-3">
          <select id="section-jump" class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2 bg-slate-50 text-slate-600 outline-none focus:ring-2 focus:ring-violet-300 cursor-pointer">
            {SECTION_NAMES.map(([en, fr], i) => (
              <option value={i + 1} data-label-fr={`${i + 1}. ${fr}`}>{i + 1}. {en}</option>
            ))}
          </select>
        </div>
      </div>
      <form id="passport-form" novalidate>
        <script type="application/json" id="ua-scale-ids" set:html={JSON.stringify(SCALE_IDS)}></script>
        <!-- 1 CHILD PROFILE -->
        <div class="form-step" data-step="1">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s1Title">Child Profile</h2>
            <p class={sub} data-i18n="s1Sub">Basic identifying information about your child — used in all PDFs and provider outreach.</p>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class={labelCls} data-i18n="s1FirstName">First name *</label>
                <input type="text" name="firstName" class={inputCls} placeholder="Child's first name" data-i18n-ph="s1FirstNamePh" />
                <p id="err-firstName" style="display:none;color:#ef4444;font-size:12px;margin-top:4px" data-i18n="errFirstName">Please enter your child's first name.</p>
              </div>
              <div>
                <label class={labelCls} data-i18n="s1LastName">Last name *</label>
                <input type="text" name="lastName" class={inputCls} placeholder="Child's last name" data-i18n-ph="s1LastNamePh" />
                <p id="err-lastName" style="display:none;color:#ef4444;font-size:12px;margin-top:4px" data-i18n="errLastName">Please enter your child's last name.</p>
              </div>
              <div>
                <label class={labelCls} data-i18n="s1Dob">Date of birth *</label>
                <input type="date" name="dob" class={inputCls} />
                <p id="err-dob" style="display:none;color:#ef4444;font-size:12px;margin-top:4px" data-i18n="errDob">Date of birth is required.</p>
              </div>
              <div>
                <label class={labelCls} data-i18n="s1Gender">Gender *</label>
                <select name="gender" class={sel}>
                  <option value="" data-i18n="commSelect">Select...</option>
                  <option value="Female" data-i18n="genderFemale">Female</option><option value="Male" data-i18n="genderMale">Male</option>
                  <option value="Non-binary" data-i18n="genderNonBinary">Non-binary</option>
                  <option value="Prefer not to say" data-i18n="genderPreferNot">Prefer not to say</option>
                  <option value="Other" data-i18n="optOther">Other</option>
                </select>
                <p id="err-gender" style="display:none;color:#ef4444;font-size:12px;margin-top:4px" data-i18n="errGender">Please make a selection.</p>
              </div>
              <div><label class={labelCls} data-i18n="s1City">City / region</label><input type="text" name="city" class={inputCls} placeholder="e.g. Montréal, QC" data-i18n-ph="s1CityPh" /></div>
              <div><label class={labelCls} data-i18n="s1Country">Country</label><input type="text" name="country" class={inputCls} placeholder="e.g. Canada" data-i18n-ph="s1CountryPh" /></div>
              <div><label class={labelCls} data-i18n="s1HealthIns">Health insurance # (e.g. RAMQ — optional)</label><input type="text" name="healthInsurance" class={inputCls} placeholder="Optional" data-i18n-ph="commOptional" /></div>
              <div><label class={labelCls} data-i18n="s1HomeLang">Language(s) spoken at home</label><input type="text" name="homeLanguages" class={inputCls} placeholder="e.g. English, French" data-i18n-ph="s1HomeLangPh" /></div>
              <div><label class={labelCls} data-i18n="s1BestLang">Language child understands best</label><input type="text" name="bestLanguage" class={inputCls} placeholder="e.g. English" data-i18n-ph="s1BestLangPh" /></div>
            </div>
          </div>
        </div>
        <!-- 2 PARENTS & HOUSEHOLD -->
        <div class="form-step" data-step="2" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s2Title">Parents & Household</h2>
            <p class={sub} data-i18n="s2Sub">Contact details for guardians and household context — helps providers know who to reach and how the family is structured.</p>
            <div class="bg-white border border-slate-200 rounded-xl p-4 space-y-3">
              <p class="font-medium text-slate-700 text-sm" data-i18n="s2Guardian1">Parent / Guardian 1 *</p>
              <div class="grid md:grid-cols-2 gap-3">
                <div>
                  <input type="text" name="g1name" class={inputCls} placeholder="Full name *" data-i18n-ph="s2FullNameReq" />
                  <p id="err-g1name" style="display:none;color:#ef4444;font-size:12px;margin-top:4px" data-i18n="errG1name">Guardian name is required.</p>
                </div>
                <select name="g1rel" class={sel}>
                  <option value="" data-i18n="s2RelPlaceholder">Relationship to child...</option>
                  <option value="Mother" data-i18n="relMother">Mother</option><option value="Father" data-i18n="relFather">Father</option><option value="Guardian" data-i18n="relGuardian">Guardian</option><option value="Other" data-i18n="optOther">Other</option>
                </select>
                <div>
                  <input type="email" name="g1email" class={inputCls} placeholder="Email *" data-i18n-ph="s2EmailReq" />
                  <p id="err-g1email" style="display:none;color:#ef4444;font-size:12px;margin-top:4px" data-i18n="errG1email">Email is required.</p>
                </div>
                <input type="tel" name="g1phone" class={inputCls} placeholder="Phone" data-i18n-ph="s2Phone" />
              </div>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl p-4 space-y-3">
              <p class="font-medium text-slate-700 text-sm" data-i18n="s2Guardian2">Parent / Guardian 2 (optional)</p>
              <div class="grid md:grid-cols-2 gap-3">
                <input type="text" name="g2name" class={inputCls} placeholder="Full name" data-i18n-ph="s2FullName" />
                <select name="g2rel" class={sel}>
                  <option value="" data-i18n="s2RelPlaceholder">Relationship to child...</option>
                  <option value="Mother" data-i18n="relMother">Mother</option><option value="Father" data-i18n="relFather">Father</option><option value="Guardian" data-i18n="relGuardian">Guardian</option><option value="Other" data-i18n="optOther">Other</option>
                </select>
                <input type="email" name="g2email" class={inputCls} placeholder="Email" data-i18n-ph="s2Email" />
                <input type="tel" name="g2phone" class={inputCls} placeholder="Phone" data-i18n-ph="s2Phone" />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class={labelCls} data-i18n="s2Custody">Legal custody</label>
                <select name="custody" class={sel}>
                  <option value="" data-i18n="commSelect">Select...</option>
                  <option value="Guardians together" data-i18n="custodyTogether">Guardians together</option><option value="Joint custody" data-i18n="custodyJoint">Joint custody</option><option value="Single custody" data-i18n="custodySingle">Single custody</option><option value="Other" data-i18n="optOther">Other</option>
                </select>
              </div>
              <div>
                <label class={labelCls} data-i18n="s2FamilyStatus">Family status</label>
                <select name="maritalStatus" class={sel}>
                  <option value="" data-i18n="commSelect">Select...</option>
                  <option value="Married" data-i18n="msMarried">Married</option><option value="Living together" data-i18n="msLiving">Living together</option><option value="Separated" data-i18n="msSeparated">Separated</option>
                  <option value="Divorced" data-i18n="msDivorced">Divorced</option><option value="Single" data-i18n="msSingle">Single</option><option value="Other" data-i18n="optOther">Other</option>
                </select>
              </div>
            </div>
            <div>
              <label class={labelCls} data-i18n="s2LivesWith">Who the child lives with</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {[["Both parents","livesBoth"],["Mother","relMother"],["Father","relFather"],["Siblings","livesSiblings"],["Grandparents","livesGrandparents"],["Foster family","livesFoster"],["Other","optOther"]].map(([v, c]) => (<label class={chip}><input type="checkbox" name="livesWith" value={v} class="accent-violet-700 w-4 h-4" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div><label class={labelCls} data-i18n="s2Siblings">Siblings (name, age, relationship)</label><textarea name="siblings" class={inputCls + " h-20"} placeholder="e.g. Sara, 8, sister" data-i18n-ph="s2SiblingsPh"></textarea></div>
            <div>
              <label class={labelCls} data-i18n="s2Funding">Do you receive government funding?</label>
              <div class="flex gap-2 mb-2">
                {ynOpts.map(([v, c]) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="funding" value={v} class="accent-violet-700" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
              <input type="text" name="fundingType" class={inputCls} placeholder="If yes, which programs / subsidies?" data-i18n-ph="s2FundingTypePh" />
            </div>
          </div>
        </div>
        <!-- 3 DIAGNOSIS & FAMILY HISTORY -->
        <div class="form-step" data-step="3" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s3Title">Diagnosis</h2>
            <p class="text-sm text-slate-500 -mt-2" data-i18n="s3Sub">Diagnoses, assessments, and family history — helpful context for any professional who works with your child.</p>
            <div>
              <label class={labelCls} data-i18n="s3Status">Diagnosis status</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {[["Diagnosed","dxDiagnosed"],["Assessment Pending","dxAssessmentPending"],["Self-Identified Concerns","dxSelfIdentified"]].map(([v, c]) => (<label class={chip}><input type="radio" name="diagnosisStatus" value={v} class="accent-violet-700" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div>
              <label class={labelCls} data-i18n="s3Diagnoses">Diagnoses (select any that apply)</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {[["Autism","dgAutism"],["ADHD","dgADHD"],["Speech / Language Disorder","dgSpeechLang"],["Global Developmental Delay","dgGDD"],["Intellectual Disability","dgIntellectual"],["Learning Difficulty","dgLearningDiff"],["Dyspraxia / DCD","dgDyspraxia"],["Sensory Processing","dgSensoryProc"],["Anxiety","dgAnxiety"],["Depression","dgDepression"],["OCD","dgOCD"],["Tourette's / Tics","dgTourettes"],["Epilepsy / Seizures","dgEpilepsy"],["Genetic Condition","dgGenetic"],["Other","optOther"]].map(([v, c]) => (<label class={chip}><input type="checkbox" name="diagnoses" value={v} class="accent-violet-700 w-4 h-4" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls} data-i18n="s3DiagnosedBy">Diagnosed / referred by</label><input type="text" name="diagnosedBy" class={inputCls} placeholder="Professional name & title" data-i18n-ph="s3DiagnosedByPh" /></div>
              <div><label class={labelCls} data-i18n="s3DiagDate">Date of diagnosis</label><input type="text" name="diagnosisDate" class={inputCls} placeholder="e.g. March 2024" data-i18n-ph="s3DiagDatePh" /></div>
            </div>
            <div><label class={labelCls} data-i18n="s3Awaiting">If awaiting assessment — with whom / where?</label><input type="text" name="awaitingAssessment" class={inputCls} placeholder="Optional" data-i18n-ph="commOptional" /></div>
            <h2 class="text-lg font-bold text-slate-800 pt-2" data-i18n="s3FamHistTitle">Family History</h2>
            <p class={sub} data-i18n="s3FamHistSub">Conditions present in close relatives (helps professionals understand the full picture).</p>
            <div class="grid sm:grid-cols-3 gap-2">
              {[["Developmental / language delay","fhDevDelay"],["Learning difficulties","fhLearningDiff"],["Autism","fhAutism"],["ADHD","fhADHD"],["Anxiety","fhAnxiety"],["Depression","fhDepression"],["OCD","fhOCD"],["Bipolar","fhBipolar"],["Tourette's / tics","fhTourettes"],["Intellectual disability","fhIntellectual"],["Epilepsy / seizures","fhEpilepsy"],["Genetic disorder","fhGenetic"],["Substance use","fhSubstance"]].map(([v, c]) => (<label class={chip}><input type="checkbox" name="familyHistory" value={v} class="accent-violet-700 w-4 h-4" /> <span data-i18n={c}>{v}</span></label>))}
            </div>
            <div><label class={labelCls} data-i18n="s3FamNotes">Notes (relation to child, details)</label><textarea name="familyHistoryNotes" class={inputCls + " h-16"} placeholder="e.g. Maternal uncle — autism" data-i18n-ph="s3FamNotesPh"></textarea></div>
          </div>
        </div>
        <!-- 4 BIRTH & DEVELOPMENT -->
        <div class="form-step" data-step="4" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s4Title">Birth & Development</h2>
            <p class="text-sm text-slate-500 -mt-2" data-i18n="s4Sub">Pregnancy, birth, and early developmental milestones — often relevant to OT, SLP, and paediatric assessments.</p>
            <div><label class={labelCls} data-i18n="s4Pregnancy">Pregnancy (any complications)</label><textarea name="pregnancy" class={inputCls + " h-16"} placeholder="Optional" data-i18n-ph="commOptional"></textarea></div>
            <div class="grid md:grid-cols-3 gap-4">
              <div><label class={labelCls} data-i18n="s4Gestation">Weeks at birth</label><input type="text" name="gestation" class={inputCls} placeholder="e.g. 40" data-i18n-ph="s4GestationPh" /></div>
              <div><label class={labelCls} data-i18n="s4BirthWeight">Birth weight</label><input type="text" name="birthWeight" class={inputCls} placeholder="e.g. 3.2 kg" data-i18n-ph="s4BirthWeightPh" /></div>
              <div><label class={labelCls} data-i18n="s4Regression">Lost / regressed skills?</label>
                <select name="regression" class={sel}><option value="" data-i18n="commSelect">Select...</option><option value="No" data-i18n="optNo">No</option><option value="Yes" data-i18n="optYes">Yes</option></select>
              </div>
            </div>
            <div><label class={labelCls} data-i18n="s4Complications">Birth / post-birth complications</label><textarea name="birthComplications" class={inputCls + " h-16"} placeholder="e.g. breathing difficulty, feeding issues, tongue tie" data-i18n-ph="s4ComplicationsPh"></textarea></div>
            <div>
              <label class={labelCls} data-i18n="s4Milestones">Developmental milestones (approx. age reached — leave blank if unsure)</label>
              <div class="grid sm:grid-cols-2 gap-3">
                {[
                  {n:"msSit",l:"Sat unsupported",c:"msSit"},{n:"msCrawl",l:"Crawled",c:"msCrawl"},{n:"msWalk",l:"Walked",c:"msWalk"},
                  {n:"msFirstWord",l:"First words",c:"msFirstWord"},{n:"msPhrases",l:"2-word phrases",c:"msPhrases"},{n:"msSentences",l:"Simple sentences",c:"msSentences"},
                  {n:"msToiletDay",l:"Toilet trained (day)",c:"msToiletDay"},{n:"msToiletNight",l:"Toilet trained (night)",c:"msToiletNight"},
                ].map((f) => (
                  <div class="flex items-center gap-2">
                    <span class="text-sm text-slate-500 w-40 shrink-0" data-i18n={f.c}>{f.l}</span>
                    <input type="text" name={f.n} class={inputCls + " py-2"} placeholder="age" data-i18n-ph="s4AgePh" />
                  </div>
                ))}
              </div>
            </div>
            <div><label class={labelCls} data-i18n="s4RegressionNotes">If skills were lost, describe</label><textarea name="regressionNotes" class={inputCls + " h-16"} placeholder="Optional" data-i18n-ph="commOptional"></textarea></div>
          </div>
        </div>
        <!-- 5 COMMUNICATION -->
        <div class="form-step" data-step="5" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s5Title">Communication Profile</h2>
            <p class="text-sm text-slate-500 -mt-2" data-i18n="s5Sub">How your child communicates today — their style, methods, strengths and challenges. Directly used for SLP referrals.</p>
            <div>
              <label class={labelCls} data-i18n="s5Style">Communication style</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {[["Fluent Verbal","commFluentVerbal"],["Verbal","commVerbal"],["Limited Verbal","commLimitedVerbal"],["Non-Speaking","commNonSpeaking"]].map(([v, c]) => (<label class={chip}><input type="radio" name="commStyle" value={v} class="accent-violet-700" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div>
              <label class={labelCls} data-i18n="s5Means">Primary means of communication (select any)</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {[["Words","meansWords"],["Sentences","meansSentences"],["Sounds","meansSounds"],["Pictures (PECS)","meansPECS"],["Sign language","meansSign"],["Device / AAC app","meansDevice"],["No primary means yet","meansNone"]].map(([v, c]) => (<label class={chip}><input type="checkbox" name="commMeans" value={v} class="accent-violet-700 w-4 h-4" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div>
              <label class={labelCls} data-i18n="s5CanExpress">Can express needs</label>
              <select name="canExpressNeeds" class={sel}>
                <option value="" data-i18n="commSelect">Select...</option><option value="Consistently" data-i18n="ceConsistently">Consistently</option><option value="Sometimes" data-i18n="ceSometimes">Sometimes</option><option value="Rarely" data-i18n="ceRarely">Rarely</option>
              </select>
            </div>
            <div>
              <label class={labelCls} data-i18n="s5Challenges">Communication challenges (select any)</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {[["Requesting","chRequesting"],["Conversation","chConversation"],["Question Answering","chQuestionAns"],["Emotional Expression","chEmotionalExpr"],["Social Communication","chSocialComm"]].map(([v, c]) => (<label class={chip}><input type="checkbox" name="commChallenges" value={v} class="accent-violet-700 w-4 h-4" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div class="pt-2">
              <label class={labelCls} data-i18n="s5ScaleHeader">How often does your child do each of these?</label>
              <div class="space-y-2">
                {SCALE_QUESTIONS.communication.map((q) => (
                  <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                    <span class="text-sm text-slate-600 flex-1" data-sq={q.id}>{q.label}</span>
                    <select name={q.id} class={sel + " sm:w-44 shrink-0"}>
                      <option value="">—</option>
                      {scale4.map((o) => <option value={o.v} data-i18n={o.c}>{o.l}</option>)}
                    </select>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        <!-- 6 SENSORY (detailed signs + severity) -->
        <div class="form-step" data-step="6" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s6Title">Sensory Profile</h2>
            <p class="text-sm text-slate-500 -mt-2" data-i18n="s6Sub">How your child responds to sensory input across each sense. This feeds directly into the development wheel.</p>
            <p class={sub} data-i18n="s6Sub2">For each sense, tick "no concerns" if it's typical, or select any signs you notice — then choose how much it affects daily life.</p>
