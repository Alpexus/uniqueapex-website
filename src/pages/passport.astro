  async function saveAndClose() {
    var btn = document.getElementById("save-close-btn");
    btn.disabled = true; btn.textContent = "Saving...";
    var s = await getValidSession();
    if (!s) { window.location.href = "/login"; return; }
    var payload = { user_id: s.user.id, data: buildPassport() };
    var method = editingId ? "PATCH" : "POST";
    var url = UA_URL + "/rest/v1/passports" + (editingId ? "?id=eq." + editingId : "");
    var hdrs = Object.assign({}, authHeaders(s.access_token), { "Prefer": editingId ? "return=minimal" : "return=representation" });
    try {
      var r = await fetch(url, { method: method, headers: hdrs, body: JSON.stringify(editingId ? { data: payload.data } : payload) });
      if (r.ok && !editingId) { var rows = await r.json(); if (rows && rows[0]) editingId = rows[0].id; }
      window.location.href = "/account";
    } catch(e) {
      btn.disabled = false; btn.textContent = "Save & close";
    }
  }
  document.getElementById("save-close-btn").addEventListener("click", saveAndClose);
  var authBanner = document.createElement("div");
  authBanner.id = "auth-banner";
  authBanner.style.cssText = "margin-bottom:12px;padding:10px 16px;border-radius:10px;font-size:13px;display:none";
  document.querySelector(".max-w-3xl").insertBefore(authBanner, document.getElementById("passport-form"));

  (async function initPassport() {
    var s = await getValidSession();
    var params = new URLSearchParams(window.location.search);
    var passportId = params.get("id");
    var goExport = params.get("export") === "1";

    if (s && s.user) {
      var email = s.user.email || "";
      authBanner.style.background = "#f5f3ff"; authBanner.style.border = "1px solid #ddd6fe";
      authBanner.style.color = "#5b21b6"; authBanner.style.display = "block";
      authBanner.innerHTML = "Signed in as <strong>" + email + "</strong> · <a href='/account' style='color:#6d28d9;font-weight:600'>My account</a>";

      if (passportId) {
        editingId = passportId;
        var r = await fetch(UA_URL + "/rest/v1/passports?id=eq." + passportId + "&select=*", { headers: authHeaders(s.access_token) });
        if (r.ok) {
          var rows = await r.json();
          if (rows && rows[0] && rows[0].data) {
            loadPassport(rows[0].data);
            authBanner.innerHTML = "Editing: <strong>" + (rows[0].data.childProfile && rows[0].data.childProfile.firstName ? rows[0].data.childProfile.firstName + " " + (rows[0].data.childProfile.lastName||"") : "child profile") + "</strong> · <a href='/account' style='color:#6d28d9;font-weight:600'>My account</a>";
            if (goExport) { currentStep = reviewStep; renderReview(); showStep(reviewStep); }
          }
        }
      }
    } else {
      authBanner.style.background = "#fef9c3"; authBanner.style.border = "1px solid #fde68a";
      authBanner.style.color = "#854d0e"; authBanner.style.display = "block";
      authBanner.innerHTML = "You're not signed in. <a href='/login' style='color:#854d0e;font-weight:600;text-decoration:underline'>Sign in</a> or <a href='/signup' style='color:#854d0e;font-weight:600;text-decoration:underline'>create an account</a> to save your passport.";
    }
  })();

  nextBtn.addEventListener("click", function () {
    if (currentStep === 1) {
      var ok = true;
      var fn = form.querySelector('[name="firstName"]'), efn = document.getElementById("err-firstName");
      var ln = form.querySelector('[name="lastName"]'), eln = document.getElementById("err-lastName");
      var gd = form.querySelector('[name="gender"]'), egd = document.getElementById("err-gender");
      var db = form.querySelector('[name="dob"]'), edb = document.getElementById("err-dob");
      if (!fn.value.trim()) { efn.style.display="block"; ok=false; } else { efn.style.display="none"; }
      if (!ln.value.trim()) { eln.style.display="block"; ok=false; } else { eln.style.display="none"; }
      if (!gd.value) { egd.style.display="block"; ok=false; } else { egd.style.display="none"; }
      if (!db.value) { edb.style.display="block"; ok=false; } else { edb.style.display="none"; }
      if (!ok) { window.scrollTo({top:0,behavior:"smooth"}); return; }
    }
    if (currentStep === 2) {
      var ok2 = true;
      var g1n = form.querySelector('[name="g1name"]'), eg1n = document.getElementById("err-g1name");
      var g1e = form.querySelector('[name="g1email"]'), eg1e = document.getElementById("err-g1email");
      if (!g1n.value.trim()) { eg1n.style.display="block"; ok2=false; } else { eg1n.style.display="none"; }
      if (!g1e.value.trim()||g1e.value.indexOf("@")===-1) { eg1e.style.display="block"; ok2=false; } else { eg1e.style.display="none"; }
      if (!ok2) { window.scrollTo({top:0,behavior:"smooth"}); return; }
    }
    if (currentStep === totalSteps) { currentStep = reviewStep; renderReview(); showStep(reviewStep); return; }
    if (currentStep === reviewStep) {
      // Save to Supabase
      (async function doSave() {
        nextBtn.disabled = true; nextBtn.textContent = "Saving...";
        var s = await getValidSession();
        if (!s) {
          saveResult.innerHTML = '<span style="color:#ef4444">Please <a href="/login" style="font-weight:600;text-decoration:underline">sign in</a> to save your passport.</span>';
          nextBtn.disabled = false; nextBtn.textContent = "Save Passport"; return;
        }
        var payload = { user_id: s.user.id, data: buildPassport() };
        var method = editingId ? "PATCH" : "POST";
        var url = UA_URL + "/rest/v1/passports" + (editingId ? "?id=eq." + editingId : "");
        var headers = Object.assign({}, authHeaders(s.access_token), { "Prefer": editingId ? "return=minimal" : "return=representation" });
        var r = await fetch(url, { method: method, headers: headers, body: JSON.stringify(editingId ? { data: payload.data } : payload) });
        if (r.ok) {
          if (!editingId) { var rows = await r.json(); if (rows && rows[0]) editingId = rows[0].id; }
          var childName = (payload.data.childProfile && payload.data.childProfile.firstName) || "child";
          saveResult.innerHTML = '<span style="color:#22c55e;font-weight:500">✓ ' + childName + "'s passport saved. <a href='/account' style='color:#16a34a;text-decoration:underline'>View my account →</a></span>";
          nextBtn.style.display = "none";
        } else {
          saveResult.innerHTML = '<span style="color:#ef4444">Something went wrong. Please try again.</span>';
          nextBtn.disabled = false; nextBtn.textContent = "Save Passport";
        }
      })();
      return;
    }
    currentStep++; showStep(currentStep);
  });

  backBtn.addEventListener("click", function () {
    if (currentStep === reviewStep) { currentStep = totalSteps; } else if (currentStep > 1) { currentStep--; }
    nextBtn.style.display = "inline-block"; saveResult.innerHTML = ""; showStep(currentStep);
  });

  showStep(1);
</script>

