              <div><label class={labelCls} data-i18n="s11Grade">Grade / year</label><input type="text" name="grade" class={inputCls} placeholder="e.g. Grade 2" data-i18n-ph="s11GradePh" /></div>
              <div><label class={labelCls} data-i18n="s11SchoolBoard">School board (if applicable)</label><input type="text" name="schoolBoard" class={inputCls} placeholder="Optional" data-i18n-ph="commOptional" /></div>
              <div><label class={labelCls} data-i18n="s11HasIEP">Has an IEP / intervention plan</label>
                <div class="flex gap-2">{ynOpts.map(([v, c]) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="hasIEP" value={v} class="accent-violet-700" /> <span data-i18n={c}>{v}</span></label>))}</div>
              </div>
              <div><label class={labelCls} data-i18n="s11ClassroomSupport">Level of classroom support</label>
                <select name="classroomSupport" class={sel}><option value="" data-i18n="commSelect">Select...</option><option value="None" data-i18n="optNone">None</option><option value="Part-time aide" data-i18n="csPartTime">Part-time aide</option><option value="Full-time aide" data-i18n="csFullTime">Full-time aide</option><option value="Other" data-i18n="optOther">Other</option></select>
              </div>
            </div>
            <div>
              <label class={labelCls} data-i18n="s11Agency">Support provided through an agency?</label>
