                <label class={chip + " flex-1 justify-center"}><input type="radio" name="hasAgency" value="Yes" class="accent-violet-700 agency-toggle" /> <span data-i18n="optYes">Yes</span></label>
                <label class={chip + " flex-1 justify-center"}><input type="radio" name="hasAgency" value="No" class="accent-violet-700 agency-toggle" /> <span data-i18n="optNo">No</span></label>
              </div>
              <div id="agency-details" style="display:none">
                <input type="text" name="agencySupport" class={inputCls} placeholder="Agency name, type of support, frequency" data-i18n-ph="s11AgencyPh" />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls} data-i18n="s11Concerns">Academic concerns</label><textarea name="schoolChallenges" class={inputCls + " h-20"} placeholder="What's hard at school?" data-i18n-ph="s11ConcernsPh"></textarea></div>
              <div><label class={labelCls} data-i18n="s11Strengths">School strengths</label><textarea name="schoolStrengths" class={inputCls + " h-20"} placeholder="What's going well?" data-i18n-ph="s11StrengthsPh"></textarea></div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls} data-i18n="s11Transition">Upcoming school transition</label><input type="text" name="upcomingTransition" class={inputCls} placeholder="e.g. Starting Grade 3 in Sept" data-i18n-ph="s11TransitionPh" /></div>
              <div><label class={labelCls} data-i18n="s11FlightRisk">Flight risk at school?</label>
                <div class="flex gap-2">{ynOpts.map(([v, c]) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="flightRisk" value={v} class="accent-violet-700" /> <span data-i18n={c}>{v}</span></label>))}</div>
              </div>
            </div>
          </div>
        </div>
        <!-- 12 THERAPY & SERVICES -->
        <div class="form-step" data-step="12" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s12Title">Therapy & Services</h2>
            <p class="text-sm text-slate-500 -mt-2" data-i18n="s12Sub">Current and past therapy involvement — helps new providers understand what has been tried and what is ongoing.</p>
            <p class={sub} data-i18n="s12Sub2">Toggle on any therapy your child currently receives and add the details.</p>
            {[["Speech Therapy","thSpeech"],["Occupational Therapy","thOT"],["ABA / Behaviour","thABA"],["Psychology","thPsychology"],["Psychiatry","thPsychiatry"],["Physiotherapy","thPhysio"],["Social Skills Group","thSocialSkills"],["Infant Stimulation","thInfantStim"],["Other","optOther"]].map(([t, tc]) => (
              <div class="bg-white border border-slate-200 rounded-xl p-4">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" class="therapy-toggle accent-violet-700 w-4 h-4" data-therapy={t} />
                  <span class="font-medium text-slate-700" data-i18n={tc}>{t}</span>
                </label>
                <div class="therapy-fields mt-4 grid md:grid-cols-2 gap-3" data-fields={t} style="display:none">
                  <input type="text" data-field="provider" class={inputCls} placeholder="Provider name" data-i18n-ph="s12Provider" />
                  <input type="text" data-field="frequency" class={inputCls} placeholder="Frequency (e.g. weekly)" data-i18n-ph="s12Frequency" />
                  <input type="date" data-field="startDate" class={inputCls} />
                  <select data-field="progress" class={sel}>
                    <option value="" data-i18n="s12ProgressPlaceholder">Progress rating...</option>
                    <option value="1" data-i18n="prog1">1 · Just started</option><option value="2" data-i18n="prog2">2 · Some progress</option>
                    <option value="3" data-i18n="prog3">3 · Steady progress</option><option value="4" data-i18n="prog4">4 · Strong progress</option>
                    <option value="5" data-i18n="prog5">5 · Goals nearly met</option>
                  </select>
                  <textarea data-field="goals" class={inputCls + " h-16 md:col-span-2"} placeholder="Current goals" data-i18n-ph="s12Goals"></textarea>
                </div>
              </div>
            ))}
            <div><label class={labelCls} data-i18n="s12PastServices">Past services received (type, provider, dates)</label><textarea name="pastServices" class={inputCls + " h-20"} placeholder="Optional" data-i18n-ph="commOptional"></textarea></div>
            <div>
              <label class={labelCls} data-i18n="s12OnWaitlist">Currently on a waitlist for any services?</label>
              <div class="flex gap-2 mb-2">{ynOpts.map(([v, c]) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="onWaitlist" value={v} class="accent-violet-700" /> <span data-i18n={c}>{v}</span></label>))}</div>
              <input type="text" name="waitlistDetails" class={inputCls} placeholder="If yes, which services / where?" data-i18n-ph="s12WaitlistPh" />
            </div>
          </div>
        </div>
        <!-- 13 GOALS & FOCUS -->
        <div class="form-step" data-step="13" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="s13Title">Goals & Focus</h2>
            <p class="text-sm text-slate-500 -mt-2" data-i18n="s13Sub">What matters most to your family right now — guides providers on where to focus their support.</p>
            <div><label class={labelCls} data-i18n="s13MainConcerns">Your main concerns right now</label><textarea name="mainConcerns" class={inputCls + " h-24"} placeholder="What's worrying you most at this time?" data-i18n-ph="s13MainConcernsPh"></textarea></div>
            <div>
              <label class={labelCls} data-i18n="s13Priorities">Top priorities (select any)</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {[["Communication","goalComm"],["Friendships","goalFriendships"],["Emotional Regulation","goalEmoReg"],["School Success","goalSchool"],["Independence","goalIndependence"],["Daily Living Skills","goalDailyLiving"],["Transition Planning","goalTransition"],["Employment Preparation","goalEmployment"]].map(([v, c]) => (<label class={chip}><input type="checkbox" name="goals" value={v} class="accent-violet-700 w-4 h-4" /> <span data-i18n={c}>{v}</span></label>))}
              </div>
            </div>
            <div><label class={labelCls} data-i18n="s13FocusAreas">Specific areas / behaviours you'd like help with</label><textarea name="focusAreas" class={inputCls + " h-20"} placeholder="Optional" data-i18n-ph="commOptional"></textarea></div>
            <div><label class={labelCls} data-i18n="s13Other">Anything else?</label><textarea name="goalsOther" class={inputCls + " h-16"} placeholder="Optional" data-i18n-ph="commOptional"></textarea></div>
          </div>
        </div>
        <!-- REVIEW & EXPORT -->
        <div class="form-step" data-step="14" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800" data-i18n="revTitle">Review & export</h2>
            <p class={sub} data-i18n="revSub">Tick the sections to include in the PDF you'll share, then download. Untick anything a particular provider doesn't need.</p>
            <div class="flex flex-wrap gap-3 pt-1">
              <button type="button" id="select-all" class="text-sm text-violet-700 font-medium hover:underline" data-i18n="revSelectAll">Select all</button>
              <button type="button" id="select-none" class="text-sm text-slate-400 font-medium hover:underline" data-i18n="revClearAll">Clear all</button>
            </div>
            <div id="review-output" class="space-y-3 mt-2"></div>
            <button type="button" id="export-pdf" class="w-full mt-2 px-8 py-3 rounded-full border-2 border-violet-700 text-violet-700 font-semibold hover:bg-violet-50 transition-colors" data-i18n="revDownload">Download PDF</button>
          </div>
        </div>
        <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
          <div class="flex items-center gap-3">
            <button type="button" id="back-btn" class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold hover:bg-slate-50 transition-colors" style="visibility:hidden" data-i18n="navBack">← Back</button>
            <button type="button" id="save-close-btn" class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold hover:bg-slate-50 transition-colors" data-i18n="navSaveClose">Save & close</button>
          </div>
          <button type="button" id="next-btn" class="px-7 py-2.5 rounded-lg bg-violet-700 hover:bg-violet-800 text-white text-sm font-semibold transition-colors">Next →</button>
        </div>
        <div id="save-result" class="mt-4 text-center"></div>
      </form>
    </div>
  <!-- Off-screen print view, shown only when printing -->
  <div id="print-view"></div>
  </div>
</AppFormLayout>
<style is:global>
  #print-view { position: fixed; left: -9999px; top: 0; width: 700px; }
  @media print {
    body * { visibility: hidden !important; }
    #print-view, #print-view * { visibility: visible !important; }
    #print-view { position: absolute; left: 0; top: 0; width: 100%; padding: 24px; font-family: system-ui, sans-serif; }
  }
  .pv-header { margin-bottom: 22px; border-bottom: 2px solid #6d28d9; padding-bottom: 10px; }
  .pv-header h1 { font-size: 22px; margin: 0 0 2px; color: #1e293b; }
  .pv-header .sub { color: #64748b; font-size: 12px; }
  .pv-section { margin-bottom: 16px; page-break-inside: avoid; }
  .pv-title { font-weight: 700; font-size: 14px; color: #6d28d9; margin-bottom: 6px; }
  .pv-row { display: flex; justify-content: space-between; gap: 24px; font-size: 12px; padding: 3px 0; border-bottom: 1px solid #f1f5f9; }
  .pv-label { color: #64748b; } .pv-val { color: #0f172a; text-align: right; }
</style>
<script is:inline define:vars={{ DICT, SQMAP }}>
  /* ---------- i18n (string codes from src/i18n/passport.js) ---------- */
  var T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
  /* the 36 scored-question labels (display map from lib-terms — values stay canonical) */
  (function () {
    var SQL = window.uaLang && SQMAP[window.uaLang];
    if (!SQL) return;
    document.querySelectorAll("[data-sq]").forEach(function (el) {
      var v = SQL[el.getAttribute("data-sq")];
      if (v) el.textContent = v;
    });
  })();
  var tpl = function (s, v) { return String(s).replace(/\{(\w+)\}/g, function (m, k) { return v && v[k] != null ? v[k] : ""; }); };
  var ofName = function (n) { return window.uaLang === "fr" ? (/^[aeiouyàâäéèêëìîïòôöùûüh]/i.test(String(n || "")) ? "d'" : "de ") : ""; };
  var currentStep = 1;
  var totalSteps = 13;
  var sectionNames = T.stepNames;
  var form = document.getElementById("passport-form");
  var backBtn = document.getElementById("back-btn");
  var nextBtn = document.getElementById("next-btn");
  var stepLabel = document.getElementById("step-label");
  var stepPct = document.getElementById("step-pct");
  var progressBar = document.getElementById("progress-bar");
  var saveResult = document.getElementById("save-result");
  var reviewStep = totalSteps + 1;
  function showStep(n) {
    var steps = document.querySelectorAll(".form-step");
    for (var i = 0; i < steps.length; i++) {
      steps[i].style.display = (parseInt(steps[i].getAttribute("data-step")) === n) ? "block" : "none";
    }
    backBtn.style.visibility = n === 1 ? "hidden" : "visible";
    if (n <= totalSteps) {
      stepLabel.textContent = tpl(T.stepOf, { n: n, total: totalSteps, name: sectionNames[n - 1] });
      var pct = Math.round((n / totalSteps) * 100);
      stepPct.textContent = pct + "%"; progressBar.style.width = pct + "%";
      nextBtn.textContent = n === totalSteps ? T.navReviewExport : T.navNext;
    } else {
      stepLabel.textContent = T.reviewStepLabel; stepPct.textContent = "100%"; progressBar.style.width = "100%";
      nextBtn.textContent = T.navSavePassport;
    }
    // sync dropdown
    if (jumpSel) jumpSel.value = n <= totalSteps ? n : totalSteps + 1;
    window.scrollTo({ top: 0, behavior: "smooth" });
  }
  // Section jump dropdown
  var jumpSel = document.getElementById("section-jump");
  jumpSel.addEventListener("change", function(){
    var go = parseInt(jumpSel.value);
    if (go === totalSteps + 1) { currentStep = reviewStep; renderReview(); showStep(reviewStep); }
    else { currentStep = go; showStep(go); }
  });
  // Eye exam toggle
  document.querySelectorAll(".eye-toggle").forEach(function(r){
    r.addEventListener("change", function(){ document.getElementById("eye-details").style.display = r.value === "Yes" ? "block" : "none"; });
  });
  // Hearing test toggle
  document.querySelectorAll(".hearing-toggle").forEach(function(r){
    r.addEventListener("change", function(){ document.getElementById("hearing-details").style.display = r.value === "Yes" ? "block" : "none"; });
  });
  // Agency toggle
  document.querySelectorAll(".agency-toggle").forEach(function(r){
    r.addEventListener("change", function(){ document.getElementById("agency-details").style.display = r.value === "Yes" ? "block" : "none"; });
  });
  // Sensory: reveal signs/severity logic
  document.querySelectorAll(".sense-typical").forEach(function(cb){
    cb.addEventListener("change", function(){
      var sense = cb.getAttribute("data-sense");
      var wrap = document.querySelector('.sense-signs-wrap[data-sense="'+sense+'"]');
      if (cb.checked) {
        // uncheck signs and hide them
        document.querySelectorAll('.sense-sign[data-sense="'+sense+'"]').forEach(function(s){ s.checked=false; });
        if (wrap) wrap.style.opacity = "0.4";
        var sevWrap = document.querySelector('.sense-sev-wrap[data-sense="'+sense+'"]');
        if (sevWrap) sevWrap.style.display = "none";
      } else {
        if (wrap) wrap.style.opacity = "1";
      }
    });
  });
  document.querySelectorAll(".sense-sign").forEach(function(cb){
    cb.addEventListener("change", function(){
      var sense = cb.getAttribute("data-sense");
      var anyChecked = document.querySelectorAll('.sense-sign[data-sense="'+sense+'"]:checked').length > 0;
      var sevWrap = document.querySelector('.sense-sev-wrap[data-sense="'+sense+'"]');
      if (sevWrap) sevWrap.style.display = anyChecked ? "block" : "none";
      // unchecking typical if a sign is selected
      if (anyChecked) { var tc = document.querySelector('.sense-typical[data-sense="'+sense+'"]'); if (tc) tc.checked = false; }
    });
  });
  var toggles = document.querySelectorAll(".therapy-toggle");
  for (var i = 0; i < toggles.length; i++) {
    toggles[i].addEventListener("change", function (e) {
      var name = e.target.getAttribute("data-therapy");
      document.querySelector('.therapy-fields[data-fields="' + name + '"]').style.display = e.target.checked ? "grid" : "none";
    });
  }
  function getRadio(n){var el=form.querySelector('input[name="'+n+'"]:checked');return el?el.value:"";}
  function getChecks(n){var els=form.querySelectorAll('input[name="'+n+'"]:checked');var o=[];for(var i=0;i<els.length;i++)o.push(els[i].value);return o;}
  function getVal(n){var el=form.querySelector('[name="'+n+'"]');return el?el.value:"";}
  function senseObj(k){
    var typical = !!form.querySelector('input[name="sense_typical_'+k+'"]:checked');
    var signs = getChecks("sense_signs_"+k);
    var severity = getVal("sense_sev_"+k);
    return { typical: typical, signs: signs, severity: severity };
  }
  // Collect every 0–4 scale answer into { id: value } using the injected id list
  function collectScales(){
    var ids = [];
    try { ids = JSON.parse(document.getElementById("ua-scale-ids").textContent); } catch(e) {}
    var out = {};
    ids.forEach(function(id){ var v = getVal(id); if (v !== "") out[id] = v; });
    return out;
  }
  function buildPassport() {
    var therapies = [];
    var tt = document.querySelectorAll(".therapy-toggle");
    for (var i = 0; i < tt.length; i++) {
      if (tt[i].checked) {
        var name = tt[i].getAttribute("data-therapy");
        var box = document.querySelector('.therapy-fields[data-fields="' + name + '"]');
        therapies.push({ type:name, provider:box.querySelector('[data-field="provider"]').value, frequency:box.querySelector('[data-field="frequency"]').value, startDate:box.querySelector('[data-field="startDate"]').value, progress:box.querySelector('[data-field="progress"]').value, goals:box.querySelector('[data-field="goals"]').value });
      }
    }
    return {
      childProfile: { firstName:getVal("firstName"), lastName:getVal("lastName"), dob:getVal("dob"), gender:getVal("gender"), city:getVal("city"), country:getVal("country"), healthInsurance:getVal("healthInsurance"), homeLanguages:getVal("homeLanguages"), bestLanguage:getVal("bestLanguage") },
      household: { g1name:getVal("g1name"), g1rel:getVal("g1rel"), g1email:getVal("g1email"), g1phone:getVal("g1phone"), g2name:getVal("g2name"), g2rel:getVal("g2rel"), g2email:getVal("g2email"), g2phone:getVal("g2phone"), custody:getVal("custody"), maritalStatus:getVal("maritalStatus"), livesWith:getChecks("livesWith"), siblings:getVal("siblings"), funding:getRadio("funding"), fundingType:getVal("fundingType") },
      diagnosis: { status:getRadio("diagnosisStatus"), diagnoses:getChecks("diagnoses"), diagnosedBy:getVal("diagnosedBy"), date:getVal("diagnosisDate"), awaiting:getVal("awaitingAssessment"), familyHistory:getChecks("familyHistory"), familyHistoryNotes:getVal("familyHistoryNotes") },
      birth: { pregnancy:getVal("pregnancy"), gestation:getVal("gestation"), birthWeight:getVal("birthWeight"), complications:getVal("birthComplications"), regression:getVal("regression"), regressionNotes:getVal("regressionNotes"), milestones:{ sit:getVal("msSit"), crawl:getVal("msCrawl"), walk:getVal("msWalk"), firstWord:getVal("msFirstWord"), phrases:getVal("msPhrases"), sentences:getVal("msSentences"), toiletDay:getVal("msToiletDay"), toiletNight:getVal("msToiletNight") } },
      communication: { style:getRadio("commStyle"), means:getChecks("commMeans"), canExpressNeeds:getVal("canExpressNeeds"), challenges:getChecks("commChallenges") },
      sensory: { auditory:senseObj("auditory"), visual:senseObj("visual"), tactile:senseObj("tactile"), oral:senseObj("oral"), smell:senseObj("smell"), movement:senseObj("movement"), body:senseObj("body"), other:getChecks("sensory_other"), notes:getVal("sensoryNotes") },
      dailyLiving: { eating:getVal("eating"), dressing:getVal("dressing"), toileting:getVal("toileting"), sleep:getVal("sleep"), safety:getVal("safety"), multiStep:getVal("multiStep"), groupActivities:getVal("groupActivities"), feeding:getVal("feeding"), dietaryRestrictions:getVal("dietaryRestrictions") },
      motor: { gross:getChecks("motor_gross"), fine:getChecks("motor_fine"), notes:getVal("motorNotes") },
      health: { handedness:getRadio("handedness"), pediatrician:getVal("pediatrician"), specialists:getVal("specialists"), allergyFood:getVal("allergyFood"), allergyEnv:getVal("allergyEnv"), allergyOther:getVal("allergyOther"), allergyTreatment:getVal("allergyTreatment"), medicalConditions:getVal("medicalConditions"), medications:getVal("medications"), pastMedications:getVal("pastMedications"), surgeries:getVal("surgeries"), hadEyeExam:getRadio("hadEyeExam"), lastEyeExam:getVal("lastEyeExam"), glasses:getRadio("glasses"), eyeNotes:getVal("eyeNotes"), hadHearingTest:getRadio("hadHearingTest"), lastHearingTest:getVal("lastHearingTest"), earInfections:getRadio("earInfections"), hearingNotes:getVal("hearingNotes") },
      behaviour: { challenges:{ meltdowns:getVal("beh_meltdowns"), aggression:getVal("beh_aggression"), selfInjury:getVal("beh_selfInjury"), elopement:getVal("beh_elopement"), anxiety:getVal("beh_anxiety"), rigidity:getVal("beh_rigidity"), emotional:getVal("beh_emotional"), repetitive:getVal("beh_repetitive"), defiance:getVal("beh_defiance"), hyperactivity:getVal("beh_hyperactivity") }, triggers:getVal("triggers"), strategies:getVal("strategies"), peersInterest:getVal("peersInterest"), peersInteract:getVal("peersInteract"), followsInstructions:getVal("followsInstructions"), suspended:getRadio("suspended"), suspendedNotes:getVal("suspendedNotes") },
      strengths: { strengths:getVal("strengthsText"), interests:getVal("interests"), dislikes:getVal("dislikes") },
      education: { schoolName:getVal("schoolName"), schoolType:getVal("schoolType"), grade:getVal("grade"), schoolBoard:getVal("schoolBoard"), hasIEP:getRadio("hasIEP"), classroomSupport:getVal("classroomSupport"), agencySupport:getVal("agencySupport"), challenges:getVal("schoolChallenges"), strengths:getVal("schoolStrengths"), upcomingTransition:getVal("upcomingTransition"), flightRisk:getRadio("flightRisk") },
      therapy: therapies,
      services: { pastServices:getVal("pastServices"), onWaitlist:getRadio("onWaitlist"), waitlistDetails:getVal("waitlistDetails") },
      goals: { mainConcerns:getVal("mainConcerns"), priorities:getChecks("goals"), focusAreas:getVal("focusAreas"), other:getVal("goalsOther") },
      scales: collectScales(),
    };
  }
  function buildSections(p) {
    var cp=p.childProfile, hh=p.household, dg=p.diagnosis, b=p.birth, m=b.milestones, hl=p.health, bh=p.behaviour, ed=p.education, s=p.sensory;
    var SEC=T.sections, R=T.rows, MP=T.msPfx;
    var secs = [
      {key:"childProfile", title:SEC.childProfile, rows:[[R.firstName,cp.firstName],[R.lastName,cp.lastName],[R.dob,cp.dob],[R.gender,cp.gender],[R.city,cp.city],[R.country,cp.country],[R.healthIns,cp.healthInsurance],[R.homeLang,cp.homeLanguages],[R.understandsBest,cp.bestLanguage]]},
