        } else {
          saveResult.innerHTML = '<span style="color:#ef4444">' + T.jsGenericError + '</span>';
          nextBtn.disabled = false; nextBtn.textContent = T.navSavePassport;
        }
      })();
      return;
    }
    currentStep++; showStep(currentStep);
  });
  backBtn.addEventListener("click", function () {
    if (currentStep === reviewStep) { currentStep = totalSteps; } else if (currentStep > 1) { currentStep--; }
    nextBtn.style.display = "inline-block"; saveResult.innerHTML = ""; showStep(currentStep);
  });
  showStep(1);
</script>

