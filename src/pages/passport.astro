---
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import { SCALE_QUESTIONS, SCALE_IDS } from "@/config/wheelConfig.js";

const inputCls = "w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white";
const cardCls = "bg-white border border-slate-200 rounded-2xl p-6 md:p-8 space-y-5";
const labelCls = "block text-sm font-medium text-slate-600 mb-2";
const chip = "flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors text-slate-600 text-sm";
const sel = inputCls + " text-slate-500";
const sub = "text-sm text-slate-500 -mt-2";
const ynOpts = ["Yes","No"];

// Section names for the step tabs (must match the data-step order below)
const SECTION_NAMES = ["Child","Household","Diagnosis","Birth","Communication","Sensory","Daily & Motor","Health","Behaviour","Strengths","Education","Therapy","Goals","Review"];
const scale4 = [
  { v: "0", l: "Never" }, { v: "1", l: "Rarely" }, { v: "2", l: "Sometimes" },
  { v: "3", l: "Often" }, { v: "4", l: "Consistently" },
];
---

<AppFormLayout title="Family Passport" activeNav="profiles">
  <div class="form-canvas">
    <div class="max-w-3xl mx-auto mt-2 mb-24">

      <div class="mb-10 text-center">
        <h1 class="text-3xl font-bold text-slate-800">
          Family <span class="text-violet-700">Passport</span>
        </h1>
        <p class="text-slate-500 mt-3 leading-relaxed max-w-xl mx-auto">
          Fill this in once and keep it updated. Export a PDF for any provider, therapist, or school — share only what's relevant.
        </p>
      </div>

      <!-- Progress -->
      <div class="bg-white border border-slate-200 rounded-xl px-5 py-4 mb-8">
        <div class="flex items-center justify-between mb-2.5">
          <span id="step-label" class="text-sm font-semibold text-slate-700">Step 1 of 13 · Child Profile</span>
          <span id="step-pct" class="text-sm font-medium text-violet-700">8%</span>
        </div>
        <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
          <div id="progress-bar" class="h-full bg-violet-600 rounded-full transition-all duration-300" style="width:8%"></div>
        </div>
        <div class="mt-3">
          <select id="section-jump" class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2 bg-slate-50 text-slate-600 outline-none focus:ring-2 focus:ring-violet-300 cursor-pointer">
            {SECTION_NAMES.map((nm, i) => (
              <option value={i + 1}>{i + 1}. {nm}</option>
            ))}
          </select>
        </div>
      </div>

      <form id="passport-form" novalidate>
        <script type="application/json" id="ua-scale-ids" set:html={JSON.stringify(SCALE_IDS)}></script>

        <!-- 1 CHILD PROFILE -->
        <div class="form-step" data-step="1">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Child Profile</h2>
            <p class={sub}>Basic identifying information about your child — used in all PDFs and provider outreach.</p>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class={labelCls}>First name *</label>
                <input type="text" name="firstName" class={inputCls} placeholder="Child's first name" />
                <p id="err-firstName" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Please enter your child's first name.</p>
              </div>
              <div>
                <label class={labelCls}>Last name *</label>
                <input type="text" name="lastName" class={inputCls} placeholder="Child's last name" />
                <p id="err-lastName" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Please enter your child's last name.</p>
              </div>
              <div>
                <label class={labelCls}>Date of birth *</label>
                <input type="date" name="dob" class={inputCls} />
                <p id="err-dob" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Date of birth is required.</p>
              </div>
              <div>
                <label class={labelCls}>Gender *</label>
                <select name="gender" class={sel}>
                  <option value="">Select...</option>
                  <option value="Female">Female</option><option value="Male">Male</option>
                  <option value="Non-binary">Non-binary</option>
                  <option value="Prefer not to say">Prefer not to say</option>
                  <option value="Other">Other</option>
                </select>
                <p id="err-gender" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Please make a selection.</p>
              </div>
              <div><label class={labelCls}>City / region</label><input type="text" name="city" class={inputCls} placeholder="e.g. Montréal, QC" /></div>
              <div><label class={labelCls}>Country</label><input type="text" name="country" class={inputCls} placeholder="e.g. Canada" /></div>
              <div><label class={labelCls}>Health insurance # (e.g. RAMQ — optional)</label><input type="text" name="healthInsurance" class={inputCls} placeholder="Optional" /></div>
              <div><label class={labelCls}>Language(s) spoken at home</label><input type="text" name="homeLanguages" class={inputCls} placeholder="e.g. English, French" /></div>
              <div><label class={labelCls}>Language child understands best</label><input type="text" name="bestLanguage" class={inputCls} placeholder="e.g. English" /></div>
            </div>
          </div>
        </div>

        <!-- 2 PARENTS & HOUSEHOLD -->
        <div class="form-step" data-step="2" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Parents & Household</h2>
            <p class={sub}>Contact details for guardians and household context — helps providers know who to reach and how the family is structured.</p>
            <div class="bg-white border border-slate-200 rounded-xl p-4 space-y-3">
              <p class="font-medium text-slate-700 text-sm">Parent / Guardian 1 *</p>
              <div class="grid md:grid-cols-2 gap-3">
                <div>
                  <input type="text" name="g1name" class={inputCls} placeholder="Full name *" />
                  <p id="err-g1name" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Guardian name is required.</p>
                </div>
                <select name="g1rel" class={sel}>
                  <option value="">Relationship to child...</option>
                  <option>Mother</option><option>Father</option><option>Guardian</option><option>Other</option>
                </select>
                <div>
                  <input type="email" name="g1email" class={inputCls} placeholder="Email *" />
                  <p id="err-g1email" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Email is required.</p>
                </div>
                <input type="tel" name="g1phone" class={inputCls} placeholder="Phone" />
              </div>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl p-4 space-y-3">
              <p class="font-medium text-slate-700 text-sm">Parent / Guardian 2 (optional)</p>
              <div class="grid md:grid-cols-2 gap-3">
                <input type="text" name="g2name" class={inputCls} placeholder="Full name" />
                <select name="g2rel" class={sel}>
                  <option value="">Relationship to child...</option>
                  <option>Mother</option><option>Father</option><option>Guardian</option><option>Other</option>
                </select>
                <input type="email" name="g2email" class={inputCls} placeholder="Email" />
                <input type="tel" name="g2phone" class={inputCls} placeholder="Phone" />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class={labelCls}>Legal custody</label>
                <select name="custody" class={sel}>
                  <option value="">Select...</option>
                  <option>Guardians together</option><option>Joint custody</option><option>Single custody</option><option>Other</option>
                </select>
              </div>
              <div>
                <label class={labelCls}>Family status</label>
                <select name="maritalStatus" class={sel}>
                  <option value="">Select...</option>
                  <option>Married</option><option>Living together</option><option>Separated</option>
                  <option>Divorced</option><option>Single</option><option>Other</option>
                </select>
              </div>
            </div>
            <div>
              <label class={labelCls}>Who the child lives with</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {["Both parents","Mother","Father","Siblings","Grandparents","Foster family","Other"].map((o) => (<label class={chip}><input type="checkbox" name="livesWith" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>))}
              </div>
            </div>
            <div><label class={labelCls}>Siblings (name, age, relationship)</label><textarea name="siblings" class={inputCls + " h-20"} placeholder="e.g. Sara, 8, sister"></textarea></div>
            <div>
              <label class={labelCls}>Do you receive government funding?</label>
              <div class="flex gap-2 mb-2">
                {ynOpts.map((o) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="funding" value={o} class="accent-violet-700" /> {o}</label>))}
              </div>
              <input type="text" name="fundingType" class={inputCls} placeholder="If yes, which programs / subsidies?" />
            </div>
          </div>
        </div>

        <!-- 3 DIAGNOSIS & FAMILY HISTORY -->
        <div class="form-step" data-step="3" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Diagnosis</h2>
            <p class="text-sm text-slate-500 -mt-2">Diagnoses, assessments, and family history — helpful context for any professional who works with your child.</p>
            <div>
              <label class={labelCls}>Diagnosis status</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {["Diagnosed","Assessment Pending","Self-Identified Concerns"].map((o) => (<label class={chip}><input type="radio" name="diagnosisStatus" value={o} class="accent-violet-700" /> {o}</label>))}
              </div>
            </div>
            <div>
              <label class={labelCls}>Diagnoses (select any that apply)</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {["Autism","ADHD","Speech / Language Disorder","Global Developmental Delay","Intellectual Disability","Learning Difficulty","Dyspraxia / DCD","Sensory Processing","Anxiety","Depression","OCD","Tourette's / Tics","Epilepsy / Seizures","Genetic Condition","Other"].map((o) => (<label class={chip}><input type="checkbox" name="diagnoses" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>))}
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls}>Diagnosed / referred by</label><input type="text" name="diagnosedBy" class={inputCls} placeholder="Professional name & title" /></div>
              <div><label class={labelCls}>Date of diagnosis</label><input type="text" name="diagnosisDate" class={inputCls} placeholder="e.g. March 2024" /></div>
            </div>
            <div><label class={labelCls}>If awaiting assessment — with whom / where?</label><input type="text" name="awaitingAssessment" class={inputCls} placeholder="Optional" /></div>

            <h2 class="text-lg font-bold text-slate-800 pt-2">Family History</h2>
            <p class={sub}>Conditions present in close relatives (helps professionals understand the full picture).</p>
            <div class="grid sm:grid-cols-3 gap-2">
              {["Developmental / language delay","Learning difficulties","Autism","ADHD","Anxiety","Depression","OCD","Bipolar","Tourette's / tics","Intellectual disability","Epilepsy / seizures","Genetic disorder","Substance use"].map((o) => (<label class={chip}><input type="checkbox" name="familyHistory" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>))}
            </div>
            <div><label class={labelCls}>Notes (relation to child, details)</label><textarea name="familyHistoryNotes" class={inputCls + " h-16"} placeholder="e.g. Maternal uncle — autism"></textarea></div>
          </div>
        </div>

        <!-- 4 BIRTH & DEVELOPMENT -->
        <div class="form-step" data-step="4" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Birth & Development</h2>
            <p class="text-sm text-slate-500 -mt-2">Pregnancy, birth, and early developmental milestones — often relevant to OT, SLP, and paediatric assessments.</p>
            <div><label class={labelCls}>Pregnancy (any complications)</label><textarea name="pregnancy" class={inputCls + " h-16"} placeholder="Optional"></textarea></div>
            <div class="grid md:grid-cols-3 gap-4">
              <div><label class={labelCls}>Weeks at birth</label><input type="text" name="gestation" class={inputCls} placeholder="e.g. 40" /></div>
              <div><label class={labelCls}>Birth weight</label><input type="text" name="birthWeight" class={inputCls} placeholder="e.g. 3.2 kg" /></div>
              <div><label class={labelCls}>Lost / regressed skills?</label>
                <select name="regression" class={sel}><option value="">Select...</option><option>No</option><option>Yes</option></select>
              </div>
            </div>
            <div><label class={labelCls}>Birth / post-birth complications</label><textarea name="birthComplications" class={inputCls + " h-16"} placeholder="e.g. breathing difficulty, feeding issues, tongue tie"></textarea></div>
            <div>
              <label class={labelCls}>Developmental milestones (approx. age reached — leave blank if unsure)</label>
              <div class="grid sm:grid-cols-2 gap-3">
                {[
                  {n:"msSit",l:"Sat unsupported"},{n:"msCrawl",l:"Crawled"},{n:"msWalk",l:"Walked"},
                  {n:"msFirstWord",l:"First words"},{n:"msPhrases",l:"2-word phrases"},{n:"msSentences",l:"Simple sentences"},
                  {n:"msToiletDay",l:"Toilet trained (day)"},{n:"msToiletNight",l:"Toilet trained (night)"},
                ].map((f) => (
                  <div class="flex items-center gap-2">
                    <span class="text-sm text-slate-500 w-40 shrink-0">{f.l}</span>
                    <input type="text" name={f.n} class={inputCls + " py-2"} placeholder="age" />
                  </div>
                ))}
              </div>
            </div>
            <div><label class={labelCls}>If skills were lost, describe</label><textarea name="regressionNotes" class={inputCls + " h-16"} placeholder="Optional"></textarea></div>
          </div>
        </div>

        <!-- 5 COMMUNICATION -->
        <div class="form-step" data-step="5" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Communication Profile</h2>
            <p class="text-sm text-slate-500 -mt-2">How your child communicates today — their style, methods, strengths and challenges. Directly used for SLP referrals.</p>
            <div>
              <label class={labelCls}>Communication style</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {["Fluent Verbal","Verbal","Limited Verbal","Non-Speaking"].map((o) => (<label class={chip}><input type="radio" name="commStyle" value={o} class="accent-violet-700" /> {o}</label>))}
              </div>
            </div>
            <div>
              <label class={labelCls}>Primary means of communication (select any)</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {["Words","Sentences","Sounds","Pictures (PECS)","Sign language","Device / AAC app","No primary means yet"].map((o) => (<label class={chip}><input type="checkbox" name="commMeans" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>))}
              </div>
            </div>
            <div>
              <label class={labelCls}>Can express needs</label>
              <select name="canExpressNeeds" class={sel}>
                <option value="">Select...</option><option>Consistently</option><option>Sometimes</option><option>Rarely</option>
              </select>
            </div>
            <div>
              <label class={labelCls}>Communication challenges (select any)</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {["Requesting","Conversation","Question Answering","Emotional Expression","Social Communication"].map((o) => (<label class={chip}><input type="checkbox" name="commChallenges" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>))}
              </div>
            </div>
            <div class="pt-2">
              <label class={labelCls}>How often does your child do each of these?</label>
              <div class="space-y-2">
                {SCALE_QUESTIONS.communication.map((q) => (
                  <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                    <span class="text-sm text-slate-600 flex-1">{q.label}</span>
                    <select name={q.id} class={sel + " sm:w-44 shrink-0"}>
                      <option value="">—</option>
                      {scale4.map((o) => <option value={o.v}>{o.l}</option>)}
                    </select>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- 6 SENSORY (detailed signs + severity) -->
        <div class="form-step" data-step="6" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Sensory Profile</h2>
            <p class="text-sm text-slate-500 -mt-2">How your child responds to sensory input across each sense. This feeds directly into the development wheel.</p>
            <p class={sub}>For each sense, tick "no concerns" if it's typical, or select any signs you notice — then choose how much it affects daily life.</p>
            {[
              {k:"auditory", l:"Sound (auditory)", signs:["Covers ears at loud sounds","Distressed by sudden noises","Bothered by background noise","Seeks loud sounds / makes noise","Doesn't respond to sounds/name"]},
              {k:"visual", l:"Sight (visual)", signs:["Bothered by bright lights","Avoids eye contact","Fascinated by spinning/lights","Visual clutter overwhelms","Misses visual details"]},
              {k:"tactile", l:"Touch (tactile)", signs:["Bothered by clothing tags/textures","Dislikes being touched","Distressed by haircuts/nails","Seeks deep pressure / tight hugs","Mouths or chews objects","High pain tolerance"]},
              {k:"oral", l:"Taste & mouth (oral)", signs:["Very limited food textures","Strong food preferences","Gags easily","Seeks crunchy/chewy foods","Chews non-food items"]},
              {k:"smell", l:"Smell", signs:["Bothered by smells","Seeks out smells","Doesn't notice strong smells"]},
              {k:"movement", l:"Movement & balance", signs:["Seeks spinning/swinging","Avoids movement / cautious","Fearful when feet leave ground","Constantly moving","Poor balance"]},
              {k:"body", l:"Body awareness", signs:["Bumps into things / clumsy","Unaware of body position","Uses too much/little force","Seeks crashing / rough play"]},
            ].map((d) => (
              <div class="bg-white border border-slate-200 rounded-xl p-4">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-slate-700">{d.l}</span>
                  <label class="flex items-center gap-2 text-xs text-slate-500 cursor-pointer"><input type="checkbox" name={"sense_typical_" + d.k} value="typical" class="sense-typical accent-violet-700 w-4 h-4" data-sense={d.k} /> No concerns / typical</label>
                </div>
                <div class="sense-signs-wrap" data-sense={d.k}>
                  <div class="grid sm:grid-cols-2 gap-1.5">
                    {d.signs.map((sg) => (<label class={chip + " text-xs py-2"}><input type="checkbox" name={"sense_signs_" + d.k} value={sg} class="sense-sign accent-violet-700 w-4 h-4" data-sense={d.k} /> {sg}</label>))}
                  </div>
                  <div class="sense-sev-wrap mt-2" data-sense={d.k} style="display:none">
                    <label class="text-xs text-slate-500">How much does this affect daily life?</label>
                    <select name={"sense_sev_" + d.k} class={sel + " mt-1"}>
                      <option value="">Select severity…</option>
                      <option value="Mild">Mild — manageable</option>
                      <option value="Moderate">Moderate — needs some support</option>
                      <option value="Significant">Significant — needs a lot of support</option>
                    </select>
                  </div>
                </div>
              </div>
            ))}
            <div>
              <label class={labelCls}>Other sensory signs (select any)</label>
              <div class="grid sm:grid-cols-3 gap-2">
                {["Insensitive to temperature","High pain tolerance","Strong difficulty with transitions"].map((it) => (<label class={chip}><input type="checkbox" name="sensory_other" value={it} class="accent-violet-700 w-4 h-4" /> {it}</label>))}
              </div>
            </div>
            <div><label class={labelCls}>Provider notes — sensory</label><textarea name="sensoryNotes" class={inputCls + " h-20"} placeholder="Anything a provider should know — e.g. 'covers ears at hand dryers', 'loves deep pressure hugs', 'will not tolerate seams in socks'"></textarea></div>
          </div>
        </div>

        <!-- (old sensory select block removed) -->

        <!-- 7 DAILY LIVING & MOTOR -->
        <div class="form-step" data-step="7" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Daily Living &amp; Motor</h2>
            <p class="text-sm text-slate-500 -mt-2">Independence in daily tasks and physical development — key information for OT assessments and school planning.</p>
            <div class="grid md:grid-cols-2 gap-4">
              {[
                {name:"eating", label:"Independent eating", opts:["Independent","With support","Not yet"]},
                {name:"dressing", label:"Independent dressing", opts:["Independent","With support","Not yet"]},
                {name:"toileting", label:"Toilet training status", opts:["Fully trained","In progress","Not started","Not applicable"]},
                {name:"sleep", label:"Sleep quality", opts:["Good","Variable","Poor"]},
                {name:"safety", label:"Safety awareness", opts:["Strong","Developing","Limited"]},
                {name:"multiStep", label:"Follows multi-step instructions", opts:["Yes","Sometimes","No"]},
                {name:"groupActivities", label:"Participates in group activities", opts:["Yes","Sometimes","No"]},
                {name:"feeding", label:"Eating / feeding difficulties", opts:["None","Mild","Significant"]},
              ].map((f) => (
                <div>
                  <label class={labelCls}>{f.label}</label>
                  <select name={f.name} class={sel}><option value="">Select...</option>{f.opts.map((o) => <option value={o}>{o}</option>)}</select>
                </div>
              ))}
            </div>
            <div><label class={labelCls}>Dietary restrictions</label><input type="text" name="dietaryRestrictions" class={inputCls} placeholder="e.g. gluten-free, no nuts" /></div>

            <h3 class="font-bold text-slate-800 pt-2">Motor & physical</h3>
            <div>
              <label class={labelCls}>Gross motor (select any that apply now)</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {["Walks on tiptoes","Clumsy / bumps into things","Poor balance","Low muscle tone","Difficulty with stairs","Difficulty running or jumping","Delayed gross-motor milestones"].map((it) => (<label class={chip}><input type="checkbox" name="motor_gross" value={it} class="accent-violet-700 w-4 h-4" /> {it}</label>))}
              </div>
            </div>
            <div>
              <label class={labelCls}>Fine motor (select any that apply now)</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {["Difficulty with handwriting / drawing","Difficulty using utensils","Difficulty with buttons / zippers","Difficulty using scissors","Weak or awkward pencil grip"].map((it) => (<label class={chip}><input type="checkbox" name="motor_fine" value={it} class="accent-violet-700 w-4 h-4" /> {it}</label>))}
              </div>
            </div>
            <div><label class={labelCls}>Motor / physical notes (past or current — e.g. "had physio for low tone age 2–3")</label><textarea name="motorNotes" class={inputCls + " h-16"} placeholder="Optional"></textarea></div>

            <h3 class="font-bold text-slate-800 pt-2">Attention & independence</h3>
            <div class="space-y-2">
              {SCALE_QUESTIONS.executive.map((q) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <span class="text-sm text-slate-600 flex-1">{q.label}</span>
                  <select name={q.id} class={sel + " sm:w-44 shrink-0"}>
                    <option value="">—</option>
                    {scale4.map((o) => <option value={o.v}>{o.l}</option>)}
                  </select>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 8 HEALTH & MEDICAL -->
        <div class="form-step" data-step="8" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Health & Medical</h2>
            <p class="text-sm text-slate-500 -mt-2">Medical background, medications, and relevant health history — useful for any clinical referral or school health plan.</p>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls}>Pediatrician / GP</label><input type="text" name="pediatrician" class={inputCls} placeholder="Name" /></div>
              <div><label class={labelCls}>Other specialists following your child</label><input type="text" name="specialists" class={inputCls} placeholder="e.g. neurologist" /></div>
            </div>
            <div>
              <label class={labelCls}>Dominant hand</label>
              <div class="flex gap-2">
                {["Right","Left","Both"].map((o) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="handedness" value={o} class="accent-violet-700" /> {o}</label>))}
              </div>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
              <div><label class={labelCls}>Food allergies</label><input type="text" name="allergyFood" class={inputCls} placeholder="Optional" /></div>
              <div><label class={labelCls}>Environmental allergies</label><input type="text" name="allergyEnv" class={inputCls} placeholder="Optional" /></div>
              <div><label class={labelCls}>Other allergies</label><input type="text" name="allergyOther" class={inputCls} placeholder="Optional" /></div>
            </div>
            <div><label class={labelCls}>Allergy reactions & treatment (e.g. EpiPen)</label><input type="text" name="allergyTreatment" class={inputCls} placeholder="Optional" /></div>
            <div><label class={labelCls}>Medical conditions / chronic illnesses</label><textarea name="medicalConditions" class={inputCls + " h-16"} placeholder="e.g. asthma, recurrent ear infections"></textarea></div>
            <div><label class={labelCls}>Current medications (name, dose, frequency, purpose)</label><textarea name="medications" class={inputCls + " h-16"} placeholder="One per line"></textarea></div>
            <div><label class={labelCls}>Past medications (and why stopped)</label><textarea name="pastMedications" class={inputCls + " h-16"} placeholder="Optional"></textarea></div>
            <div><label class={labelCls}>Surgeries / hospitalizations</label><textarea name="surgeries" class={inputCls + " h-16"} placeholder="Optional"></textarea></div>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class={labelCls}>Has your child had an eye exam?</label>
                <div class="flex gap-2 mb-2">
                  <label class={chip + " flex-1 justify-center"}><input type="radio" name="hadEyeExam" value="Yes" class="accent-violet-700 eye-toggle" /> Yes</label>
                  <label class={chip + " flex-1 justify-center"}><input type="radio" name="hadEyeExam" value="No" class="accent-violet-700 eye-toggle" /> No</label>
                </div>
                <div id="eye-details" style="display:none" class="space-y-2">
                  <input type="text" name="lastEyeExam" class={inputCls} placeholder="Date of last exam (e.g. June 2024)" />
                  <div class="flex gap-2">
                    <label class={chip + " flex-1 justify-center text-xs"}><input type="radio" name="glasses" value="Yes" class="accent-violet-700" /> Wears glasses</label>
                    <label class={chip + " flex-1 justify-center text-xs"}><input type="radio" name="glasses" value="No" class="accent-violet-700" /> No glasses</label>
                  </div>
                  <textarea name="eyeNotes" class={inputCls + " h-16"} placeholder="Any findings or concerns (optional)"></textarea>
                </div>
              </div>
              <div>
                <label class={labelCls}>Has your child had a hearing test?</label>
                <div class="flex gap-2 mb-2">
                  <label class={chip + " flex-1 justify-center"}><input type="radio" name="hadHearingTest" value="Yes" class="accent-violet-700 hearing-toggle" /> Yes</label>
                  <label class={chip + " flex-1 justify-center"}><input type="radio" name="hadHearingTest" value="No" class="accent-violet-700 hearing-toggle" /> No</label>
                </div>
                <div id="hearing-details" style="display:none" class="space-y-2">
                  <input type="text" name="lastHearingTest" class={inputCls} placeholder="Date of last test (e.g. 2023)" />
                  <div class="flex gap-2">
                    <label class={chip + " flex-1 justify-center text-xs"}><input type="radio" name="earInfections" value="Yes" class="accent-violet-700" /> Recurrent ear infections / PE tubes</label>
                    <label class={chip + " flex-1 justify-center text-xs"}><input type="radio" name="earInfections" value="No" class="accent-violet-700" /> No</label>
                  </div>
                  <textarea name="hearingNotes" class={inputCls + " h-16"} placeholder="Any findings or concerns (optional)"></textarea>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 9 BEHAVIOUR & SOCIAL -->
        <div class="form-step" data-step="9" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Behaviour & Social</h2>
            <p class="text-sm text-slate-500 -mt-2">Behavioural patterns, social engagement, and frequency of specific challenges. Also includes developmental questions for the profile wheel.</p>
            <div>
              <label class={labelCls}>How often does each happen? (leave at "—" if it doesn't apply)</label>
              <div class="space-y-2">
                {[
                  {k:"meltdowns",l:"Meltdowns"},{k:"aggression",l:"Aggression toward others"},
                  {k:"selfInjury",l:"Self-injury"},{k:"elopement",l:"Elopement / flight risk"},
                  {k:"anxiety",l:"Anxiety"},{k:"rigidity",l:"Rigidity / difficulty with change"},
                  {k:"emotional",l:"Difficulty regulating emotions"},{k:"repetitive",l:"Repetitive behaviours"},
                  {k:"defiance",l:"Defiance / non-compliance"},{k:"hyperactivity",l:"Hyperactivity / impulsivity"},
                ].map((c) => (
                  <div class="flex items-center gap-3">
                    <span class="text-sm text-slate-600 flex-1">{c.l}</span>
                    <select name={"beh_" + c.k} class={sel + " sm:w-44 shrink-0"}>
                      <option value="">—</option>
                      <option value="Rarely">Rarely</option>
                      <option value="Sometimes">Sometimes</option>
                      <option value="Often">Often</option>
                      <option value="Daily">Daily</option>
                    </select>
                  </div>
                ))}
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls}>Triggers</label><textarea name="triggers" class={inputCls + " h-20"} placeholder="What tends to set things off?"></textarea></div>
              <div><label class={labelCls}>Strategies tried (what worked / didn't)</label><textarea name="strategies" class={inputCls + " h-20"} placeholder="What helps, what doesn't"></textarea></div>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
              {[
                {name:"peersInterest", label:"Shows interest in peers"},
                {name:"peersInteract", label:"Interacts with peers"},
                {name:"followsInstructions", label:"Follows familiar instructions"},
              ].map((f) => (
                <div><label class={labelCls}>{f.label}</label>
                  <select name={f.name} class={sel}><option value="">Select...</option><option>Yes</option><option>Sometimes</option><option>No</option></select>
                </div>
              ))}
            </div>
            <div>
              <label class={labelCls}>Ever expelled or suspended from school?</label>
              <div class="flex gap-2 mb-2">{ynOpts.map((o) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="suspended" value={o} class="accent-violet-700" /> {o}</label>))}</div>
              <input type="text" name="suspendedNotes" class={inputCls} placeholder="If yes, briefly explain" />
            </div>

            <h3 class="font-bold text-slate-800 pt-2">Social connection</h3>
            <div class="space-y-2">
              {SCALE_QUESTIONS.social.map((q) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <span class="text-sm text-slate-600 flex-1">{q.label}</span>
                  <select name={q.id} class={sel + " sm:w-44 shrink-0"}><option value="">—</option>{scale4.map((o) => <option value={o.v}>{o.l}</option>)}</select>
                </div>
              ))}
            </div>

            <h3 class="font-bold text-slate-800 pt-2">Flexibility & transitions</h3>
            <div class="space-y-2">
              {SCALE_QUESTIONS.flexibility.map((q) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <span class="text-sm text-slate-600 flex-1">{q.label}</span>
                  <select name={q.id} class={sel + " sm:w-44 shrink-0"}><option value="">—</option>{scale4.map((o) => <option value={o.v}>{o.l}</option>)}</select>
                </div>
              ))}
            </div>

            <h3 class="font-bold text-slate-800 pt-2">Emotional regulation</h3>
            <div class="space-y-2">
              {SCALE_QUESTIONS.emotional.map((q) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <span class="text-sm text-slate-600 flex-1">{q.label}</span>
                  <select name={q.id} class={sel + " sm:w-44 shrink-0"}><option value="">—</option>{scale4.map((o) => <option value={o.v}>{o.l}</option>)}</select>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 10 STRENGTHS & INTERESTS -->
        <div class="form-step" data-step="10" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Strengths & Interests</h2>
            <p class="text-sm text-slate-500 -mt-2">What your child excels at and loves — used by therapists to build motivation and engagement in sessions.</p>
            <p class={sub}>This helps providers connect with your child — and ABA teams use favourite things as motivators.</p>
            <div><label class={labelCls}>Strengths</label><textarea name="strengthsText" class={inputCls + " h-20"} placeholder="e.g. strong memory, visual learner, kind"></textarea></div>
            <div><label class={labelCls}>Interests & favourite things</label><textarea name="interests" class={inputCls + " h-20"} placeholder="e.g. trains, music, building blocks, bubbles"></textarea></div>
            <div><label class={labelCls}>Dislikes / things that upset them</label><textarea name="dislikes" class={inputCls + " h-20"} placeholder="e.g. loud noises, being rushed"></textarea></div>

            <h3 class="font-bold text-slate-800 pt-2">Learning & play</h3>
            <div class="space-y-2">
              {SCALE_QUESTIONS.learning.map((q) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <span class="text-sm text-slate-600 flex-1">{q.label}</span>
                  <select name={q.id} class={sel + " sm:w-44 shrink-0"}><option value="">—</option>{scale4.map((o) => <option value={o.v}>{o.l}</option>)}</select>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 11 EDUCATION -->
        <div class="form-step" data-step="11" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Education Profile</h2>
            <p class="text-sm text-slate-500 -mt-2">School context, supports in place, and academic strengths and challenges. Essential for school-based referrals and transitions.</p>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls}>School / daycare name</label><input type="text" name="schoolName" class={inputCls} placeholder="Optional" /></div>
              <div><label class={labelCls}>School type</label>
                <select name="schoolType" class={sel}><option value="">Select...</option><option>Mainstream</option><option>Specialized</option><option>Homeschool</option><option>Daycare / preschool</option><option>Not in school yet</option><option>Other</option></select>
              </div>
              <div><label class={labelCls}>Grade / year</label><input type="text" name="grade" class={inputCls} placeholder="e.g. Grade 2" /></div>
              <div><label class={labelCls}>School board (if applicable)</label><input type="text" name="schoolBoard" class={inputCls} placeholder="Optional" /></div>
              <div><label class={labelCls}>Has an IEP / intervention plan</label>
                <div class="flex gap-2">{ynOpts.map((o) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="hasIEP" value={o} class="accent-violet-700" /> {o}</label>))}</div>
              </div>
              <div><label class={labelCls}>Level of classroom support</label>
                <select name="classroomSupport" class={sel}><option value="">Select...</option><option>None</option><option>Part-time aide</option><option>Full-time aide</option><option>Other</option></select>
              </div>
            </div>
            <div>
              <label class={labelCls}>Support provided through an agency?</label>
              <div class="flex gap-2 mb-2">
                <label class={chip + " flex-1 justify-center"}><input type="radio" name="hasAgency" value="Yes" class="accent-violet-700 agency-toggle" /> Yes</label>
                <label class={chip + " flex-1 justify-center"}><input type="radio" name="hasAgency" value="No" class="accent-violet-700 agency-toggle" /> No</label>
              </div>
              <div id="agency-details" style="display:none">
                <input type="text" name="agencySupport" class={inputCls} placeholder="Agency name, type of support, frequency" />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls}>Academic concerns</label><textarea name="schoolChallenges" class={inputCls + " h-20"} placeholder="What's hard at school?"></textarea></div>
              <div><label class={labelCls}>School strengths</label><textarea name="schoolStrengths" class={inputCls + " h-20"} placeholder="What's going well?"></textarea></div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class={labelCls}>Upcoming school transition</label><input type="text" name="upcomingTransition" class={inputCls} placeholder="e.g. Starting Grade 3 in Sept" /></div>
              <div><label class={labelCls}>Flight risk at school?</label>
                <div class="flex gap-2">{ynOpts.map((o) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="flightRisk" value={o} class="accent-violet-700" /> {o}</label>))}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- 12 THERAPY & SERVICES -->
        <div class="form-step" data-step="12" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Therapy & Services</h2>
            <p class="text-sm text-slate-500 -mt-2">Current and past therapy involvement — helps new providers understand what has been tried and what is ongoing.</p>
            <p class={sub}>Toggle on any therapy your child currently receives and add the details.</p>
            {["Speech Therapy","Occupational Therapy","ABA / Behaviour","Psychology","Psychiatry","Physiotherapy","Social Skills Group","Infant Stimulation","Other"].map((t) => (
              <div class="bg-white border border-slate-200 rounded-xl p-4">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" class="therapy-toggle accent-violet-700 w-4 h-4" data-therapy={t} />
                  <span class="font-medium text-slate-700">{t}</span>
                </label>
                <div class="therapy-fields mt-4 grid md:grid-cols-2 gap-3" data-fields={t} style="display:none">
                  <input type="text" data-field="provider" class={inputCls} placeholder="Provider name" />
                  <input type="text" data-field="frequency" class={inputCls} placeholder="Frequency (e.g. weekly)" />
                  <input type="date" data-field="startDate" class={inputCls} />
                  <select data-field="progress" class={sel}>
                    <option value="">Progress rating...</option>
                    <option value="1">1 · Just started</option><option value="2">2 · Some progress</option>
                    <option value="3">3 · Steady progress</option><option value="4">4 · Strong progress</option>
                    <option value="5">5 · Goals nearly met</option>
                  </select>
                  <textarea data-field="goals" class={inputCls + " h-16 md:col-span-2"} placeholder="Current goals"></textarea>
                </div>
              </div>
            ))}
            <div><label class={labelCls}>Past services received (type, provider, dates)</label><textarea name="pastServices" class={inputCls + " h-20"} placeholder="Optional"></textarea></div>
            <div>
              <label class={labelCls}>Currently on a waitlist for any services?</label>
              <div class="flex gap-2 mb-2">{ynOpts.map((o) => (<label class={chip + " flex-1 justify-center"}><input type="radio" name="onWaitlist" value={o} class="accent-violet-700" /> {o}</label>))}</div>
              <input type="text" name="waitlistDetails" class={inputCls} placeholder="If yes, which services / where?" />
            </div>
          </div>
        </div>

        <!-- 13 GOALS & FOCUS -->
        <div class="form-step" data-step="13" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Goals & Focus</h2>
            <p class="text-sm text-slate-500 -mt-2">What matters most to your family right now — guides providers on where to focus their support.</p>
            <div><label class={labelCls}>Your main concerns right now</label><textarea name="mainConcerns" class={inputCls + " h-24"} placeholder="What's worrying you most at this time?"></textarea></div>
            <div>
              <label class={labelCls}>Top priorities (select any)</label>
              <div class="grid sm:grid-cols-2 gap-2">
                {["Communication","Friendships","Emotional Regulation","School Success","Independence","Daily Living Skills","Transition Planning","Employment Preparation"].map((o) => (<label class={chip}><input type="checkbox" name="goals" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>))}
              </div>
            </div>
            <div><label class={labelCls}>Specific areas / behaviours you'd like help with</label><textarea name="focusAreas" class={inputCls + " h-20"} placeholder="Optional"></textarea></div>
            <div><label class={labelCls}>Anything else?</label><textarea name="goalsOther" class={inputCls + " h-16"} placeholder="Optional"></textarea></div>
          </div>
        </div>

        <!-- REVIEW & EXPORT -->
        <div class="form-step" data-step="14" style="display:none">
          <div class={cardCls}>
            <h2 class="text-lg font-bold text-slate-800">Review & export</h2>
            <p class={sub}>Tick the sections to include in the PDF you'll share, then download. Untick anything a particular provider doesn't need.</p>
            <div class="flex flex-wrap gap-3 pt-1">
              <button type="button" id="select-all" class="text-sm text-violet-700 font-medium hover:underline">Select all</button>
              <button type="button" id="select-none" class="text-sm text-slate-400 font-medium hover:underline">Clear all</button>
            </div>
            <div id="review-output" class="space-y-3 mt-2"></div>
            <button type="button" id="export-pdf" class="w-full mt-2 px-8 py-3 rounded-full border-2 border-violet-700 text-violet-700 font-semibold hover:bg-violet-50 transition-colors">Download PDF</button>
          </div>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
          <div class="flex items-center gap-3">
            <button type="button" id="back-btn" class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold hover:bg-slate-50 transition-colors" style="visibility:hidden">← Back</button>
            <button type="button" id="save-close-btn" class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold hover:bg-slate-50 transition-colors">Save & close</button>
          </div>
          <button type="button" id="next-btn" class="px-7 py-2.5 rounded-lg bg-violet-700 hover:bg-violet-800 text-white text-sm font-semibold transition-colors">Next →</button>
        </div>
        <div id="save-result" class="mt-4 text-center"></div>

      </form>
    </div>

  <!-- Off-screen print view, shown only when printing -->
  <div id="print-view"></div>
  </div>
</AppFormLayout>

<style is:global>
  #print-view { position: fixed; left: -9999px; top: 0; width: 700px; }
  @media print {
    body * { visibility: hidden !important; }
    #print-view, #print-view * { visibility: visible !important; }
    #print-view { position: absolute; left: 0; top: 0; width: 100%; padding: 24px; font-family: system-ui, sans-serif; }
  }
  .pv-header { margin-bottom: 22px; border-bottom: 2px solid #6d28d9; padding-bottom: 10px; }
  .pv-header h1 { font-size: 22px; margin: 0 0 2px; color: #1e293b; }
  .pv-header .sub { color: #64748b; font-size: 12px; }
  .pv-section { margin-bottom: 16px; page-break-inside: avoid; }
  .pv-title { font-weight: 700; font-size: 14px; color: #6d28d9; margin-bottom: 6px; }
  .pv-row { display: flex; justify-content: space-between; gap: 24px; font-size: 12px; padding: 3px 0; border-bottom: 1px solid #f1f5f9; }
  .pv-label { color: #64748b; } .pv-val { color: #0f172a; text-align: right; }
</style>

<script is:inline>
  var currentStep = 1;
  var totalSteps = 13;
  var sectionNames = ["Child Profile","Parents & Household","Diagnosis & Family History","Birth & Development","Communication","Sensory Profile","Daily Living","Health & Medical","Behaviour & Social","Strengths & Interests","Education","Therapy & Services","Goals & Focus"];

  var form = document.getElementById("passport-form");
  var backBtn = document.getElementById("back-btn");
  var nextBtn = document.getElementById("next-btn");
  var stepLabel = document.getElementById("step-label");
  var stepPct = document.getElementById("step-pct");
  var progressBar = document.getElementById("progress-bar");
  var saveResult = document.getElementById("save-result");
  var reviewStep = totalSteps + 1;

  function showStep(n) {
    var steps = document.querySelectorAll(".form-step");
    for (var i = 0; i < steps.length; i++) {
      steps[i].style.display = (parseInt(steps[i].getAttribute("data-step")) === n) ? "block" : "none";
    }
    backBtn.style.visibility = n === 1 ? "hidden" : "visible";
    if (n <= totalSteps) {
      stepLabel.textContent = "Step " + n + " of " + totalSteps + " · " + sectionNames[n - 1];
      var pct = Math.round((n / totalSteps) * 100);
      stepPct.textContent = pct + "%"; progressBar.style.width = pct + "%";
      nextBtn.textContent = n === totalSteps ? "Review & export →" : "Next →";
    } else {
      stepLabel.textContent = "Review & export"; stepPct.textContent = "100%"; progressBar.style.width = "100%";
      nextBtn.textContent = "Save Passport";
    }
    // sync dropdown
    if (jumpSel) jumpSel.value = n <= totalSteps ? n : totalSteps + 1;
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  // Section jump dropdown
  var jumpSel = document.getElementById("section-jump");
  jumpSel.addEventListener("change", function(){
    var go = parseInt(jumpSel.value);
    if (go === totalSteps + 1) { currentStep = reviewStep; renderReview(); showStep(reviewStep); }
    else { currentStep = go; showStep(go); }
  });

  // Eye exam toggle
  document.querySelectorAll(".eye-toggle").forEach(function(r){
    r.addEventListener("change", function(){ document.getElementById("eye-details").style.display = r.value === "Yes" ? "block" : "none"; });
  });
  // Hearing test toggle
  document.querySelectorAll(".hearing-toggle").forEach(function(r){
    r.addEventListener("change", function(){ document.getElementById("hearing-details").style.display = r.value === "Yes" ? "block" : "none"; });
  });
  // Agency toggle
  document.querySelectorAll(".agency-toggle").forEach(function(r){
    r.addEventListener("change", function(){ document.getElementById("agency-details").style.display = r.value === "Yes" ? "block" : "none"; });
  });

  // Sensory: reveal signs/severity logic
  document.querySelectorAll(".sense-typical").forEach(function(cb){
    cb.addEventListener("change", function(){
      var sense = cb.getAttribute("data-sense");
      var wrap = document.querySelector('.sense-signs-wrap[data-sense="'+sense+'"]');
      if (cb.checked) {
        // uncheck signs and hide them
        document.querySelectorAll('.sense-sign[data-sense="'+sense+'"]').forEach(function(s){ s.checked=false; });
        if (wrap) wrap.style.opacity = "0.4";
        var sevWrap = document.querySelector('.sense-sev-wrap[data-sense="'+sense+'"]');
        if (sevWrap) sevWrap.style.display = "none";
      } else {
        if (wrap) wrap.style.opacity = "1";
      }
    });
  });
  document.querySelectorAll(".sense-sign").forEach(function(cb){
    cb.addEventListener("change", function(){
      var sense = cb.getAttribute("data-sense");
      var anyChecked = document.querySelectorAll('.sense-sign[data-sense="'+sense+'"]:checked').length > 0;
      var sevWrap = document.querySelector('.sense-sev-wrap[data-sense="'+sense+'"]');
      if (sevWrap) sevWrap.style.display = anyChecked ? "block" : "none";
      // unchecking typical if a sign is selected
      if (anyChecked) { var tc = document.querySelector('.sense-typical[data-sense="'+sense+'"]'); if (tc) tc.checked = false; }
    });
  });

  var toggles = document.querySelectorAll(".therapy-toggle");
  for (var i = 0; i < toggles.length; i++) {
    toggles[i].addEventListener("change", function (e) {
      var name = e.target.getAttribute("data-therapy");
