    function sc(name, vals) { if (!vals || !vals.length) return; form.querySelectorAll('input[name="'+name+'"]').forEach(function(cb){ cb.checked = vals.indexOf(cb.value) !== -1; }); }
    var cp=p.childProfile||{}, hh=p.household||{}, dg=p.diagnosis||{}, b=p.birth||{}, m=b.milestones||{};
