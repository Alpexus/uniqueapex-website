---
// UniqueApex Admin Dashboard
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UniqueApex Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
    body { background: #f8fafc; min-height: 100vh; }

    /* Password Gate */
    #password-gate {
      position: fixed; inset: 0; background: #0f172a;
      display: flex; align-items: center; justify-content: center; z-index: 50;
    }
    .gate-card {
      background: white; border-radius: 20px; padding: 40px;
      width: 100%; max-width: 360px; text-align: center; box-shadow: 0 25px 50px rgba(0,0,0,0.3);
    }
    .gate-icon {
      width: 56px; height: 56px; background: #ede9fe; border-radius: 16px;
      display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;
    }
    .gate-icon svg { width: 28px; height: 28px; color: #6d28d9; }
    .gate-title { font-size: 20px; font-weight: 700; color: #1e293b; margin-bottom: 4px; }
    .gate-sub { font-size: 14px; color: #94a3b8; margin-bottom: 24px; }
    .gate-input {
      width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0;
      border-radius: 12px; font-size: 15px; text-align: center; color: #1e293b;
      outline: none; margin-bottom: 12px;
    }
    .gate-input:focus { border-color: #a78bfa; box-shadow: 0 0 0 3px #ede9fe; }
    .gate-error { color: #ef4444; font-size: 13px; margin-bottom: 12px; display: none; }
    .gate-btn {
      width: 100%; background: #6d28d9; color: white; font-weight: 600;
      padding: 12px 24px; border: none; border-radius: 12px; font-size: 15px;
      cursor: pointer; transition: background 0.2s;
    }
    .gate-btn:hover { background: #5b21b6; }

    /* Dashboard */
    #admin-dashboard { display: none; }

    /* Header */
    .header {
      background: white; border-bottom: 1px solid #e2e8f0;
      position: sticky; top: 0; z-index: 10;
    }
    .header-inner {
      max-width: 1200px; margin: 0 auto; padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .header-left { display: flex; align-items: center; gap: 12px; }
    .header-icon {
      width: 32px; height: 32px; background: #6d28d9; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .header-icon svg { width: 16px; height: 16px; color: white; }
    .header-title { font-size: 15px; font-weight: 700; color: #1e293b; }
    .header-sub { font-size: 12px; color: #94a3b8; }
    .header-right { display: flex; align-items: center; gap: 20px; }
    #stats-bar { display: flex; gap: 16px; font-size: 14px; }
    .stat-total { color: #64748b; }
    .stat-total span { font-weight: 700; color: #1e293b; }
    .stat-new { color: #6d28d9; }
    .stat-new span { font-weight: 700; }
    .stat-matched { color: #0d9488; }
    .stat-matched span { font-weight: 700; }
    .refresh-btn {
      background: none; border: none; cursor: pointer;
      color: #94a3b8; display: flex; align-items: center;
    }
    .refresh-btn:hover { color: #6d28d9; }
    .refresh-btn svg { width: 20px; height: 20px; }

    /* Filters */
    .filters {
      max-width: 1200px; margin: 0 auto; padding: 20px 24px;
      display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
    }
    .filter-select, .filter-input {
      padding: 8px 14px; background: white; border: 1px solid #e2e8f0;
      border-radius: 10px; font-size: 13px; color: #475569; outline: none; cursor: pointer;
    }
    .filter-select:focus, .filter-input:focus { border-color: #a78bfa; box-shadow: 0 0 0 3px #ede9fe; }
    .filter-input { width: 240px; }
    .clear-btn {
      background: none; border: none; font-size: 13px;
      color: #94a3b8; cursor: pointer; padding: 8px 12px;
    }
    .clear-btn:hover { color: #6d28d9; }

    /* Table */
    .table-wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px 48px; }
    .table-card { background: white; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; }
    #loading { text-align: center; padding: 64px 0; color: #94a3b8; font-size: 14px; }
    #empty-state { text-align: center; padding: 64px 0; color: #94a3b8; font-size: 14px; display: none; }
    .table-scroll { overflow-x: auto; display: none; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead { background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
    th {
      text-align: left; padding: 10px 20px;
      font-size: 11px; font-weight: 600; color: #94a3b8;
      text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;
    }
    td { padding: 14px 20px; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafafa; }
    .name { font-weight: 600; color: #1e293b; }
    .sub { font-size: 11px; color: #94a3b8; margin-top: 3px; }
    .email { color: #475569; }
    .record-count { text-align: center; color: #94a3b8; font-size: 12px; margin-top: 12px; }

    /* Status dropdown */
    .status-select {
      padding: 5px 10px; border-radius: 8px; font-size: 12px;
      font-weight: 600; border: none; outline: none; cursor: pointer;
    }
    .status-new { background: #ede9fe; color: #6d28d9; }
    .status-contacted { background: #dbeafe; color: #1d4ed8; }
    .status-matched { background: #dcfce7; color: #15803d; }
    .status-waitlisted { background: #fef9c3; color: #a16207; }
    .status-closed { background: #f1f5f9; color: #64748b; }
  </style>
</head>
<body>

  <!-- Password Gate -->
  <div id="password-gate">
    <div class="gate-card">
      <div class="gate-icon">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <div class="gate-title">Admin Access</div>
      <div class="gate-sub">UniqueApex coordinator portal</div>
      <input type="password" id="admin-password" placeholder="Enter password" class="gate-input" />
      <div id="password-error" class="gate-error">Incorrect password. Try again.</div>
      <button id="unlock-btn" class="gate-btn">Enter Dashboard</button>
    </div>
  </div>

  <!-- Admin Dashboard -->
  <div id="admin-dashboard">

    <!-- Header -->
    <div class="header">
      <div class="header-inner">
        <div class="header-left">
          <div class="header-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <div class="header-title">UniqueApex Admin</div>
            <div class="header-sub">Waitlist Dashboard</div>
          </div>
        </div>
        <div class="header-right">
          <div id="stats-bar"></div>
          <button id="refresh-btn" class="refresh-btn">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="filters">
      <select id="filter-status" class="filter-select">
        <option value="">All Statuses</option>
        <option value="New">New</option>
        <option value="Contacted">Contacted</option>
        <option value="Matched">Matched</option>
        <option value="Waitlisted">Waitlisted</option>
        <option value="Closed">Closed</option>
      </select>
      <select id="filter-service" class="filter-select">
        <option value="">All Services</option>
        <option value="Speech-Language Therapy">Speech-Language Therapy</option>
        <option value="Occupational Therapy">Occupational Therapy</option>
        <option value="Behavioural Therapy">Behavioural Therapy</option>
      </select>
      <select id="filter-language" class="filter-select">
        <option value="">All Languages</option>
        <option value="English">English</option>
        <option value="French">French</option>
        <option value="Both">Both</option>
      </select>
      <input type="text" id="filter-search" placeholder="Search by name or email..." class="filter-input" />
      <button id="clear-filters" class="clear-btn">Clear filters</button>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <div class="table-card">
        <div id="loading">Loading families...</div>
        <div id="empty-state">No families match your filters.</div>
        <div class="table-scroll" id="table-container">
          <table>
            <thead>
              <tr>
                <th>Family</th>
                <th>Contact</th>
                <th>Child</th>
                <th>Services</th>
                <th>Location</th>
                <th>Signed Up</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
      </div>
      <p class="record-count" id="record-count"></p>
    </div>
  </div>

  <script>
    const SUPABASE_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
    const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
    const ADMIN_PASSWORD = "qPL!gVM$#Wpj&n";

    let allFamilies = [];

    // Password Gate
    const gate = document.getElementById("password-gate");
    const dashboard = document.getElementById("admin-dashboard");
    const passwordInput = document.getElementById("admin-password");
    const passwordError = document.getElementById("password-error");

    function unlock() {
      if (passwordInput.value === ADMIN_PASSWORD) {
        gate.style.display = "none";
        dashboard.style.display = "block";
        loadFamilies();
      } else {
        passwordError.style.display = "block";
        passwordInput.value = "";
        passwordInput.focus();
      }
    }

    document.getElementById("unlock-btn").addEventListener("click", unlock);
    passwordInput.addEventListener("keydown", e => { if (e.key === "Enter") unlock(); });

    // Load Data
    async function loadFamilies() {
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/waitlist?select=*&order=created_at.desc`, {
          headers: { "apikey": SUPABASE_KEY, "Authorization": `Bearer ${SUPABASE_KEY}` }
        });
        allFamilies = await res.json();
        updateStats();
        renderTable(allFamilies);
      } catch (e) {
        console.error(e);
      }
    }

    function updateStats() {
      const total = allFamilies.length;
      const newCount = allFamilies.filter(f => !f.status || f.status === "New").length;
      const matched = allFamilies.filter(f => f.status === "Matched").length;
      document.getElementById("stats-bar").innerHTML = `
        <span class="stat-total"><span>${total}</span> total</span>
        <span class="stat-new"><span>${newCount}</span> new</span>
        <span class="stat-matched"><span>${matched}</span> matched</span>
      `;
    }

    function statusClass(s) {
      const map = { New: "status-new", Contacted: "status-contacted", Matched: "status-matched", Waitlisted: "status-waitlisted", Closed: "status-closed" };
      return map[s] || "status-new";
    }

    function renderTable(families) {
      document.getElementById("loading").style.display = "none";
      if (families.length === 0) {
        document.getElementById("empty-state").style.display = "block";
        document.getElementById("table-container").style.display = "none";
        document.getElementById("record-count").textContent = "";
        return;
      }
      document.getElementById("empty-state").style.display = "none";
      document.getElementById("table-container").style.display = "block";

      const tbody = document.getElementById("table-body");
      tbody.innerHTML = families.map(f => {
        const services = [f.service_slp, f.service_ot, f.service_aba, f.service_other].filter(Boolean).join(", ") || "—";
        const date = new Date(f.created_at).toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "numeric" });
        const status = f.status || "New";
        return `<tr>
          <td><div class="name">${f.full_name || "—"}</div><div class="sub">${f.language || "—"}</div></td>
          <td><div class="email">${f.email || "—"}</div><div class="sub">${f.phone || "—"}</div></td>
          <td><div>${f.diagnosis || "—"}</div><div class="sub">${f.child_age ? f.child_age + " yrs" : "—"}</div></td>
          <td style="max-width:180px;font-size:12px;color:#475569">${services}</td>
          <td><div>${f.location || "—"}</div><div class="sub">${f.referral || "—"}</div></td>
          <td style="color:#64748b;white-space:nowrap">${date}</td>
          <td><select class="status-select ${statusClass(status)}" onchange="updateStatus(${f.id}, this.value, this)">
            <option value="New" ${status==="New"?"selected":""}>New</option>
            <option value="Contacted" ${status==="Contacted"?"selected":""}>Contacted</option>
            <option value="Matched" ${status==="Matched"?"selected":""}>Matched</option>
            <option value="Waitlisted" ${status==="Waitlisted"?"selected":""}>Waitlisted</option>
            <option value="Closed" ${status==="Closed"?"selected":""}>Closed</option>
          </select></td>
        </tr>`;
      }).join("");

      document.getElementById("record-count").textContent = `Showing ${families.length} of ${allFamilies.length} families`;
    }

    async function updateStatus(id, newStatus, el) {
      await fetch(`${SUPABASE_URL}/rest/v1/waitlist?id=eq.${id}`, {
        method: "PATCH",
        headers: { "apikey": SUPABASE_KEY, "Authorization": `Bearer ${SUPABASE_KEY}`, "Content-Type": "application/json", "Prefer": "return=minimal" },
        body: JSON.stringify({ status: newStatus })
      });
      const f = allFamilies.find(f => f.id === id);
      if (f) f.status = newStatus;
      el.className = `status-select ${statusClass(newStatus)}`;
      updateStats();
    }
    window.updateStatus = updateStatus;

    function applyFilters() {
      const status = document.getElementById("filter-status").value;
      const service = document.getElementById("filter-service").value;
      const language = document.getElementById("filter-language").value;
      const search = document.getElementById("filter-search").value.toLowerCase();
      renderTable(allFamilies.filter(f => {
        if (status && (f.status || "New") !== status) return false;
        if (language && f.language !== language) return false;
        if (service && ![f.service_slp, f.service_ot, f.service_aba, f.service_other].includes(service)) return false;
        if (search && !(f.full_name||"").toLowerCase().includes(search) && !(f.email||"").toLowerCase().includes(search)) return false;
        return true;
      }));
    }

    document.getElementById("filter-status").addEventListener("change", applyFilters);
    document.getElementById("filter-service").addEventListener("change", applyFilters);
    document.getElementById("filter-language").addEventListener("change", applyFilters);
    document.getElementById("filter-search").addEventListener("input", applyFilters);
    document.getElementById("clear-filters").addEventListener("click", () => {
      ["filter-status","filter-service","filter-language"].forEach(id => document.getElementById(id).value = "");
      document.getElementById("filter-search").value = "";
      renderTable(allFamilies);
    });
    document.getElementById("refresh-btn").addEventListener("click", loadFamilies);
  </script>

</body>
</html>