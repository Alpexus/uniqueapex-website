---
// UniqueApex Admin Dashboard - No layout/navbar
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UniqueApex Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50">

  <!-- Password Gate -->
  <div id="password-gate" class="fixed inset-0 bg-slate-900 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl p-10 w-full max-w-sm shadow-2xl text-center">
      <div class="w-14 h-14 bg-violet-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-violet-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <h2 class="text-xl font-bold text-slate-800 mb-1">Admin Access</h2>
      <p class="text-slate-500 text-sm mb-6">UniqueApex coordinator portal</p>
      <input
        type="password"
        id="admin-password"
        placeholder="Enter password"
        class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 mb-3 text-center text-slate-700"
      />
      <div id="password-error" class="text-red-500 text-sm mb-3 hidden">Incorrect password</div>
      <button
        id="unlock-btn"
        class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors">
        Enter Dashboard
      </button>
    </div>
  </div>

  <!-- Admin Dashboard -->
  <div id="admin-dashboard" class="hidden min-h-screen">

    <!-- Header -->
    <div class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-violet-700 rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <h1 class="text-base font-bold text-slate-800">UniqueApex Admin</h1>
            <p class="text-xs text-slate-500">Waitlist Dashboard</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div id="stats-bar" class="flex gap-4 text-sm"></div>
          <button id="refresh-btn" class="text-slate-400 hover:text-violet-700 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="max-w-7xl mx-auto px-6 py-5">
      <div class="flex flex-wrap gap-3 items-center">
        <select id="filter-status" class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm text-slate-600 outline-none focus:ring-2 focus:ring-violet-300">
          <option value="">All Statuses</option>
          <option value="New">New</option>
          <option value="Contacted">Contacted</option>
          <option value="Matched">Matched</option>
          <option value="Waitlisted">Waitlisted</option>
          <option value="Closed">Closed</option>
        </select>
        <select id="filter-service" class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm text-slate-600 outline-none focus:ring-2 focus:ring-violet-300">
          <option value="">All Services</option>
          <option value="Speech-Language Therapy">Speech-Language Therapy</option>
          <option value="Occupational Therapy">Occupational Therapy</option>
          <option value="Behavioural Therapy">Behavioural Therapy</option>
        </select>
        <select id="filter-language" class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm text-slate-600 outline-none focus:ring-2 focus:ring-violet-300">
          <option value="">All Languages</option>
          <option value="English">English</option>
          <option value="French">French</option>
          <option value="Both">Both</option>
        </select>
        <input
          type="text"
          id="filter-search"
          placeholder="Search by name or email..."
          class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm text-slate-600 outline-none focus:ring-2 focus:ring-violet-300 w-64"
        />
        <button id="clear-filters" class="px-4 py-2 text-sm text-slate-500 hover:text-violet-700 transition-colors">
          Clear filters
        </button>
      </div>
    </div>

    <!-- Table -->
    <div class="max-w-7xl mx-auto px-6 pb-12">
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div id="loading" class="text-center py-16 text-slate-400">
          <svg class="w-8 h-8 mx-auto mb-3 animate-spin text-violet-400" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Loading families...
        </div>
        <div id="empty-state" class="text-center py-16 text-slate-400 hidden">
          No families match your filters.
        </div>
        <div id="table-container" class="hidden overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 border-b border-slate-200">
              <tr>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Family</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Contact</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Child</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Services</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Location</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Signed Up</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Status</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
      </div>
      <p class="text-center text-slate-400 text-xs mt-4" id="record-count"></p>
    </div>
  </div>

  <script>
    const SUPABASE_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
    const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
    const ADMIN_PASSWORD = "qPL!gVM$#Wpj&n";

    let allFamilies = [];

    // ── Password Gate ──────────────────────────────────────────
    const gate = document.getElementById("password-gate");
    const dashboard = document.getElementById("admin-dashboard");
    const passwordInput = document.getElementById("admin-password");
    const unlockBtn = document.getElementById("unlock-btn");
    const passwordError = document.getElementById("password-error");

    function unlock() {
      if (passwordInput.value === ADMIN_PASSWORD) {
        gate.style.display = "none";
        dashboard.classList.remove("hidden");
        loadFamilies();
      } else {
        passwordError.classList.remove("hidden");
        passwordInput.value = "";
        passwordInput.focus();
      }
    }

    unlockBtn.addEventListener("click", unlock);
    passwordInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") unlock();
    });

    // ── Load Data ──────────────────────────────────────────────
    async function loadFamilies() {
      document.getElementById("loading").classList.remove("hidden");
      document.getElementById("table-container").classList.add("hidden");
      document.getElementById("empty-state").classList.add("hidden");

      try {
        const response = await fetch(
          `${SUPABASE_URL}/rest/v1/waitlist?select=*&order=created_at.desc`,
          {
            headers: {
              "apikey": SUPABASE_KEY,
              "Authorization": `Bearer ${SUPABASE_KEY}`,
            }
          }
        );
        allFamilies = await response.json();
        updateStats();
        renderTable(allFamilies);
      } catch (error) {
        console.error("Error loading families:", error);
      }
    }

    // ── Stats Bar ──────────────────────────────────────────────
    function updateStats() {
      const stats = {
        total: allFamilies.length,
        new: allFamilies.filter(f => f.status === "New" || !f.status).length,
        matched: allFamilies.filter(f => f.status === "Matched").length,
      };
      document.getElementById("stats-bar").innerHTML = `
        <span class="text-slate-500"><span class="font-bold text-slate-800">${stats.total}</span> total</span>
        <span class="text-violet-600"><span class="font-bold">${stats.new}</span> new</span>
        <span class="text-teal-600"><span class="font-bold">${stats.matched}</span> matched</span>
      `;
    }

    // ── Render Table ───────────────────────────────────────────
    function renderTable(families) {
      document.getElementById("loading").classList.add("hidden");

      if (families.length === 0) {
        document.getElementById("empty-state").classList.remove("hidden");
        document.getElementById("table-container").classList.add("hidden");
        document.getElementById("record-count").textContent = "";
        return;
      }

      document.getElementById("empty-state").classList.add("hidden");
      document.getElementById("table-container").classList.remove("hidden");

      const statusColors = {
        "New": "bg-violet-100 text-violet-700",
        "Contacted": "bg-blue-100 text-blue-700",
        "Matched": "bg-green-100 text-green-700",
        "Waitlisted": "bg-yellow-100 text-yellow-700",
        "Closed": "bg-slate-100 text-slate-500",
      };

      const tbody = document.getElementById("table-body");
      tbody.innerHTML = families.map(f => {
        const services = [f.service_slp, f.service_ot, f.service_aba, f.service_other]
          .filter(Boolean)
          .join(", ") || "—";
        const date = new Date(f.created_at).toLocaleDateString("en-CA", {
          month: "short", day: "numeric", year: "numeric"
        });
        const status = f.status || "New";
        const statusClass = statusColors[status] || "bg-slate-100 text-slate-500";

        return `
          <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
            <td class="px-5 py-4">
              <div class="font-semibold text-slate-800">${f.full_name || "—"}</div>
              <div class="text-xs text-slate-400 mt-0.5">${f.language || "—"}</div>
            </td>
            <td class="px-5 py-4">
              <div class="text-slate-700">${f.email || "—"}</div>
              <div class="text-xs text-slate-400 mt-0.5">${f.phone || "—"}</div>
            </td>
            <td class="px-5 py-4">
              <div class="text-slate-700">${f.diagnosis || "—"}</div>
              <div class="text-xs text-slate-400 mt-0.5">${f.child_age ? f.child_age + ' yrs' : '—'}</div>
            </td>
            <td class="px-5 py-4 max-w-[180px]">
              <div class="text-slate-700 text-xs leading-relaxed">${services}</div>
            </td>
            <td class="px-5 py-4">
              <div class="text-slate-700">${f.location || "—"}</div>
              <div class="text-xs text-slate-400 mt-0.5">${f.referral || "—"}</div>
            </td>
            <td class="px-5 py-4 text-slate-500 whitespace-nowrap">${date}</td>
            <td class="px-5 py-4">
              <select
                class="status-select px-3 py-1.5 rounded-lg text-xs font-semibold border-0 outline-none cursor-pointer ${statusClass}"
                data-id="${f.id}"
                onchange="updateStatus(${f.id}, this.value, this)">
                <option value="New" ${status === "New" ? "selected" : ""}>New</option>
                <option value="Contacted" ${status === "Contacted" ? "selected" : ""}>Contacted</option>
                <option value="Matched" ${status === "Matched" ? "selected" : ""}>Matched</option>
                <option value="Waitlisted" ${status === "Waitlisted" ? "selected" : ""}>Waitlisted</option>
                <option value="Closed" ${status === "Closed" ? "selected" : ""}>Closed</option>
              </select>
            </td>
          </tr>
        `;
      }).join("");

      document.getElementById("record-count").textContent =
        `Showing ${families.length} of ${allFamilies.length} families`;
    }

    // ── Update Status ──────────────────────────────────────────
    async function updateStatus(id, newStatus, selectEl) {
      const statusColors = {
        "New": "bg-violet-100 text-violet-700",
        "Contacted": "bg-blue-100 text-blue-700",
        "Matched": "bg-green-100 text-green-700",
        "Waitlisted": "bg-yellow-100 text-yellow-700",
        "Closed": "bg-slate-100 text-slate-500",
      };

      try {
        const response = await fetch(
          `${SUPABASE_URL}/rest/v1/waitlist?id=eq.${id}`,
          {
            method: "PATCH",
            headers: {
              "apikey": SUPABASE_KEY,
              "Authorization": `Bearer ${SUPABASE_KEY}`,
              "Content-Type": "application/json",
              "Prefer": "return=minimal"
            },
            body: JSON.stringify({ status: newStatus })
          }
        );

        if (response.ok) {
          const family = allFamilies.find(f => f.id === id);
          if (family) family.status = newStatus;
          selectEl.className = `status-select px-3 py-1.5 rounded-lg text-xs font-semibold border-0 outline-none cursor-pointer ${statusColors[newStatus]}`;
          updateStats();
        }
      } catch (error) {
        console.error("Error updating status:", error);
      }
    }
    window.updateStatus = updateStatus;

    // ── Filters ────────────────────────────────────────────────
    function applyFilters() {
      const status = document.getElementById("filter-status").value;
      const service = document.getElementById("filter-service").value;
      const language = document.getElementById("filter-language").value;
      const search = document.getElementById("filter-search").value.toLowerCase();

      let filtered = allFamilies.filter(f => {
        if (status && (f.status || "New") !== status) return false;
        if (language && f.language !== language) return false;
        if (service) {
          const services = [f.service_slp, f.service_ot, f.service_aba, f.service_other];
          if (!services.includes(service)) return false;
        }
        if (search) {
          const name = (f.full_name || "").toLowerCase();
          const email = (f.email || "").toLowerCase();
          if (!name.includes(search) && !email.includes(search)) return false;
        }
        return true;
      });

      renderTable(filtered);
    }

    document.getElementById("filter-status").addEventListener("change", applyFilters);
    document.getElementById("filter-service").addEventListener("change", applyFilters);
    document.getElementById("filter-language").addEventListener("change", applyFilters);
    document.getElementById("filter-search").addEventListener("input", applyFilters);
    document.getElementById("clear-filters").addEventListener("click", () => {
      document.getElementById("filter-status").value = "";
      document.getElementById("filter-service").value = "";
      document.getElementById("filter-language").value = "";
      document.getElementById("filter-search").value = "";
      renderTable(allFamilies);
    });

    document.getElementById("refresh-btn").addEventListener("click", loadFamilies);
  </script>

</body>
</html>