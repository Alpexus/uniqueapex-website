---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const features = [
  { label: "Profils enfants", free: "1", monthly: "Illimités", concierge: "Illimités" },
  { label: "Demandes de contact", free: "1 par service", monthly: "Illimitées", concierge: "Illimitées" },
  { label: "Jumelage automatique", free: true, monthly: true, concierge: true },
  { label: "Suivi des listes d'attente", free: true, monthly: true, concierge: true },
  { label: "Service en français et anglais", free: true, monthly: true, concierge: true },
  { label: "Accès communautaire", free: true, monthly: true, concierge: true },
  { label: "Ateliers d'experts", free: false, monthly: true, concierge: true },
  { label: "Outils de documentation", free: false, monthly: true, concierge: true },
  { label: "Soutien prioritaire", free: false, monthly: true, concierge: true },
  { label: "Coordonnateur humain dédié", free: false, monthly: false, concierge: true },
  { label: "Suivis avec les professionnels", free: false, monthly: false, concierge: true },
  { label: "Coordination multi-services", free: false, monthly: false, concierge: true },
  { label: "Soutien à la documentation", free: false, monthly: false, concierge: true },
];
---

<Layout title="Tarifs" lang="fr">
  <Container>

    <!-- Hero -->
    <div class="text-center max-w-2xl mx-auto mt-16 mb-24">
      <p class="text-2xl font-semibold text-violet-700 uppercase tracking-wide">Tarifs</p>
      <h1 class="text-5xl font-bold text-slate-800 leading-tight mt-3">
        Du soutien adapté à <span class="text-violet-700">là où vous en êtes</span>
      </h1>
      <p class="text-slate-600 leading-relaxed text-lg mt-6">
        Chaque famille est à une étape différente. UniqueApex vous rejoint là où vous êtes — que vous commenciez tout juste ou que vous ayez besoin de quelqu'un pour prendre le relais.
      </p>
    </div>

    <!-- Plan 1: Free -->
    <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
      <div class="space-y-6">
        <span class="inline-block bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1 rounded-full">Gratuit pour toujours</span>
        <h2 class="text-4xl font-bold text-slate-800 leading-tight">
          Vous commencez? <span class="text-violet-700">On s'en occupe.</span>
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          Vous ne devriez pas avoir à payer juste pour être mis en contact avec les bons professionnels. Soumettez un profil, et UniqueApex contacte automatiquement des professionnels vérifiés en orthophonie, ergothérapie et thérapie comportementale en votre nom.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Un profil enfant</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Une demande de contact par type de service</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Jumelage automatique</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Suivi des listes d'attente</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Service en français et anglais</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Accès communautaire</li>
        </ul>
        <div class="flex items-center gap-4 pt-2">
          <a href="/fr/waitlist" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base">Commencer gratuitement</a>
          <span class="text-3xl font-bold text-slate-800">0 $</span>
        </div>
      </div>
      <div class="flex items-center justify-center">
        <img src="/pricing-free.png" alt="Illustration du plan gratuit" class="w-full max-w-[460px]" />
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-100 mb-24"></div>

    <!-- Plan 2: Monthly -->
    <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
      <div class="flex items-center justify-center">
        <img src="/pricing-monthly.png" alt="Illustration du plan mensuel" class="w-full max-w-[460px]" />
      </div>
      <div class="space-y-6">
        <span class="inline-block bg-violet-700 text-white text-sm font-semibold px-4 py-1 rounded-full">Le plus populaire · 19 $/mois</span>
        <h2 class="text-4xl font-bold text-slate-800 leading-tight">
          Vous coordonnez activement? <span class="text-violet-700">Plus d'outils pour vous.</span>
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          Quand vous jonglez avec plusieurs professionnels, services et listes d'attente, le plan gratuit ne suffit plus. Le plan mensuel vous donne des demandes de contact illimitées, des ateliers d'experts et un soutien prioritaire — pour rester au-dessus de tout.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Profils enfants multiples</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Demandes de contact illimitées</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Accès aux ateliers d'experts</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Accès à la communauté de pairs</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Outils de documentation</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Soutien prioritaire</li>
        </ul>
        <div class="flex items-center gap-4 pt-2">
          <a href="/fr/waitlist" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base shadow-md">Choisir le plan mensuel</a>
          <span class="text-3xl font-bold text-slate-800">19 $<span class="text-lg text-slate-400">/mois</span></span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-100 mb-24"></div>

    <!-- Plan 3: Concierge -->
    <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
      <div class="space-y-6">
        <span class="inline-block bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1 rounded-full">Frais unique · 99 $</span>
        <h2 class="text-4xl font-bold text-slate-800 leading-tight">
          Besoin qu'on prenne le relais? <span class="text-violet-700">C'est pour ça qu'on est là.</span>
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          Parfois, vous avez simplement besoin de quelqu'un dans votre coin. Notre service de conciergerie vous assigne un coordonnateur humain dédié qui gère tout — les suivis, la documentation, la coordination entre services — pour que vous puissiez vous concentrer entièrement sur votre enfant.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Coordonnateur humain dédié</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Suivis avec les professionnels pris en charge</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Coordination multi-services</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Soutien à la documentation</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Coordination entre plusieurs services</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Un accompagnement inclus</li>
        </ul>
        <div class="flex items-center gap-4 pt-2">
          <a href="/fr/contact" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base">Commencer avec la conciergerie</a>
          <span class="text-3xl font-bold text-slate-800">99 $<span class="text-lg text-slate-400"> frais unique</span></span>
        </div>
      </div>
      <div class="flex items-center justify-center">
        <img src="/pricing-concierge.png" alt="Illustration du plan conciergerie" class="w-full max-w-[460px]" />
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-100 mb-24"></div>

    <!-- Comparison Table -->
    <div class="mb-24">
      <div class="text-center mb-12">
        <p class="text-2xl font-semibold text-violet-700 uppercase tracking-wide">Comparer les plans</p>
        <h2 class="text-4xl font-bold mt-3 text-slate-800">Voir ce qui est inclus</h2>
      </div>

      <div class="relative mt-8">
        <div class="absolute -top-5 z-20" style="left: 56.75%; transform: translateX(-50%);">
          <span class="inline-block bg-violet-700 text-white text-sm font-bold px-8 py-3 rounded-full shadow-lg">LE PLUS POPULAIRE</span>
        </div>
        <div class="overflow-x-auto rounded-3xl border border-slate-100 shadow-sm">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-100">
              <th class="text-left py-8 px-8 text-slate-400 font-medium w-2/5"></th>
              <th class="text-center py-8 px-8 align-bottom">
                <div class="text-slate-800 font-bold text-xl">Gratuit</div>
                <div class="text-lg font-semibold text-slate-600 mt-1">0 $</div>
              </th>
              <th class="text-center py-8 px-8 bg-violet-50 align-bottom">
                <div class="text-violet-700 font-bold text-xl">Mensuel</div>
                <div class="text-lg font-semibold text-slate-600 mt-1">19 $/mois</div>
              </th>
              <th class="text-center py-8 px-8 align-bottom">
                <div class="text-slate-800 font-bold text-xl">Conciergerie</div>
                <div class="text-lg font-semibold text-slate-600 mt-1">99 $ frais unique</div>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {features.map((row) => (
              <tr class="hover:bg-slate-50 transition-colors duration-150">
                <td class="py-5 px-8 text-slate-700 font-medium text-base">{row.label}</td>
                <td class="py-5 px-8 text-center">
                  {typeof row.free === 'boolean'
                    ? row.free
                      ? <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-violet-100 text-violet-700 font-bold text-sm">✓</span>
                      : <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-300 font-bold text-sm">✕</span>
                    : <span class="text-slate-700 text-base font-semibold">{row.free}</span>
                  }
                </td>
                <td class="py-5 px-8 text-center bg-violet-50">
                  {typeof row.monthly === 'boolean'
                    ? row.monthly
                      ? <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-violet-200 text-violet-700 font-bold text-sm">✓</span>
                      : <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-300 font-bold text-sm">✕</span>
                    : <span class="text-violet-700 text-base font-semibold">{row.monthly}</span>
                  }
                </td>
                <td class="py-5 px-8 text-center">
                  {typeof row.concierge === 'boolean'
                    ? row.concierge
                      ? <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-violet-100 text-violet-700 font-bold text-sm">✓</span>
                      : <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-300 font-bold text-sm">✕</span>
                    : <span class="text-slate-700 text-base font-semibold">{row.concierge}</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="border-t border-slate-100">
              <td class="py-8 px-8"></td>
              <td class="py-8 px-8 text-center">
                <a href="/fr/waitlist" class="inline-block border-2 border-violet-700 text-violet-700 font-semibold px-8 py-3 rounded-full hover:bg-violet-50 transition-colors text-base whitespace-nowrap">
                  Commencer gratuitement
                </a>
              </td>
              <td class="py-8 px-8 text-center bg-violet-50">
                <a href="/fr/waitlist" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base shadow-md whitespace-nowrap">
                  Choisir le plan mensuel
                </a>
              </td>
              <td class="py-8 px-8 text-center">
                <a href="/fr/contact" class="inline-block border-2 border-violet-700 text-violet-700 font-semibold px-8 py-3 rounded-full hover:bg-violet-50 transition-colors text-base whitespace-nowrap">
                  Commencer avec la conciergerie
                </a>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- Bottom note -->
    <div class="text-center mt-8 mb-24">
      <p class="text-slate-400 text-sm">Tous les prix sont en dollars canadiens. Aucuns frais cachés. Annulez en tout temps.</p>
    </div>

  </Container>
</Layout>
