---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Liste d'attente" lang="fr">
  <Container>

    <!-- Hero -->
    <div class="text-center max-w-3xl mx-auto mt-16 mb-16">
      <p class="text-2xl font-semibold text-violet-700 uppercase tracking-wide">Liste d'attente</p>
      <h1 class="text-5xl font-bold text-slate-800 leading-tight mt-3">
        Soyez parmi les premières <span class="text-violet-700">familles à Montréal</span>
      </h1>
      <p class="text-slate-600 leading-relaxed text-lg mt-6">
        UniqueApex lance son projet pilote à Montréal. Inscrivez-vous à la liste d'attente et nous vous contacterons dès que l'accès sera disponible dans votre secteur.
      </p>
    </div>

    <!-- Form -->
    <div class="max-w-2xl mx-auto mb-24">
      <form
        id="waitlist-form"
        class="space-y-6"
        novalidate>

        <!-- honeypot: caché aux humains, les bots le remplissent. PAS une colonne réelle. -->
        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;height:0;width:0;overflow:hidden">
          <label>Company (leave empty)
            <input type="text" name="company" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <!-- About You -->
        <div class="bg-slate-50 rounded-2xl p-8 space-y-4">
          <h2 class="text-lg font-bold text-slate-800">À propos de vous</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <input
                type="text"
                name="full_name"
                placeholder="Nom complet"
                class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
              />
              <p id="error-full_name" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
            <div>
              <input
                type="email"
                name="email"
                placeholder="Adresse courriel"
                class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
              />
              <p id="error-email" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
          </div>
          <input
            type="tel"
            name="phone"
            placeholder="Numéro de téléphone (optionnel)"
            class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
          />
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-3">Langue préférée</label>
            <div class="flex gap-6">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="language" value="English" class="accent-violet-700" />
                <span class="text-slate-600">Anglais</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="language" value="French" class="accent-violet-700" />
                <span class="text-slate-600">Français</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="language" value="Both" class="accent-violet-700" />
                <span class="text-slate-600">Les deux</span>
              </label>
            </div>
            <p id="error-language" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
          </div>
        </div>

        <!-- About Your Child -->
        <div class="bg-slate-50 rounded-2xl p-8 space-y-4">
          <h2 class="text-lg font-bold text-slate-800">À propos de votre enfant</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <select
                name="child_age"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 text-slate-500 bg-white">
                <option value="" disabled selected>Tranche d'âge</option>
                <option value="0-3">0 – 3 ans</option>
                <option value="4-6">4 – 6 ans</option>
                <option value="7-10">7 – 10 ans</option>
                <option value="11+">11 ans et plus</option>
              </select>
              <p id="error-child_age" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
            <div>
              <select
                name="diagnosis"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 text-slate-500 bg-white">
                <option value="" disabled selected>Domaine de préoccupation</option>
                <option value="Autism">Autisme</option>
                <option value="ADHD">TDAH</option>
                <option value="Speech delay">Retard de langage</option>
                <option value="Language delay">Retard de parole</option>
                <option value="Developmental delay">Retard de développement</option>
                <option value="Other">Autre</option>
              </select>
              <p id="error-diagnosis" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-3">Services recherchés</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_slp" value="Speech-Language Therapy" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Orthophonie</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_ot" value="Occupational Therapy" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Ergothérapie</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_aba" value="Behavioural Therapy" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Thérapie comportementale</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors">
                <input type="checkbox" name="service_other" value="Other" class="accent-violet-700 w-4 h-4" />
                <span class="text-slate-600 text-sm">Autre</span>
              </label>
            </div>
            <p id="error-services" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
          </div>
        </div>

        <!-- Location & Additional -->
        <div class="bg-slate-50 rounded-2xl p-8 space-y-4">
          <h2 class="text-lg font-bold text-slate-800">Localisation et informations supplémentaires</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <input
                type="text"
                name="location"
                placeholder="Ville / Arrondissement à Montréal"
                class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
              />
              <p id="error-location" style="display:none;color:#ef4444;font-size:12px;margin-top:4px"></p>
            </div>
            <select
              name="referral"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 text-slate-500 bg-white">
              <option value="" disabled selected>Comment avez-vous entendu parler de nous?</option>
              <option value="Social media">Réseaux sociaux</option>
              <option value="Google">Google</option>
              <option value="Friend or family">Ami(e) ou famille</option>
              <option value="Healthcare provider">Professionnel de la santé</option>
              <option value="Other">Autre</option>
            </select>
          </div>
          <textarea
            name="additional_info"
            placeholder="Autre chose que vous aimeriez nous dire? (optionnel)"
            class="w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none h-32 focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white"
          ></textarea>
        </div>

        <!-- Cloudflare Turnstile -->
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

        <!-- Submit -->
        <div>
          <div class="cf-turnstile" data-sitekey="0x4AAAAAADlSug3Xc8zF8CaJ" style="margin:0 auto 12px;display:flex;justify-content:center"></div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-4 px-8 rounded-full transition-colors duration-200 text-lg">
            Rejoindre la liste d'attente
          </button>
          <p class="text-slate-400 text-sm text-center mt-4">Nous ne partagerons jamais vos informations. Vous pouvez vous désinscrire en tout temps.</p>
          <div id="waitlist-result" class="mt-4 text-center"></div>
        </div>

      </form>
    </div>

  </Container>
</Layout>

<script is:inline>
  var SUPABASE_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
  var SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";

  var form = document.getElementById("waitlist-form");
  var result = document.getElementById("waitlist-result");
  var submitBtn = document.getElementById("submit-btn");

  // protections anti-bots
  var formLoadTime = Date.now();
  var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function showError(id, msg) {
    var el = document.getElementById(id);
    if (el) {
      el.textContent = msg;
      el.style.display = "block";
    }
  }

  function clearErrors() {
    var ids = ["error-full_name","error-email","error-language","error-child_age","error-diagnosis","error-services","error-location"];
    for (var i = 0; i < ids.length; i++) {
      var el = document.getElementById(ids[i]);
      if (el) { el.textContent = ""; el.style.display = "none"; }
    }
  }

  function fakeSuccess() {
    // bot détecté — on fait semblant que ça a marché, mais on n'envoie rien
    result.innerHTML = "<span style='color:#22c55e;font-weight:500'>Vous êtes sur la liste d'attente! Nous vous contacterons bientôt.</span>";
    form.reset();
    submitBtn.disabled = true;
    submitBtn.textContent = "Inscription complétée!";
  }

  form.addEventListener("submit", function(e) {
    e.preventDefault();
    e.stopPropagation();
    clearErrors();

    var formData = new FormData(form);

    // --- contrôles anti-bots : honeypot rempli, ou envoi trop rapide ---
    var honey = formData.get("company");
    var tooFast = (Date.now() - formLoadTime) < 2500;
    if ((honey && honey.trim() !== "") || tooFast) {
      fakeSuccess();
      return false;
    }

    var valid = true;

    var fullName = formData.get("full_name");
    if (!fullName || fullName.trim() === "") {
      showError("error-full_name", "Veuillez entrer votre nom complet.");
      valid = false;
    }

    var email = formData.get("email");
    if (!email || !EMAIL_RE.test(email.trim())) {
      showError("error-email", "Veuillez entrer une adresse courriel valide.");
      valid = false;
    }

    var language = formData.get("language");
    if (!language) {
      showError("error-language", "Veuillez sélectionner une langue préférée.");
      valid = false;
    }

    var childAge = formData.get("child_age");
    if (!childAge) {
      showError("error-child_age", "Veuillez sélectionner une tranche d'âge.");
      valid = false;
    }

    var diagnosis = formData.get("diagnosis");
    if (!diagnosis) {
      showError("error-diagnosis", "Veuillez sélectionner un domaine de préoccupation.");
      valid = false;
    }

    var slp = formData.get("service_slp");
    var ot = formData.get("service_ot");
    var aba = formData.get("service_aba");
    var other = formData.get("service_other");
    if (!slp && !ot && !aba && !other) {
      showError("error-services", "Veuillez sélectionner au moins un service.");
      valid = false;
    }

    var location = formData.get("location");
    if (!location || location.trim() === "") {
      showError("error-location", "Veuillez entrer votre ville ou arrondissement.");
      valid = false;
    }

    if (!valid) {
      return false;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Envoi en cours...";
    result.innerHTML = "";

    var token = (window.turnstile && window.turnstile.getResponse) ? window.turnstile.getResponse() : "";
    if (!token) {
      result.innerHTML = "<span style='color:#ef4444'>Veuillez compléter la vérification ci-dessus.</span>";
      submitBtn.disabled = false;
      submitBtn.textContent = "Rejoindre la liste d'attente";
      return false;
    }

    var data = {
      full_name: formData.get("full_name") || null,
      email: formData.get("email") || null,
      phone: formData.get("phone") || null,
      language: formData.get("language") || null,
      child_age: formData.get("child_age") || null,
      diagnosis: formData.get("diagnosis") || null,
      service_slp: formData.get("service_slp") || null,
      service_ot: formData.get("service_ot") || null,
      service_aba: formData.get("service_aba") || null,
      service_other: formData.get("service_other") || null,
      location: formData.get("location") || null,
      referral: formData.get("referral") || null,
      additional_info: formData.get("additional_info") || null,
      company: honey || null,
      turnstileToken: token
    };

    fetch(SUPABASE_URL + "/functions/v1/waitlist-submit", {
      method: "POST",
      headers: { "Content-Type": "application/json", "apikey": SUPABASE_KEY },
      body: JSON.stringify(data)
    }).then(function(response) {
      return response.json().catch(function(){ return { ok: response.ok }; });
    }).then(function(out) {
      if (out && out.ok) {
        result.innerHTML = "<span style='color:#22c55e;font-weight:500'>Vous êtes sur la liste d'attente! Nous vous contacterons bientôt.</span>";
        form.reset();
        submitBtn.textContent = "Inscription complétée!";
      } else {
        result.innerHTML = "<span style='color:#ef4444'>Une erreur est survenue. Veuillez réessayer.</span>";
        submitBtn.disabled = false;
        submitBtn.textContent = "Rejoindre la liste d'attente";
        if (window.turnstile && window.turnstile.reset) window.turnstile.reset();
      }
    }).catch(function() {
      result.innerHTML = "<span style='color:#ef4444'>Une erreur est survenue. Veuillez réessayer.</span>";
      submitBtn.disabled = false;
      submitBtn.textContent = "Rejoindre la liste d'attente";
      if (window.turnstile && window.turnstile.reset) window.turnstile.reset();
    });

  });
</script>
