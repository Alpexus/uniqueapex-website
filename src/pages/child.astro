---
/* OVERVIEW-V5 — the front door of the living profile (CHILD-IA-V2, light):
   · LIGHT hero (lavender-mist gradient, violet accents only — no dark
     panels): morphing avatar, identity chips, about sentence, completion
     ring, quick actions, linked stat chips
   · CHECK-IN NUDGE when the passport is stale or thin — the profile asks
     to stay alive
   · WHAT'S NEXT: top 3 steps from the journey engine (personalized whys,
     real destinations) + link to the full Journey
   · Support wheel snapshot (SHARED band-ring engine, calculation untouched)
     with most-support / going-strong chips
   · "Shines at" star chips + working-on + team, personalized guidance
   · Quietly records a passport check-in (history.js) so Growth can show
     then-vs-now — the profile never forgets where you started. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="My Child" titleFr="Mon enfant" activeNav="child">
  <div class="c3-tabs"><SectionTabs section="child" active="overview" /></div>

  <div class="ov-wrap">

    <!-- ================= HERO (light) ================= -->
    <section class="ov5-hero cu-rev">
      <span class="c3-spark" style="top:16px;left:46%">✦</span>
      <span class="c3-spark s2" style="top:42px;left:58%">✦</span>
      <span class="c3-spark s3" style="bottom:50px;right:9%">✦</span>
      <div class="ov5-top">
        <div class="ov5-av" id="ov-avatar">·</div>
        <div class="ov5-id">
          <h1 id="ov-name">Loading…</h1>
          <div class="ov5-chips" id="ov-meta"></div>
          <p class="ov5-about" id="ov-about"></p>
        </div>
        <div class="ov5-side">
          <div class="ov5-ringrow">
            <span class="ov5-ring">
              <svg width="56" height="56" viewBox="0 0 64 64">
                <circle cx="32" cy="32" r="26" fill="none" stroke="var(--line)" stroke-width="5.5"></circle>
                <circle id="ov-ring-c" cx="32" cy="32" r="26" fill="none" stroke="var(--violet-600)" stroke-width="5.5" stroke-linecap="round" stroke-dasharray="0 163.4" transform="rotate(-90 32 32)" style="transition:stroke-dasharray 1.1s cubic-bezier(.22,1,.36,1)"></circle>
                <text id="ov-ring-t" x="32" y="33" text-anchor="middle" dominant-baseline="central" font-size="13" font-weight="700" fill="var(--ink)">—</text>
              </svg>
            </span>
            <span class="ov5-ringlab"><b data-i18n="passportLabel">Passport</b><span id="ov-ring-sub">—</span></span>
          </div>
          <div class="ov5-btns">
            <a class="btn btn-primary btn-sm" id="ov-edit" href="/passport" data-i18n="editProfile">Edit profile</a>
            <a class="btn btn-ghost btn-sm" id="ov-export" href="/passport?export=1" data-i18n="exportPdf">Export PDF</a>
          </div>
        </div>
      </div>
      <div class="ov5-stats" id="ov-stats"></div>
    </section>

    <!-- ================= CHECK-IN NUDGE ================= -->
    <div class="ov5-nudge cu-rev" id="ov-nudge" style="--d:.06s;display:none">
      <span class="cu-blob" style="--blob:#EDE9FE;color:#6D28D9;width:36px;height:36px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="8" cy="8" r="6"/><path d="M8 4.5V8l2.3 2.3"/></svg></span>
      <p id="ov-nudge-text"></p>
      <a class="btn btn-primary btn-sm" id="ov-nudge-cta" href="/passport" data-i18n="checkIn5">5-minute check-in</a>
    </div>

    <!-- ================= WHAT'S NEXT ================= -->
    <div class="ov-card cu-rev" style="--d:.08s">
      <div class="ov5-nexthead">
        <p class="ov-label" style="margin:0" id="ov-next-title">What's next</p>
        <a class="ov-link" href="/child/journey"><span data-i18n="fullJourney">Full journey</span> <span class="ov-arr">→</span></a>
      </div>
      <div class="ov5-next" id="ov-next"></div>
    </div>

    <!-- ================= MAIN GRID ================= -->
    <div class="ov-grid cu-rev" style="--d:.14s">
      <div class="ov-card">
        <div class="ov5-nexthead">
          <p class="ov-label" style="margin:0" data-i18n="supportToday">Support today</p>
          <a class="ov-link" href="/child/support-wheel"><span data-i18n="openFullWheel">Open full wheel</span> <span class="ov-arr">→</span></a>
        </div>
        <div id="ov-rose" class="ov-rose c3-stage c3-anim"></div>
        <p class="ov-rose-cap" data-i18n="roseCaption">Fuller petals = more support is helpful right now · tap a petal to explore</p>
        <div class="ov-splits" id="ov-splits"></div>
      </div>

      <div class="ov-rightcol">
        <div class="ov-card">
          <p class="ov-label" id="ov-shine-title">Shines at</p>
          <div class="ov-shinegrid" id="ov-shine"></div>
        </div>
        <div class="ov-card">
          <p class="ov-label" data-i18n="workingOn">Working on right now</p>
          <div class="ov-pri" id="ov-pri"></div>
          <div class="ov-teamline" id="ov-team"></div>
        </div>
      </div>
    </div>

    <!-- ================= GUIDANCE ================= -->
    <div class="ov-card ov-insights cu-rev cu-sparkle-host" style="--d:.2s">
      <span class="cu-spark" style="top:14px;right:26px">✦</span>
      <span class="cu-spark s2" style="top:32px;right:48px">✦</span>
      <p class="ov-ins-title"><svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg> <span data-i18n="familyGuidance">Family guidance</span></p>
      <p class="ov-ins-text" id="ov-insights">Loading…</p>
      <p class="ov-note" data-i18n="guidanceNote">Observations drawn from your passport — supportive guidance, not medical advice.</p>
    </div>

  </div>
</AppFormLayout>

<style is:global>
  .ov-wrap{display:flex;flex-direction:column;gap:14px;max-width:1040px}
  .ov-card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:18px 20px;box-shadow:var(--shadow)}

  /* ---- light hero ---- */
  .ov5-hero{position:relative;overflow:hidden;border-radius:22px;padding:22px 24px 16px;background:linear-gradient(120deg,#FDFCFF 0%,#F4EFFE 46%,#EFF9F6 100%);border:1px solid var(--violet-100);box-shadow:var(--shadow)}
  .ov5-hero::before{content:"";position:absolute;top:-90px;right:-60px;width:320px;height:280px;background:radial-gradient(closest-side,rgba(139,92,246,.13),transparent 72%);border-radius:50%;pointer-events:none}
  .ov5-hero::after{content:"";position:absolute;bottom:-110px;left:8%;width:300px;height:240px;background:radial-gradient(closest-side,rgba(94,234,212,.13),transparent 72%);border-radius:50%;pointer-events:none}
  .ov5-top{position:relative;display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;z-index:1}
  .ov5-av{width:58px;height:58px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#A78BFA,#6D28D9);color:#fff;display:grid;place-items:center;font-family:var(--display);font-size:1.5rem;font-weight:700;flex-shrink:0;animation:c3Morph 9s ease-in-out infinite alternate;box-shadow:0 6px 18px rgba(109,40,217,.24)}
  .ov5-id{flex:1;min-width:220px}
  .ov5-id h1{font-family:var(--display);font-size:1.55rem;font-weight:700;letter-spacing:-.02em;color:var(--ink);margin:0;line-height:1.15}
  .ov5-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
  .ov5-about{font-size:.86rem;font-style:italic;line-height:1.55;color:var(--ink-2);margin:9px 0 0;max-width:560px}
  .ov5-side{display:flex;flex-direction:column;align-items:flex-end;gap:10px}
  .ov5-ringrow{display:flex;align-items:center;gap:9px}
  .ov5-ring{position:relative;flex-shrink:0}
  .ov5-ringlab{font-size:.68rem;color:var(--muted);line-height:1.3}
  .ov5-ringlab b{display:block;color:var(--ink);font-size:.76rem}
  .ov5-btns{display:flex;gap:8px}
  .ov5-stats{position:relative;display:flex;gap:8px;flex-wrap:wrap;border-top:1px solid var(--violet-100);margin-top:15px;padding-top:12px;z-index:1}
  .ov5-stat{display:inline-flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--line);border-radius:9999px;padding:5px 13px;font-size:.76rem;font-weight:600;color:var(--ink-2);text-decoration:none;box-shadow:var(--shadow);transition:border-color .15s,transform .15s}
  .ov5-stat:hover{border-color:#DDD6FE;transform:translateY(-1px);color:var(--violet-700)}
  .ov5-stat b{font-weight:700;color:var(--ink)}
  .ov5-stat svg{flex-shrink:0}

  /* ---- nudge ---- */
  .ov5-nudge{display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,var(--violet-50),#F9F7FE 60%,var(--violet-50));border:1px solid var(--violet-100);border-radius:16px;padding:12px 16px}
  .ov5-nudge p{flex:1;font-size:.86rem;color:#5b21b6;line-height:1.5;margin:0;min-width:0}

  /* ---- what's next ---- */
  .ov5-nexthead{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
  .ov5-next{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px}
  .ov5-step{display:flex;gap:10px;align-items:flex-start;border:1px solid var(--line);border-radius:14px;padding:12px 14px;text-decoration:none;transition:border-color .15s,transform .15s,box-shadow .15s}
  .ov5-step:hover{border-color:#DDD6FE;transform:translateY(-2px);box-shadow:0 8px 20px rgba(109,40,217,.1)}
  .ov5-step .tt{font-size:.84rem;font-weight:700;color:var(--ink);line-height:1.3}
  .ov5-step .why{font-size:.74rem;color:var(--muted);margin-top:3px;line-height:1.45}
  .ov5-step .go{font-size:.74rem;font-weight:700;color:var(--violet-700);margin-top:6px;display:inline-block}

  /* ---- main grid ---- */
  .ov-grid{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(0,1fr);gap:14px;align-items:stretch}
  .ov-rightcol{display:flex;flex-direction:column;gap:14px;min-width:0}
  @media (max-width:760px){.ov-grid{grid-template-columns:1fr}}

  /* ---- wheel card ---- */
  .ov-label{font-size:.78rem;color:var(--muted);margin:0 0 10px;font-weight:600}
  .ov-link{font-size:.8rem;font-weight:600;color:var(--violet-700);text-decoration:none}
  .ov-link .ov-arr{display:inline-block;transition:transform .18s}
  .ov-link:hover .ov-arr{transform:translateX(3px)}
  .ov-rose{display:flex;justify-content:center;border-radius:14px}
  .ov-rose svg{max-width:380px}
  .ov-rose [data-domain]:hover path{opacity:.82}
  .ov-rose-cap{font-size:.72rem;color:var(--faint);text-align:center;margin:6px 0 0}
  .ov-splits{display:grid;grid-template-columns:1fr 1fr;gap:12px;border-top:1px solid var(--line);margin-top:12px;padding-top:12px}
  .ov-split-t{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin:0 0 7px}
  .ov-split-t.need{color:var(--amber)}
  .ov-split-t.strong{color:var(--green)}
  .ov-split-li{display:inline-flex;align-items:center;gap:7px;font-size:.8rem;font-weight:600;margin:0 5px 6px 0;text-decoration:none;border-radius:9999px;padding:4px 11px;transition:transform .15s}
  a.ov-split-li:hover{transform:translateY(-1px)}
  .ov-split-li .dd{width:7px;height:7px;border-radius:50%;flex-shrink:0}
  .ov-split-empty{font-size:.8rem;color:var(--faint);margin:0}

  /* ---- shines grid ---- */
  .ov-shinegrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:8px}
  .ov-shinecard{background:var(--green-bg);border-radius:12px;padding:11px 6px 9px;text-align:center;color:var(--green);transition:transform .16s,box-shadow .16s}
  .ov-shinecard:hover{transform:translateY(-2px);box-shadow:0 8px 18px rgba(14,143,102,.16)}
  .ov-shinecard p{font-size:.72rem;font-weight:600;color:#0a6b4d;margin:5px 0 0;line-height:1.25;overflow-wrap:break-word}
  .ov-shinecard svg{display:block;margin:0 auto}

  /* ---- working on ---- */
  .ov-pri{display:flex;flex-wrap:wrap;gap:7px}
  .ov-pri-tag{font-size:.82rem;font-weight:600;padding:6px 12px;border-radius:9999px;background:var(--violet-50);color:var(--violet-700)}
  .ov-teamline{font-size:.8rem;color:var(--muted);border-top:1px solid var(--line);margin-top:12px;padding-top:10px}
  .ov-teamline b{color:var(--ink-2);font-weight:600}

  /* ---- guidance ---- */
  .ov-insights{position:relative;background:linear-gradient(135deg,var(--violet-50),#F9F7FE 55%,var(--violet-50));border-color:var(--violet-100)}
  .ov-insights .cu-spark{font-style:normal;font-size:13px;color:#8B5CF6}
  .ov-insights .cu-spark.s2{font-size:10px;color:#5EEAD4}
  .ov-ins-title{display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:700;color:var(--violet-700);margin:0 0 8px}
  .ov-ins-text{font-size:.92rem;line-height:1.65;color:#5b21b6;margin:0}
  .ov-note{font-size:.72rem;color:var(--faint);margin:8px 0 0}
  .ov-empty{font-size:.85rem;color:var(--muted);margin:0}
  .ov-empty a{color:var(--violet-700);font-weight:600}

  @media (max-width:760px){
    .ov5-side{align-items:flex-start;width:100%}
  }
  @media (prefers-reduced-motion:reduce){
    #ov-ring-c{transition:none!important}
    .ov5-av{animation:none}
  }
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../lib/ua-data.js";
  import { scoreWheel, DOMAINS, snapshotWheel, HUES } from "../lib/wheelScore.js";
  import { generateWheelSVG, domainColor } from "../lib/wheelSvg.js";
  import { dv, domainShort, domainLow } from "../lib/libI18n.js";
  import { buildFamilyGuidance } from "../lib/domainInsights.js";
  import { iconFor } from "../lib/interestIcons.js";
  import { buildJourney } from "../lib/journey.js";
  import { ensureSnapshot } from "../lib/history.js";
  import DICT from "../i18n/child.js";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const lc = (s) => String(s || "").toLowerCase();
  const cap = (s) => { s = String(s || ""); return s.charAt(0).toUpperCase() + s.slice(1); };
  const clean = (s) => cap(String(s || "").trim().replace(/[.,;:!]+$/, ""));
  const textToList = (s) => String(s || "").split(/[,\n;•]+/).map((x) => x.trim()).filter(Boolean);

  /* ---------- i18n (string codes from src/i18n/child.js) ---------- */
  const T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
  const tpl = (s, v) => String(s).replace(/\{(\w+)\}/g, (m, k) => (v && v[k] != null ? v[k] : ""));
  const ofName = (n) => (window.uaLang === "fr"
    ? (/^[aeiouyàâäéèêëìîïòôöùûüh]/i.test(String(n || "")) ? "d'" : "de ")
    : "");
  /* Script-owned labels — translate the fallbacks before data arrives. */
  $("ov-name").textContent = T.loading;
  $("ov-insights").textContent = T.loading;
  $("ov-next-title").textContent = T.whatsNext;

  const listPhrase = (arr) => {
    arr = arr.filter(Boolean);
    if (!arr.length) return "";
    if (arr.length === 1) return arr[0];
    if (arr.length === 2) return arr[0] + T.pairJoin + arr[1];
    return arr.slice(0, -1).join(", ") + T.finalJoin + arr[arr.length - 1];
  };
  /* display names resolve per language (libI18n) — EN values unchanged */
  const SHORT = Object.fromEntries(DOMAINS.map((d) => [d, domainShort(d)]));
  const domSent = (n) => ((window.uaLang || "en") === "en" ? lc(SHORT[n] || n) : domainLow(n)); /* in-sentence form */
  const tintOf = (nm, a) => { const i = DOMAINS.indexOf(nm); return i === -1 ? "rgba(109,40,217," + a + ")" : "hsla(" + HUES[i] + ",70%,45%," + a + ")"; };
  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    const data = (p && p.data) || {};
    const id = UA.childIdentity(data);
    const cp = data.childProfile || {};
    const scored = scoreWheel(data);
    const firstName = id.first || T.yourChild;
    const pLink = "/passport" + (p ? "?id=" + p.id : "");

    if (p) {
      $("ov-edit").href = `/passport?id=${p.id}`;
      $("ov-export").href = `/passport?id=${p.id}&export=1`;
      $("ov-nudge-cta").href = `/passport?id=${p.id}`;
    }

    /* ---- hero identity ---- */
    $("ov-avatar").textContent = (firstName || "·")[0].toUpperCase();
    $("ov-name").textContent = id.name;
    const metaBits = [];
    const dxList = (data.diagnosis && data.diagnosis.diagnoses) || [];
    if (Array.isArray(dxList)) dxList.slice(0, 2).forEach((d) => metaBits.push(esc(d)));
    if (id.age != null) metaBits.push(tpl(id.age === 1 ? T.ageYears1 : T.ageYearsN, { n: id.age }));
    const loc = id.city || cp.location || "";
    if (loc) metaBits.push(esc(loc));
    if (id.languages) metaBits.push(esc(id.languages));
    const school = (data.education && (data.education.schoolName || data.education.schoolType)) || "";
    if (school) metaBits.push(esc(school));
    $("ov-meta").innerHTML = metaBits.map((m) => `<span class="c3-glass">${m}</span>`).join("");

    /* ---- about sentence ---- */
    const interests = textToList(data.strengths && data.strengths.interests);
    const strengthsText = textToList(data.strengths && data.strengths.strengths);
    const needs = DOMAINS.filter((n) => scored[n].score != null).sort((a, b) => scored[b].score - scored[a].score);
    const aboutParts = [];
    if (interests.length) aboutParts.push(tpl(T.enjoys, { list: listPhrase(interests.slice(0, 3).map(lc)) }));
    else if (strengthsText.length) aboutParts.push(tpl(T.strengthsIn, { list: listPhrase(strengthsText.slice(0, 3).map(lc)) }));
    if (needs.length) aboutParts.push(tpl(T.routines, { list: listPhrase(needs.slice(0, 2).map((n) => domSent(n))) }));
    $("ov-about").textContent = aboutParts.join(" ");

    /* ---- completion ring ---- */
    const comp = UA.completion(data);
    const C = 2 * Math.PI * 26;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      $("ov-ring-c").setAttribute("stroke-dasharray", `${((comp.pct / 100) * C).toFixed(1)} ${C.toFixed(1)}`);
    }));
    if (reduceMotion) { $("ov-ring-t").textContent = comp.pct + "%"; }
    else {
      let t0 = null;
      const tick = (ts) => {
        if (!t0) t0 = ts;
        const pr = Math.min(1, (ts - t0) / 1000), e = 1 - Math.pow(1 - pr, 3);
        $("ov-ring-t").textContent = Math.round(comp.pct * e) + "%";
        if (pr < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
    const left = comp.total - comp.done;
    $("ov-ring-sub").textContent = left === 0 ? T.complete : tpl(left === 1 ? T.sectionsLeft1 : T.sectionsLeftN, { n: left });

    /* ---- stat chips ---- */
    const pri = (data.goals && data.goals.priorities) || [];
    const team = (data.therapy || []).filter((t) => t && t.type);
    const docs = p ? await UA.getRecentDocuments(p.id).catch(() => []) : [];
    const strengths = [];
    strengthsText.forEach((x) => strengths.push(clean(x)));
    interests.forEach((x) => { if (strengths.length < 6) strengths.push(tpl(T.lovesX, { x: lc(clean(x)) })); });
    if (strengths.length < 3) {
      DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 55)
        .sort((a, b) => scored[b].strength - scored[a].strength)
        .forEach((n) => { if (strengths.length < 6) strengths.push(tpl(T.strongX, { x: domSent(n) })); });
    }
    const sIc = (d, c) => `<svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="${c}" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
    const teamAbbr = team.map((t) => String(dv(t.type)).split(/\s+/).map((w) => w[0]).join("").slice(0, 2).toUpperCase()).join(" + ");
    const stats = [
      [`<b>${Array.isArray(pri) ? pri.length : 0}</b> ${esc(T.statFocus)}`, sIc(`<path d="M8 1.5l2 4.2 4.5.5-3.3 3.1.9 4.5L8 11.7 3.9 13.8l.9-4.5L1.5 6.2 6 5.7z"/>`, "#6D28D9"), pLink],
      [`<b>${team.length}</b> ${esc(T.statProviders)}${teamAbbr ? " · " + esc(teamAbbr) : ""}`, sIc(`<circle cx="6" cy="5" r="2.2"/><path d="M2 13c.4-2.2 2-3.2 4-3.2s3.6 1 4 3.2"/><circle cx="11.5" cy="5.5" r="1.8"/>`, "#0E8C82"), "/providers"],
      [`<b>${docs.length}</b> ${esc(T.statDocuments)}`, sIc(`<path d="M4 1.8h5.2L12.4 5v9.2H4z"/><path d="M9 1.8V5h3.4"/>`, "#A8650A"), "/documents"],
      [`<b>${strengths.length}</b> ${esc(T.statStrengths)}`, sIc(`<path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/>`, "#0E8F66"), "/child/growth"],
    ];
    $("ov-stats").innerHTML = stats.map((s) => `<a class="ov5-stat" href="${s[2]}">${s[1]}<span>${s[0]}</span></a>`).join("");

    /* ---- check-in nudge (staleness or thin passport) ---- */
    const daysSince = p && p.updated_at ? Math.floor((Date.now() - new Date(p.updated_at)) / 864e5) : null;
    if (p && (daysSince == null || daysSince >= 60)) {
      const time = daysSince != null
        ? (daysSince >= 30 ? tpl(T.nudgeMonths, { n: Math.round(daysSince / 30) }) : tpl(T.nudgeDays, { n: daysSince }))
        : T.nudgeAWhile;
      $("ov-nudge-text").innerHTML = tpl(T.nudgeStale, { time, name: esc(firstName), of: ofName(firstName) });
      $("ov-nudge").style.display = "flex";
    } else if (p && comp.pct < 60) {
      $("ov-nudge-text").innerHTML = tpl(T.nudgeThin, { name: esc(firstName), of: ofName(firstName), pct: comp.pct, n: comp.total - comp.done });
      $("ov-nudge").style.display = "flex";
    }

    /* ---- journey teaser: top 3 next steps ---- */
    const wl = await UA.getWaitlist().catch(() => []);
    const apps = p ? await UA.getFundingApplications(p.id).catch(() => []) : [];
    const fo = UA.fundingOverview(apps);
    const journey = buildJourney(data, scored, {
      firstName, passportLink: pLink, completion: comp,
      docsCount: docs.length, onWaitlists: wl.length > 0,
      dtcStarted: fo.rows.some((r) => r.key === "dtc" && r.status !== "not_started"),
      fundingStarted: fo.started, daysSinceUpdate: daysSince, lastWinDays: null,
    });
    $("ov-next-title").textContent = id.first ? tpl(T.whatsNextFor, { name: id.first }) : T.whatsNextForYou;
    const DOTS = {
      now: `<span class="c3-dot now"><svg viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="3.5"/></svg></span>`,
      next: `<span class="c3-dot next"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>`,
    };
    $("ov-next").innerHTML = journey.nextUp.slice(0, 3).map((s) =>
      `<a class="ov5-step" href="${s.href}">${DOTS[s.status] || DOTS.next}<span style="min-width:0"><span class="tt" style="display:block">${esc(s.title)}</span><span class="why" style="display:block">${esc(s.why)}</span><span class="go">${esc(s.cta)} →</span></span></a>`).join("")
      || `<p class="ov-empty">${esc(T.nextEmpty)}</p>`;

    /* ---- support wheel — SHARED band-ring engine ---- */
    const anyScore = DOMAINS.some((n) => scored[n].score != null);
    const rose = $("ov-rose");
    if (anyScore) {
      rose.innerHTML = generateWheelSVG(scored, "needs");
      void rose.offsetWidth;
      rose.classList.add("play");
      rose.querySelectorAll("[data-domain]").forEach((g) => {
        const go = () => location.href = "/child/support-wheel?domain=" + encodeURIComponent(g.dataset.domain);
        g.addEventListener("click", go);
        g.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); go(); } });
      });
    } else {
      rose.innerHTML = `<p class="ov-empty" style="padding:34px 10px;text-align:center">${tpl(esc(T.wheelEmpty), { name: esc(firstName), of: ofName(firstName) })} <a href="${pLink}">${esc(T.openPassport)}</a></p>`;
      document.querySelector(".ov-rose-cap").style.display = "none";
    }

    /* ---- most support / going strong ---- */
    const shine = DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 45).sort((a, b) => scored[b].strength - scored[a].strength);
    const needLi = (n) => `<a class="ov-split-li" style="background:${tintOf(n, 0.1)};color:${domainColor(n)}" href="/child/support-wheel?domain=${encodeURIComponent(n)}"><span class="dd" style="background:${domainColor(n)}"></span>${esc(SHORT[n] || n)}</a>`;
    const strongLi = (n) => `<a class="ov-split-li" style="background:var(--green-bg);color:var(--green)" href="/child/support-wheel?domain=${encodeURIComponent(n)}"><span class="dd" style="background:var(--green)"></span>${esc(SHORT[n] || n)}</a>`;
    $("ov-splits").innerHTML = `
      <div><p class="ov-split-t need">${esc(T.mostSupportNow)}</p>${needs.length ? needs.slice(0, 3).map(needLi).join("") : `<p class="ov-split-empty">${esc(T.notEnoughAnswers)}</p>`}</div>
      <div><p class="ov-split-t strong">${esc(T.goingStrong)}</p>${shine.length ? shine.slice(0, 3).map(strongLi).join("") : `<p class="ov-split-empty">${esc(T.notEnoughAnswers)}</p>`}</div>`;

    /* ---- shines at ---- */
    $("ov-shine-title").textContent = id.first ? tpl(T.shinesAtNamed, { name: id.first }) : T.shinesAt;
    $("ov-shine").innerHTML = strengths.length
      ? strengths.slice(0, 6).map((s, i) => `<div class="ov-shinecard cu-pop" style="--d:${(0.12 + i * 0.06).toFixed(2)}s">${iconFor(s)}<p>${esc(s)}</p></div>`).join("")
      : `<p class="ov-empty">${esc(T.shinesEmpty)} <a href="${pLink}">${esc(T.addSome)}</a></p>`;

    /* ---- working on + team ---- */
    $("ov-pri").innerHTML = (Array.isArray(pri) && pri.length)
      ? pri.map((x, i) => `<span class="ov-pri-tag cu-pop" style="--d:${(0.12 + i * 0.06).toFixed(2)}s">${esc(dv(x))}</span>`).join("")
      : `<p class="ov-empty">${esc(T.priEmpty)} <a href="${pLink}">${esc(T.choosePriorities)}</a></p>`;
    $("ov-team").innerHTML = team.length
      ? `${esc(T.teamLabel)} <b>${team.map((t) => esc(dv(t.type))).join(" · ")}</b>`
      : `${esc(T.teamLabel)} <a href="${pLink}" style="color:var(--violet-700);font-weight:600">${tpl(esc(T.addTeam), { name: esc(firstName), of: ofName(firstName) })}</a>`;

    /* ---- guidance ---- */
    const g = buildFamilyGuidance(data, scored, firstName);
    $("ov-insights").textContent = g.length ? g.join(" ") : tpl(T.guidanceEmpty, { name: firstName });

    /* ---- quietly record a check-in for Growth (never blocks the page) ---- */
    if (p) ensureSnapshot(p, snapshotWheel(scored)).then((r) => {
      if (r && r.created && r.rows && r.rows.length >= 2 && window.uaNotify) window.uaNotify("info", T.snapshotToast);
    }).catch(() => {});
  })().catch((e) => console.error("[child overview] hydrate failed", e));
</script>
