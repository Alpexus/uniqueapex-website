---
/* OVERVIEW-V3 — structural redesign to match the approved mockup:
   · ONE hero card = identity + about sentence + profile ring + stat strip
   · Mini support wheel (rose petals, petal length = support level) is the
     centerpiece, with "Most support now" / "Going strong" beside it
   · Strengths render as ICON CARDS via a keyword→icon dictionary (EN+FR)
     with a star fallback for anything unmatched
   · Insights condensed into one warm guidance paragraph
   Data logic and Supabase calls unchanged. */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="My Child" activeNav="child">
  <SectionTabs section="child" active="overview" />

  <h1 class="page-title" data-rec-name>Your child</h1>
  <p class="page-sub">A warm, at-a-glance picture of your child — built automatically from your Family Passport.</p>

  <div class="ov-wrap">

    <!-- ================= HERO: identity + about + stats ================= -->
    <div class="ov-card ov-hero cu-hero-grad cu-rev">
      <div class="ov-hero-top">
        <div class="ov-avatar" id="ov-avatar">·</div>
        <div class="ov-hero-id">
          <p class="ov-name" id="ov-name">Loading…</p>
          <p class="ov-meta" id="ov-meta"></p>
          <p class="ov-about" id="ov-about"></p>
        </div>
        <div class="ov-ring">
          <svg width="64" height="64" viewBox="0 0 64 64">
            <circle cx="32" cy="32" r="26" fill="none" stroke="var(--line)" stroke-width="5.5"></circle>
            <circle id="ov-ring-c" cx="32" cy="32" r="26" fill="none" stroke="#7C3AED" stroke-width="5.5" stroke-linecap="round" stroke-dasharray="0 163.4" transform="rotate(-90 32 32)" style="transition:stroke-dasharray 1.1s cubic-bezier(.22,1,.36,1)"></circle>
            <text id="ov-ring-t" x="32" y="33" text-anchor="middle" dominant-baseline="central" font-size="14" font-weight="700" fill="var(--ink)">—</text>
          </svg>
          <span class="ov-ring-lab">Profile complete</span>
        </div>
      </div>
      <div class="ov-statstrip">
        <div class="ov-stats" id="ov-stats"></div>
        <div class="ov-actions">
          <a class="ov-btn" id="ov-edit" href="/passport">Edit profile</a>
          <a class="ov-btn ov-btn-v" id="ov-export" href="/passport?export=1">Export PDF</a>
        </div>
      </div>
    </div>

    <!-- ================= MAIN GRID: wheel + strengths ================= -->
    <div class="ov-grid cu-rev" style="--d:.1s">

      <div class="ov-card ov-wheelcard">
        <div class="ov-snap-head">
          <p class="ov-label" style="margin:0">Support today</p>
          <a class="ov-link" href="/child/support-wheel">Open full wheel <span class="ov-arr">→</span></a>
        </div>
        <div id="ov-rose" class="ov-rose"></div>
        <p class="ov-rose-cap">Bigger petal = more support is helpful right now · tap a petal to explore</p>
        <div class="ov-splits" id="ov-splits"></div>
      </div>

      <div class="ov-rightcol">
        <div class="ov-card">
          <p class="ov-label" id="ov-shine-title">Shines at</p>
          <div class="ov-shinegrid" id="ov-shine"></div>
        </div>
        <div class="ov-card">
          <p class="ov-label">Working on right now</p>
          <div class="ov-pri" id="ov-pri"></div>
          <div class="ov-teamline" id="ov-team"></div>
        </div>
      </div>

    </div>

    <!-- ================= GUIDANCE ================= -->
    <div class="ov-card ov-insights cu-rev" style="--d:.18s">
      <p class="ov-ins-title"><svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg> Family guidance</p>
      <p class="ov-ins-text" id="ov-insights">Loading…</p>
      <p class="ov-note">Observations drawn from your passport — supportive guidance, not medical advice.</p>
    </div>

  </div>
</AppFormLayout>

<style is:global>
  .ov-wrap{display:flex;flex-direction:column;gap:14px;max-width:1040px}
  .ov-card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:18px 20px;box-shadow:var(--shadow)}

  /* ---- hero ---- */
  .ov-hero{border-radius:22px}
  .ov-hero-top{display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;position:relative;z-index:1}
  .ov-avatar{width:58px;height:58px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#8B5CF6,#6D28D9);color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--display);font-size:1.5rem;font-weight:700;flex-shrink:0;box-shadow:0 6px 18px rgba(109,40,217,.25)}
  .ov-hero-id{flex:1;min-width:200px}
  .ov-name{font-family:var(--display);font-size:1.4rem;font-weight:700;letter-spacing:-.015em;color:var(--ink);margin:0}
  .ov-meta{font-size:.82rem;color:var(--muted);margin:3px 0 0}
  .ov-about{font-size:.86rem;font-style:italic;line-height:1.55;color:var(--ink-2);margin:7px 0 0;max-width:560px}
  .ov-ring{display:flex;flex-direction:column;align-items:center;gap:2px;position:relative;z-index:1}
  .ov-ring-lab{font-size:.66rem;color:var(--muted)}
  .ov-statstrip{display:flex;align-items:center;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);margin-top:14px;padding-top:12px;position:relative;z-index:1}
  .ov-stats{display:flex;gap:18px;flex-wrap:wrap;flex:1}
  .ov-stat{display:inline-flex;align-items:center;gap:6px;font-size:.82rem;color:var(--ink-2);text-decoration:none;font-weight:500;border-radius:8px;padding:2px 4px;transition:background .15s,color .15s}
  .ov-stat:hover{background:var(--violet-50);color:var(--violet-700)}
  .ov-stat svg{flex-shrink:0}
  .ov-stat b{font-weight:700;color:var(--ink)}
  .ov-actions{display:flex;gap:8px;flex-wrap:wrap}
  .ov-btn{font-size:.8rem;font-weight:600;padding:7px 15px;border-radius:9999px;text-decoration:none;border:1px solid var(--line-2);color:var(--ink-2);background:var(--card);transition:border-color .15s,color .15s}
  .ov-btn:hover{border-color:var(--violet-500);color:var(--violet-700)}
  .ov-btn-v{background:var(--violet-700);color:#fff;border-color:var(--violet-700);transition:filter .15s}
  .ov-btn-v:hover{filter:brightness(1.1);color:#fff;border-color:var(--violet-700)}

  /* ---- main grid ---- */
  .ov-grid{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(0,1fr);gap:14px;align-items:stretch}
  .ov-rightcol{display:flex;flex-direction:column;gap:14px;min-width:0}
  @media (max-width:760px){.ov-grid{grid-template-columns:1fr}}

  /* ---- wheel card ---- */
  .ov-snap-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
  .ov-label{font-size:.78rem;color:var(--muted);margin:0 0 10px;font-weight:600}
  .ov-link{font-size:.8rem;font-weight:600;color:var(--violet-700);text-decoration:none}
  .ov-link .ov-arr{display:inline-block;transition:transform .18s}
  .ov-link:hover .ov-arr{transform:translateX(3px)}
  .ov-rose{display:flex;justify-content:center}
  .ov-rose svg{max-width:100%}
  .ov-rose [data-domain]{cursor:pointer}
  .ov-rose [data-domain]:hover path{opacity:.75}
  .ov-rose-anim{transform-origin:50% 50%;animation:ovRose .9s cubic-bezier(.22,1,.36,1) .15s both}
  @keyframes ovRose{from{transform:scale(.55);opacity:0}to{transform:scale(1);opacity:1}}
  .ov-rose-cap{font-size:.72rem;color:var(--faint);text-align:center;margin:4px 0 0}
  .ov-splits{display:grid;grid-template-columns:1fr 1fr;gap:12px;border-top:1px solid var(--line);margin-top:12px;padding-top:12px}
  .ov-split-t{font-size:.74rem;font-weight:700;margin:0 0 7px}
  .ov-split-t.need{color:var(--amber)}
  .ov-split-t.strong{color:var(--green)}
  .ov-split-li{display:flex;align-items:center;gap:7px;font-size:.86rem;color:var(--ink-2);margin-bottom:5px;text-decoration:none;border-radius:7px;padding:1px 3px;transition:background .15s}
  a.ov-split-li:hover{background:var(--violet-50);color:var(--violet-700)}
  .ov-split-li .dd{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .ov-split-empty{font-size:.8rem;color:var(--faint);margin:0}

  /* ---- shines grid ---- */
  .ov-shinegrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:8px}
  .ov-shinecard{background:var(--green-bg);border-radius:12px;padding:11px 6px 9px;text-align:center;color:var(--green);transition:transform .16s,box-shadow .16s}
  .ov-shinecard:hover{transform:translateY(-2px);box-shadow:0 8px 18px rgba(14,143,102,.16)}
  .ov-shinecard p{font-size:.72rem;font-weight:600;color:#0a6b4d;margin:5px 0 0;line-height:1.25;overflow-wrap:break-word}
  .ov-shinecard svg{display:block;margin:0 auto}

  /* ---- working on ---- */
  .ov-pri{display:flex;flex-wrap:wrap;gap:7px}
  .ov-pri-tag{font-size:.82rem;font-weight:600;padding:6px 12px;border-radius:9999px;background:var(--violet-50);color:var(--violet-700)}
  .ov-teamline{font-size:.8rem;color:var(--muted);border-top:1px solid var(--line);margin-top:12px;padding-top:10px}
  .ov-teamline b{color:var(--ink-2);font-weight:600}

  /* ---- guidance ---- */
  .ov-insights{background:linear-gradient(135deg,var(--violet-50),#F9F7FE 55%,var(--violet-50));border-color:var(--violet-100)}
  .ov-ins-title{display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:700;color:var(--violet-700);margin:0 0 8px}
  .ov-ins-text{font-size:.92rem;line-height:1.65;color:#5b21b6;margin:0}
  .ov-note{font-size:.72rem;color:var(--faint);margin:8px 0 0}
  .ov-empty{font-size:.85rem;color:var(--muted);margin:0}
  .ov-empty a{color:var(--violet-700);font-weight:600}

  @media (prefers-reduced-motion:reduce){
    #ov-ring-c{transition:none!important}
    .ov-rose-anim{animation:none}
  }
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import * as UA from "../lib/ua-data.js";
  import { scoreWheel, DOMAINS, scoreToBand } from "../lib/wheelScore.js";
  import { HUES } from "../config/wheelConfig.js";
  import { domainColor } from "../lib/wheelSvg.js";
  import { buildFamilyGuidance } from "../lib/domainInsights.js";
  import { iconFor } from "../lib/interestIcons.js";

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const lc = (s) => String(s || "").toLowerCase();
  const cap = (s) => { s = String(s || ""); return s.charAt(0).toUpperCase() + s.slice(1); };
  const clean = (s) => cap(String(s || "").trim().replace(/[.,;:!]+$/, ""));
  const textToList = (s) => String(s || "").split(/[,\n;•]+/).map((x) => x.trim()).filter(Boolean);
  const listPhrase = (arr) => {
    arr = arr.filter(Boolean);
    if (!arr.length) return "";
    if (arr.length === 1) return arr[0];
    if (arr.length === 2) return arr[0] + " and " + arr[1];
    return arr.slice(0, -1).join(", ") + ", and " + arr[arr.length - 1];
  };
  const SHORT = { "Communication": "Communication", "Social Connection": "Social", "Sensory Processing": "Sensory", "Flexibility & Transitions": "Flexibility", "Emotional Regulation": "Emotional", "Executive Function": "Executive", "Daily Living Skills": "Daily living", "Learning & Play": "Learning & play" };

  /* iconFor now lives in src/lib/interestIcons.js (shared with the
     Strengths & Challenges tab) — imported above. */

  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

  (async () => {
    const passports = await UA.getPassports().catch(() => []);
    const p = UA.pickActivePassport(passports);
    const data = (p && p.data) || {};
    const id = UA.childIdentity(data);
    const cp = data.childProfile || {};
    const scored = scoreWheel(data);
    const firstName = id.first || "Your child";

    if (p) {
      $("ov-edit").href = `/passport?id=${p.id}`;
      $("ov-export").href = `/passport?id=${p.id}&export=1`;
    }

    /* ---- hero: identity ---- */
    if (id.name) { const h = document.querySelector("[data-rec-name]"); if (h) h.textContent = id.name; }
    $("ov-avatar").textContent = (firstName || "·")[0].toUpperCase();
    $("ov-name").textContent = id.name;

    const metaBits = [];
    const dxList = (data.diagnosis && data.diagnosis.diagnoses) || [];
    if (Array.isArray(dxList)) dxList.forEach((d) => metaBits.push(esc(d)));
    if (id.age != null) metaBits.push(id.age + " year" + (id.age === 1 ? "" : "s"));
    const loc = id.city || cp.location || "";
    if (loc) metaBits.push(esc(loc));
    if (id.languages) metaBits.push(esc(id.languages));
    const school = (data.education && (data.education.schoolName || data.education.schoolType)) || "";
    if (school) metaBits.push(esc(school));
    $("ov-meta").innerHTML = metaBits.join(" · ");

    /* ---- hero: about sentence ---- */
    const interests = textToList(data.strengths && data.strengths.interests);
    const strengthsText = textToList(data.strengths && data.strengths.strengths);
    const needs = DOMAINS.filter((n) => scored[n].score != null).sort((a, b) => scored[b].score - scored[a].score);
    const aboutParts = [];
    if (interests.length) aboutParts.push("Enjoys " + listPhrase(interests.slice(0, 3).map(lc)) + ".");
    else if (strengthsText.length) aboutParts.push("Has strengths in " + listPhrase(strengthsText.slice(0, 3).map(lc)) + ".");
    if (needs.length) aboutParts.push("Does best with clear, predictable routines and benefits from extra support with " + listPhrase(needs.slice(0, 2).map((n) => lc(SHORT[n] || n))) + ".");
    $("ov-about").textContent = aboutParts.join(" ");

    /* ---- hero: profile ring ---- */
    const comp = UA.completion(data);
    const C = 2 * Math.PI * 26;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      $("ov-ring-c").setAttribute("stroke-dasharray", `${((comp.pct / 100) * C).toFixed(1)} ${C.toFixed(1)}`);
    }));
    if (reduceMotion) { $("ov-ring-t").textContent = comp.pct + "%"; }
    else {
      let t0 = null;
      const tick = (ts) => {
        if (!t0) t0 = ts;
        const pr = Math.min(1, (ts - t0) / 1000), e = 1 - Math.pow(1 - pr, 3);
        $("ov-ring-t").textContent = Math.round(comp.pct * e) + "%";
        if (pr < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    /* ---- hero: stat strip ---- */
    const pri = (data.goals && data.goals.priorities) || [];
    const team = (data.therapy || []).filter((t) => t && t.type);
    const docs = p ? await UA.getRecentDocuments(p.id).catch(() => []) : [];
    const strengths = [];
    strengthsText.forEach((x) => strengths.push(clean(x)));
    interests.forEach((x) => { if (strengths.length < 6) strengths.push("Loves " + lc(clean(x))); });
    if (strengths.length < 3) {
      DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 55)
        .sort((a, b) => scored[b].strength - scored[a].strength)
        .forEach((n) => { if (strengths.length < 6) strengths.push("Strong " + lc(SHORT[n] || n)); });
    }
    const sIc = (d, c) => `<svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="${c}" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
    const pLink = "/passport" + (p ? "?id=" + p.id : "");
    const teamAbbr = team.map((t) => String(t.type).split(/\s+/).map((w) => w[0]).join("").slice(0, 2).toUpperCase()).join(" + ");
    const stats = [
      [`<b>${Array.isArray(pri) ? pri.length : 0}</b> focus areas`, sIc(`<path d="M8 1.5l2 4.2 4.5.5-3.3 3.1.9 4.5L8 11.7 3.9 13.8l.9-4.5L1.5 6.2 6 5.7z"/>`, "#6D28D9"), pLink],
      [`<b>${team.length}</b> providers${teamAbbr ? " · " + esc(teamAbbr) : ""}`, sIc(`<circle cx="6" cy="5" r="2.2"/><path d="M2 13c.4-2.2 2-3.2 4-3.2s3.6 1 4 3.2"/><circle cx="11.5" cy="5.5" r="1.8"/>`, "#0E8C82"), "/providers"],
      [`<b>${docs.length}</b> documents`, sIc(`<path d="M4 1.8h5.2L12.4 5v9.2H4z"/><path d="M9 1.8V5h3.4"/>`, "#A8650A"), "/documents"],
      [`<b>${strengths.length}</b> strengths`, sIc(`<path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/>`, "#0E8F66"), "/child/strengths"],
    ];
    $("ov-stats").innerHTML = stats.map((s) => `<a class="ov-stat" href="${s[2]}">${s[1]}<span>${s[0]}</span></a>`).join("");

    /* ---- rose wheel (petal length = support level) ---- */
    const anyScore = DOMAINS.some((n) => scored[n].score != null);
    if (anyScore) {
      const cx = 230, cy = 172, r0 = 20, R = 128, n8 = DOMAINS.length, seg = (2 * Math.PI) / n8;
      const pt = (r, a) => [(cx + r * Math.cos(a)).toFixed(1), (cy + r * Math.sin(a)).toFixed(1)];
      let svg = `<g class="${reduceMotion ? "" : "ov-rose-anim"}">`;
      /* faint band rings behind the petals — keeps the wheel's structure */
      for (let k = 1; k <= 5; k++) {
        const rr = (r0 + (R - r0) * k / 5).toFixed(1);
        svg += `<circle cx="${cx}" cy="${cy}" r="${rr}" fill="none" stroke="#ECE8F6" stroke-width="1"/>`;
      }
      DOMAINS.forEach((name, i) => {
        const a0 = -Math.PI / 2 + i * seg + 0.025, a1 = a0 + seg - 0.05;
        const sc = scored[name].score;
        const frac = sc == null ? 0.1 : Math.max(0.12, sc / 100);
        const r = r0 + (R - r0) * frac;
        const fill = sc == null ? "#EAE7F3" : `hsl(${HUES[i]},62%,60%)`;
        const p0 = pt(r0, a0), p1 = pt(r, a0), p2 = pt(r, a1), p3 = pt(r0, a1);
        const band = sc == null ? null : scoreToBand(sc);
        const tip = SHORT[name] + (band ? " — " + band.label : " — not enough answers yet");
        svg += `<g data-domain="${esc(name)}" role="button" tabindex="0" aria-label="${esc(tip)}">
          <title>${esc(tip)}</title>
          <path d="M${p0} L${p1} A${r.toFixed(1)},${r.toFixed(1)} 0 0 1 ${p2} L${p3} A${r0},${r0} 0 0 0 ${p0} Z" fill="${fill}" stroke="#fff" stroke-width="1.5"/>
        </g>`;
        const mid = a0 + (seg - 0.05) / 2, lp = pt(R + 14, mid);
        const anchor = Math.cos(mid) > 0.25 ? "start" : (Math.cos(mid) < -0.25 ? "end" : "middle");
        svg += `<text x="${lp[0]}" y="${lp[1]}" font-size="10.5" fill="var(--muted)" text-anchor="${anchor}" dominant-baseline="middle">${SHORT[name]}</text>`;
      });
      /* white ring lines over the petals so every petal shows its bands */
      for (let k = 1; k <= 4; k++) {
        const rr = (r0 + (R - r0) * k / 5).toFixed(1);
        svg += `<circle cx="${cx}" cy="${cy}" r="${rr}" fill="none" stroke="#fff" stroke-opacity=".55" stroke-width="1.4" style="pointer-events:none"/>`;
      }
      svg += `<circle cx="${cx}" cy="${cy}" r="${r0}" fill="var(--card)" stroke="var(--line)"/></g>`;
      $("ov-rose").innerHTML = `<svg viewBox="0 0 460 344" width="100%" style="max-width:430px" role="img"><title>Support wheel snapshot</title>${svg}</svg>`;
      $("ov-rose").querySelectorAll("[data-domain]").forEach((g) => {
        const go = () => location.href = "/child/support-wheel?domain=" + encodeURIComponent(g.dataset.domain);
        g.addEventListener("click", go);
        g.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); go(); } });
      });
    } else {
      $("ov-rose").innerHTML = `<p class="ov-empty" style="padding:34px 10px;text-align:center">Answer a few passport questions to see ${esc(firstName)}'s support wheel here. <a href="${pLink}">Open the passport →</a></p>`;
      document.querySelector(".ov-rose-cap").style.display = "none";
    }

    /* ---- most support / going strong ---- */
    const shine = DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 45).sort((a, b) => scored[b].strength - scored[a].strength);
    const li = (n) => `<a class="ov-split-li" href="/child/support-wheel?domain=${encodeURIComponent(n)}"><span class="dd" style="background:${domainColor(n)}"></span>${esc(SHORT[n] || n)}</a>`;
    $("ov-splits").innerHTML = `
      <div><p class="ov-split-t need">Most support now</p>${needs.length ? needs.slice(0, 3).map(li).join("") : `<p class="ov-split-empty">Not enough answers yet.</p>`}</div>
      <div><p class="ov-split-t strong">Going strong</p>${shine.length ? shine.slice(0, 3).map(li).join("") : `<p class="ov-split-empty">Not enough answers yet.</p>`}</div>`;

    /* ---- shines at (icon cards) ---- */
    $("ov-shine-title").textContent = firstName + " shines at";
    $("ov-shine").innerHTML = strengths.length
      ? strengths.slice(0, 6).map((s, i) => `<div class="ov-shinecard cu-pop" style="--d:${(0.12 + i * 0.06).toFixed(2)}s">${iconFor(s)}<p>${esc(s)}</p></div>`).join("")
      : `<p class="ov-empty">No strengths recorded yet. <a href="${pLink}">Add some →</a></p>`;

    /* ---- working on + team ---- */
    $("ov-pri").innerHTML = (Array.isArray(pri) && pri.length)
      ? pri.map((x, i) => `<span class="ov-pri-tag cu-pop" style="--d:${(0.12 + i * 0.06).toFixed(2)}s">${esc(x)}</span>`).join("")
      : `<p class="ov-empty">No priorities chosen yet. <a href="${pLink}">Choose focus areas →</a></p>`;
    $("ov-team").innerHTML = team.length
      ? `Support team: <b>${team.map((t) => esc(t.type)).join(" · ")}</b>`
      : `Support team: <a href="${pLink}" style="color:var(--violet-700);font-weight:600">add ${esc(firstName)}'s team →</a>`;

    /* ---- guidance paragraph: fully personalized from THIS child's answers
       (their top-need domains, their specific challenges, their strategies,
       their strengths + interests, their sensory profile) ---- */
    const g = buildFamilyGuidance(data, scored, firstName);
    $("ov-insights").textContent = g.length ? g.join(" ") : `Complete more of the passport to see guidance for ${firstName}.`;
  })().catch((e) => console.error("[child overview] hydrate failed", e));
</script>
