---
/* PROVIDERS-NOTES-V1 — from stub to the call log: after every provider
   call, write down who said what and when. Copyable as one clean list.
   Saved on this device for now (localStorage per account). */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
---
<AppFormLayout title="Providers" titleFr="Professionnels" activeNav="providers">
  <SectionTabs section="providers" active="notes" />

  <div class="pn-wrap">
    <div class="c3-ribbon rib-rose cu-rev">
      <span class="c3-spark" style="top:12px;right:120px">✦</span>
      <span class="c3-spark s2" style="bottom:14px;right:74px">✦</span>
      <span class="c3-rib-av"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4.5 3h5l2 2v8h-7z"/><path d="M9.5 3v2h2"/></svg></span>
      <div class="c3-rib-id">
        <h1 data-i18n="notes_title">The Call Log</h1>
        <p data-i18n="notes_sub">"They said they'd call back Tuesday…" — never lose track of a conversation again.</p>
      </div>
      <div class="c3-rib-stats" id="rb-stats"></div>
    </div>

    <div class="pn-add cu-rev" style="--d:.05s">
      <div class="pn-grid">
        <input class="pn-f" id="n-date" type="date" />
        <input class="pn-f" id="n-who" placeholder="Who (clinic, person) *" data-i18n-ph="notes_phWho" maxlength="80" />
        <input class="pn-f pn-wide" id="n-text" placeholder="What was said / next step *" data-i18n-ph="notes_phText" maxlength="240" />
      </div>
      <div class="pn-actions">
        <span class="pn-hint" data-i18n="notes_hint">Saved on this device for now — syncing comes with the directory.</span>
        <button class="btn btn-ghost btn-sm" id="n-copy" type="button" data-i18n="notes_copyLog">Copy the log</button>
        <button class="btn btn-primary btn-sm" id="n-save" type="button" data-i18n="notes_logIt">Log it</button>
      </div>
    </div>

    <div id="pn-list" class="pn-list"></div>
  </div>
</AppFormLayout>

<style is:global>
  .pn-wrap{display:flex;flex-direction:column;gap:14px;max-width:840px}
  .pn-add{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:15px 17px;box-shadow:var(--shadow)}
  .pn-grid{display:grid;grid-template-columns:150px 1fr;gap:9px}
  .pn-wide{grid-column:1/-1}
  @media (max-width:560px){.pn-grid{grid-template-columns:1fr}}
  .pn-f{width:100%;padding:9px 12px;border:1px solid var(--line-2);border-radius:10px;font-size:.86rem;color:var(--ink);background:var(--card);outline:none;font-family:inherit}
  .pn-f:focus{border-color:#F9A8D4;box-shadow:0 0 0 3px rgba(177,74,102,.12)}
  .pn-actions{display:flex;align-items:center;gap:10px;margin-top:11px;flex-wrap:wrap}
  .pn-hint{flex:1;font-size:.7rem;color:var(--faint);min-width:200px}
  .pn-list{display:flex;flex-direction:column}
  .pn-item{display:flex;gap:13px;position:relative;padding-bottom:14px}
  .pn-item::before{content:"";position:absolute;left:16px;top:36px;bottom:-2px;width:2px;border-radius:2px;background:linear-gradient(to bottom,#F3D8E1,#EAE7F3)}
  .pn-item.last::before{display:none}
  .pn-dot{width:33px;height:33px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;z-index:1;background:#F9EDF1;color:var(--rose);border:3px solid var(--card);box-shadow:0 2px 8px rgba(34,27,54,.14)}
  .pn-card{flex:1;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:11px 14px;position:relative;box-shadow:var(--shadow);transition:transform .15s,border-color .15s}
  .pn-item:hover .pn-card{transform:translateY(-1px);border-color:#F3D8E1}
  .pn-meta{font-size:.7rem;color:var(--faint);margin-bottom:2px}
  .pn-meta b{color:var(--rose);font-weight:700}
  .pn-text{font-size:.87rem;color:var(--ink);line-height:1.5;padding-right:18px}
  .pn-del{position:absolute;top:8px;right:10px;border:none;background:none;color:#E7D3DB;font-size:1.05rem;line-height:1;cursor:pointer;padding:2px}
  .pn-del:hover{color:#B14A66}
  .pn-empty{display:flex;gap:14px;align-items:center;border:1.5px dashed #F3D8E1;border-radius:16px;background:#FFFDFD;padding:18px}
  .pn-empty p{font-size:.85rem;color:var(--ink-2);line-height:1.55;margin:0}
</style>

<script is:inline>
  (function () {
    var raw = localStorage.getItem("ua_session"), s = null;
    try { s = raw ? JSON.parse(raw) : null; } catch (e) {}
    if (!s || !s.access_token) location.href = "/login";
  })();
</script>

<script>
  import { getSession } from "../../lib/ua-data.js";
  import { notify } from "../../lib/notify.js";
  import DICT from "../../i18n/providers-sub.js";

  const T = window.uaI18n ? window.uaI18n(DICT) : DICT.en;
  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  const uid = (getSession() && getSession().user && getSession().user.id) || "anon";
  const KEY = "ua_provnotes_" + uid;
  const load = () => { try { return JSON.parse(localStorage.getItem(KEY) || "[]"); } catch { return []; } };
  const save = (list) => localStorage.setItem(KEY, JSON.stringify(list));
  const fmtD = (iso) => { const d = new Date(iso + "T12:00:00"); return isNaN(d) ? iso : d.toLocaleDateString(window.uaLocale || "en-CA", { month: "short", day: "numeric", year: "numeric" }); };
  let notes = load();

  $("n-date").value = new Date().toISOString().slice(0, 10);

  function stats() {
    $("rb-stats").innerHTML = `<span class="c3-rstat"><b>${notes.length}</b><span>${notes.length === 1 ? esc(T.notes_entry1) : esc(T.notes_entryN)}</span></span>`;
  }
  function render() {
    stats();
    if (!notes.length) {
      $("pn-list").innerHTML = `<div class="pn-empty cu-rev"><span class="cu-blob" style="--blob:#F9EDF1;color:#B14A66;width:42px;height:42px"><svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4.5 3h5l2 2v8h-7z"/><path d="M9.5 3v2h2"/></svg></span><p>${T.notes_empty}</p></div>`;
      return;
    }
    const sorted = notes.slice().sort((a, b) => String(b.date).localeCompare(String(a.date)));
    $("pn-list").innerHTML = sorted.map((n, i) => `
      <div class="pn-item cu-rev${i === sorted.length - 1 ? " last" : ""}" style="--d:${Math.min(i * 0.04, 0.4).toFixed(2)}s">
        <span class="pn-dot"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3.5 2.5h3l1.5 3.5-2 1a8 8 0 004 4l1-2 3.5 1.5v3a1.5 1.5 0 01-1.5 1.5A12 12 0 012 4a1.5 1.5 0 011.5-1.5z"/></svg></span>
        <div class="pn-card">
          <div class="pn-meta">${esc(fmtD(n.date))} · <b>${esc(n.who)}</b></div>
          <div class="pn-text">${esc(n.text)}</div>
          <button class="pn-del" data-id="${esc(String(n.id))}" aria-label="${esc(T.notes_deleteAria)}">×</button>
        </div>
      </div>`).join("");
    $("pn-list").querySelectorAll(".pn-del").forEach((b) => b.addEventListener("click", () => {
      if (!confirm(T.notes_confirmDelete)) return;
      notes = notes.filter((n) => String(n.id) !== b.dataset.id);
      save(notes); render();
    }));
  }

  $("n-save").addEventListener("click", () => {
    const date = $("n-date").value, who = $("n-who").value.trim(), text = $("n-text").value.trim();
    if (!who || !text) { (!who ? $("n-who") : $("n-text")).focus(); return; }
    notes.unshift({ id: Date.now(), date: date || new Date().toISOString().slice(0, 10), who, text });
    save(notes);
    $("n-who").value = ""; $("n-text").value = "";
    render();
    notify("ok", T.notes_logged);
  });
  $("n-copy").addEventListener("click", () => {
    if (!notes.length) return;
    const txt = notes.slice().sort((a, b) => String(b.date).localeCompare(String(a.date)))
      .map((n) => fmtD(n.date) + " — " + n.who + ": " + n.text).join("\n");
    navigator.clipboard && navigator.clipboard.writeText(txt).then(() => notify("ok", T.notes_copied)).catch(() => {});
  });
  render();
</script>
