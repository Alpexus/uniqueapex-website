      }

      function renderDetail() {
        const name = DOMAINS[sel], dm = scored[name];
        const box = $("wheel-detail");
        box.style.display = "block";
        const L = levelInfo(dm.score), det = domainDetail(name, data), dc = domainColor(name);
        const segCount = dm.score == null ? 0 : (dm.score === 0 ? 0 : scoreToBand(dm.score).rings);
        const strCount = dm.strength == null ? 0 : (dm.strength === 0 ? 0 : scoreToBand(dm.strength, "strength").rings);
        let segs = ""; for (let k = 1; k <= 5; k++) segs += `<span class="d3d-seg">${k <= segCount ? `<b style="background:${L.seg};--d:${(k * 0.07).toFixed(2)}s"></b>` : ""}</span>`;
        let ssegs = ""; for (let k = 1; k <= 5; k++) ssegs += `<span class="d3d-seg">${k <= strCount ? `<b style="background:#0E8F66;--d:${(k * 0.07).toFixed(2)}s"></b>` : ""}</span>`;
        const confLbl = dm.confidence === "high" ? "High" : dm.confidence === "medium" ? "Medium" : dm.confidence === "low" ? "Low" : "No data";
        const chips = det.support.slice(0, 2).map((t, i) => `<span class="d3d-chip sup cu-pop" style="--d:${(0.08 + i * 0.05).toFixed(2)}s">${esc(t)}</span>`).join("")
          + det.strategies.slice(0, 2).map((t, i) => `<span class="d3d-chip tip cu-pop" style="--d:${(0.18 + i * 0.05).toFixed(2)}s">${esc(t)}</span>`).join("");
        box.style.borderTopColor = dc;
        box.innerHTML = `<div class="d3d-in">`
          + `<div class="d3d-head"><span class="d3d-dot" style="background:${tintOf(name, 0.14)}"><i style="background:${dc}"></i></span><span class="d3d-name">${esc(name)}</span><span class="d3d-pill" style="background:${L.bg};color:${L.fg}">${L.label}</span></div>`
          + (dm.score == null
              ? `<p style="font-size:.8rem;color:var(--faint);margin:0">Add more in the passport to build this part of the profile.</p>`
              : `<div class="d3d-meta"><span class="l">Support level</span><span class="d3d-segs">${segs}</span></div>`
                + (dm.strength != null ? `<div class="d3d-meta"><span class="l">Strengths</span><span class="d3d-segs">${ssegs}</span></div>` : "")
                + `<div class="d3d-meta"><span class="l">Confidence</span><span class="d3d-conf">${confLbl} — ${dm.answered} of ${dm.total} related questions</span></div>`)
          + (chips ? `<div class="d3d-chips">${chips}</div>` : "")
          + `<div class="d3d-foot"><a href="${wheelDeep(name)}">Full detail →</a></div>`
          + `</div>`;
      }

      function renderTops() {
        const host = $("wheel-tops");
        const needTop = DOMAINS.filter((n) => scored[n].score != null).sort((a, b) => scored[b].score - scored[a].score).slice(0, 2);
        const strTop = DOMAINS.filter((n) => scored[n].strength != null && scored[n].strength >= 45).sort((a, b) => scored[b].strength - scored[a].strength).slice(0, 2);
        let html = "";
        if (needTop.length) html += `<div class="d3-tops-row"><span class="lbl">Most support</span>` + needTop.map((n) => `<a class="d3-topchip" style="background:${tintOf(n, 0.1)};color:${domainColor(n)}" href="${wheelDeep(n)}"><i style="background:${domainColor(n)}"></i>${esc(n)}</a>`).join("") + `</div>`;
        if (strTop.length) html += `<div class="d3-tops-row"><span class="lbl">Going strong</span>` + strTop.map((n) => `<a class="d3-topchip" style="background:var(--green-bg);color:var(--green)" href="${wheelDeep(n)}"><i style="background:var(--green)"></i>${esc(n)}</a>`).join("") + `</div>`;
        host.innerHTML = html;
      }

      if (scoredCount < 3) {
        $("wheel-toggle").parentElement.style.display = "none";
        $("wheel-caption").textContent = "";
        document.querySelector(".d3-ringleg").style.display = "none";
        $("wheel-host").innerHTML = `<div style="text-align:center;padding:26px 14px"><p style="color:var(--muted);font-size:.85rem;margin:0 0 12px">Fill in more of the passport (communication, sensory, behaviour, daily living) to generate ${esc(first || "your child")}'s support wheel.</p><a class="btn btn-primary btn-sm" href="${passportLink}">Continue passport →</a></div>`;
      } else {
        const wc = wheelCompleteness(data);
        const lowConf = DOMAINS.filter((n) => scored[n].confidence === "low");
        $("wheel-warning").innerHTML = wc.pct < 70
          ? `<div style="background:var(--amber-bg);border:1px solid #f3e2c0;border-radius:12px;padding:10px 14px;font-size:12px;color:var(--amber)"><strong>Wheel is ${wc.pct}% complete</strong> — ${wc.answered} of ${wc.total} contributing questions answered.${lowConf.length ? " Lower confidence in: " + esc(lowConf.join(", ")) + "." : ""} <a href="${passportLink}" style="color:var(--amber);font-weight:600;text-decoration:underline">Complete more →</a></div>`
          : "";
        renderToggle();
        renderWheel();
        buildOverlay();
        renderDetail();
        renderTops();
      }

      /* ================= TIP OF THE DAY ================= */
      const SECTION_LABEL = { communication: "Communication", sensory: "Sensory", dailyLiving: "Daily living", behaviour: "Behaviour", education: "School", birth: "Development", therapy: "Services", goals: "Goals" };
      const SECTION_TINT = { communication: ["#EDE9FE", "#6D28D9"], sensory: ["#F9EDF1", "#B14A66"], dailyLiving: ["#E8F6F0", "#0E8F66"], behaviour: ["#FBF2E2", "#A8650A"], education: ["#E6F4F2", "#0E8C82"], birth: ["#EDE9FE", "#6D28D9"], therapy: ["#E6F4F2", "#0E8C82"], goals: ["#EDE9FE", "#6D28D9"] };
      const tips = matchAdvice(data);
      const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0)) / 864e5);
      let tipIdx = tips.length ? dayOfYear % tips.length : 0;
      function renderTip() {
        if (!tips.length) {
          $("tip-text").textContent = "Answer a few more passport questions and a daily tip matched to your answers will appear here.";
          $("tip-src").innerHTML = `<a href="${passportLink}" style="color:var(--violet-700);font-weight:600;text-decoration:none">Continue the passport →</a>`;
          return;
        }
        const t = tips[tipIdx % tips.length];
        const tint = SECTION_TINT[t.section] || ["#EDE9FE", "#6D28D9"];
        $("tip-tag").textContent = SECTION_LABEL[t.section] || t.section;
        $("tip-tag").style.background = tint[0]; $("tip-tag").style.color = tint[1];
        $("tip-tag").style.display = "inline-block";
        $("tip-text").textContent = t.tip;
        $("tip-src").textContent = "Because you noted: " + t.label.toLowerCase();
        $("tip-copy").style.display = "inline-block";
        $("tip-note").textContent = tips.length > 1 ? "New tip each day · " + tips.length + " matched" : "Matched to the passport";
        if (tips.length > 1) $("tip-next").style.display = "inline-block";
      }
      renderTip();
      $("tip-copy").addEventListener("click", () => {
        const t = tips[tipIdx % tips.length]; if (!t) return;
        navigator.clipboard && navigator.clipboard.writeText(t.tip).then(() => {
          $("tip-copy").textContent = "Copied ✓";
          setTimeout(() => { $("tip-copy").textContent = "Copy"; }, 1600);
        }).catch(() => {});
      });
      $("tip-next").addEventListener("click", () => { tipIdx++; renderTip(); });

      /* ================= DOCUMENTS ================= */
      const docs = p ? await UA.getRecentDocuments(p.id).catch(() => []) : [];
      const docIcon = `<svg viewBox="0 0 16 16" fill="none" stroke-width="1.6"><path d="M4 1.8h5.2L12.4 5v9.2H4V1.8z"/><path d="M9 1.8V5h3.4"/></svg>`;
      $("d-docs").innerHTML = docs.length
        ? docs.map((d) => `<div class="doc-row"><span class="doc-ic">${docIcon}</span><span class="doc-meta"><span class="doc-name">${esc(d.file_name)}</span><span class="doc-sub">Uploaded ${UA.fmtDate(d.created_at)}</span></span><span class="doc-status"><span class="pill new">${esc((d.file_type || "file").toUpperCase())}</span></span></div>`).join("")
        : `<div style="color:var(--muted);font-size:.82rem;padding:14px 20px">No documents yet. Upload a report to get started.</div>`;

      /* ================= ACTIVITY ================= */
      const acts = p ? await UA.getActivity(p.id) : [];
      const aIcon = { document: ["t-doc", `<path d="M8 3v8M4.5 7.5L8 11l3.5-3.5M3 13.5h10"/>`], profile: ["t-edit", `<path d="M10.5 2.5l3 3L6 13H3v-3l7.5-7.5z"/>`], funding: ["t-fund", `<circle cx="8" cy="8" r="5.5"/><path d="M8 5.5v5M6.3 7.2L8 5.5l1.7 1.7"/>`], provider: ["t-prov", `<circle cx="8" cy="5.2" r="2.4"/><path d="M3.4 13c.5-2.4 2.3-3.5 4.6-3.5s4.1 1.1 4.6 3.5"/>`] };
      $("d-activity").innerHTML = acts.length
        ? acts.map((a) => { const ic = aIcon[a.type] || aIcon.profile; return `<div class="t-item"><span class="t-ic ${ic[0]}"><svg viewBox="0 0 16 16" fill="none" stroke-width="1.7">${ic[1]}</svg></span><div class="t-meta">${esc(a.label)}<div class="t-time">${UA.relTime(a.created_at)}</div></div></div>`; }).join("")
        : `<div style="color:var(--muted);font-size:.82rem;padding:6px 0">Your recent uploads, edits and applications will appear here.</div>`;

      /* ================= FUNDING ================= */
      const apps = p ? await UA.getFundingApplications(p.id) : [];
      const fo = UA.fundingOverview(apps);
      $("d-fund-stats").innerHTML = [
        [fo.total, "Programs available"],
        ["$18.4K<span>/yr</span>", "Potential funding"],
        [fo.started, "Applications started"],
        [fo.submitted, "Submitted"],
      ].map(([n, l]) => `<div class="fund-stat"><div class="fund-num">${n}</div><div class="fund-label">${l}</div></div>`).join("");
      $("d-fund-rows").innerHTML = fo.rows.filter((r) => r.status !== "not_started").concat(fo.rows.filter((r) => r.status === "not_started")).slice(0, 3)
        .map((r) => { const pl = UA.STATUS_PILL[r.status]; return `<div class="fund-row"><span class="fund-name">${esc(r.name)}<small>${esc(r.level)} · ${esc(r.note)}</small></span><span class="pill ${pl.cls}">${pl.label}</span></div>`; }).join("");
      $("kpi-funding-num").innerHTML = `$${fo.approvedAmount.toLocaleString("en-CA")}<span style="font-size:.85rem;color:var(--muted)">/yr</span>`;
      $("kpi-funding-sub").textContent = fo.submitted ? fo.submitted + " program" + (fo.submitted === 1 ? "" : "s") + " active" : "Funding approved";

      /* ================= WAITLIST KPI ================= */
      const wl = await UA.getWaitlist();
      if (wl.length) {
        countUp($("kpi-waitlist"), wl.length);
        $("kpi-waitlist-sub").textContent = "Waitlists · " + esc(wl[0].status || "New");
      } else {
        $("kpi-waitlist").textContent = "0";
        $("kpi-waitlist-sub").textContent = "Waitlists joined";
      }

      /* ================= NEXT STEPS (recommendations) ================= */
      const needsSorted = DOMAINS.filter((n) => scored[n].score != null).sort((a, b) => scored[b].score - scored[a].score);
      const ctx = {
        documents: docs.map((d) => ({ type: (d.file_type || "") + " " + (d.file_name || ""), date: d.created_at })),
        appliedTaxCredit: fo.rows.some((r) => r.key === "dtc" && r.status !== "not_started"),
        fundingProgramsAvailable: fo.total - fo.started,
        onWaitlists: wl.length > 0,
        topUnmetNeed: needsSorted.length ? needsSorted[0] + " support" : undefined,
      };
      const recs = getRecommendations(data, ctx).filter((r) => r.severity !== "done");
      const SEV = {
        warn: ["#FBF2E2", "#A8650A", `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3.5v6M8 12.4v.2"/></svg>`],
        todo: ["#EDE9FE", "#6D28D9", `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M2.5 8h9M8 4.5L11.5 8 8 11.5"/></svg>`],
        info: ["#E6F4F2", "#0E8C82", `<svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.5 4.2L14 7.2l-4.5 1.5L8 13l-1.5-4.3L2 7.2l4.5-1.5z"/></svg>`],
      };
      /* hero-adjacent card: the single top step */
      const top = recs[0];
      if (top) {
        const pillTxt = top.severity === "warn" ? "Worth doing soon" : top.severity === "todo" ? "Good next step" : "Nice to have";
        const tint = SEV[top.severity] || SEV.info;
        $("step-pill").textContent = pillTxt;
        $("step-pill").style.background = tint[0]; $("step-pill").style.color = tint[1];
        $("step-pill").style.display = "inline-block";
        $("step-title").textContent = top.title;
        $("step-why").textContent = top.reason || "";
        $("step-cta").textContent = top.cta || "Open";
        $("step-cta").href = top.href;
        $("step-cta").style.display = "inline-flex";
        if (recs.length > 1) $("step-more").textContent = (recs.length - 1) + " more below";
      } else {
        $("step-title").textContent = "You're all caught up ✦";
        $("step-why").textContent = "Nothing urgent on the list right now.";
      }
      /* the checklist card: the following three */
      const rest = recs.slice(1, 4);
      $("d-steps").innerHTML = rest.length
        ? rest.map((r) => { const t = SEV[r.severity] || SEV.info; return `<a class="d3-step" href="${r.href}"><span class="ic" style="background:${t[0]};color:${t[1]}">${t[2]}</span><span class="tx"><span class="tt">${esc(r.title)}</span>${r.reason ? `<span class="why">${esc(r.reason)}</span>` : ""}</span><span class="go">→</span></a>`; }).join("")
        : `<div style="color:var(--muted);font-size:.82rem;padding:8px 0 10px">All caught up — check back after your next passport update.</div>`;
      if (first) $("steps-note").textContent = "Based on " + first + "'s profile — the list updates as you go.";

      /* ================= KPIs ================= */
      const pri = (data.goals && data.goals.priorities) || [];
      countUp($("kpi-focus"), Array.isArray(pri) ? pri.length : 0);
      countUp($("kpi-docs"), docs.length);

      /* ================= WINS + MOMENTUM ================= */
      $("d-explore-title").textContent = first ? "Explore " + first + "'s profile" : "Explore the profile";
      const star = '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.6l1.7 4.4 4.6.4-3.5 3 .9 4.5L8 11.9 3.8 14.3l.9-4.5L1.2 6.4l4.6-.4z"/></svg>';
      let wins = [];
      const dayKey = (d) => { const x = new Date(d); return x.getFullYear() + "-" + (x.getMonth() + 1) + "-" + x.getDate(); };
      const weekStart = (d) => { const x = new Date(d); x.setHours(0, 0, 0, 0); const wd = (x.getDay() + 6) % 7; x.setDate(x.getDate() - wd); return x.getTime(); };

      function renderMomentum() {
        const now = new Date();
        const thisWeek = weekStart(now);
        const weekWins = wins.filter((w) => new Date(w.created_at).getTime() >= thisWeek).length;
        countUp($("mo-count"), weekWins);
        if (!weekWins) { $("mo-count").textContent = "0"; $("mo-lab").textContent = "wins logged this week — tiny ones count"; }
        else $("mo-lab").textContent = "win" + (weekWins === 1 ? "" : "s") + " this week";
        /* 7-day dots */
        const hitDays = new Set(wins.map((w) => dayKey(w.created_at)));
        let dots = "";
        for (let i = 6; i >= 0; i--) {
          const d = new Date(now); d.setDate(now.getDate() - i);
          const letter = d.toLocaleDateString("en-CA", { weekday: "narrow" });
          dots += `<span class="d3-day${hitDays.has(dayKey(d)) ? " hit" : ""}${i === 0 ? " today" : ""}"><i></i>${letter}</span>`;
        }
        $("mo-days").innerHTML = dots;
        /* weekly streak */
        const weeks = new Set(wins.map((w) => weekStart(new Date(w.created_at))));
        let streak = 0, cursor = thisWeek;
        if (!weeks.has(cursor)) cursor -= 7 * 864e5; /* week just started — count from last week */
        while (weeks.has(cursor)) { streak++; cursor -= 7 * 864e5; }
        $("mo-streak").textContent = streak >= 2 ? "✦ " + streak + " weeks in a row with a win" : "";
        /* recent list */
        $("d-wins").innerHTML = wins.length
          ? wins.slice(0, 3).map((w) => `<div class="dash-win"><span class="st">${star}</span><span>${esc(w.text)}</span><span class="wh">${w.justNow ? "just now" : UA.relTime(w.created_at)}</span></div>`).join("")
          : `<div style="color:var(--muted);font-size:.82rem;padding:8px 0">No wins yet — the first one is a win itself.</div>`;
        /* month KPI */
        const m0 = new Date(now.getFullYear(), now.getMonth(), 1).getTime();
        const monthWins = wins.filter((w) => new Date(w.created_at).getTime() >= m0).length;
        $("kpi-wins").textContent = String(monthWins);
      }

      try {
        if (p) {
          const s = await getValidSession();
          if (s) {
            const wr = await fetch(UA_URL + "/rest/v1/wins?select=id,text,created_at&passport_id=eq." + p.id + "&order=created_at.desc&limit=40", { headers: authHeaders(s.access_token) });
            if (wr.ok) wins = await wr.json();
          }
        }
      } catch (e) { /* momentum stays in empty state */ }
      renderMomentum();

      /* save a win from the dashboard */
      async function saveWin() {
        const inp = $("win-input"), btn = $("win-save");
        const v = inp.value.trim();
        if (!v) { inp.focus(); return; }
        if (!p) { $("win-msg").textContent = "Create the passport first — then wins have a home."; return; }
        btn.disabled = true;
        const s = await getValidSession();
        if (!s) { location.href = "/login"; return; }
        try {
          const r = await fetch(UA_URL + "/rest/v1/wins", { method: "POST", headers: Object.assign({}, authHeaders(s.access_token), { Prefer: "return=representation" }), body: JSON.stringify({ user_id: s.user.id, passport_id: p.id, text: v }) });
          if (!r.ok) throw new Error("save failed");
          const rows = await r.json(), row = rows && rows[0];
          wins.unshift({ id: row ? row.id : Date.now(), text: v, created_at: row ? row.created_at : new Date().toISOString(), justNow: true });
          inp.value = "";
          $("win-msg").textContent = "Saved" + (first ? " — " + first + " is on a roll." : " — nice one.");
          renderMomentum();
          if (!reduceMotion) {
            const burst = $("win-burst");
            burst.classList.remove("go"); void burst.offsetWidth; burst.classList.add("go");
            setTimeout(() => burst.classList.remove("go"), 900);
          }
          setTimeout(() => { $("win-msg").textContent = "It lands in the Progress journal, dated today."; }, 4000);
        } catch (e) {
          $("win-msg").textContent = "Couldn't save just now — try again in a moment.";
        } finally {
          btn.disabled = false;
        }
      }
      $("win-save").addEventListener("click", saveWin);
      $("win-input").addEventListener("keydown", (e) => { if (e.key === "Enter") saveWin(); });

      /* ================= WORKSHOP ================= */
      const ws = await UA.getNextWorkshop().catch(() => null);
      $("d-workshop").innerHTML = ws
        ? (() => { const d = new Date(ws.starts_at); const day = d.getDate(); const mon = d.toLocaleDateString("en-CA", { month: "short" }); const time = d.toLocaleTimeString("en-CA", { hour: "numeric", minute: "2-digit" }); return `<div class="ws"><span class="ws-date"><b>${day}</b><span>${mon}</span></span><span class="ws-meta"><b>${esc(ws.title)}</b><span>${time} · ${esc(ws.location_type || "Online")}</span></span><a class="btn btn-ghost btn-sm" href="/resources/workshops" style="margin-left:auto">Register</a></div>`; })()
        : `<div style="color:var(--muted);font-size:.82rem;padding:14px 20px">No upcoming workshops scheduled.</div>`;
    })().catch((e) => console.error("[dashboard] hydrate failed", e));
  </script>

</AppLayout>
