---
/* DASHBOARD-V3 — the "morning coffee" dashboard. Brand-new design:
   · GRADIENT HERO BAND (deep violet, white text): greeting + day-aware
     subline, child identity chip, animated completion ring, personalized
     guidance line (buildFamilyGuidance) pinned at the bottom.
   · "TODAY" STRIP — three live mini-cards:
       1. Tip of the day  — deterministic daily pick from the closed
          advice library (matchAdvice), with provenance + copy button.
       2. Suggested next step — top item from recommendations.js with
          its plain-language reason.
       3. Log a win — save straight to the wins table from the dashboard,
          with a sparkle-burst celebration.
   · KPI ROW (5 live tiles, count-ups, every tile is a link).
   · SUPPORT WHEEL — now the EXACT support-wheel-tab logic:
     generateWheelSVG (shared band rings) + click-overlay wedges with
     violet selection outline + compact domain detail panel (level
     segments, chips from domainDetail) + needs/strengths sliding toggle
     + draw-in animation + ring-scale legend.
   · MOMENTUM card — wins this week, 7-day dot strip, weekly streak,
     recent wins feed (live).
   · NEXT STEPS card — personalized checklist (recommendations.js).
   · Reports / Funding / Workshop / Explore keep their live hydration.
   Removed from V2: separate AI-insights card (its actions moved to Next
   steps; strengths/watch live on the child pages), separate guidance
   band (now in the hero), quick-action chip row (replaced by Today strip). */
import AppLayout from "../layouts/AppLayout.astro";
---
<AppLayout title="Dashboard" activeNav="dashboard">

  <!-- ================= HERO ================= -->
  <section class="d3-hero cu-rev" id="d3-hero">
    <span class="d3-spark" style="top:18px;left:46%">✦</span>
    <span class="d3-spark s2" style="top:44px;left:56%">✦</span>
    <span class="d3-spark s3" style="bottom:58px;right:12%">✦</span>
    <div class="d3-hero-main">
      <div class="d3-hello">
        <h1 id="g-hello">Welcome back</h1>
        <p class="d3-sub" id="g-sub"></p>
        <p class="d3-date" id="g-date"></p>
      </div>
      <div class="d3-hero-side">
        <a class="d3-chip" id="h-chip" href="/child" aria-label="Open the child profile">
          <span class="d3-chip-av" id="h-avatar">·</span>
          <span class="d3-chip-meta">
            <b id="h-name">Loading…</b>
            <span id="h-sub"></span>
          </span>
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" style="opacity:.7;flex-shrink:0"><path d="M6 3.5L10.5 8 6 12.5"/></svg>
        </a>
        <div class="d3-ring-row">
          <span class="d3-ring">
            <svg width="50" height="50" viewBox="0 0 52 52" fill="none">
              <circle cx="26" cy="26" r="22" stroke="var(--line)" stroke-width="5"/>
              <circle id="d-ring" cx="26" cy="26" r="22" stroke="var(--violet-600)" stroke-width="5" stroke-linecap="round" stroke-dasharray="0 138.2" style="transition:stroke-dasharray 1s cubic-bezier(.22,1,.36,1)"/>
            </svg>
            <span class="pctw" id="d-pct">—</span>
          </span>
          <span class="d3-ring-label"><b>Passport</b><span id="d-remaining">—</span></span>
          <div class="d3-hero-btns">
            <a class="d3-btn-solid" id="d-edit" href="/passport">Continue passport</a>
            <a class="d3-btn-line" id="d-export" href="/passport?export=1">Export PDF</a>
          </div>
        </div>
      </div>
    </div>
    <div class="d3-guide" id="g-guide" style="display:none">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="#5EEAD4" style="flex-shrink:0;margin-top:3px"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg>
      <p id="g-guide-text"></p>
      <a href="/child" class="d3-guide-link">More →</a>
    </div>
  </section>

  <!-- ================= TODAY STRIP ================= -->
  <div class="d3-today">

    <!-- Tip of the day -->
    <div class="card t3 cu-rev cu-lift" style="--d:.06s">
      <div class="t3-head">
        <span class="cu-blob t3-blob" style="--blob:#EDE9FE;color:#6D28D9"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 4.3L14 7.2l-4.4 1.5L8 13l-1.6-4.3L2 7.2l4.4-1.4z"/></svg></span>
        <span class="t3-title">Today's tip</span>
        <span class="t3-pill" id="tip-tag" style="display:none"></span>
      </div>
      <p class="t3-body" id="tip-text">Loading…</p>
      <p class="t3-src" id="tip-src"></p>
      <div class="t3-foot">
        <button class="t3-mini" id="tip-copy" type="button" style="display:none">Copy</button>
        <button class="t3-mini" id="tip-next" type="button" style="display:none">Another tip</button>
        <span class="t3-note" id="tip-note"></span>
      </div>
    </div>

    <!-- Suggested next step -->
    <div class="card t3 cu-rev cu-lift" style="--d:.1s">
      <div class="t3-head">
        <span class="cu-blob t3-blob" style="--blob:#E6F4F2;color:#0E8C82"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 8h9M8 4.5L11.5 8 8 11.5"/></svg></span>
        <span class="t3-title">Suggested next step</span>
        <span class="t3-pill" id="step-pill" style="display:none"></span>
      </div>
      <p class="t3-body" id="step-title" style="font-weight:600">Loading…</p>
      <p class="t3-src" id="step-why"></p>
      <div class="t3-foot">
        <a class="btn btn-primary btn-sm" id="step-cta" href="/child" style="display:none">Do it</a>
        <span class="t3-note" id="step-more"></span>
      </div>
    </div>

    <!-- Log a win -->
    <div class="card t3 t3-win cu-rev cu-lift" style="--d:.14s">
      <div class="t3-head">
        <span class="cu-blob t3-blob" style="--blob:#E8F6F0;color:#0E8F66"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.6l1.7 4.4 4.6.4-3.5 3 .9 4.5L8 11.9 3.8 14.3l.9-4.5L1.2 6.4l4.6-.4z"/></svg></span>
        <span class="t3-title">Log today's win</span>
      </div>
      <div class="t3-winrow">
        <input id="win-input" type="text" maxlength="200" placeholder="Even tiny ones count…" autocomplete="off" />
        <button id="win-save" type="button" class="d3-winbtn">
          <span class="d3-burst" id="win-burst" aria-hidden="true"><i>✦</i><i>✦</i><i>✦</i><i>✦</i><i>✦</i><i>✦</i></span>
          Save
        </button>
      </div>
      <p class="t3-src" id="win-msg">It lands in the Progress journal, dated today.</p>
    </div>
  </div>

  <!-- ================= KPI ROW ================= -->
  <div class="d3-kpis">
    <a class="card d3-kpi cu-rev cu-lift" href="/child" style="--d:.16s"><span class="cu-blob d3-kpi-blob" style="--blob:#EDE9FE;color:#6D28D9"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M8 1.5l2 4.2 4.5.5-3.3 3.1.9 4.5L8 11.7 3.9 13.8l.9-4.5L1.5 6.2 6 5.7z"/></svg></span><span><span class="d3-kpi-num" id="kpi-focus">—</span><span class="d3-kpi-lab">Focus areas</span></span></a>
    <a class="card d3-kpi cu-rev cu-lift" href="/child/growth" style="--d:.19s"><span class="cu-blob d3-kpi-blob" style="--blob:#E8F6F0;color:#0E8F66"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.6l1.7 4.4 4.6.4-3.5 3 .9 4.5L8 11.9 3.8 14.3l.9-4.5L1.2 6.4l4.6-.4z"/></svg></span><span><span class="d3-kpi-num" id="kpi-wins">—</span><span class="d3-kpi-lab">Wins this month</span></span></a>
    <a class="card d3-kpi cu-rev cu-lift" href="/documents" style="--d:.22s"><span class="cu-blob d3-kpi-blob" style="--blob:#E6F4F2;color:#0E8C82"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 1.8h5.2L12.4 5v9.2H4z"/><path d="M9 1.8V5h3.4"/></svg></span><span><span class="d3-kpi-num" id="kpi-docs">—</span><span class="d3-kpi-lab">Documents</span></span></a>
    <a class="card d3-kpi cu-rev cu-lift" href="/providers/waitlists" style="--d:.25s"><span class="cu-blob d3-kpi-blob" style="--blob:#FBF2E2;color:#A8650A"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="8" cy="8" r="6"/><path d="M8 4.5V8l2.3 2.3"/></svg></span><span><span class="d3-kpi-num" id="kpi-waitlist">—</span><span class="d3-kpi-lab" id="kpi-waitlist-sub">Waitlists</span></span></a>
    <a class="card d3-kpi cu-rev cu-lift" href="/funding" style="--d:.28s"><span class="cu-blob d3-kpi-blob" style="--blob:#F9EDF1;color:#B14A66"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="8" cy="8" r="6"/><path d="M8 5v6M6.5 6.7L8 5l1.5 1.7"/></svg></span><span><span class="d3-kpi-num" id="kpi-funding-num">$0</span><span class="d3-kpi-lab" id="kpi-funding-sub">Funding approved</span></span></a>
  </div>

  <div class="grid">
    <!-- ===== LEFT ===== -->
    <div class="col">

      <!-- Support wheel — support-wheel-tab logic -->
      <div class="card cu-rev" style="--d:.2s">
        <div class="card-head">
          <span class="card-title" id="wheel-title">Support wheel</span>
          <a class="card-link" href="/child/support-wheel">Full wheel →</a>
        </div>
        <div id="wheel-warning" style="padding:10px 20px 0"></div>
        <div class="d3-seg-wrap"><div id="wheel-toggle" class="d3-seg" role="tablist"></div></div>
        <p class="d3-caption" id="wheel-caption"></p>
        <div class="d3-wheelwrap">
          <div id="wheel-host" class="d3-anim"></div>
          <svg id="wheel-overlay" class="d3-overlay" viewBox="0 0 480 420" preserveAspectRatio="xMidYMid meet" aria-hidden="true"></svg>
        </div>
        <div class="d3-ringleg">
          <span class="d3-ringleg-dots"><i style="width:5px;height:5px"></i><i style="width:7px;height:7px"></i><i style="width:9px;height:9px"></i><i style="width:11px;height:11px"></i><i style="width:13px;height:13px"></i></span>
          <span id="wheel-leg-text">1 ring = minimal · 5 rings = intensive</span>
        </div>
        <div id="wheel-tops" class="d3-tops"></div>
        <div id="wheel-detail" class="d3-detail" style="display:none"></div>
        <div style="padding:4px 20px 18px">
          <div style="background:var(--amber-bg);border:1px solid #f3e2c0;border-radius:12px;padding:10px 12px">
            <p style="color:var(--amber);font-size:11px;line-height:1.45;margin:0"><strong>Preliminary profile — not a diagnosis.</strong> Generated from your passport answers. Confidence reflects how many related questions you've completed. For any concerns, speak with a qualified professional.</p>
          </div>
        </div>
      </div>

      <!-- Recent reports -->
      <div class="card cu-rev" style="--d:.26s">
        <div class="card-head"><span class="card-title">Recent reports</span><a class="card-link" href="/documents">View all →</a></div>
        <div id="d-docs"><div style="color:var(--muted);font-size:.82rem;padding:14px 20px">Loading…</div></div>
        <div class="card-foot">
          <a class="btn btn-primary btn-sm" href="/documents">Upload document</a>
          <a class="btn btn-ghost btn-sm" href="/documents">Open vault</a>
        </div>
      </div>

      <!-- Activity -->
      <div class="card cu-rev" style="--d:.32s">
        <div class="card-head"><span class="card-title">Recent activity</span></div>
        <div class="timeline" id="d-activity"><div style="color:var(--muted);font-size:.82rem;padding:6px 0">Loading…</div></div>
      </div>
    </div>

    <!-- ===== RIGHT ===== -->
    <div class="col">

      <!-- Momentum -->
      <div class="card cu-rev" style="--d:.22s">
        <div class="card-head"><span class="card-title">This week</span><a class="card-link" href="/child/growth">Open growth →</a></div>
        <div class="d3-mo">
          <div class="d3-mo-big">
            <span class="cu-blob" style="--blob:#E8F6F0;color:#0E8F66;width:40px;height:40px"><svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.6l1.7 4.4 4.6.4-3.5 3 .9 4.5L8 11.9 3.8 14.3l.9-4.5L1.2 6.4l4.6-.4z"/></svg></span>
            <div><div class="d3-mo-num" id="mo-count">—</div><div class="d3-mo-lab" id="mo-lab">wins this week</div></div>
          </div>
          <div class="d3-days" id="mo-days" aria-label="Wins over the last 7 days"></div>
          <p class="d3-streak" id="mo-streak"></p>
        </div>
        <div id="d-wins" style="padding:0 20px 8px"><div style="color:var(--muted);font-size:.82rem;padding:8px 0">Loading…</div></div>
        <div class="card-foot">
          <a class="btn btn-ghost btn-sm" href="/child/growth">Add a moment</a>
          <a class="btn btn-ghost btn-sm" href="/child/growth">All wins</a>
        </div>
      </div>

      <!-- Next steps -->
      <div class="card cu-rev" style="--d:.26s">
        <div class="card-head"><span class="card-title">Next steps</span><span class="ai-badge"><svg width="10" height="10" viewBox="0 0 16 16" fill="var(--violet-700)"><path d="M8 1.5l1.5 4.2L14 7.2l-4.5 1.5L8 13l-1.5-4.3L2 7.2l4.5-1.5z"/></svg>Personalized</span></div>
        <div id="d-steps" style="padding:6px 20px 8px"></div>
        <div class="ai-foot"><span style="font-size:.68rem;color:var(--faint)" id="steps-note">Based on this profile — the list updates as you go.</span></div>
      </div>

      <!-- Funding overview -->
      <div class="card cu-rev" style="--d:.3s">
        <div class="card-head"><span class="card-title">Funding overview</span><a class="card-link" href="/funding">Open navigator →</a></div>
        <div class="fund-stats" id="d-fund-stats"></div>
        <div id="d-fund-rows"></div>
      </div>

      <!-- Next workshop -->
      <div class="card cu-rev" style="--d:.34s">
        <div class="card-head"><span class="card-title">Next workshop</span><a class="card-link" href="/resources/workshops">All workshops →</a></div>
        <div id="d-workshop"><div style="color:var(--muted);font-size:.82rem;padding:14px 20px">Loading…</div></div>
      </div>

      <!-- Explore the profile -->
      <div class="card cu-rev" style="--d:.38s">
        <div class="card-head"><span class="card-title" id="d-explore-title">Explore the profile</span></div>
        <div class="d3-explore">
          <a href="/child"><span class="cu-blob" style="--blob:#EDE9FE;color:#6D28D9;width:34px;height:34px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="8" cy="5.2" r="2.6"/><path d="M2.8 13.5c.6-2.8 2.6-4.2 5.2-4.2s4.6 1.4 5.2 4.2"/></svg></span>Overview</a>
          <a href="/child/journey"><span class="cu-blob" style="--blob:#FBF2E2;color:#A8650A;width:34px;height:34px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 13.5c3.5 0 3.5-4 7-4s3.5-4 3-7"/><circle cx="3" cy="13.5" r="1.3" fill="currentColor" stroke="none"/><path d="M10.6 2.5H13v2.4"/></svg></span>Journey</a>
          <a href="/child/support-wheel"><span class="cu-blob" style="--blob:#F9EDF1;color:#B14A66;width:34px;height:34px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="8" cy="8" r="5.6"/><path d="M8 2.4v11.2M2.4 8h11.2M4.2 4.2l7.6 7.6M11.8 4.2l-7.6 7.6"/></svg></span>Wheel</a>
          <a href="/child/growth"><span class="cu-blob" style="--blob:#E8F6F0;color:#0E8F66;width:34px;height:34px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2.5 13V3M2.5 13h11M5.5 10l2-2.6 2 1.4 2.7-4"/></svg></span>Growth</a>
          <a href="/child/assessments"><span class="cu-blob" style="--blob:#E6F4F2;color:#0E8C82;width:34px;height:34px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 1.8h5.2L12.4 5v9.2H4z"/><path d="M9 1.8V5h3.4"/></svg></span>Records</a>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    /* ============ HERO ============ */
    .d3-hero{position:relative;overflow:hidden;border-radius:22px;padding:24px 26px 20px;color:var(--ink);background:linear-gradient(120deg,#FDFCFF 0%,#F4EFFE 46%,#EFF9F6 100%);border:1px solid var(--violet-100);box-shadow:var(--shadow)}
    .d3-hero::before{content:"";position:absolute;top:-90px;right:-60px;width:340px;height:300px;background:radial-gradient(closest-side,rgba(139,92,246,.13),transparent 72%);border-radius:50%;pointer-events:none}
    .d3-hero::after{content:"";position:absolute;bottom:-120px;left:6%;width:320px;height:260px;background:radial-gradient(closest-side,rgba(94,234,212,.13),transparent 72%);border-radius:50%;pointer-events:none}
    .d3-spark{position:absolute;font-style:normal;font-size:12px;color:#A78BFA;pointer-events:none;animation:d3Twinkle 2.6s ease infinite}
    .d3-spark.s2{font-size:9px;color:#5EEAD4;animation-delay:.9s}
    .d3-spark.s3{font-size:10px;color:#F9A8D4;animation-delay:1.6s}
    @keyframes d3Twinkle{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.3);opacity:1}}
    .d3-hero-main{position:relative;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap}
    .d3-hello h1{font-family:var(--display);font-size:1.7rem;font-weight:700;letter-spacing:-.02em;margin:0;line-height:1.15}
    .d3-sub{font-size:.9rem;color:var(--ink-2);margin:7px 0 0}
    .d3-date{font-size:.72rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--faint);margin:6px 0 0}
    .d3-hero-side{display:flex;flex-direction:column;align-items:flex-end;gap:12px}
    .d3-chip{display:inline-flex;align-items:center;gap:10px;background:var(--card);border:1px solid var(--line);border-radius:9999px;padding:6px 14px 6px 7px;text-decoration:none;color:var(--ink);box-shadow:var(--shadow);transition:border-color .15s,transform .15s}
    .d3-chip:hover{border-color:#DDD6FE;transform:translateY(-1px)}
    .d3-chip-av{width:32px;height:32px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:linear-gradient(135deg,#A78BFA,#6D28D9);color:#fff;display:grid;place-items:center;font-family:var(--display);font-weight:700;font-size:.95rem;flex-shrink:0;animation:d3Morph 9s ease-in-out infinite alternate}
    @keyframes d3Morph{0%{border-radius:46% 54% 58% 42%/52% 44% 56% 48%}100%{border-radius:56% 44% 44% 56%/46% 56% 44% 54%}}
    .d3-chip-meta{display:flex;flex-direction:column;line-height:1.2;min-width:0}
    .d3-chip-meta b{font-size:.88rem;font-weight:700}
    .d3-chip-meta span{font-size:.68rem;color:var(--muted)}
    .d3-ring-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end}
    .d3-ring{width:50px;height:50px;position:relative;flex-shrink:0}
    .d3-ring svg{transform:rotate(-90deg)}
    .pctw{position:absolute;inset:0;display:grid;place-items:center;font-size:.68rem;font-weight:700;color:var(--ink)}
    .d3-ring-label{font-size:.68rem;color:var(--muted);line-height:1.3}
    .d3-ring-label b{display:block;color:var(--ink);font-size:.76rem}
    .d3-hero-btns{display:flex;gap:8px;margin-left:6px}
    .d3-btn-solid{background:var(--violet-700);color:#fff;font-size:.78rem;font-weight:700;padding:7px 14px;border-radius:9999px;text-decoration:none;transition:filter .15s,transform .15s}
    .d3-btn-solid:hover{filter:brightness(1.08);transform:translateY(-1px)}
    .d3-btn-line{border:1px solid var(--line-2);background:var(--card);color:var(--ink-2);font-size:.78rem;font-weight:600;padding:7px 14px;border-radius:9999px;text-decoration:none;transition:border-color .15s,color .15s}
    .d3-btn-line:hover{border-color:var(--violet-500);color:var(--violet-700)}
    .d3-guide{position:relative;display:flex;align-items:flex-start;gap:9px;background:linear-gradient(135deg,var(--violet-50),#F9F7FE 60%,var(--violet-50));border:1px solid var(--violet-100);border-radius:13px;padding:10px 14px;margin-top:16px}
    .d3-guide p{flex:1;font-size:.84rem;color:#5b21b6;line-height:1.5;margin:0;min-width:0}
    .d3-guide-link{font-size:.78rem;font-weight:700;color:var(--violet-700);text-decoration:none;white-space:nowrap;align-self:center}

    /* ============ TODAY STRIP ============ */
    .d3-today{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:14px}
    .t3{display:flex;flex-direction:column;padding:15px 17px 13px}
    .t3-head{display:flex;align-items:center;gap:9px;margin-bottom:9px}
    .t3-blob{width:30px;height:30px}
    .t3-title{font-size:.8rem;font-weight:700;letter-spacing:-.01em;color:var(--ink)}
    .t3-pill{font-size:.62rem;font-weight:700;padding:2px 8px;border-radius:9999px;margin-left:auto;white-space:nowrap}
