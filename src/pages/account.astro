      /* ---------- HERO ---------- */
      const g1 = String((data.household && data.household.g1name) || "").replace(/\s*\([^)]*\)\s*$/, "").trim();
      if (g1) setGreeting(g1);
      $("h-avatar").textContent = (first || id.name || "·")[0].toUpperCase();
