    const getRawSession = () => { try { return JSON.parse(localStorage.getItem("ua_session") || "null"); } catch { return null; } };
    const isValid = (s) => s && s.access_token && Math.floor(Date.now() / 1000) < (s.expires_at || 0) - 60;
    const authHeaders = (t) => ({ apikey: ANON, Authorization: "Bearer " + t, "Content-Type": "application/json" });
    async function getValidSession() {
      let s = getRawSession();
      if (isValid(s)) return s;
      if (s && s.refresh_token) {
        const r = await fetch(UA_URL + "/auth/v1/token?grant_type=refresh_token", { method: "POST", headers: { apikey: ANON, "Content-Type": "application/json" }, body: JSON.stringify({ refresh_token: s.refresh_token }) });
