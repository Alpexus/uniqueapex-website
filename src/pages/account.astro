    ];
    function setGreeting(name) {
      const now = new Date(), h = now.getHours();
      const part = h < 5 ? "Good night" : h < 12 ? "Good morning" : h < 18 ? "Good afternoon" : "Good evening";
      const emoji = h >= 5 && h < 18 ? "☀️" : "🌙";
