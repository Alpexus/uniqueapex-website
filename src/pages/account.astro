      if (reduceMotion) $("d-pct").textContent = comp.pct + "%";
      else { let t0 = null; const tick = (ts) => { if (!t0) t0 = ts; const pr = Math.min(1, (ts - t0) / 900), e = 1 - Math.pow(1 - pr, 3); $("d-pct").textContent = Math.round(comp.pct * e) + "%"; if (pr < 1) requestAnimationFrame(tick); }; requestAnimationFrame(tick); }
      const left = comp.total - comp.done;
      $("d-remaining").textContent = left === 0 ? "Complete ✦" : left + " section" + (left === 1 ? "" : "s") + " left";
      if (left === 0) $("d-edit").textContent = "Edit passport";

      /* ---------- GUIDANCE LINE (in the hero) ---------- */
      const scored = scoreWheel(data);
      const guide = buildFamilyGuidance(data, scored, first || "Your child");
      if (guide.length) {
        $("g-guide-text").textContent = guide.slice(0, 2).join(" ");
        $("g-guide").style.display = "flex";
      }

      /* ================= SUPPORT WHEEL — support-wheel-tab logic ================= */
      const scoredCount = DOMAINS.filter((n) => scored[n].score != null).length;
      const wheelDeep = (nm) => "/child/support-wheel?domain=" + encodeURIComponent(nm);
      if (first) $("wheel-title").textContent = first + "'s support wheel";
      let mode = "needs";
      let sel = 0;
      for (let i = 0; i < DOMAINS.length; i++) { if (scored[DOMAINS[i]].score != null) { sel = i; break; } }

      function levelInfo(score) {
        if (score == null) return { label: "Not enough data", bg: "#F4F3F8", fg: "#7B7491", seg: "#D8D3E6" };
        const b = scoreToBand(score);
        if (b.key === "minimal" || b.key === "low") return { label: b.label, bg: "#E8F6F0", fg: "#0E8F66", seg: "#0E8F66" };
        if (b.key === "high" || b.key === "intensive") return { label: b.label, bg: "#EDE9FE", fg: "#6D28D9", seg: "#7C3AED" };
        return { label: b.label, bg: "#FBF2E2", fg: "#A8650A", seg: "#D97706" };
      }

      function renderToggle() {
        const seg = $("wheel-toggle");
        seg.innerHTML = `<span class="thumb"></span>` + ["needs", "strengths"].map((m) =>
          `<button data-mode="${m}" class="${m === mode ? "on" : ""}" role="tab" aria-selected="${m === mode}">${m === "needs" ? "Support needs" : "Strengths"}</button>`).join("");
        const onBtn = seg.querySelector("button.on"), thumb = seg.querySelector(".thumb");
        requestAnimationFrame(() => { thumb.style.left = onBtn.offsetLeft + "px"; thumb.style.width = onBtn.offsetWidth + "px"; });
        seg.querySelectorAll("button").forEach((b) =>
          b.addEventListener("click", () => { mode = b.dataset.mode; renderToggle(); renderWheel(); renderDetail(); }));
        $("wheel-caption").innerHTML = mode === "strengths"
          ? "Fuller petals mean <strong>stronger</strong> areas — tap one for detail."
          : "Fuller petals mean <strong>more support</strong> is helpful — tap one for detail.";
        $("wheel-leg-text").textContent = mode === "strengths"
          ? "1 ring = emerging · 5 rings = shining"
          : "1 ring = minimal support · 5 rings = intensive support";
      }

      function renderWheel() {
        const host = $("wheel-host");
        host.classList.remove("play");
        host.innerHTML = generateWheelSVG(scored, mode);
        void host.offsetWidth; /* restart the draw-in */
        host.classList.add("play");
        /* keyboard access on the base petals */
        host.querySelectorAll("[data-domain]").forEach((g) => {
          g.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              const qi = DOMAINS.indexOf(g.dataset.domain);
              if (qi > -1) { sel = qi; renderDetail(); buildOverlay(); }
            }
          });
