---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Invite Only">
  <div class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md text-center">

      <a href="/" class="inline-flex items-center gap-2 mb-6">
        <img src="/Logo.png" alt="UniqueApex" class="h-10 w-auto" />
        <span class="text-lg font-bold text-slate-800">Unique<span class="text-violet-700">Apex</span></span>
      </a>

      <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">
        <h1 class="text-2xl font-bold text-slate-800">We're invite-only right now</h1>
        <p class="text-slate-500 mt-3 leading-relaxed">
          UniqueApex is in its Montréal pilot. Join the waitlist and we'll reach out with an
          invitation as soon as a spot opens for your family.
        </p>
        <a href="/waitlist" class="mt-6 inline-block w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-3.5 rounded-full transition-colors">
          Join the waitlist
        </a>
        <p class="text-center text-sm text-slate-500 mt-4">
          Already invited?
          <a href="/login" class="text-violet-700 font-semibold hover:underline">Sign in →</a>
        </p>
      </div>

    </div>
  </div>
</Layout>
