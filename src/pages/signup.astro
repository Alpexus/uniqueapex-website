---
import Layout from "@/layouts/Layout.astro";

const inputCls = "w-full px-4 py-3 border border-slate-200 placeholder:text-slate-400 rounded-xl outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400 bg-white";
const chip = "flex items-center gap-3 cursor-pointer bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-violet-300 transition-colors text-slate-600 text-sm";
---

<Layout title="Create Account">
  <!-- Cloudflare Turnstile -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

  <div class="max-w-2xl mx-auto px-6 py-12">

    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 mb-6">
        <img src="/Logo.png" alt="UniqueApex" class="h-10 w-auto" />
        <span class="text-lg font-bold text-slate-800">Unique<span class="text-violet-700">Apex</span></span>
      </a>
      <h1 class="text-3xl font-bold text-slate-800">Create your account</h1>
      <p class="text-slate-500 mt-2">Tell us about yourself and your child so we can start helping right away.</p>
    </div>

    <!-- Success screen (hidden until signup succeeds) -->
    <div id="signup-success" style="display:none" class="bg-violet-50 border border-violet-200 rounded-2xl p-8 text-center">
      <div class="text-4xl mb-3">📬</div>
      <h2 class="text-2xl font-bold text-slate-800">Check your email</h2>
      <p class="text-slate-600 mt-3">
        We sent a confirmation link to <span id="success-email" class="font-semibold text-violet-700"></span>.
        Click it to activate your account, then sign in.
      </p>
      <p class="text-sm text-slate-400 mt-4">
        Don't see it? Check your spam folder. The link can take a minute to arrive.
      </p>
      <a href="/login" class="inline-block mt-6 bg-violet-700 hover:bg-violet-800 text-white font-semibold px-8 py-3 rounded-full transition-colors">
        Go to sign in →
      </a>
    </div>

    <form id="signup-form" novalidate class="space-y-6">

      <!-- Parent info -->
      <div class="bg-slate-50 rounded-2xl p-6 space-y-4">
        <h2 class="text-base font-bold text-slate-800">About you</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">First name *</label>
            <input name="parentFirst" type="text" class={inputCls} placeholder="Your first name" />
            <p id="err-parentFirst" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Required.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Last name *</label>
            <input name="parentLast" type="text" class={inputCls} placeholder="Your last name" />
            <p id="err-parentLast" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Required.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Email address *</label>
            <input name="email" type="email" class={inputCls} placeholder="you@example.com" />
            <p id="err-email" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Please enter a valid email.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Phone (optional)</label>
            <input name="phone" type="tel" class={inputCls} placeholder="(514) 555-0100" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-600 mb-2">Password *</label>
            <input id="pw-input" name="password" type="password" class={inputCls} placeholder="Create a strong password" />
            <!-- Strength bar -->
            <div class="mt-2 h-1.5 w-full bg-slate-100 rounded-full overflow-hidden">
              <div id="pw-bar" class="h-full rounded-full transition-all duration-300" style="width:0%;background:#ef4444"></div>
            </div>
            <p id="pw-label" class="text-xs mt-1 text-slate-400"></p>
            <!-- Requirements -->
            <ul id="pw-reqs" class="mt-2 grid grid-cols-2 gap-1 text-xs" style="display:none">
              <li id="req-len" class="text-slate-400">✗ At least 8 characters</li>
              <li id="req-upper" class="text-slate-400">✗ One uppercase letter</li>
              <li id="req-lower" class="text-slate-400">✗ One lowercase letter</li>
              <li id="req-num" class="text-slate-400">✗ One number</li>
            </ul>
            <p id="err-password" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Password doesn't meet requirements.</p>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-600 mb-2">Confirm password *</label>
            <input name="confirm" type="password" class={inputCls} placeholder="Same password again" />
            <p id="err-confirm" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Passwords don't match.</p>
          </div>
        </div>
      </div>

      <!-- Child info -->
      <div class="bg-slate-50 rounded-2xl p-6 space-y-4">
        <div>
          <h2 class="text-base font-bold text-slate-800">About your child</h2>
          <p class="text-sm text-slate-500 mt-0.5">This creates your child's initial profile. You can complete it in detail later.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Child's first name *</label>
            <input name="childFirst" type="text" class={inputCls} placeholder="First name" />
            <p id="err-childFirst" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Required.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Child's last name</label>
            <input name="childLast" type="text" class={inputCls} placeholder="Last name (optional)" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Date of birth</label>
            <input name="childDob" type="date" class={inputCls} />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">City / region *</label>
            <input name="city" type="text" class={inputCls} placeholder="e.g. Montréal, QC" />
            <p id="err-city" style="display:none;color:#ef4444;font-size:12px;margin-top:4px">Required for matching.</p>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-600 mb-2">Primary language at home</label>
            <div class="flex gap-3 flex-wrap">
              {["English","French","Both"].map((o) => (
                <label class={chip}><input type="radio" name="language" value={o} class="accent-violet-700" /> {o}</label>
              ))}
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-600 mb-2">Areas of concern (select any)</label>
          <div class="grid sm:grid-cols-3 gap-2">
            {["Autism","ADHD","Speech / Language","Developmental Delay","Anxiety","Other"].map((o) => (
              <label class={chip}><input type="checkbox" name="diagnoses" value={o} class="accent-violet-700 w-4 h-4" /> {o}</label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-600 mb-2">Services you're looking for (select any)</label>
          <div class="grid sm:grid-cols-2 gap-2">
            <label class={chip}><input type="checkbox" name="service_slp" value="Speech Therapy" class="accent-violet-700 w-4 h-4" /> Speech therapy (SLP)</label>
            <label class={chip}><input type="checkbox" name="service_ot" value="Occupational Therapy" class="accent-violet-700 w-4 h-4" /> Occupational therapy (OT)</label>
            <label class={chip}><input type="checkbox" name="service_aba" value="ABA / Behaviour" class="accent-violet-700 w-4 h-4" /> ABA / Behaviour therapy</label>
            <label class={chip}><input type="checkbox" name="service_other" value="Other" class="accent-violet-700 w-4 h-4" /> Other</label>
          </div>
        </div>
      </div>

      <!-- Honeypot — hidden from humans, bots fill it in -->
      <div style="position:absolute;left:-9999px;top:-9999px" aria-hidden="true">
        <label>Company<input name="company" type="text" tabindex="-1" autocomplete="off" /></label>
      </div>

      <!-- Turnstile widget -->
      <div class="flex justify-center">
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADlSug3Xc8zF8CaJ"></div>
      </div>

      <p class="text-xs text-slate-400 text-center leading-relaxed">
        Your information is stored securely and only accessible by you. We never share personal data with third parties.
      </p>

      <p id="err-general" style="display:none;color:#ef4444;font-size:14px;text-align:center"></p>

      <button type="submit" id="signup-btn" class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-3.5 rounded-full transition-colors text-base">
        Create my account
      </button>

      <p class="text-center text-sm text-slate-500">
        Already have an account?
        <a href="/login" class="text-violet-700 font-semibold hover:underline">Sign in →</a>
      </p>

    </form>
  </div>
</Layout>

<script is:inline>
  var UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
  var UA_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";

  function getSession(){try{return JSON.parse(localStorage.getItem("ua_session")||"null");}catch{return null;}}
  function isValid(s){return s&&s.access_token&&Math.floor(Date.now()/1000)<(s.expires_at||0)-60;}

  // If already signed in, skip the form.
  var existing=getSession();
  if(isValid(existing))window.location.href="/account";

  // Password strength
  var pwInput=document.getElementById("pw-input");
  var pwBar=document.getElementById("pw-bar");
  var pwLabel=document.getElementById("pw-label");
  var pwReqs=document.getElementById("pw-reqs");

  function checkPw(pw){
    return {
      len: pw.length>=8,
      upper: /[A-Z]/.test(pw),
      lower: /[a-z]/.test(pw),
      num: /[0-9]/.test(pw)
    };
  }
  function getStrength(r){ var n=Object.values(r).filter(Boolean).length; if(n<=1)return{label:"Weak",color:"#ef4444",pct:"25%"}; if(n===2)return{label:"Fair",color:"#f59e0b",pct:"50%"}; if(n===3)return{label:"Good",color:"#84cc16",pct:"75%"}; return{label:"Strong",color:"#22c55e",pct:"100%"}; }

  function setReq(id,ok){ var el=document.getElementById(id); if(!el)return; el.textContent=(ok?"✓ ":"✗ ")+el.textContent.slice(2); el.style.color=ok?"#22c55e":"#94a3b8"; }

  pwInput.addEventListener("input",function(){
    var pw=pwInput.value;
    if(!pw){ pwBar.style.width="0%"; pwLabel.textContent=""; pwReqs.style.display="none"; return; }
    pwReqs.style.display="grid";
    var r=checkPw(pw);
    var s=getStrength(r);
    pwBar.style.width=s.pct; pwBar.style.background=s.color;
    pwLabel.textContent=s.label; pwLabel.style.color=s.color;
    setReq("req-len",r.len); setReq("req-upper",r.upper);
    setReq("req-lower",r.lower); setReq("req-num",r.num);
  });

  function val(name){var el=document.querySelector('[name="'+name+'"]');return el?el.value.trim():"";}
  function getChecks(name){var els=document.querySelectorAll('input[name="'+name+'"]:checked');var o=[];for(var i=0;i<els.length;i++)o.push(els[i].value);return o;}
  function getRadio(name){var el=document.querySelector('input[name="'+name+'"]:checked');return el?el.value:"";}
  function getServiceVal(name){var box=document.querySelector('input[name="'+name+'"]');return (box&&box.checked)?box.value:null;}
  function showErr(id,msg){var el=document.getElementById(id);if(el){el.textContent=msg;el.style.display="block";}}
  function hideErr(id){var el=document.getElementById(id);if(el)el.style.display="none";}
  function clearErrors(){["err-parentFirst","err-parentLast","err-email","err-password","err-confirm","err-childFirst","err-city","err-general"].forEach(hideErr);}

  function resetTurnstile(){ try{ if(window.turnstile) window.turnstile.reset(); }catch(e){} }

  document.getElementById("signup-form").addEventListener("submit",function(e){
    e.preventDefault();
    clearErrors();
    var ok=true;

    var parentFirst=val("parentFirst"), parentLast=val("parentLast");
    var email=val("email"), password=val("password"), confirm=val("confirm");
    var childFirst=val("childFirst"), city=val("city");

    if(!parentFirst){showErr("err-parentFirst","Required.");ok=false;}
    if(!parentLast){showErr("err-parentLast","Required.");ok=false;}
    if(!email||email.indexOf("@")===-1){showErr("err-email","Please enter a valid email.");ok=false;}
    if(password.length<8||!checkPw(password).upper||!checkPw(password).lower||!checkPw(password).num){showErr("err-password","Password doesn't meet requirements.");ok=false;}
    if(password!==confirm){showErr("err-confirm","Passwords don't match.");ok=false;}
    if(!childFirst){showErr("err-childFirst","Required.");ok=false;}
    if(!city){showErr("err-city","Required for matching.");ok=false;}
    if(!ok)return;

    // Turnstile token (the widget must have loaded + verified)
    var token = (window.turnstile ? window.turnstile.getResponse() : "") || "";
    if(!token){ showErr("err-general","Please complete the verification below and try again."); return; }

    var btn=document.getElementById("signup-btn");
    btn.disabled=true; btn.textContent="Creating account...";

    var body={
      turnstileToken: token,
      company: val("company"),
      email: email,
      password: password,
      parentFirst: parentFirst,
      parentLast: parentLast,
      phone: val("phone"),
      childFirst: childFirst,
      childLast: val("childLast"),
      childDob: val("childDob"),
      city: city,
      language: getRadio("language"),
      diagnoses: getChecks("diagnoses"),
      service_slp: getServiceVal("service_slp"),
      service_ot: getServiceVal("service_ot"),
      service_aba: getServiceVal("service_aba"),
      service_other: getServiceVal("service_other")
    };

    // ONE call -> edge function (verifies Turnstile, creates user + passport).
    // No session comes back (Confirm email is ON) -- user must click the email link.
    fetch(UA_URL+"/functions/v1/signup-submit",{
      method:"POST",
      headers:{
        "apikey":UA_KEY,
        "Authorization":"Bearer "+UA_KEY,
        "Content-Type":"application/json"
      },
      body:JSON.stringify(body)
    })
    .then(function(r){return r.json().then(function(d){return{ok:r.ok,data:d};});})
    .then(function(res){
      if(!res.ok || !res.data || !res.data.ok){
        var msg=(res.data&&res.data.error)?friendly(res.data.error):"Something went wrong. Please try again.";
        showErr("err-general",msg);
        btn.disabled=false; btn.textContent="Create my account";
        resetTurnstile();
        return;
      }
      // Success -> show "check your email" screen
      document.getElementById("signup-form").style.display="none";
      document.getElementById("success-email").textContent=email;
      document.getElementById("signup-success").style.display="block";
      window.scrollTo({top:0,behavior:"smooth"});
    })
    .catch(function(){
      showErr("err-general","Something went wrong. Please try again.");
      btn.disabled=false; btn.textContent="Create my account";
      resetTurnstile();
    });
  });

  function friendly(code){
    var c=String(code).toLowerCase();
    if(c.indexOf("already")>-1||c.indexOf("registered")>-1) return "An account with this email already exists. Try signing in instead.";
    if(c==="verification_failed") return "Verification failed. Please complete the check below and try again.";
    if(c==="weak_password") return "Please choose a stronger password (at least 8 characters).";
    if(c==="bad_email") return "Please enter a valid email address.";
    return code;
  }
</script>