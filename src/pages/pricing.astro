---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const features = [
  { label: "Child profiles", free: "1", monthly: "Unlimited", concierge: "Unlimited" },
  { label: "Outreach batches", free: "1 per service", monthly: "Unlimited", concierge: "Unlimited" },
  { label: "Automatic provider matching", free: true, monthly: true, concierge: true },
  { label: "Waitlist status tracking", free: true, monthly: true, concierge: true },
  { label: "English & French support", free: true, monthly: true, concierge: true },
  { label: "Community access", free: true, monthly: true, concierge: true },
  { label: "Expert workshops", free: false, monthly: true, concierge: true },
  { label: "Documentation tools", free: false, monthly: true, concierge: true },
  { label: "Priority support", free: false, monthly: true, concierge: true },
  { label: "Dedicated human coordinator", free: false, monthly: false, concierge: true },
  { label: "Provider follow-ups handled", free: false, monthly: false, concierge: true },
  { label: "Cross-service orchestration", free: false, monthly: false, concierge: true },
  { label: "Documentation support", free: false, monthly: false, concierge: true },
];
---

<Layout title="Pricing">
  <Container>

    <!-- Hero -->
    <div class="text-center max-w-2xl mx-auto mt-16 mb-24">
      <p class="text-2xl font-semibold text-violet-700 uppercase tracking-wide">Pricing</p>
      <h1 class="text-5xl font-bold text-slate-800 leading-tight mt-3">
        Support that fits <span class="text-violet-700">where you are</span>
      </h1>
      <p class="text-slate-600 leading-relaxed text-lg mt-6">
        Every family is at a different stage. UniqueApex meets you there — whether you are just getting started or need someone to take over completely.
      </p>
    </div>

    <!-- Plan 1: Free -->
    <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
      <div class="space-y-6">
        <span class="inline-block bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1 rounded-full">Free Forever</span>
        <h2 class="text-4xl font-bold text-slate-800 leading-tight">
          Just getting started? <span class="text-violet-700">We have you covered.</span>
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          You should not have to pay just to get matched with the right providers. Submit one profile, and UniqueApex reaches out to verified speech, OT, and behavioural therapy providers on your behalf — automatically.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> One child profile</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> One outreach batch per service type</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Automatic provider matching</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Waitlist status tracking</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> English & French support</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Community access</li>
        </ul>
        <div class="flex items-center gap-4 pt-2">
          <a href="/waitlist" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base">Start for Free</a>
          <span class="text-3xl font-bold text-slate-800">$0</span>
        </div>
      </div>
      <div class="flex items-center justify-center">
        <img src="/pricing-free.png" alt="Free plan illustration" class="w-full max-w-[460px]" />
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-100 mb-24"></div>

    <!-- Plan 2: Monthly -->
    <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
      <div class="flex items-center justify-center">
        <img src="/pricing-monthly.png" alt="Monthly plan illustration" class="w-full max-w-[460px]" />
      </div>
      <div class="space-y-6">
        <span class="inline-block bg-violet-700 text-white text-sm font-semibold px-4 py-1 rounded-full">Most Popular · $19/mo</span>
        <h2 class="text-4xl font-bold text-slate-800 leading-tight">
          Actively coordinating care? <span class="text-violet-700">Get more tools.</span>
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          When you are juggling multiple providers, services, and waitlists, the free tier is not enough. The monthly plan gives you unlimited outreach, expert workshops, and priority support — so you stay on top of everything.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Multiple child profiles</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Unlimited outreach batches</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Expert workshops access</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Peer community access</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Documentation tools</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Priority support</li>
        </ul>
        <div class="flex items-center gap-4 pt-2">
          <a href="/waitlist" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base shadow-md">Start Monthly Plan</a>
          <span class="text-3xl font-bold text-slate-800">$19<span class="text-lg text-slate-400">/mo</span></span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-100 mb-24"></div>

    <!-- Plan 3: Concierge -->
    <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
      <div class="space-y-6">
        <span class="inline-block bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1 rounded-full">One-Time · $99</span>
        <h2 class="text-4xl font-bold text-slate-800 leading-tight">
          Need someone to take over? <span class="text-violet-700">That is what we are here for.</span>
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          Sometimes you just need someone in your corner. Our Concierge service assigns you a dedicated human coordinator who handles everything — follow-ups, documentation, cross-service orchestration — so you can focus entirely on your child.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Dedicated human coordinator</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Provider follow-ups handled for you</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Cross-service orchestration</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Documentation support</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> Multi-service coordination</li>
          <li class="flex items-center gap-3 text-slate-700"><span class="text-violet-600 font-bold">✓</span> One engagement included</li>
        </ul>
        <div class="flex items-center gap-4 pt-2">
          <a href="/contact" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base">Start with Concierge</a>
          <span class="text-3xl font-bold text-slate-800">$99<span class="text-lg text-slate-400"> one-time</span></span>
        </div>
      </div>
      <div class="flex items-center justify-center">
        <img src="/pricing-concierge.png" alt="Concierge plan illustration" class="w-full max-w-[460px]" />
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-100 mb-24"></div>

    <!-- Comparison Table -->
    <div class="mb-24">
      <div class="text-center mb-12">
        <p class="text-2xl font-semibold text-violet-700 uppercase tracking-wide">Compare Plans</p>
        <h2 class="text-4xl font-bold mt-3 text-slate-800">See what's included</h2>
      </div>

      <div class="relative mt-8">
        <div class="absolute -top-5 z-20" style="left: 65.5%; transform: translateX(-50%);">
          <span class="inline-block bg-violet-700 text-white text-sm font-bold px-8 py-3 rounded-full shadow-lg">MOST POPULAR</span>
        </div>
        <div class="overflow-x-auto rounded-3xl border border-slate-100 shadow-sm">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-100">
              <th class="text-left py-8 px-8 text-slate-400 font-medium w-2/5"></th>
              <th class="text-center py-8 px-8 align-bottom">
                <div class="text-slate-800 font-bold text-xl">Free</div>
                <div class="text-lg font-semibold text-slate-600 mt-1">$0</div>
              </th>
              <th class="text-center py-8 px-8 bg-violet-50 align-bottom">
                <div class="text-violet-700 font-bold text-xl">Monthly</div>
                <div class="text-lg font-semibold text-slate-600 mt-1">$19/mo</div>
              </th>
              <th class="text-center py-8 px-8 align-bottom">
                <div class="text-slate-800 font-bold text-xl">Concierge</div>
                <div class="text-lg font-semibold text-slate-600 mt-1">$99 one-time</div>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {features.map((row) => (
              <tr class="hover:bg-slate-50 transition-colors duration-150">
                <td class="py-5 px-8 text-slate-700 font-medium text-base">{row.label}</td>
                <td class="py-5 px-8 text-center">
                  {typeof row.free === 'boolean'
                    ? row.free
                      ? <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-violet-100 text-violet-700 font-bold text-sm">✓</span>
                      : <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-300 font-bold text-sm">✕</span>
                    : <span class="text-slate-700 text-base font-semibold">{row.free}</span>
                  }
                </td>
                <td class="py-5 px-8 text-center bg-violet-50">
                  {typeof row.monthly === 'boolean'
                    ? row.monthly
                      ? <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-violet-200 text-violet-700 font-bold text-sm">✓</span>
                      : <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-300 font-bold text-sm">✕</span>
                    : <span class="text-violet-700 text-base font-semibold">{row.monthly}</span>
                  }
                </td>
                <td class="py-5 px-8 text-center">
                  {typeof row.concierge === 'boolean'
                    ? row.concierge
                      ? <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-violet-100 text-violet-700 font-bold text-sm">✓</span>
                      : <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-300 font-bold text-sm">✕</span>
                    : <span class="text-slate-700 text-base font-semibold">{row.concierge}</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="border-t border-slate-100">
              <td class="py-8 px-8"></td>
              <td class="py-8 px-8 text-center">
                <a href="/waitlist" class="inline-block border-2 border-violet-700 text-violet-700 font-semibold px-8 py-3 rounded-full hover:bg-violet-50 transition-colors text-base whitespace-nowrap">
                  Start for Free
                </a>
              </td>
              <td class="py-8 px-8 text-center bg-violet-50">
                <a href="/waitlist" class="inline-block bg-violet-700 text-white font-semibold px-8 py-3 rounded-full hover:bg-violet-800 transition-colors text-base shadow-md whitespace-nowrap">
                  Start Monthly Plan
                </a>
              </td>
              <td class="py-8 px-8 text-center">
                <a href="/contact" class="inline-block border-2 border-violet-700 text-violet-700 font-semibold px-8 py-3 rounded-full hover:bg-violet-50 transition-colors text-base whitespace-nowrap">
                  Start with Concierge
                </a>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- Bottom note -->
    <div class="text-center mt-8 mb-24">
      <p class="text-slate-400 text-sm">All prices in Canadian dollars. No hidden fees. Cancel anytime.</p>
    </div>

  </Container>
</Layout>