---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import PricingCard from "@/components/pricing.astro";

const pricing = [
  {
    name: "Free",
    price: "$0",
    popular: false,
    features: [
      "One child profile",
      "One outreach batch per service type",
      "Automatic provider matching",
      "Waitlist status tracking",
      "English & French support",
      "Community access",
    ],
    button: {
      text: "Get Started Free",
      link: "/waitlist",
    },
  },
  {
    name: "Monthly",
    price: "$19/mo",
    popular: true,
    features: [
      "Multiple child profiles",
      "Unlimited outreach batches",
      "Expert workshops access",
      "Peer community access",
      "Documentation tools",
      "Priority support",
    ],
    button: {
      text: "Start Monthly Plan",
      link: "/waitlist",
    },
  },
  {
    name: "Concierge",
    price: "$99",
    onetime: true,
    popular: false,
    features: [
      "Dedicated human coordinator",
      "Provider follow-ups handled for you",
      "Cross-service orchestration",
      "Documentation support",
      "Multi-service coordination",
      "One engagement included",
    ],
    button: {
      text: "Get Concierge Support",
      link: "/contact",
    },
  },
];
---

<Layout title="Pricing">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Simple, transparent <span class="text-violet-700">pricing</span></Fragment>
      <Fragment slot="desc">
        Choose the plan that fits where you are in your journey — start free, upgrade when you're ready.
      </Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-screen-lg mt-12">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>

    <p class="text-center text-slate-500 mt-10 text-sm">
      All prices in Canadian dollars. No hidden fees. Cancel anytime.
    </p>
  </Container>
</Layout>