---
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
import AiPanel from "@/components/AiPanel.astro";
import "@/styles/mock.css";
---
<AppFormLayout title="Documents" activeNav="documents">
  <SectionTabs section="documents" active="vault" />
  <h1 class="page-title">Document Vault</h1>
  <p class="page-sub">Reports, evaluations and letters — stored securely and ready to share.</p>

  <div class="mk-actions">
    <button class="mk-btn" type="button">＋ Upload document</button>
    <button class="mk-btn ghost" type="button">New folder</button>
  </div>

  <AiPanel section="documents" />

  <div class="mk-grid">
    <div class="mk-card"><h3>Speech &amp; Language Report</h3><p>Orthophonie evaluation</p><div class="mk-meta"><span class="mk-tag">PDF</span><span class="mk-tag muted">Mar 2025</span></div></div>
    <div class="mk-card"><h3>OT Evaluation</h3><p>Occupational therapy</p><div class="mk-meta"><span class="mk-tag">PDF</span><span class="mk-tag muted">Jan 2025</span></div></div>
    <div class="mk-card"><h3>Diagnosis Letter</h3><p>Developmental pediatrician</p><div class="mk-meta"><span class="mk-tag">PDF</span><span class="mk-tag muted">Nov 2024</span></div></div>
    <div class="mk-card"><h3>IEP / Plan d'intervention</h3><p>School plan</p><div class="mk-meta"><span class="mk-tag">DOCX</span><span class="mk-tag muted">Sep 2024</span></div></div>
  </div>

  <p class="page-sub" style="margin-top:18px">This is the wide, tabbed layout for the vault. <b>If you already have a working vault with real uploads, don't overwrite your file</b> — apply the two changes in the README to keep your upload logic and just gain the tabs + width.</p>
</AppFormLayout>
