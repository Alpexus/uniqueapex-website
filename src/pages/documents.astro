---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Documents">
  <div class="max-w-3xl mx-auto px-6 py-12">

    <div id="loading" class="text-center py-24">
      <div class="inline-block w-8 h-8 border-4 border-violet-200 border-t-violet-700 rounded-full animate-spin"></div>
    </div>

    <div id="content" style="display:none">
      <a href="/account" class="text-sm text-violet-700 font-semibold hover:underline">← Back to my account</a>

      <div class="mt-4 mb-2">
        <h1 class="text-3xl font-bold text-slate-800">Document <span class="text-violet-700">vault</span></h1>
        <p class="text-slate-500 mt-2 max-w-2xl">Keep your child's reports, assessments, and IEPs in one secure place — so you always have them on hand and can attach them to your child's profile.</p>
      </div>

      <!-- AI coming soon banner -->
      <div class="flex items-start gap-3 bg-amber-50 border border-amber-100 rounded-xl p-4 mb-6">
        <span class="shrink-0 bg-amber-100 text-amber-700 text-xs font-bold px-2.5 py-1 rounded-full mt-0.5">Coming soon</span>
        <p class="text-slate-600 text-sm leading-relaxed"><span class="font-semibold text-slate-700">AI Document Intelligence:</span> soon you'll be able to upload a diagnosis report or therapy note and get a plain-language summary, with key findings offered to auto-fill your child's passport (you always review before anything is saved). For now, this is your secure document vault.</p>
      </div>

      <!-- Upload -->
      <div class="bg-slate-50 rounded-2xl p-6 mb-6">
        <h2 class="font-bold text-slate-800 mb-3">Upload a document</h2>
        <div class="grid sm:grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">For which child? (optional)</label>
            <select id="child-select" class="w-full px-4 py-3 border border-slate-200 rounded-xl bg-white text-slate-600 outline-none focus:ring-2 focus:ring-violet-300">
              <option value="">Not specific to a child</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">File (PDF, image, or doc)</label>
            <input id="file-input" type="file" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx" class="w-full text-sm text-slate-500 file:mr-3 file:py-2.5 file:px-4 file:rounded-full file:border-0 file:bg-violet-100 file:text-violet-700 file:font-semibold file:cursor-pointer" />
          </div>
        </div>
        <button id="upload-btn" class="bg-violet-700 hover:bg-violet-800 text-white font-semibold px-6 py-2.5 rounded-full transition-colors text-sm">Upload document</button>
        <p id="upload-msg" class="text-sm mt-3" style="display:none"></p>
      </div>

      <!-- Document list -->
      <h2 class="font-bold text-slate-800 mb-3">Your documents</h2>
      <div id="doc-list" class="space-y-3"></div>
      <div id="doc-empty" style="display:none" class="bg-white border-2 border-dashed border-slate-200 rounded-2xl p-8 text-center">
        <p class="text-slate-500">No documents yet. Upload your child's reports above to keep them in one place.</p>
      </div>
      <div id="setup-notice" style="display:none" class="bg-white border border-slate-200 rounded-2xl p-6 text-center">
        <p class="text-slate-500 text-sm">The document vault is being set up. Check back shortly.</p>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  var UA_URL="https://eghqufgiudxjkbsddtnx.supabase.co";
  var UA_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
  function getSession(){try{return JSON.parse(localStorage.getItem("ua_session")||"null");}catch{return null;}}
  function setSession(d){var s=Object.assign({},d,{expires_at:Math.floor(Date.now()/1000)+(d.expires_in||3600)});localStorage.setItem("ua_session",JSON.stringify(s));return s;}
  function isValid(s){return s&&s.access_token&&Math.floor(Date.now()/1000)<(s.expires_at||0)-60;}
  function authHdr(t){return{"apikey":UA_KEY,"Authorization":"Bearer "+t,"Content-Type":"application/json"};}
  async function getValidSession(){var s=getSession();if(isValid(s))return s;if(s&&s.refresh_token){var r=await fetch(UA_URL+"/auth/v1/token?grant_type=refresh_token",{method:"POST",headers:{"apikey":UA_KEY,"Content-Type":"application/json"},body:JSON.stringify({refresh_token:s.refresh_token})});if(r.ok)return setSession(await r.json());}return null;}
  function fmtDate(iso){try{return new Date(iso).toLocaleDateString("en-CA",{year:"numeric",month:"short",day:"numeric"});}catch{return "";}}

  var SESSION=null, CHILDREN={};

  async function loadDocuments(){
    var listEl=document.getElementById("doc-list");
    var emptyEl=document.getElementById("doc-empty");
    var setupEl=document.getElementById("setup-notice");
    var r;
    try{
      r=await fetch(UA_URL+"/rest/v1/documents?select=*&order=created_at.desc",{headers:authHdr(SESSION.access_token)});
    }catch(e){ setupEl.style.display="block"; return; }
    if(!r.ok){ setupEl.style.display="block"; return; }
    var docs=await r.json();
    if(!Array.isArray(docs)||!docs.length){ emptyEl.style.display="block"; listEl.innerHTML=""; return; }
    emptyEl.style.display="none";
    var html="";
    docs.forEach(function(d){
      var childName = d.passport_id && CHILDREN[d.passport_id] ? CHILDREN[d.passport_id] : "General";
      html+='<div class="bg-white border border-slate-200 rounded-xl p-4 flex items-center justify-between gap-3">';
      html+='<div class="min-w-0"><p class="font-medium text-slate-800 truncate">'+d.file_name+'</p>';
      html+='<p class="text-xs text-slate-400 mt-0.5">'+childName+' · '+fmtDate(d.created_at)+'</p></div>';
      html+='<div class="flex items-center gap-2 shrink-0">';
      html+='<button class="dl-btn text-sm font-semibold text-violet-700 hover:underline" data-path="'+d.file_path+'">Download</button>';
      html+='<button class="del-btn text-sm text-slate-400 hover:text-red-500" data-id="'+d.id+'" data-path="'+d.file_path+'">Delete</button>';
      html+='</div></div>';
    });
    listEl.innerHTML=html;

    listEl.querySelectorAll(".dl-btn").forEach(function(b){
      b.addEventListener("click",async function(){
        var path=b.getAttribute("data-path");
        var sr=await fetch(UA_URL+"/storage/v1/object/sign/documents/"+path,{method:"POST",headers:authHdr(SESSION.access_token),body:JSON.stringify({expiresIn:3600})});
        if(sr.ok){ var sd=await sr.json(); window.open(UA_URL+"/storage/v1"+sd.signedURL,"_blank"); }
      });
    });
    listEl.querySelectorAll(".del-btn").forEach(function(b){
      b.addEventListener("click",async function(){
        if(!confirm("Delete this document?"))return;
        var id=b.getAttribute("data-id"), path=b.getAttribute("data-path");
        await fetch(UA_URL+"/storage/v1/object/documents/"+path,{method:"DELETE",headers:{"apikey":UA_KEY,"Authorization":"Bearer "+SESSION.access_token}});
        await fetch(UA_URL+"/rest/v1/documents?id=eq."+id,{method:"DELETE",headers:authHdr(SESSION.access_token)});
        loadDocuments();
      });
    });
  }

  (async function(){
    SESSION=await getValidSession();
    if(!SESSION){window.location.href="/login";return;}
    document.getElementById("loading").style.display="none";
    document.getElementById("content").style.display="block";

    // Load children for the selector
    try{
      var pr=await fetch(UA_URL+"/rest/v1/passports?select=id,data&order=created_at.desc",{headers:authHdr(SESSION.access_token)});
      if(pr.ok){
        var ps=await pr.json();
        var sel=document.getElementById("child-select");
        (ps||[]).forEach(function(p){
          var cp=(p.data&&p.data.childProfile)||{};
          var nm=[cp.firstName,cp.lastName].filter(Boolean).join(" ")||"Child";
          CHILDREN[p.id]=nm;
          var o=document.createElement("option"); o.value=p.id; o.textContent=nm; sel.appendChild(o);
        });
      }
    }catch(e){}

    await loadDocuments();

    document.getElementById("upload-btn").addEventListener("click",async function(){
      var fileInput=document.getElementById("file-input");
      var msg=document.getElementById("upload-msg");
      var btn=this;
      if(!fileInput.files||!fileInput.files[0]){ msg.style.display="block"; msg.style.color="#ef4444"; msg.textContent="Please choose a file first."; return; }
      var file=fileInput.files[0];
      if(file.size > 10*1024*1024){ msg.style.display="block"; msg.style.color="#ef4444"; msg.textContent="File is too large (max 10 MB)."; return; }

      btn.disabled=true; btn.textContent="Uploading...";
      var safeName=file.name.replace(/[^a-zA-Z0-9._-]/g,"_");
      var path=SESSION.user.id+"/"+Date.now()+"_"+safeName;

      try{
        var up=await fetch(UA_URL+"/storage/v1/object/documents/"+path,{
          method:"POST",
          headers:{"apikey":UA_KEY,"Authorization":"Bearer "+SESSION.access_token},
          body:file
        });
        if(!up.ok){ throw new Error("upload"); }
        var childId=document.getElementById("child-select").value;
        await fetch(UA_URL+"/rest/v1/documents",{
          method:"POST",
          headers:Object.assign({},authHdr(SESSION.access_token),{"Prefer":"return=minimal"}),
          body:JSON.stringify({user_id:SESSION.user.id, passport_id:childId||null, file_name:file.name, file_path:path, file_type:file.type})
        });
        msg.style.display="block"; msg.style.color="#22c55e"; msg.textContent="✓ Uploaded.";
        fileInput.value="";
        loadDocuments();
      }catch(e){
        msg.style.display="block"; msg.style.color="#ef4444"; msg.textContent="Upload failed. The vault may still be getting set up.";
      }
      btn.disabled=false; btn.textContent="Upload document";
    });
  })();
</script>
