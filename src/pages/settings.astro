---
/* SETTINGS-ACCOUNT-V3 — fully functional: name, language and timezone save
   to the Supabase account (user metadata); password change is real; email
   change sends Supabase's confirmation link.
   Bilingual (APP-I18N-V2 string codes): markup carries data-i18n codes;
   strings live in the central catalog (src/i18n/settings.js) and are
   injected at build time. The "Preferred language" segment actually
   switches the app: it saves ua_lang and reloads (unless you have
   unsaved edits — then it applies on the next page). */
import AppFormLayout from "@/layouts/AppFormLayout.astro";
import SectionTabs from "@/components/SectionTabs.astro";
import DICT from "@/i18n/settings.js";
import "@/styles/settings.css";
---
<AppFormLayout title="Settings" titleFr="Paramètres" activeNav="settings">
  <SectionTabs section="settings" active="account" />
  <div class="set-wrap">
    <h1 class="page-title" data-i18n="title">Account</h1>
    <p class="page-sub" data-i18n="sub">Your identity and how you sign in. Nothing about your child, billing or notifications lives here.</p>

    <div class="set-section">
      <h2 data-i18n="identity">Identity</h2>
      <div class="set-field">
        <label for="set-name" data-i18n="fullName">Full name</label>
        <input class="set-input" id="set-name" type="text" placeholder="Primary account holder" data-i18n-ph="fullNamePh" />
      </div>
      <div class="set-field">
        <label for="set-email" data-i18n="emailLabel">Email address</label>
        <input class="set-input" id="set-email" type="email" placeholder="you@email.com" data-i18n-ph="emailPh" />
        <span class="set-hint" data-i18n="emailHint">Used to sign in. If you change it, we'll email a confirmation link to the new address before it takes effect.</span>
      </div>
      <div class="set-row">
        <div class="l"><h3 data-i18n="pwTitle">Password</h3><p data-i18n="pwDesc">Change the password you use to sign in.</p></div>
        <button class="set-btn ghost" type="button" id="pw-toggle" data-i18n="pwToggle">Change password</button>
      </div>
      <div id="pw-fields" style="display:none">
        <div class="set-field">
          <label for="set-pw1" data-i18n="pw1">New password</label>
          <input class="set-input" id="set-pw1" type="password" autocomplete="new-password" placeholder="At least 8 characters" data-i18n-ph="pw1Ph" />
        </div>
        <div class="set-field">
          <label for="set-pw2" data-i18n="pw2">Confirm new password</label>
          <input class="set-input" id="set-pw2" type="password" autocomplete="new-password" placeholder="Type it again" data-i18n-ph="pw2Ph" />
        </div>
        <div class="set-actions" style="margin-top:0">
          <button class="set-btn" type="button" id="pw-save" data-i18n="pwSave">Update password</button>
          <span class="set-hint" id="pw-msg" style="align-self:center"></span>
        </div>
      </div>
      <div class="set-row">
        <div class="l"><h3 data-i18n="loginMethod">Login method</h3><p data-i18n="loginMethodDesc">Email and password. Google / Apple sign-in coming later.</p></div>
        <span class="always" style="background:#F4F3F8;color:#7B7491" data-i18n="emailChip">Email</span>
      </div>
    </div>

    <div class="set-section">
      <h2 data-i18n="prefs">Preferences</h2>
      <div class="set-row">
        <div class="l"><h3 data-i18n="prefLang">Preferred language</h3><p data-i18n="prefLangDesc">Used across the app and your emails.</p></div>
        <div class="seg" data-pref="lang"><button data-val="en" class="on" type="button">English</button><button data-val="fr" type="button">Français</button></div>
      </div>
      <div class="set-field">
        <label for="set-tz" data-i18n="tz">Time zone</label>
        <input class="set-input" id="set-tz" type="text" placeholder="Auto-detected" data-i18n-ph="tzPh" />
        <span class="set-hint" data-i18n="tzHint">Detected automatically — edit if it's wrong.</span>
      </div>
    </div>

    <div class="set-actions">
      <button class="set-btn" type="button" id="acc-save" data-i18n="save">Save changes</button>
      <span class="set-hint" id="acc-msg" style="align-self:center"></span>
    </div>
  </div>
</AppFormLayout>

<script is:inline define:vars={{ DICT }}>
  (function () {
    /* ---------- i18n: catalog dict injected at build time ---------- */
    var PT = window.uaI18n(DICT);

    /* ---------- session + Supabase helpers ---------- */
    var UA_URL = "https://eghqufgiudxjkbsddtnx.supabase.co";
    var ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVnaHF1ZmdpdWR4amtic2RkdG54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzIyOTYsImV4cCI6MjA5NDk0ODI5Nn0.0aHDnCOny0DQlE1oEgxzC__k1GKbR-XNpoMGVlyQK2I";
    function getSession(){ try { return JSON.parse(localStorage.getItem("ua_session")); } catch(e){ return null; } }
    var s = getSession();
    if (!s || !s.access_token) { location.href = "/login"; return; }
    var meta = (s.user && s.user.user_metadata) || {};

    function patchUser(body) {
      return fetch(UA_URL + "/auth/v1/user", {
        method: "PUT",
        headers: { apikey: ANON, Authorization: "Bearer " + s.access_token, "Content-Type": "application/json" },
        body: JSON.stringify(body)
      }).then(function(r){ return r.json().then(function(j){ return { ok: r.ok, j: j }; }); });
    }
    function saveSessionUser(user) {
      try { var cur = getSession(); if (cur && user) { cur.user = user; localStorage.setItem("ua_session", JSON.stringify(cur)); } } catch(e){}
    }

    /* ---------- prefill ---------- */
    var nameEl = document.getElementById("set-name");
    var emailEl = document.getElementById("set-email");
    var tzEl = document.getElementById("set-tz");
    if (meta.full_name) nameEl.value = meta.full_name;
    if (s.user && s.user.email) emailEl.value = s.user.email;
    tzEl.value = meta.timezone || (function(){ try { return Intl.DateTimeFormat().resolvedOptions().timeZone || ""; } catch(e){ return ""; } })();
    var prefName = nameEl.value, prefEmail = emailEl.value, prefTz = tzEl.value;

    function isDirty() {
      return nameEl.value !== prefName || emailEl.value !== prefEmail || tzEl.value !== prefTz ||
        document.getElementById("set-pw1").value !== "" || document.getElementById("set-pw2").value !== "";
    }

    /* ---------- language segment (drives the whole app's language) ---------- */
    var K = function(n){ return "ua_pref_" + n; };
    document.querySelectorAll(".seg[data-pref]").forEach(function(seg){
      var key = seg.dataset.pref;
      // For the language segment, the source of truth is the resolved
      // app language (I18nBoot) — the same one the UI is rendered in.
      var saved = key === "lang" ? (window.uaLang || "en") : (meta[key] || localStorage.getItem(K(key)));
      var btns = seg.querySelectorAll("button");
      btns.forEach(function(b){
        if (saved) b.classList.toggle("on", b.dataset.val === saved);
        b.addEventListener("click", function(){
          btns.forEach(function(x){ x.classList.remove("on"); });
          b.classList.add("on");
          localStorage.setItem(K(key), b.dataset.val);
          if (key === "lang") {
            var val = b.dataset.val;
            if (val === window.uaLang) return;
            try { localStorage.setItem("ua_lang", val); } catch(e){}
            if (isDirty()) {
              // Don't wipe unsaved edits with a reload — it applies next page.
              var msg = document.getElementById("acc-msg");
              msg.textContent = PT.langPending; msg.style.color = "#6D28D9";
            } else {
              location.reload();
            }
          }
        });
      });
    });

    /* ---------- save identity + preferences ---------- */
    document.getElementById("acc-save").addEventListener("click", function(){
      var msg = document.getElementById("acc-msg");
      msg.textContent = PT.saving; msg.style.color = "";
      var langBtn = document.querySelector('.seg[data-pref="lang"] button.on');
      var body = { data: {
        full_name: nameEl.value.trim(),
        timezone: tzEl.value.trim(),
        lang: langBtn ? langBtn.dataset.val : "en"
      }};
      var emailChanged = s.user && emailEl.value.trim() && emailEl.value.trim() !== s.user.email;
      if (emailChanged) body.email = emailEl.value.trim();
      patchUser(body).then(function(res){
        if (res.ok) {
          saveSessionUser(res.j);
          prefName = nameEl.value; prefEmail = emailEl.value; prefTz = tzEl.value;
          msg.textContent = emailChanged
            ? PT.savedEmail1 + emailEl.value.trim() + PT.savedEmail2
            : PT.saved;
          msg.style.color = "#15803D";
          // If the saved language differs from the rendered one, apply it now.
          var savedLang = body.data.lang;
          if (savedLang && savedLang !== window.uaLang) {
            try { localStorage.setItem("ua_lang", savedLang); } catch(e){}
            setTimeout(function(){ location.reload(); }, 400);
          }
        } else {
          msg.textContent = (res.j && (res.j.msg || res.j.message || res.j.error_description)) || PT.saveFail;
          msg.style.color = "#B42318";
        }
      }).catch(function(){ msg.textContent = PT.network; msg.style.color = "#B42318"; });
    });

    /* ---------- password change ---------- */
    var pwFields = document.getElementById("pw-fields");
    document.getElementById("pw-toggle").addEventListener("click", function(){
      pwFields.style.display = pwFields.style.display === "none" ? "block" : "none";
    });
    document.getElementById("pw-save").addEventListener("click", function(){
      var p1 = document.getElementById("set-pw1").value;
      var p2 = document.getElementById("set-pw2").value;
      var msg = document.getElementById("pw-msg");
      if (p1.length < 8) { msg.textContent = PT.pwMin; msg.style.color = "#B42318"; return; }
      if (p1 !== p2) { msg.textContent = PT.pwNoMatch; msg.style.color = "#B42318"; return; }
      msg.textContent = PT.pwUpdating; msg.style.color = "";
      patchUser({ password: p1 }).then(function(res){
        if (res.ok) {
          msg.textContent = PT.pwUpdated; msg.style.color = "#15803D";
          document.getElementById("set-pw1").value = ""; document.getElementById("set-pw2").value = "";
        } else {
          msg.textContent = (res.j && (res.j.msg || res.j.message)) || PT.pwFail;
          msg.style.color = "#B42318";
        }
      }).catch(function(){ msg.textContent = PT.pwServer; msg.style.color = "#B42318"; });
    });
  })();
</script>
